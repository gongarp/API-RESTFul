procedure Obtener_Tasa_base_Mem(const CodigoTasaBase      : string;
                                 var BaseTasa        : integer;
                                 var TipoInteres     : string;
                                 var BaseMensual     : integer;
                                 var TipoCalculoDias : String;
                                 var VigenciaValor   : Integer;
                                 var Vigencia_Meses  : Integer;
                                 var sPais_Tasa      : String;
                                 var Modulo_err      : String;
                                 var String_err      : String;
                                 var Result          : Boolean);
var i
   ,iLimite_Superior : Integer;
  // x : String;
begin
  if Not VarIsArray(Reg_Base_Conversion.Cod_Tasa_Base) then
     Carga_Valores_Tasa_base_Mem;

  Modulo_Err := 'Obtener Tasa Base';
  Result     := False;
  iLimite_Superior := VarArrayHighBound(Reg_Base_Conversion.Cod_Tasa_Base, 1 )-1;
  for i := 0 to iLimite_Superior do
  begin
     if Trim(Reg_Base_Conversion.Cod_Tasa_Base[i]) = Trim(CodigoTasaBase) then
     begin
        Result := True;
        Break;
     end;
  end;
  
  if Result then
  begin
      BaseTasa        := Reg_Base_Conversion.Dias_Base[i];
      TipoInteres     := Trim(Reg_Base_Conversion.Tipo_interes[i]);
      BaseMensual     := Reg_Base_Conversion.Base_Mensual[i];
      VigenciaValor   := Reg_Base_Conversion.Vigencia_Valor[i];
      Vigencia_Meses  := Reg_Base_Conversion.Vigencia_Meses[i];
      sPais_Tasa      := Reg_Base_Conversion.Pais_Tasa[i];
      TipoCalculoDias := Reg_Base_Conversion.Tipo_Calculo_Dias[i];
  end
  else
  begin
     String_err := ' Tasa Base '+trim(CodigoTasaBase)+' No Existe';
     Exit;
  end;

  if (BaseTasa = 0) or
     (BaseTasa = Null) then
  begin
    String_Err := ' Definición incorrecta Tasa Base: '+trim(CodigoTasaBase)+' Dias_Base';
    Result := False;
    exit;
  end;

   if (TipoInteres = EmptyStr) or
      (TipoInteres = Null)  then
   begin
     String_Err  := 'Definición Incorrecta de Tipo Interés, Tasa Base: '+trim(CodigoTasaBase);//Definición incorrecta,
     Result := False;
     exit;
   end;
end;

procedure Carga_Valores_Tasa_base_Mem;
var i : LongInt;
begin
  with DMFuncionesMemory.QRY_General do
  begin
    Close;
    Sql.clear;
    Sql.Add('SELECT a.COD_TASA_BASE'
            +'     ,a.DIAS_BASE_TASA As Dias_Base'
            +'     ,a.TIPO_INTERES_TASA As Tipo_Interes'
            +'     ,a.BASE_MENSUAL_TASA As Base_Mensual'
            +'     ,a.VIGENCIA_VALOR'
            +'     ,a.VIGENCIA_MESES'
            +'     ,a.TIPO_CALCULO_DIAS'
            +'     ,b.Nacion_moneda'
            +'  FROM qs_fin_tasa_base a'
            +'      ,qs_sys_monedas b'
            +' WHERE a.cod_tasa_base = b.cod_moneda'
            +' ORDER BY COD_TASA_BASE'
            );
    Open;

//    DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;
    Reg_Base_Conversion.Cod_Tasa_Base     := VarArrayCreate([0, i], varOleStr);
    Reg_Base_Conversion.Dias_Base         := VarArrayCreate([0, i], varDouble);
    Reg_Base_Conversion.Tipo_interes      := VarArrayCreate([0, i], varOleStr);
    Reg_Base_Conversion.Base_Mensual      := VarArrayCreate([0, i], varDouble);
    Reg_Base_Conversion.Vigencia_Valor    := VarArrayCreate([0, i], varDouble);
    Reg_Base_Conversion.Vigencia_Meses    := VarArrayCreate([0, i], varDouble);
    Reg_Base_Conversion.Pais_Tasa         := VarArrayCreate([0, i], varOleStr);
    Reg_Base_Conversion.Tipo_Calculo_Dias := VarArrayCreate([0, i], varOleStr);

    i := 0;
    while not eof do
    begin
       Reg_Base_Conversion.Cod_Tasa_Base[i]     := FieldByName('COD_TASA_BASE').AsString;
       Reg_Base_Conversion.Dias_Base[i]         := FieldByName('Dias_Base').AsInteger;
       Reg_Base_Conversion.Tipo_Interes[i]      := FieldByName('Tipo_interes').AsString;
       Reg_Base_Conversion.Base_Mensual[i]      := FieldByName('Base_Mensual').AsInteger;
       Reg_Base_Conversion.Vigencia_Valor[i]    := FieldByName('Vigencia_Valor').AsInteger;
       Reg_Base_Conversion.Vigencia_Meses[i]    := FieldByName('Vigencia_Meses').AsInteger;
       Reg_Base_Conversion.Pais_Tasa[i]         := Fieldbyname('Nacion_Moneda').asString;
       Reg_Base_Conversion.Tipo_Calculo_Dias[i] := Fieldbyname('TIPO_CALCULO_DIAS').asString;

       Next;
       Inc(i);
    end;

    close;
    Unprepare;
  end;
end;

