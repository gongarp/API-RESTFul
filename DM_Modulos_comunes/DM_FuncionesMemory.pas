Procedure Busca_Equivalencia_Instrum_Mem( const sProceso     : String;
                                          const sInstrumento : String;
                                          const sTipo_Emisor : String;
                                          const sPais_Emisor : String;
                                          const sEmisor      : String;
                                          const sSerie       : String;
                                          const dFecha_Calculo : TDateTime;
                                          var sCodigo_Equiv    : String;
                                          var Result           : Boolean );
var i : Integer;
begin
  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Equivalencia_Instrum.Proceso) then
     Carga_Valores_Equivalencia_Instrum( dFecha_Calculo );

  // Si la fecha no corresponde la vuelve a cargar
  if Reg_Equivalencia_Instrum.Fecha_Calculo[0] <> dFecha_Calculo then
