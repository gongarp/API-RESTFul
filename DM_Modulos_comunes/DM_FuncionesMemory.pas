  end;
  //if Result then
  //   Exit;

  //Busco Emisor, Instrumento
  if Not Result then
  begin
     dFecha_aux     := StrToDate('01/01/1800');
     for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo.COD_EMP_SERIE, 1 )-1 do
