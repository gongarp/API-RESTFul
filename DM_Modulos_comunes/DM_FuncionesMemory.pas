Procedure Ordenamiento_Registro_Nominales_Pactados_Mem( var Reg_Nominales_Pactados : TReg_Nominales_Pactados;
                                                    iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno_Rel,
    fFolio_Interno,
    fItem_Omd_Rel,
    fItem_Omd,
    fValor_Pactado_UM,
    fValor_Pactado_MC,
    fValor_Nominal   : Double;
    sTransaccion_Rel,
    sCartera,
    sTransaccion   : String;
    dFecha_Operacion,
    dFecha_Vcto_Pacto : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Nominales_Pactados.Folio_Interno_Rel[(Lo + Hi) div 2];

    repeat
      while Reg_Nominales_Pactados.Folio_Interno_Rel[Lo] < Mid do
            Inc(Lo);
      while Reg_Nominales_Pactados.Folio_Interno_Rel[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio_Interno_Rel := Reg_Nominales_Pactados.Folio_Interno_Rel[Lo];
         fItem_Omd_Rel      := Reg_Nominales_Pactados.Item_Omd_Rel[Lo];
         fFolio_Interno     := Reg_Nominales_Pactados.Folio_Interno[Lo];
         fItem_Omd          := Reg_Nominales_Pactados.Item_Omd[Lo];
         sTransaccion_Rel   := Reg_Nominales_Pactados.Transaccion_Rel[Lo];
         sTransaccion       := Reg_Nominales_Pactados.Transaccion[Lo];
         fValor_Pactado_UM  := Reg_Nominales_Pactados.Valor_Pactado_UM[Lo];         
         fValor_Pactado_MC  := Reg_Nominales_Pactados.Valor_Pactado_MC[Lo];
         fValor_Nominal     := Reg_Nominales_Pactados.Valor_Nominal[Lo];
         dFecha_Operacion   := Reg_Nominales_Pactados.Fecha_Operacion[Lo];
         dFecha_Vcto_Pacto  := Reg_Nominales_Pactados.Fecha_Vcto_Pacto[Lo];
         sCartera           := Reg_Nominales_Pactados.Cartera[Lo];

         Reg_Nominales_Pactados.Cartera[Lo]           :=
                       Reg_Nominales_Pactados.Cartera[Hi];
         Reg_Nominales_Pactados.Folio_Interno_Rel[Lo] :=
                       Reg_Nominales_Pactados.Folio_Interno_Rel[Hi];
         Reg_Nominales_Pactados.Item_Omd_Rel[Lo]      :=
                       Reg_Nominales_Pactados.Item_Omd_Rel[Hi];
         Reg_Nominales_Pactados.Folio_Interno[Lo]     :=
                       Reg_Nominales_Pactados.Folio_Interno[Hi];
         Reg_Nominales_Pactados.Item_Omd[Lo]          :=
                       Reg_Nominales_Pactados.Item_Omd[Hi];
         Reg_Nominales_Pactados.Transaccion_Rel[Lo]   :=
                       Reg_Nominales_Pactados.Transaccion_Rel[Hi];
         Reg_Nominales_Pactados.Valor_Nominal[Lo]     :=
                       Reg_Nominales_Pactados.Valor_Nominal[Hi];
         Reg_Nominales_Pactados.Fecha_Operacion[Lo]   :=
                       Reg_Nominales_Pactados.Fecha_Operacion[Hi];
         Reg_Nominales_Pactados.Fecha_Vcto_Pacto[Lo]  :=
                       Reg_Nominales_Pactados.Fecha_Vcto_Pacto[Hi];
         Reg_Nominales_Pactados.Transaccion[Lo]       :=
                       Reg_Nominales_Pactados.Transaccion[Hi];
         Reg_Nominales_Pactados.Valor_Pactado_UM[Lo]  :=
                       Reg_Nominales_Pactados.Valor_Pactado_UM[Hi];
         Reg_Nominales_Pactados.Valor_Pactado_MC[Lo]  :=
                       Reg_Nominales_Pactados.Valor_Pactado_MC[Hi];

         Reg_Nominales_Pactados.Cartera[Hi]           := sCartera;                       
         Reg_Nominales_Pactados.Folio_Interno_Rel[Hi] := fFolio_Interno_Rel;
         Reg_Nominales_Pactados.Item_Omd_Rel[Hi]      := fItem_Omd_Rel;
         Reg_Nominales_Pactados.Folio_Interno[Hi]     := fFolio_Interno;
         Reg_Nominales_Pactados.Item_Omd[Hi]          := fItem_Omd;
         Reg_Nominales_Pactados.Transaccion_Rel[Hi]   := sTransaccion_Rel;
         Reg_Nominales_Pactados.Transaccion[Hi]       := sTransaccion;
         Reg_Nominales_Pactados.Valor_Nominal[Hi]     := fValor_Nominal;
         Reg_Nominales_Pactados.Fecha_Operacion[Hi]   := dFecha_Operacion;
         Reg_Nominales_Pactados.Fecha_Vcto_Pacto[Hi]  := dFecha_Vcto_Pacto;
         Reg_Nominales_Pactados.Valor_Pactado_UM[Hi]  := fValor_Pactado_UM;         
         Reg_Nominales_Pactados.Valor_Pactado_MC[Hi]  := fValor_Pactado_MC;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Nominales_Pactados_Mem(Reg_Nominales_Pactados, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Nominales_Pactados_Mem(Reg_Nominales_Pactados, Lo, iHi);
end;

Procedure Carga_UF_Mem( dFecha_Calculo : TDatetime );
var i : LongInt;
begin
     WITH DMFuncionesMemory.QRY_General do
     begin
       Close;
       Sql.Clear;
       SQL.Add('SELECT Fecha_Paridad'
             +'      ,Valor_Moneda'
             +'  FROM QS_SYS_VAL_CAMBIO'
             +' WHERE Fecha_Paridad  <= :Fecha'
             +'   AND Cod_Moneda      = ''UF'''
             +'   AND TIPO_DE_PARIDAD = ''BC'''
             +' ORDER BY Fecha_Paridad'
             );
       Parambyname('Fecha').asDate := dFecha_Calculo;
       Open;

//       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;
       Reg_UF.Fecha_Paridad := VarArrayCreate([0, i], varDate);
       Reg_UF.Valor_Moneda  := VarArrayCreate([0, i], varDouble);

       i := 0;
       while not eof do
       begin
          Reg_UF.Fecha_Paridad[i] := Fieldbyname('Fecha_Paridad').asDatetime;
          Reg_UF.Valor_Moneda[i]  := Fieldbyname('Valor_Moneda').asFloat;
          Inc(i);
          Next;
       end;
       Close;
    end;
end;

Procedure Busca_UF_Mem(   dFecha : TDatetime;
                      var fValor : Double;
                      var Result : Boolean
                      );
var i
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
begin
  Result := False;
  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_UF.Fecha_Paridad, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if Reg_UF.Fecha_Paridad[i] = dFecha then
     begin
        fValor := Reg_UF.Valor_Moneda[i];
        Result := True;
        Break;
     end;

     if dFecha > Reg_UF.Fecha_Paridad[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i - 1;
  end;
end;

