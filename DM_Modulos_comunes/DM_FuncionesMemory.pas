                                 var sTasa_Base_Tir    : String;
                                 var sFormula_Par      : String;
                                 var sFormula_Tir      : String;
                                 var Result            : Boolean);
var  i: Integer;
begin
  Result := False;
  if sInstrumento = EmptyStr then
  begin
     Result := False;
     exit;
  end;

   if NOT VarIsArray(Reg_Instrumentos_Unicos.Cod_instrumento) then
      Carga_Instrumentos_Unicos_Mem;

  for i := 0 to VarArrayHighBound(Reg_Instrumentos_Unicos.Cod_Instrumento , 1 )  do
