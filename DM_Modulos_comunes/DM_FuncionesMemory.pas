function Existe_Nemotecnico_Mem( Const sNemotecnico : String) : Boolean;
var i
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
begin
  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Nemotecnicos.Codigo_Nemotecnico, 1 )-1;
  Result           := False;

  //Esta busqueda tiene problemas con los numeros del nemotecnico
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Nemotecnicos.Codigo_Nemotecnico[i] = sNemotecnico then
     begin
        Result := True;
        Break;
     end;

     if sNemotecnico > Reg_Nemotecnicos.Codigo_Nemotecnico[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i -1;

  end;
end;

Procedure Carga_Emision_Implicita_Mem;
var i : LongInt;
begin
     WITH DMFuncionesMemory.QRY_General do
     begin
       Close;
       Sql.Clear;
       SQL.Add('SELECT *                      ');
       SQL.Add('  FROM QS_FIN_NEM_EMI_DEF     ');
       SQL.Add(' ORDER BY Codigo_Nemotecnico  ');
       Open;

       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
       Reg_Emision_Implicita.Codigo_Nemotecnico := VarArrayCreate([0, i], varOleStr);
       Reg_Emision_Implicita.Dia                := VarArrayCreate([0, i], varDouble);
       Reg_Emision_Implicita.Dia_Refer          := VarArrayCreate([0, i], varOleStr);
       Reg_Emision_Implicita.Dia_Ant_Des        := VarArrayCreate([0, i], varDouble);
       Reg_Emision_Implicita.Mes                := VarArrayCreate([0, i], varDouble);
       Reg_Emision_Implicita.Mes_Refer          := VarArrayCreate([0, i], varOleStr);
       Reg_Emision_Implicita.Mes_Ant_Des        := VarArrayCreate([0, i], varDouble);
       Reg_Emision_Implicita.Ano                := VarArrayCreate([0, i], varDouble);
       Reg_Emision_Implicita.Ano_Refer          := VarArrayCreate([0, i], varOleStr);
       Reg_Emision_Implicita.Ano_Ant_Des        := VarArrayCreate([0, i], varDouble);

       i := 0;
       while not eof do
       begin
          Reg_Emision_Implicita.Codigo_Nemotecnico[i] :=
                                     Fieldbyname('Codigo_Nemotecnico').AsString;
          Reg_Emision_Implicita.Dia[i]         := Fieldbyname('Dia'        ).AsFloat;
          Reg_Emision_Implicita.Dia_Refer[i]   := Fieldbyname('Dia_Refer'  ).AsString;
