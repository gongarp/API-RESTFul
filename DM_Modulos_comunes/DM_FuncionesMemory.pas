         Reg_Marca_Posicion.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Marca_Posicion.Item_Omd[Hi]      := fItem_Omd;
         Reg_Marca_Posicion.Fecha_Hora[Hi]    := dFecha_Hora;
         Reg_Marca_Posicion.Fecha_Desde[Hi]   := dFecha_Desde;
         Reg_Marca_Posicion.Fecha_Hasta[Hi]   := dFecha_Hasta;
         Reg_Marca_Posicion.Cod_Marca[Hi]     := sCod_Marca;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Marca_Posicion_Mem(Reg_Marca_Posicion, iLo, Hi);
    if Lo < iHi then Ordenamiento_Marca_Posicion_Mem(Reg_Marca_Posicion, Lo, iHi);
end;

Function Busca_Marca_Posicion_Mem(  const sEmpresa       : String;
                                    const sTransaccion   : String;
                                    const sFolio_Interno : String;
                                          fItem_Omd      : Double;
                                          dFecha_Desde   : TDatetime ) : String;
var i
   ,j             : Integer;
   fFolio_Interno : Double;
   bExiste        : Boolean;
begin
  Busca_Marca_Posicion_Mem := '';
  bExiste := False;
  fFolio_Interno      := StrToFloat(sFolio_Interno);

  if NOT VarIsArray(Reg_Marca_Posicion.Folio_Interno) then
     Carga_Marca_PosicionOMD_Mem( dFecha_Desde );

  for i := 0 to  VarArrayHighBound(Reg_Marca_Posicion.Folio_Interno, 1 )-1 do
  begin
     if Reg_Marca_Posicion.Folio_Interno[i] = fFolio_Interno then
     begin
        bExiste := True;
        Break;
     end;
  end;

  if bExiste then
  begin
     //Retrocedo hasta Primer Folio Igual  por cuestion de fechas
     For j := i Downto 0 do
       if Reg_Marca_Posicion.Folio_Interno[J] <> fFolio_Interno then
          Break;

     i := j + 1;
     while (i <= VarArrayHighBound(Reg_Marca_Posicion.Folio_Interno , 1 )) and
           (Reg_Marca_Posicion.Folio_Interno[i] = fFolio_Interno) do
     begin

       if (Reg_Marca_Posicion.Empresa[i]      = sEmpresa )     and
          (Reg_Marca_Posicion.Transaccion[i]  = sTransaccion ) and
          (Reg_Marca_Posicion.Item_Omd[i]     = fItem_Omd )    and
          (Reg_Marca_Posicion.Fecha_Desde[i] <= dFecha_Desde ) and
         ((Reg_Marca_Posicion.Fecha_Hasta[i] >= dFecha_Desde ) or
          (Reg_Marca_Posicion.Fecha_Hasta[i]  = StrToDateTime(Fecha_Nula) )) then
         begin
           Busca_Marca_Posicion_Mem := Reg_Marca_Posicion.Cod_Marca[i];
           Break;
        end;
        Inc(i);
     end;
  end;
end;

