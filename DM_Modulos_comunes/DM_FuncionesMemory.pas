Procedure Ordenamiento_Registro_Mercado_Mem( var Reg_Datos_Mercado : TReg_Datos_Mercado;
                                                iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd,
    fVALOR_PTE_MC_CPA,
    fVALOR_PTE_MC_MDO : Double;
    sTransaccion,
    sCartera         : String;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Datos_Mercado.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Datos_Mercado.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Datos_Mercado.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio_Interno    := Reg_Datos_Mercado.Folio_Interno[Lo];
         fItem_Omd         := Reg_Datos_Mercado.Item_Omd[Lo];
         sTransaccion      := Reg_Datos_Mercado.Transaccion[Lo];
         sCartera          := Reg_Datos_Mercado.Cartera[Lo];
         fVALOR_PTE_MC_CPA := Reg_Datos_Mercado.VALOR_PTE_MC_CPA[Lo];
         fVALOR_PTE_MC_MDO := Reg_Datos_Mercado.VALOR_PTE_MC_MDO[Lo];

         Reg_Datos_Mercado.Folio_Interno[Lo] :=
                       Reg_Datos_Mercado.Folio_Interno[Hi];
         Reg_Datos_Mercado.Item_Omd[Lo]      :=
                       Reg_Datos_Mercado.Item_Omd[Hi];
         Reg_Datos_Mercado.Transaccion[Lo]   :=
                       Reg_Datos_Mercado.Transaccion[Hi];
         Reg_Datos_Mercado.Cartera[Lo]       :=
                       Reg_Datos_Mercado.Cartera[Hi];
         Reg_Datos_Mercado.VALOR_PTE_MC_CPA[Lo]  :=
                       Reg_Datos_Mercado.VALOR_PTE_MC_CPA[Hi];
         Reg_Datos_Mercado.VALOR_PTE_MC_MDO[Lo]  :=
                       Reg_Datos_Mercado.VALOR_PTE_MC_MDO[Hi];


         Reg_Datos_Mercado.Folio_Interno[Hi]    := fFolio_Interno;
         Reg_Datos_Mercado.Item_Omd[Hi]         := fItem_Omd;
         Reg_Datos_Mercado.Transaccion[Hi]      := sTransaccion;
         Reg_Datos_Mercado.Cartera[Hi]          := sCartera;
         Reg_Datos_Mercado.VALOR_PTE_MC_CPA[Hi] := fVALOR_PTE_MC_CPA;
         Reg_Datos_Mercado.VALOR_PTE_MC_MDO[Hi] := fVALOR_PTE_MC_MDO;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Mercado_Mem(Reg_Datos_Mercado, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Mercado_Mem(Reg_Datos_Mercado, Lo, iHi);
end;

procedure Determina_Datos_Mercado_Mem(const scartera        :String;
                                      const sTransaccion    :String;
                                      const sFolio          :String;
                                      dItem_omd             :Double;
                                   var fVALOR_PTE_MC_CPA: Double;
                                   var fVALOR_PTE_MC_MDO: Double
                                    );
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Result           : Boolean;
begin
   fVALOR_PTE_MC_CPA := 0;
   fVALOR_PTE_MC_MDO := 0;

   fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Datos_Mercado.Folio_Interno, 1 )-1;
   i := 0;


   Result := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
      i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

      if Reg_Datos_Mercado.Folio_Interno[i] = fFolio_Buscado then
      begin
         Result := True;
         Break;
      end;

      if  fFolio_Buscado > Reg_Datos_Mercado.Folio_Interno[i] then
         iLimite_Inferior := i + 1
      else
         iLimite_Superior := i - 1;
   end;

   if Result then
   begin
      //Retrocedo hasta Primer Folio diferente
      For j := i Downto 0 do
        if Reg_Datos_Mercado.Folio_Interno[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Datos_Mercado.Folio_Interno , 1 )) and
            (Reg_Datos_Mercado.Folio_Interno[i] = fFolio_Buscado) do
      begin
         if (Reg_Datos_Mercado.Transaccion[i]  = sTransaccion) and
            (Reg_Datos_Mercado.Item_Omd[i]     = dItem_Omd)    and
            (Reg_Datos_Mercado.Cartera[i]      = sCartera)      then
         begin
            fVALOR_PTE_MC_CPA := Reg_Datos_Mercado.VALOR_PTE_MC_CPA[i];
            fVALOR_PTE_MC_MDO := Reg_Datos_Mercado.VALOR_PTE_MC_MDO[i];
         end;
         Inc(i);
      end;
   end;
end;

Procedure Carga_Metodos_Valuacion_Super_Mem( dFecha : Tdatetime );
Var i : LongInt;
    sProceso,
    sEmpresa,
    sCartera,
    sPais,
    sEmisor,
    sInstrumento,
    sSerie,
    sMotivo,
    sVALORIZACION : String;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      SQL.Clear;
      SQL.Add('SELECT Proceso, Empresa, Cartera, Pais, Emisor, Instrumento '
             +'      ,Serie, Motivo, VALORIZACION '
             +'  FROM QS_SUP_VALUAC'
             +' WHERE Fecha_Desde <= :Fecha'
             +'   AND (Fecha_Hasta IS NULL OR Fecha_Hasta >= :Fecha)'
             );
      Parambyname('Fecha').asDate := dFecha;
      Open;
//      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;

      Reg_Valuacion_Sup.PROCESO      := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.Empresa      := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.CARTERA      := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.PAIS         := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.EMISOR       := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.INSTRUMENTO  := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.SERIE        := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.MOTIVO       := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion_Sup.VALORIZACION := VarArrayCreate([0, i], varOleStr);
      i := 0;
      while not eof do
      begin
//Proceso
        if Fieldbyname('Proceso').IsNull then
           sProceso := ''
        else
           sProceso := Fieldbyname('Proceso').asString;
//Empresa
        if Fieldbyname('Empresa').IsNull then
           sEmpresa := ''
        else
           sEmpresa := Fieldbyname('Empresa').asString;
// Cartera
        if Fieldbyname('Cartera').IsNull then
           sCartera := ''
        else
           sCartera := Fieldbyname('Cartera').asString;
// Pais
        if Fieldbyname('Pais').IsNull then
           sPais := ''
        else
           sPais := Fieldbyname('Pais').asString;
//Emisor
        if Fieldbyname('Emisor').IsNull then
           sEmisor := ''
        else
           sEmisor := Fieldbyname('Emisor').asString;
// Instrumento
        if Fieldbyname('Instrumento').IsNull then
           sInstrumento := ''
        else
           sInstrumento := Fieldbyname('Instrumento').asString;
//Serie
        if Fieldbyname('Serie').IsNull then
           sSerie := ''
        else
           sSerie := Fieldbyname('Serie').asString;
//Motivo
        if Fieldbyname('Motivo').IsNull then
           sMotivo := ''
        else
           sMotivo := Fieldbyname('Motivo').asString;
//VALORIZACION
        if Fieldbyname('VALORIZACION').IsNull then
           sVALORIZACION := ''
        else
           sVALORIZACION := Fieldbyname('VALORIZACION').asString;

        Reg_Valuacion_Sup.PROCESO[i]      := sProceso;
        Reg_Valuacion_Sup.Empresa[i]      := sEmpresa;
        Reg_Valuacion_Sup.CARTERA[i]      := sCartera;
