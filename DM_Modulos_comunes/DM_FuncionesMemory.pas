Procedure Carga_Tran_Implic_Mem;
var i : LongInt;
begin
     WITH DMFuncionesMemory.QRY_General do
     begin
        SQL.Clear;
        SQL.Add('SELECT *'
               +'  FROM QS_SYS_TRAN_IMPLIC'
               +' ORDER BY Codigo_Transaccion'
               );
        Open;

        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

        Reg_Tran_Implic.Codigo_Transaccion := VarArrayCreate([0, i], varOleStr);
        Reg_Tran_Implic.Implicancia        := VarArrayCreate([0, i], varOleStr);

        i := 0;
          while not eof do
        begin
           Reg_Tran_Implic.Codigo_Transaccion[i] := Trim(Fieldbyname('Codigo_Transaccion').asString);
           Reg_Tran_Implic.Implicancia[i]        := Trim(Fieldbyname('Implicancia').asString);
           Next;
           Inc(i);
        end;
        Close;
    end;
end;

function transaccion_implica_Mem(sTransaccion,
                                sImplicancia : String): Boolean;
var i : Integer;
begin
  if NOT VarIsArray(Reg_Tran_Implic.Codigo_Transaccion) then
     Carga_Tran_Implic_Mem;

  Result := False;
  for i := 0 to VarArrayHighBound(Reg_Tran_Implic.Codigo_Transaccion, 1 )-1 do
  begin
     if (Reg_Tran_Implic.Codigo_Transaccion[i] = sTransaccion ) and
        (Reg_Tran_Implic.Implicancia[i]        = sImplicancia )then
     begin
        Result := True;
        Break;
     end;
  end;
end;

procedure Determina_Nominales_Pactados_Mem(dFecha_Calculo,
                                           dFecha_Servidor       :TDateTime;
                                           const sEmpresa        :String;
                                           const sTransaccion    :String;
                                           const sFolio          :String;
                                           dItem_omd       :Double;
                                       var Nominales_Pactados: Double;
                                       var Nominales_Pactados_Reales: Double);
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Result           : Boolean;
begin

   if NOT VarIsArray(Reg_Nominales_Pactados.Folio_Interno_Rel) then
      Carga_Nominales_Pactados_Mem(sEmpresa
                                             ,dFecha_Calculo
                                             );

   Nominales_Pactados := 0;
   i := 0;
   Nominales_Pactados_Reales := 0;
   fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Nominales_Pactados.Folio_Interno_Rel, 1 )-1;

   Result := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Nominales_Pactados.Folio_Interno_Rel[i] = fFolio_Buscado then
        begin
           Result := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Nominales_Pactados.Folio_Interno_Rel[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;

   end;

   if Result then
   begin
      //Retrocedo hasta Primer Folio diferente
      For j := i Downto 0 do
        if Reg_Nominales_Pactados.Folio_Interno_Rel[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while  (i <= VarArrayHighBound(Reg_Nominales_Pactados.Folio_Interno_Rel , 1 )) and
             (Reg_Nominales_Pactados.Folio_Interno_Rel[i] = fFolio_Buscado) do
      begin
         if (Reg_Nominales_Pactados.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Pactados.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Pactados.Fecha_Operacion[i]   <= dFecha_Calculo)       and
            (Reg_Nominales_Pactados.Fecha_Vcto_Pacto[i]   > dFecha_Calculo)       then
             Nominales_Pactados := Nominales_Pactados + Reg_Nominales_Pactados.Valor_Nominal[i];

         if (Reg_Nominales_Pactados.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Pactados.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Pactados.Fecha_Operacion[i]   <= dFecha_Servidor)       and
            (Reg_Nominales_Pactados.Fecha_Vcto_Pacto[i]   > dFecha_Servidor)       then
             Nominales_Pactados_Reales := Nominales_Pactados_Reales + Reg_Nominales_Pactados.Valor_Nominal[i];

         Inc(i);
      end;
   end;
   Nominales_Pactados        := Abs(Nominales_Pactados);
   Nominales_Pactados_Reales := Abs(Nominales_Pactados_Reales);
end;

