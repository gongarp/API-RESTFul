Procedure Carga_Spread_Mem;
var i : LongInt;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add(' SELECT * FROM QS_SUP_1658_SPREAD ');
      Open;
      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;


      Reg_Spread.Empresa       := VarArrayCreate([0, i], varOleStr);
      Reg_Spread.Transaccion   := VarArrayCreate([0, i], varOleStr);
      Reg_Spread.Folio_Interno := VarArrayCreate([0, i], varDouble);
      Reg_Spread.Item_Omd      := VarArrayCreate([0, i], varDouble);
      Reg_Spread.spread        := VarArrayCreate([0, i], varDouble);

      i := 0;
      while not eof do
      begin
         Reg_Spread.Empresa[i]       := Fieldbyname('Empresa').asString;
         Reg_Spread.Transaccion[i]   := Fieldbyname('Transaccion').asString;
         Reg_Spread.Folio_Interno[i] := Fieldbyname('Folio_Interno').asFloat;
         Reg_Spread.Item_Omd[i]      := Fieldbyname('Item_Omd').asFloat;
         Reg_Spread.spread[i]        := Fieldbyname('spread').asFloat;
         Next;
         Inc(i);
      end;
      Close;
  end;
  //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
  if i <> 0 then
     Ordenamiento_Spread_Operacion_Mem(  Reg_Spread
                                        ,0
                                        ,VarArrayHighBound(Reg_Spread.Folio_Interno, 1 )-1
                                      );

end;

Procedure Ordenamiento_Spread_Operacion_Mem( var Reg_Spread : TReg_Spread;
                                            iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd,
    fSpread      : Double;
    sTransaccion,
    sEmpresa    : String;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Spread.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Spread.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Spread.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sEmpresa           := Reg_Spread.Empresa[Lo];
         sTransaccion       := Reg_Spread.Transaccion[Lo];
         fFolio_Interno     := Reg_Spread.Folio_Interno[Lo];
         fItem_Omd          := Reg_Spread.Item_Omd[Lo];
         fSpread            := Reg_Spread.Spread[Lo];

         Reg_Spread.Empresa[Lo]       :=
                       Reg_Spread.Empresa[Hi];
         Reg_Spread.Transaccion[Lo]   :=
                       Reg_Spread.Transaccion[Hi];
         Reg_Spread.Folio_Interno[Lo] :=
                       Reg_Spread.Folio_Interno[Hi];
         Reg_Spread.Item_Omd[Lo]      :=
                       Reg_Spread.Item_Omd[Hi];
         Reg_Spread.Spread[Lo]        :=
                       Reg_Spread.Spread[Hi];

         Reg_Spread.Empresa[Hi]       := sEmpresa;
         Reg_Spread.Transaccion[Hi]   := sTransaccion;
         Reg_Spread.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Spread.Item_Omd[Hi]      := fItem_Omd;
         Reg_Spread.Spread[Hi]        := fSpread;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Spread_Operacion_Mem(Reg_Spread, iLo, Hi);
    if Lo < iHi then Ordenamiento_Spread_Operacion_Mem(Reg_Spread, Lo, iHi);
end;

Function Busca_Spread_Mem(  const sEmpresa       : String;
                            const sTransaccion   : String;
                            const sFolio_Interno : String;
                                  fItem_Omd      : Double                            
                         ) : Double;

var i
   ,j
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
   fFolio_Interno    : Double;
   bExiste           : Boolean;
begin
  Result := 0;
  i := 0;
  bExiste             := False;


  fFolio_Interno   := StrToFloat(sFolio_Interno);

  if Not VarIsArray(Reg_Spread.Folio_Interno) then
     Carga_Spread_Mem;

  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Spread.Folio_Interno, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Spread.Folio_Interno[i] = fFolio_Interno then
     begin
        bExiste := True;
        Break;
     end;

     if fFolio_Interno > Reg_Spread.Folio_Interno[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i -1;

  end;

  if bExiste then
  begin
     //Retrocedo hasta Primer Folio Igual  por cuestion de fechas
     For j := i Downto 0 do
       if Reg_Spread.Folio_Interno[J] <> fFolio_Interno then
          Break;

     i := j + 1;
     while (i <= VarArrayHighBound(Reg_Spread.Folio_Interno , 1 )) and
           (Reg_Spread.Folio_Interno[i] = fFolio_Interno) do
     begin
       if (Reg_Spread.Empresa[i]     = sEmpresa )     and
          (Reg_Spread.Transaccion[i] = sTransaccion ) and
          (Reg_Spread.Item_Omd[i]    = fItem_Omd )    then
         begin
           Result := Reg_Spread.Spread[i];
           Break;
        end;
        Inc(i);
     end;
  end;
end;

