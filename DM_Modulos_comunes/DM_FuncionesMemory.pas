procedure Verifica_Excepcion_Variacion_Cambiaria_Vigente_Mem(sCodigo_Emisor                 : String;
                                                             sCodigo_Instrumento            : String;
                                                             sSerie                         : String;
                                                             fCupon                         : Double;
                                                             dFecha_Calculo                 : TDatetime;
                                                             var fPtje_Aplica_Reajuste      : Double;
                                                             var sCodigo_MondInd            : String;
                                                             var s0Cod_Tratam_Inicio        : String;
                                                             var s1Cod_Tratam_Termino       : String;
                                                             var dFecha_Inicio_Tratamiento  : TDatetime;
                                                             var dFecha_Termino_Tratamiento : TDatetime;
                                                             var sPaga_Reajuste_Capital     : String;
                                                             var sNo_Considera_en_Interes   : String;
                                                             var sSolo_Aplica_en_Vctos      : String;
                                                             var sNo_Considera_Negativos    : String;
                                                             var Result                     : Boolean);
var i      : Integer;
   //,j      : Integer;
   bExiste : Boolean;
begin
  Result  := False;
  bExiste := False;


  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Excepcion_Cambiaria.Codigo_Emisor) then
     Carga_Excepcion_Cambiaria_Mem;

  for i := 0 to VarArrayHighBound(Reg_Excepcion_Cambiaria.Codigo_Emisor , 1 )  do
  begin
     if  (Reg_Excepcion_Cambiaria.Codigo_Emisor[i]      = sCodigo_Emisor)       and
         (Reg_Excepcion_Cambiaria.Codigo_Instrumento[i] = sCodigo_Instrumento ) and
         (Reg_Excepcion_Cambiaria.Serie[i]              = sSerie )              and
         (Reg_Excepcion_Cambiaria.Fecha_Desde[i]        <= dFecha_Calculo)      and
         ((Reg_Excepcion_Cambiaria.Fecha_Hasta[i]       >= dFecha_Calculo)      or
          (Reg_Excepcion_Cambiaria.Fecha_Hasta[i]       = 0 ))                  and
          (Reg_Excepcion_Cambiaria.Cupon_Desde[i]       <= fCupon )             and
          (Reg_Excepcion_Cambiaria.Cupon_Hasta[i]       >= fCupon )             then
     begin
        fPtje_Aplica_Reajuste      := Reg_Excepcion_Cambiaria.Ptje_Aplica_Reajuste[i];
        sCodigo_MondInd            := Reg_Excepcion_Cambiaria.COD_MONEDA_IND[i];
        s0Cod_Tratam_Inicio        := Reg_Excepcion_Cambiaria.COD_TRATAM_INICIO[i];
        s1Cod_Tratam_Termino       := Reg_Excepcion_Cambiaria.COD_TRATAM_Termino[i];
        dFecha_Inicio_Tratamiento  := Reg_Excepcion_Cambiaria.Fecha_Inicio_Tratam[i];
        dFecha_Termino_Tratamiento := Reg_Excepcion_Cambiaria.Fecha_Termino_Tratam[i];
        sPaga_Reajuste_Capital     := Reg_Excepcion_Cambiaria.PAGA_REAJUSTE_CAPITAL[i];
        //ggarcia 12-07-2018
        sNo_Considera_en_Interes   := Reg_Excepcion_Cambiaria.NO_CONSIDERA_EN_INTERES[i];
        sSolo_Aplica_en_Vctos      := Reg_Excepcion_Cambiaria.SOLO_APLICA_EN_VCTOS[i];
        sNo_Considera_Negativos    := Reg_Excepcion_Cambiaria.NO_CONSIDERA_NEGATIVOS[i];
        bExiste := True;
        Result := True;
        Break;
     end;
  end;

  if NOT bExiste then
  begin
     If (not Result) and (fCupon <> 0) Then
        Verifica_Excepcion_Variacion_Cambiaria_Vigente_Mem(sCodigo_Emisor,
                                                           sCodigo_Instrumento,
                                                           sSerie,
                                                           0,
                                                           dFecha_Calculo,
                                                           fPtje_Aplica_Reajuste,
                                                           sCodigo_MondInd,
                                                           s0Cod_Tratam_Inicio,
                                                           s1Cod_Tratam_Termino,
                                                           dFecha_Inicio_Tratamiento,
                                                           dFecha_Termino_Tratamiento,
                                                           sPaga_Reajuste_Capital,
                                                           sNo_Considera_en_Interes,
                                                           sSolo_Aplica_en_Vctos,
                                                           sNo_Considera_Negativos,
                                                           Result);
  end;
end;

Procedure Carga_Valores_Clasif_Riesgo_Mem( dFecha : TDatetime );
var i : LongInt;
    sCOD_EMP_SERIE,
    sCOD_INST_SERIE,
    sSERIE_CLASIF,
    sNEMOTECNICO,
    sCLASIF_SERIE  : String;
    dFecha_Aux     : Tdatetime;
    sOrigen        : String;
    sTipo_Clasif   : String;
begin
   with DmFuncionesMemory.Qry_General do
   begin
     Sql.Clear;
     Sql.Add(' SELECT a.*'
            +'   FROM QS_FIN_CL_RIESGOS a '
            +'  WHERE a.F_CLASIF_SERIE <= :Fecha');

     Parambyname('Fecha').asDate := dFecha;

     try
       Open;
       DmFuncionesMemory.Qry_General.FetchAll;
       DmFuncionesMemory.T_TmpRiesgo.Data := DmFuncionesMemory.Qry_General.Data;
       DmFuncionesMemory.T_TmpRiesgo.First;
     finally
       Close;
     end;
   end;

   DmFuncionesMemory.FDLocalSQL2.Active := True;

   With DmFuncionesMemory.T_TmpRiesgo do
   begin
     Last;
     Filtered := False;
     Filter   := ' (SERIE_CLASIF = '' '' OR SERIE_CLASIF IS NULL) ';
     Filtered := True;
     First;
     while not Eof do
     begin
       DmFuncionesMemory.T_TmpRiesgo.Edit;
       if DmFuncionesMemory.T_TmpRiesgo.FieldByName('SERIE_CLASIF').IsNull then
          DmFuncionesMemory.T_TmpRiesgo.FieldByName('SERIE_CLASIF').AsString := ''
       else
          DmFuncionesMemory.T_TmpRiesgo.FieldByName('SERIE_CLASIF').AsString := trim(DmFuncionesMemory.T_TmpRiesgo.FieldByName('SERIE_CLASIF').AsString);

       DmFuncionesMemory.T_TmpRiesgo.Post;
       Next;
     end;
   end;

   DmFuncionesMemory.T_TmpRiesgo.Filtered := False;

   with DMFuncionesMemory.Qry_TmpRiesgo do
   begin
     Sql.Clear;
     Sql.Add(' SELECT *'
            +'   FROM '+DmFuncionesMemory.T_TmpRiesgo.Name
            +'  ORDER BY COD_EMP_SERIE'
            +'          ,COD_INST_SERIE DESC'
            +'          ,SERIE_CLASIF '
            +'          ,F_CLASIF_SERIE DESC' );

     try
       Open;
     except on E: EFDDBEngineException do
        begin
           ShowError(E);
           Close;
           Reg_Clasif_Riesgo.COD_EMP_SERIE  := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.COD_INST_SERIE := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.SERIE_CLASIF   := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.NEMOTECNICO    := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.CLASIF_SERIE   := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.F_CLASIF_SERIE := VarArrayCreate([0, 0], varDate);
           Reg_Clasif_Riesgo.ORIGEN         := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo.TIPO_CLASIF    := VarArrayCreate([0, 0], varOleStr);
           Exit;
        end;
     end;

     DmFuncionesMemory.Qry_TmpRiesgo.last;
     i := DmFuncionesMemory.Qry_TmpRiesgo.RecordCount;
     DmFuncionesMemory.Qry_TmpRiesgo.first;

     Reg_Clasif_Riesgo.COD_EMP_SERIE  := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.COD_INST_SERIE := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.SERIE_CLASIF   := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.NEMOTECNICO    := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.CLASIF_SERIE   := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.F_CLASIF_SERIE := VarArrayCreate([0, i], varDate);
     Reg_Clasif_Riesgo.ORIGEN         := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo.TIPO_CLASIF    := VarArrayCreate([0, i], varOleStr);

     i := 0;
     while Not DmFuncionesMemory.Qry_TmpRiesgo.eof do
     begin
        sCOD_EMP_SERIE  := Fieldbyname('COD_EMP_SERIE').asString;
        sCOD_INST_SERIE := Fieldbyname('COD_INST_SERIE').asString;
        if (Fieldbyname('SERIE_CLASIF').isnull) then
           sSERIE_CLASIF   := ''
        else
           sSERIE_CLASIF   := Trim(Fieldbyname('SERIE_CLASIF').asString);
        sNEMOTECNICO    := Fieldbyname('NEMOTECNICO').asString;
        sOrigen         := Fieldbyname('ORIGEN').asString;
        sTipo_Clasif    := Fieldbyname('TIPO_CLASIF').asString;

        Reg_Clasif_Riesgo.COD_EMP_SERIE[i]  := sCOD_EMP_SERIE;
        Reg_Clasif_Riesgo.COD_INST_SERIE[i] := trim(sCOD_INST_SERIE);    // Se le agrego trim con fecha 10-11-2005 ya que no encontraba con un blanco en el bice
        Reg_Clasif_Riesgo.SERIE_CLASIF[i]   := trim(sSERIE_CLASIF);
        Reg_Clasif_Riesgo.NEMOTECNICO[i]    := trim(sNEMOTECNICO);
        Reg_Clasif_Riesgo.ORIGEN[i]         := trim(sORIGEN);
        Reg_Clasif_Riesgo.TIPO_CLASIF[i]    := trim(sTipo_Clasif);

        dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
        sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;

        Next;
        Reg_Clasif_Riesgo.CLASIF_SERIE[i]   := sCLASIF_SERIE;
        Reg_Clasif_Riesgo.F_CLASIF_SERIE[i] := dFecha_Aux;

        Inc(i);
     end;

     if i > 0 then
        Dec(i);

     VarArrayRedim(Reg_Clasif_Riesgo.COD_EMP_SERIE , i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.COD_INST_SERIE, i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.SERIE_CLASIF  , i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.NEMOTECNICO   , i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.CLASIF_SERIE  , i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.F_CLASIF_SERIE, i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.ORIGEN        , i + 1);
     VarArrayRedim(Reg_Clasif_Riesgo.TIPO_CLASIF   , i + 1);
     Close;

     Sql.Clear;
     Sql.Add(' SELECT *'
            +'   FROM '+DmFuncionesMemory.T_TmpRiesgo.Name
            +'  WHERE NEMOTECNICO <> '' '' and NEMOTECNICO IS NOT NULL '
            +' ORDER BY F_CLASIF_SERIE DESC'
            +'         ,COD_EMP_SERIE'
            +'         ,COD_INST_SERIE DESC'
            +'         ,SERIE_CLASIF '
            );

     try
       Open;
     except on E: EFDDBEngineException do
        begin
           ShowError(E);
           Close;
           Reg_Clasif_Riesgo_Nem.COD_EMP_SERIE  := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.COD_INST_SERIE := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.SERIE_CLASIF   := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.NEMOTECNICO    := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.CLASIF_SERIE   := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.F_CLASIF_SERIE := VarArrayCreate([0, 0], varDate);
           Reg_Clasif_Riesgo_Nem.ORIGEN         := VarArrayCreate([0, 0], varOleStr);
           Reg_Clasif_Riesgo_Nem.TIPO_CLASIF    := VarArrayCreate([0, 0], varOleStr);
           Exit;
        end;
     end;


     DmFuncionesMemory.Qry_TmpRiesgo.last;
      i := DmFuncionesMemory.Qry_TmpRiesgo.RecordCount;
      DmFuncionesMemory.Qry_TmpRiesgo.first;

     Reg_Clasif_Riesgo_Nem.COD_EMP_SERIE  := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.COD_INST_SERIE := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.SERIE_CLASIF   := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.NEMOTECNICO    := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.CLASIF_SERIE   := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.F_CLASIF_SERIE := VarArrayCreate([0, i], varDate);
     Reg_Clasif_Riesgo_Nem.ORIGEN         := VarArrayCreate([0, i], varOleStr);
     Reg_Clasif_Riesgo_Nem.TIPO_CLASIF    := VarArrayCreate([0, i], varOleStr);

     i := 0;
     while Not DmFuncionesMemory.Qry_TmpRiesgo.eof do
     begin
        sCOD_EMP_SERIE  := Fieldbyname('COD_EMP_SERIE').asString;
        sCOD_INST_SERIE := Fieldbyname('COD_INST_SERIE').asString;
        if Fieldbyname('SERIE_CLASIF').isnull then
           sSERIE_CLASIF   := ''
        else
           sSERIE_CLASIF   := Fieldbyname('SERIE_CLASIF').asString;
        sNEMOTECNICO    := Fieldbyname('NEMOTECNICO').asString;
        sOrigen         := Fieldbyname('ORIGEN').asString;
        sTipo_Clasif    := Fieldbyname('TIPO_CLASIF').asString;

        Reg_Clasif_Riesgo_Nem.COD_EMP_SERIE[i]  := sCOD_EMP_SERIE;
        Reg_Clasif_Riesgo_Nem.COD_INST_SERIE[i] := trim(sCOD_INST_SERIE);    // Se le agrego trim con fecha 10-11-2005 ya que no encontraba con un blanco en el bice
        Reg_Clasif_Riesgo_Nem.SERIE_CLASIF[i]   := trim(sSERIE_CLASIF);
        Reg_Clasif_Riesgo_Nem.NEMOTECNICO[i]    := trim(sNEMOTECNICO);
        Reg_Clasif_Riesgo_Nem.ORIGEN[i]         := trim(sORIGEN);
