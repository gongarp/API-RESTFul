      Reg_Descriptores.TIPO_PAGO[j]          := FieldByName('TIPO_PAGO').AsString;
      Reg_Descriptores.PERIODO_GRACIA[j]     := FieldByName('PERIODO_GRACIA').AsFloat;
      Next;
      if Eof then
         Break;

     end;
     Close;
  end;
end;
