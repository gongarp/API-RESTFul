Procedure Carga_Valores_Indices_Mem( dFecha_Inicial
                                    ,dFecha_Final   : TDatetime;
                                    sMoneda_Indice : String
                                    );
Var i          : LongInt;
   sConversion : String;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      SQL.Clear;
      SQL.Add(' SELECT Count(*) As Num_Regs FROM QS_SYS_VAL_CAMBIO'
             +' WHERE Fecha_Paridad BETWEEN  :Fecha_Inicial AND :Fecha_Final'
             +'  AND  Cod_Moneda       = :Cod_Indice'
             +'  AND  Tipo_de_Paridad  = ''BC'''
             );
      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Parambyname('Cod_Indice').asString      := sMoneda_Indice;
      Open;

      i := Round(FieldByName('Num_Regs').AsFloat);

      Close;
      SQL.Clear;
      SQL.Add(' SELECT UNIDAD_CONVERSION FROM QS_SYS_MONEDAS '
             +' WHERE COD_MONEDA = '''+ sMoneda_Indice+''''
             );
      Open;
      if FieldByName('UNIDAD_CONVERSION').IsNull then
         sConversion := sMoneda_Indice
      else
         sConversion := FieldByName('UNIDAD_CONVERSION').AsString;

      Close;
      SQL.Clear;
      SQL.Add('SELECT * FROM QS_SYS_VAL_CAMBIO'
             +' WHERE Fecha_Paridad BETWEEN  :Fecha_Inicial AND :Fecha_Final'
             +'  AND  Cod_Moneda       = :Cod_Indice'
             +'  AND  Moneda_Paridad   = :Moneda_Paridad'
             +'  AND  Tipo_de_Paridad  = ''BC'''
             +' ORDER BY Fecha_Paridad'
             );
      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Parambyname('Cod_Indice').asString      := sMoneda_Indice;
      Parambyname('Moneda_Paridad').asString  := sConversion;
      Open;

      Reg_Valores_Indices.Codigo_Indice   := VarArrayCreate([0, i], varOleStr);
      Reg_Valores_Indices.MONEDA_PARIDAD  := VarArrayCreate([0, i], varOleStr);
      Reg_Valores_Indices.FECHA_PARIDAD   := VarArrayCreate([0, i], varDate);
      Reg_Valores_Indices.Valor_Indice    := VarArrayCreate([0, i], varDouble);

      i := 0;
      While NOT Eof  do
      begin
         Reg_Valores_Indices.Codigo_Indice[i]   := Fieldbyname('COD_MONEDA').asString;
         Reg_Valores_Indices.MONEDA_PARIDAD[i]  := Fieldbyname('MONEDA_PARIDAD').asString;
         Reg_Valores_Indices.FECHA_PARIDAD[i]   := Fieldbyname('FECHA_PARIDAD').asDatetime;
         Reg_Valores_Indices.Valor_Indice[i]    := Fieldbyname('VALOR_MONEDA').asFloat;
         Next;
         Inc(i);
      end;
      Close;
  end;
end;

Procedure Leer_Valor_Indice_Mem( sCod_Indice    : String;
                                 dFecha_Paridad : Tdatetime;
                             var fValor         : Double;
                                 Result         : Boolean
                                 );
var i : LongInt;
begin
//   Result := False;
   for i := 0  to VarArrayHighBound(Reg_Valores_Indices.Codigo_Indice, 1 )-1 do
   begin
      if ( Reg_Valores_Indices.Codigo_Indice[i] = sCod_Indice    ) and
         ( Reg_Valores_Indices.FECHA_PARIDAD[i] = dFecha_Paridad ) then
      begin
         fValor  := Reg_Valores_Indices.Valor_Indice[i];
//         Result  := True;
         Break;
      end;

      if Reg_Valores_Indices.FECHA_PARIDAD[i] > dFecha_Paridad then
         Break;
   end;
end;

