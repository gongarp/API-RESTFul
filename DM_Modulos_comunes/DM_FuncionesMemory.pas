Function Busca_Car_Nem_Fechas( Const sNemotecnico : String;
                               Const scartera     : String;
                               var j              : Integer): Boolean;

var i
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
    bEncontrado : Boolean;
    sCartera_Array : string;
    snemotec_Array : string;
begin
   iLimite_Inferior := 0;
   i := 0;
   iLimite_Superior := VarArrayHighBound(Registro_RV.scartera, 1 )-1;
//   Result      := False;
   bEncontrado := False;

   While iLimite_Inferior <= iLimite_Superior do
   begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     sCartera_Array := Trim(Registro_RV.scartera[i]);
     snemotec_Array := Trim(Registro_RV.sNemotecnico[i]);

     if  (Registro_RV.scartera[i] = scartera) and
         (Registro_RV.sNemotecnico[i] = sNemotecnico) then
     begin
        bEncontrado := True;
        Break;
     end;

     if scartera > Registro_RV.scartera[i] then
        iLimite_Inferior := i + 1
     else
        if Trim(sNemotecnico) > TRIM(Registro_RV.sNemotecnico[i]) then
//           if Trim(scartera) = Trim(Registro_RV.scartera[i]) then
           if Trim(scartera) = sCartera_Array then
              iLimite_Superior := iLimite_Superior + 1
           else
//              iLimite_Superior := i + 1
              iLimite_Superior := i - 1
        else
           iLimite_Superior := i - 1;
   end;

   if bEncontrado then
        //Retrocedo hasta Primer Nemotecnico
      while (Registro_RV.scartera[i]     = scartera) AND
            (Registro_RV.sNemotecnico[i] = sNemotecnico ) AND
            (i >= 0) do
         begin
            i := i - 1;
            if i < 0 then
               break;
         end;
      begin
         j := i + 1;
         Result := True;
         Exit;
      end;
end;

Function Busca_Nemotec_Fechas( Const sNemotecnico : String;
                               var j              : Integer): Boolean;
var i
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
    bEncontrado : Boolean;
begin
   iLimite_Inferior := 0;
   i := 0;
   iLimite_Superior := VarArrayHighBound(Registro_RV.sNemotecnico, 1 )-1;
//   Result      := False;
   bEncontrado := False;
   While iLimite_Inferior <= iLimite_Superior do
   begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if (Registro_RV.sNemotecnico[i] = sNemotecnico) then
     begin
        bEncontrado := True;
        Break;
     end;

     if sNemotecnico > Registro_RV.sNemotecnico[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i - 1;
   end;

   if bEncontrado then
        //Retrocedo hasta Primer Nemotecnico
      while (Registro_RV.sNemotecnico[i] = sNemotecnico ) AND
            (i >= 0) do
         begin
            i := i - 1;
            if i < 0 then
               break;
         end;
      begin
         j := i + 1;
         Result := True;
         Exit;
      end;
end;

Procedure Carga_Prob_Deterioro_Nemo_Mem(dFecha :TDateTime);
var i : LongInt;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT a.* '
             +'  FROM QS_FIN_PROB_DETER_NEMOTECNICO a '
             //ggarcia 25-10-2023
             //+' WHERE a.Fecha_Vigencia = (SELECT MAX(a.Fecha_Vigencia) '
             //+'                             FROM QS_FIN_PROB_DETER_NEMOTECNICO a '
             //+'                            WHERE a.Fecha_Vigencia <= :Fecha ) ');
             +' WHERE a.Fecha_Vigencia = :Fecha ');
      ParamByName('Fecha').AsDateTime     := dFecha;
      Open;

      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;

      Reg_Prob_Deterioro_Nemo.Nemotecnico    := VarArrayCreate([0, i], varOleStr);
      Reg_Prob_Deterioro_Nemo.Prob_Deterioro := VarArrayCreate([0, i], varDouble);
      i := 0;
      while not eof do
      begin
        Reg_Prob_Deterioro_Nemo.Nemotecnico[i]    := trim(FieldByName('Nemotecnico').AsString);
        Reg_Prob_Deterioro_Nemo.Prob_Deterioro[i] := FieldByName('Prob_Deterioro').AsFloat;
        Inc(i);
        Next;
      end;
      close;
   end;
end;

