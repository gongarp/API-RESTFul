function lee_tasa_mercado_Mem(const sNemotecnico : String;
                              dFecha       : TDateTime;
                              bBuscar      : Boolean;
                          var sOrigen      : String;
                          var fTasaMercado : Double;
                          var sTipo        : String ) : Boolean;
var i : Integer;
// Cambio para que lea fisico si no encuentra memory
begin
  if NOT VarIsArray(Reg_Tasas_Mercado.Codigo_Nemotecnico) then
  begin
     if sLlamado_Desde = 'MESA DE DINERO' then
        Carga_Valores_Tasas_Mercado_Optimizado_Mem(dFecha)
     else
        Carga_Valores_Tasas_Mercado_Mem(dFecha);
  end;

  fTasaMercado := 0;
  Result := false;

  if Reg_Tasas_Mercado.Fecha[0] <> dFecha then
  begin
     Exit;
  end;

  for i := 0 to VarArrayHighBound( Reg_Tasas_Mercado.Codigo_Nemotecnico, 1 )-1 do
  begin
     if sOrigen = 'MUL-ORIGEN' then
     begin
         if (Reg_Tasas_Mercado.Codigo_Nemotecnico[i] = sNemotecnico) then
         begin
            fTasaMercado := Reg_Tasas_Mercado.Valor[i];
            sTipo        := Reg_Tasas_Mercado.Tipo[i];
            sOrigen      := Reg_Tasas_Mercado.Origen[i];
            Result := true;
            Break;
         end;
     end
     else
     begin
         if (Reg_Tasas_Mercado.Codigo_Nemotecnico[i] = sNemotecnico) and
            (Reg_Tasas_Mercado.Origen[i]             = sOrigen) then
         begin
            fTasaMercado := Reg_Tasas_Mercado.Valor[i];
            sTipo        := Reg_Tasas_Mercado.Tipo[i];
            Result := true;
            Break;
         end;
     end;
  end;
end;

