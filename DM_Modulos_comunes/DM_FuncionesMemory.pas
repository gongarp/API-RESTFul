function Leer_Tir_Mra_Mem(sNemotecnico   : String;
                          dFecha_Calculo : TDatetime;
                          var sOrigen    : String;
                          sTipo_TasPre   : String ) : Double;
var fDias,
    anos_enteros,
    anos_fraccion,
    meses_enteros,
    fValor : Double;
    aa,
    mm,
    dd : word;
    //dFecha_Tasa : TDateTime;
    //bExiste,
    Resultado  : Boolean;
    dFecha_Emision,
    dFecha_Vencimiento : TDatetime;
    sTipoBono : String;
    i : Integer;
    sModulo_Error   : String;
    sString_Error   : String;
begin
  //ggarcia 07-03-2018
  if NOT VarIsArray(Reg_Valores_Tirmra.Fecha_Calculo) then
     Carga_Valores_Tirmra_Mem( dFecha_Calculo );

  if Reg_Valores_Tirmra.Fecha_Calculo[0] <> dFecha_Calculo then
  begin
     Leer_Tir_Mra_Mem := 0;
     Exit;
  end;

  Decodifica_Nemotecnico_Br(sNemotecnico,
                           sTipoBono,
                           dFecha_Emision,
                           dFecha_Vencimiento,
                           sModulo_Error,
                           sString_Error,
                           Resultado);

  calculo_de_dias( dFecha_Calculo,
                   dfecha_Vencimiento,
                   'EXACTOS',
                   sPais_Usuario,
                   fDias,
                   anos_enteros,
                   anos_fraccion,
                   meses_enteros);

  Leer_Tir_Mra_Mem := 0;
  Decodedate(dFecha_Calculo, aa,mm,dd);

  // Antes de Enero del 98 es en ańos ....
  if dFecha_Calculo >= EncodeDate(1998,01,01) then
    fValor := fDias
  else
    fValor := anos_fraccion;

  For i := 0 to VarArrayHighBound( Reg_Valores_Tirmra.Dias_Desde, 1 ) do
  begin
     if sOrigen = 'MUL-ORIGEN' then
     begin
         if (Reg_Valores_Tirmra.Dias_Desde[i]  <= fValor ) and
            (Reg_Valores_Tirmra.Dias_Hasta[i]  >= fValor ) then
         begin
            Leer_Tir_Mra_Mem := Reg_Valores_Tirmra.Valor[i];
            sTipo_TasPre     := Reg_Valores_Tirmra.Tipo[i];
            sOrigen          := Reg_Valores_Tirmra.Origen[i];
            Break;
         end;
     end
     else
         if (Reg_Valores_Tirmra.Dias_Desde[i]  <= fValor ) and
            (Reg_Valores_Tirmra.Dias_Hasta[i]  >= fValor ) and
            (Reg_Valores_Tirmra.Origen[i]       = sOrigen ) then
         begin
            Leer_Tir_Mra_Mem := Reg_Valores_Tirmra.Valor[i];
            sTipo_TasPre     := Reg_Valores_Tirmra.Tipo[i];
            Break;
         end;
  end;
end;

