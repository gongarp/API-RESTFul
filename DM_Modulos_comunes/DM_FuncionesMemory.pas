            Break;
         end;
      end;

   // Busco Clasificacion para Instrumento
   if Not bClasifica then
      for i := 0 to VarArrayHighBound(Reg_Clasifica_Var.Instrumento , 1 )  do
      begin
         if (Reg_Clasifica_Var.Instrumento[i] = sInstrumento) and
            (Reg_Clasifica_Var.Moneda[i]      = EmptyStr)     and
            (Reg_Clasifica_Var.Emisor[i]      = EmptyStr)     and
            (Reg_Clasifica_Var.Cod_Clasif[i]  = scod_Clasif)  then
         begin
            bClasifica := True;
            Break;
         end;
      end;

    if Not bClasifica then
    begin
       Result := '';
       Exit;
    end;

    Result := Reg_Clasifica_Var.CLASIFICACION[i];

end;

