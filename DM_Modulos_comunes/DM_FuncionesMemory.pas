          Reg_Emision_Implicita.Mes_Refer[i]   := Fieldbyname('Mes_Refer'  ).AsString;
          Reg_Emision_Implicita.Mes_Ant_Des[i] := Fieldbyname('Mes_Ant_Des').AsFloat;
          Reg_Emision_Implicita.Ano[i]         := Fieldbyname('Ano'        ).AsFloat;
          Reg_Emision_Implicita.Ano_Refer[i]   := Fieldbyname('Ano_Refer'  ).AsString;
          Reg_Emision_Implicita.Ano_Ant_Des[i] := Fieldbyname('Ano_Ant_Des').AsFloat;

          Inc(i);
