function Busca_Nem_Fechas( Const sNemotecnico : String;
                           iNro_Cupon          : Integer;
                           var dFecha          : TDatetime) : Boolean;
var i
   ,j
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
   bEncontrado : Boolean;
begin
  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Nem_Fechas.Codigo_Nemotecnico, 1 )-1;
  Result      := False;
  bEncontrado := False;
  i := 0;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Nem_Fechas.Codigo_Nemotecnico[i] = sNemotecnico then
     begin
        bEncontrado := True;
        Break;
     end;

     if sNemotecnico > Reg_Nem_Fechas.Codigo_Nemotecnico[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i - 1;
  end;

  if bEncontrado then
  begin
      //Retrocedo hasta Primer Nemotecnico
      For j := i Downto 0 do
        if Reg_Nem_Fechas.Codigo_Nemotecnico[j] <> sNemotecnico then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Nem_Fechas.Codigo_Nemotecnico , 1 )) and
            ( Reg_Nem_Fechas.Codigo_Nemotecnico[i] = sNemotecnico ) do
      begin
         if (Reg_Nem_Fechas.Codigo_Nemotecnico[i] = sNemotecnico) and
            (Reg_Nem_Fechas.Cupon[i]   = iNro_Cupon)  then
         begin
             dFecha := Reg_Nem_Fechas.Fecha[i];
             Result := True;
             Exit;
         end;
         Inc(i);
      end;
  end;

  if Not Result Then // Por si Falla la Busqueda
  begin
     WITH dmFuncionesMemory.QRY_General do
     begin
        SQL.Clear;
        SQL.Add('SELECT Fecha_Vencimiento'
               +'  FROM QS_FIN_Nem_Fechas'
               +' WHERE Codigo_Nemotecnico = :Nemotecnico '
               +'   AND Nro_Cupon = :Cupon');
        ParamByName('Nemotecnico').AsString := sNemotecnico;
        ParamByName('Cupon').AsFloat        := iNro_Cupon;
        Open;
        if FieldByName('Fecha_Vencimiento').IsNull then
           Result := False
        else
        begin
           dFecha := FieldByName('Fecha_Vencimiento').AsDatetime;
           Result := True;
        end;
        Close;
    end;
  end;
end;

