Procedure Carga_Metodos_Valuacion_Mem;
Var i : LongInt;
begin

   with DmFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add(' SELECT * FROM QS_FIN_MET_VALUAC ' );
      Open;

        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Valuacion.PROCESO        := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.CARTERA        := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.PAIS           := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.EMISOR         := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.INSTRUMENTO    := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.MONEDA_INSTRUM := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.SERIE          := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.MOTIVO         := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.TIPO_VALUAC    := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.FECHA_DESDE    := VarArrayCreate([0, i], varDate);
      Reg_Valuacion.FECHA_HASTA    := VarArrayCreate([0, i], varDate);
      Reg_Valuacion.FORMULA_PTE    := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.ORIGEN         := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.BASE_PRECIO    := VarArrayCreate([0, i], varDouble);
      Reg_Valuacion.MON_IND        := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.TRANSACCION    := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.TASA_BASE      := VarArrayCreate([0, i], varOleStr);
      Reg_Valuacion.CODIGO_FORMULA := VarArrayCreate([0, i], varOleStr);
      i := 0;
      while not eof do
