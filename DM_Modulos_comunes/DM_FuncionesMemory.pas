procedure Carga_VarCamb_Depende_de_Operacion_Mem;
var i : LongInt;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      SQL.Clear;
      if sDriver = 'ORACLE' then
         SQL.Add(' SELECT COUNT(DISTINCT B.CODIGO_EMISOR||B.CODIGO_INSTRUMENTO||B.SERIE) AS Num_Regs ')
      else
         SQL.Add(' SELECT COUNT(DISTINCT B.CODIGO_EMISOR+B.CODIGO_INSTRUMENTO+B.SERIE) AS Num_Regs ');

      SQL.Add ('   FROM QS_SYS_TRATAM A'
              +'       ,QS_FIN_EXCP_VARCAM B'
              +'  WHERE A.REFERENCIA IN  (''FECOPERAC'',''FECCOMP'')  '
              +'    AND (B.COD_TRATAM_INICIO = A.CODIGO_TRATAM OR B.COD_TRATAM_TERMINO = A.CODIGO_TRATAM)   ');
      Open;
      i := FieldByName('Num_Regs').AsInteger;
      Close;

      SQL.Clear;
      SQL.Add(' SELECT DISTINCT B.CODIGO_EMISOR,B.CODIGO_INSTRUMENTO,B.SERIE   '
              +'  FROM QS_SYS_TRATAM A '
	      +'      ,QS_FIN_EXCP_VARCAM B  '
              +' WHERE A.REFERENCIA IN  (''FECOPERAC'',''FECCOMP'')  '
             +'   AND (B.COD_TRATAM_INICIO = A.CODIGO_TRATAM OR B.COD_TRATAM_TERMINO = A.CODIGO_TRATAM) '
             +'   ORDER BY B.CODIGO_EMISOR,B.CODIGO_INSTRUMENTO,B.SERIE ');
     Open;

      Reg_VarCamb_Operacion.Codigo_Emisor      := VarArrayCreate([0, i], varOleStr);
      Reg_VarCamb_Operacion.Codigo_Instrumento := VarArrayCreate([0, i], varOleStr);
      Reg_VarCamb_Operacion.Serie              := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_VarCamb_Operacion.Codigo_Emisor[i]      := Fieldbyname('CODIGO_EMISOR').asString;
         Reg_VarCamb_Operacion.Codigo_Instrumento[i] := Fieldbyname('CODIGO_INSTRUMENTO').asString;
         Reg_VarCamb_Operacion.Serie[i]              := Fieldbyname('SERIE').asString;
         Next;
         Inc(i);
      end;
      Close;
   end;
end;
//-----------------------------------------------------------------------------------------
function VarCamb_Depende_de_Operacion_Mem( sEmisor      : String;
                                           sInstrumento : String;
                                           sSerie       : String) : Boolean;
var i : LongInt;                                           
begin
 Result  := False;

 if NOT VarIsArray(Reg_VarCamb_Operacion.Codigo_Emisor) then
     Carga_VarCamb_Depende_de_Operacion_Mem;

 for i := 0 to VarArrayHighBound( Reg_VarCamb_Operacion.Codigo_Emisor, 1 )-1 do
 begin
    if  (Reg_VarCamb_Operacion.Codigo_Emisor[i]      = sEmisor)      AND
        (Reg_VarCamb_Operacion.Codigo_Instrumento[i] = sInstrumento) AND
        (Reg_VarCamb_Operacion.Serie[i]              = sSerie)       then
    begin
       Result := True;
       Break;
    end;
 end;
end;
