Procedure Carga_Ultimo_Valor_de_Cambio_Mem( dFecha_Calculo : TDatetime );
Var i : LongInt;
begin
   // Valores para calculo de tasa proyeccion simple
   with DmFuncionesMemory.QRY_General do
   begin
       SQL.Clear;
       SQL.Add('SELECT a.Cod_Moneda'
              +'      ,a.Fecha_Paridad'
              +'      ,a.Valor_Moneda'
              +'  FROM qs_sys_val_cambio a'
              +' WHERE a.Fecha_Paridad in (SELECT MAX(b.Fecha_Paridad)'
                                         +'  FROM qs_sys_val_cambio b'
                                         +' WHERE b.Cod_Moneda = a.Cod_moneda'
                                         +'   AND b.Moneda_Paridad = a.Moneda_Paridad'
                                         +'   AND b.Fecha_Paridad <= :Fecha)'
              +' GROUP BY a.Cod_Moneda'
              +'         ,a.Fecha_Paridad'
              +'         ,a.Valor_Moneda');

       //antes de agregar el order by se cuentan los registros 02-06-2015 PnP
       i := SelectCountSql(sql.Text,['Fecha'],[ftDate],[DateToStr(dFecha_Calculo)]);

       SQL.Add(' ORDER BY Cod_Moneda' );
       ParamByName('Fecha').AsDate := dFecha_Calculo;
       Open;
       //se reemplaza por la funcion selectCountSQl 02-06-2015PnP
//       DmFuncionesMemory.QRY_General.last;
//        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;

       Reg_Ultimo_Valor_Cambio.COD_MONEDA   := VarArrayCreate([0, i], varOleStr);
       Reg_Ultimo_Valor_Cambio.VALOR_MONEDA := VarArrayCreate([0, i], varDouble);
       Reg_Ultimo_Valor_Cambio.Fecha_Paridad:= VarArrayCreate([0, i], varDate);

       i := 0;
       while not eof do
       begin
          Reg_Ultimo_Valor_Cambio.COD_MONEDA[i]    := Fieldbyname('COD_MONEDA').asString;
          Reg_Ultimo_Valor_Cambio.VALOR_MONEDA[i]  := Fieldbyname('VALOR_MONEDA').asString;
          Reg_Ultimo_Valor_Cambio.Fecha_Paridad[i] := Fieldbyname('fecha_Paridad').asDatetime;
          Next;
         Inc(i);
       end;
       Close;
  end;
end;

procedure Tasa_Proyeccion_Simple_Mem(sCodigo_Tasa       : String;
                                    dFecha             : TDateTime;
                                    var dFecha_Tasa    : TDateTime;
                                    var sReal_Estimada : String;
                                    var fValor_Tasa    : Double;
                                    var sModulo_Err    : String;
                                    var sString_Err    : String;
                                    var Result         : Boolean );
var  i
  ,iLimite_Inferior
  ,iLimite_Superior : Integer;
begin
  Result         := False;
  sReal_Estimada := '';

  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Ultimo_Valor_Cambio.Cod_Moneda, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Ultimo_Valor_Cambio.Cod_Moneda[i] = sCodigo_Tasa then
     begin
         fValor_Tasa    := Reg_Ultimo_Valor_Cambio.VALOR_MONEDA[i];
         dFecha_Tasa    := Reg_Ultimo_Valor_Cambio.Fecha_Paridad[i];
         sReal_Estimada := 'PROYSIMPLE';
         Result         := True;
         Break;
     end;

     if sCodigo_Tasa > Reg_Ultimo_Valor_Cambio.Cod_Moneda[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i -1;
    end;

end;

