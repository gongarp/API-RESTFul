procedure Valida_Permiso_Mem(const sNombre_Programa  : String;
                             var bEjecuta            : Boolean;
                             var bInserta            : Boolean;
                             var bElimina            : Boolean;
                             var bModifica           : Boolean);
Var
  i : Integer;
begin
  bEjecuta  := False;
  bInserta  := False;
  bElimina  := False;
  bModifica := False;
  for i := 0  to VarArrayHighBound(Reg_Permisos.Nombre_programa, 1 )-1 do
  begin
    if  Reg_Permisos.Nombre_programa[i] = sNombre_Programa then
    begin
       bEjecuta  := (Reg_Permisos.Ejecuta_sn[i] = 'S');
       bInserta  := (Reg_Permisos.Inserta_sn[i] = 'S');
       bElimina  := (Reg_Permisos.Elimina_sn[i] = 'S');
       bModifica := (Reg_Permisos.Modifica_sn[i] = 'S');
       Break;
    end;
  end;
end;

Procedure Carga_Valores_Tasas_Instrumento_Mem( dFecha : TDatetime );
Var i : Integer;
    sPais_Tasa      :String;
    dFecha_Inicial  :TDateTime;
    sTipo_Proceso   :String;
    fCantidad       :Double;
    sUnidad         :String;
    sAntes_Despues  :String;
    bResult         :Boolean;
begin
   //ggarcia 15-11-2023 Se incorpora lectura ultimo conocido hasta la fecha indicada en proyeccion de precios
   sPais_Tasa     := sPais_Usuario;
   sTipo_Proceso := 'VALORIZA';
   Busca_Proy_Precio_Mem(sTipo_Proceso,
                         fCantidad,
                         sUnidad,
                         sAntes_Despues,
                         bResult);
   if bResult then
   begin
      if sAntes_Despues = 'A' then
         dFecha_Inicial := Resta_dias_corridos(sPais_Tasa,                 // Resta_dias_habiles(sPais_Tasa,
                                               dFecha,
                                               fCantidad)
      else
         dFecha_Inicial := Suma_dias_corridos(sPais_Tasa,                  // Suma_dias_habiles(sPais_Tasa,
                                              dFecha,
                                              fCantidad);
   end
   else
      dFecha_Inicial := dFecha;

   with DmFuncionesMemory.Qry_General do
   begin
      Close;
      Sql.Clear;
      SQL.Add(' SELECT a.Unidad_Medida ');
      SQL.Add('       ,c.Codigo        ');
      SQL.Add('       ,c.Dias_Desde    ');
      SQL.Add('       ,c.Dias_hasta    ');
      SQL.Add('       ,c.Valor         ');
      SQL.Add('       ,a.Origen        ');
      SQL.Add('       ,c.Tipo          ');
      SQL.Add('   FROM  QS_FIN_FECHA_TRAMO a ');
      SQL.Add('        ,QS_FIN_VALOR_TRAMO c ');
      SQL.Add('  WHERE a.Codigo IN (SELECT d.Cod_instrumento FROM QS_FIN_INSTRUM d) ');
      SQL.Add('    AND c.Codigo = a.Codigo ');
      SQL.Add('    AND c.Fecha  = a.Fecha  ');
      SQL.Add('    AND c.Origen = a.Origen ');
      //ggarcia 15-11-2023 Se incorpora lectura ultimo conocido hasta la fecha indicada en proyeccion de precios
      //SQL.Add('    AND a.fecha  = :Fecha                     ');
      SQL.Add('    AND a.fecha  In (SELECT MAX(a.fecha) '
                                +'    FROM QS_FIN_FECHA_TRAMO a'
                                +'        ,QS_FIN_INSTRUM     b'
                                +'        ,QS_FIN_VALOR_TRAMO c'
                                +'   WHERE a.Codigo = b.Cod_Instrumento'
                                +'     AND a.Codigo = c.Codigo'
                                +'     AND a.Fecha  = c.Fecha'
                                +'     AND a.Fecha between :Fecha_inicial and :Fecha )');
      SQL.Add('    ORDER BY a.Unidad_Medida, c.Codigo, c.Dias_Desde ');

      // E.S. Lo volvi a dejar como antes (18-11-2010)
      // y condicione la busqueda de tasas por instruento que sea <> 'B' (bono reco)
      // E.S.  21-09-2012, volvi a dejar la condicion de busqueda al dia del proceso
      // el no hacerlo, provoca que busque tasas de mil ańos atras y no de maximo 180 dias (caso OHIO)

      // E.S. & P.M. , debe buscar valor solo a la fecha de proceso
      //      SQL.Add('    AND a.fecha  In ( SELECT MAX(x.fecha) FROM  QS_FIN_VALOR_TRAMO x       ');
      //      SQL.Add('                       WHERE x.Codigo = a.Codigo                           ');
      //      SQL.Add('                         AND x.Origen = a.Origen                           ');
      //      SQL.Add('                         AND x.Fecha <= :Fecha                             ');
      //      SQL.Add('                 )                                                         ');
      //      SQL.Add('    ORDER BY c.Dias_Desde                                                  ');

      { Se corrigio y optimizo el SQL con fecha 25-09-2009 E.S. & F.I.
      Sql.Add( 'SELECT a.Unidad_Medida'
              +'      ,c.Codigo'
              +'      ,c.Dias_Desde'
              +'      ,c.Dias_hasta'
              +'      ,c.Valor'
              +'      ,a.Origen'
              +' FROM  QS_FIN_FECHA_TRAMO a'
              +'      ,QS_FIN_INSTRUM b'
              +'      ,QS_FIN_VALOR_TRAMO c'
              +' WHERE a.Codigo = b.Cod_Instrumento'
              +'   AND a.Codigo = c.Codigo'
              +'   AND a.Fecha  = c.Fecha'
              +'   AND a.fecha  In ( SELECT MAX(a.fecha) FROM  QS_FIN_FECHA_TRAMO a'
                                +'      ,QS_FIN_INSTRUM     b'
                                +'      ,QS_FIN_VALOR_TRAMO c'
                                +'  WHERE a.Codigo = b.Cod_Instrumento'
                                +'    AND a.Codigo = c.Codigo'
                                +'    AND a.Fecha  = c.Fecha'
                                +'    AND a.Fecha <= :Fecha'
                                +'  )'
              +' ORDER BY c.Dias_Desde'
             );
      }
      ParamByName('Fecha_inicial').AsDate := dFecha_Inicial;
      ParamByName('Fecha').AsDate         := dFecha;
      Open;

      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Valores_Tasas_Instrumento.Unidad     := VarArrayCreate([0, i], varOleStr);
      Reg_Valores_Tasas_Instrumento.Instrumento:= VarArrayCreate([0, i], varOleStr);
      Reg_Valores_Tasas_Instrumento.Dias_Desde := VarArrayCreate([0, i], varDouble);
      Reg_Valores_Tasas_Instrumento.Dias_Hasta := VarArrayCreate([0, i], varDouble);
      Reg_Valores_Tasas_Instrumento.Valor      := VarArrayCreate([0, i], varDouble);
      Reg_Valores_Tasas_Instrumento.Origen     := VarArrayCreate([0, i], varOleStr);
      Reg_Valores_Tasas_Instrumento.Tipo       := VarArrayCreate([0, i], varOleStr);
      i := 0;
      while Not DmFuncionesMemory.Qry_General.Eof do
      begin
         Reg_Valores_Tasas_Instrumento.Unidad[i]     := Fieldbyname('Unidad_Medida').asString;
         Reg_Valores_Tasas_Instrumento.Instrumento[i]:= Fieldbyname('Codigo').asString;
         Reg_Valores_Tasas_Instrumento.Dias_Desde[i] := Fieldbyname('Dias_Desde').asFloat;
         Reg_Valores_Tasas_Instrumento.Dias_Hasta[i] := Fieldbyname('Dias_Hasta').asFloat;
         Reg_Valores_Tasas_Instrumento.Valor[i]      := Fieldbyname('Valor').asFloat;
         Reg_Valores_Tasas_Instrumento.Origen[i]     := Fieldbyname('Origen').asString;
         Reg_Valores_Tasas_Instrumento.Tipo[i]       := Fieldbyname('Tipo').asString;
         Next;
         Inc(i);
      end;
      Close;
   end;
end;

function Leer_Tasa_Instrumento_Mem( sInstrumento   : String;
                                    dFecha_Calculo,
                                    dFecha_Vencimiento : TDatetime;
                                var sTipo              : String;
                                var sOrigen :String )  : Double;
var fDias,
    fanos_enteros,
    fanos_fraccion,
    fmeses_enteros : Double;
    //fValor : Double;
    i      : Integer;
begin
  //ggarcia 07-03-2018
  if NOT VarIsArray(Reg_Valores_Tasas_Instrumento.unidad) then
     carga_valores_Tasas_Instrumento_Mem(dFecha_Calculo);

  calculo_de_dias( dFecha_Calculo,
                   dFecha_Vencimiento,
                   'EXACTOS',
                   sPais_Usuario,
                   fDias,
                   fanos_enteros,
                   fanos_fraccion,
                   fmeses_enteros);

  Leer_Tasa_Instrumento_Mem := 0;
  sTipo                     := '';
  for i := 0 to VarArrayHighBound( Reg_Valores_Tasas_Instrumento.Dias_Desde, 1 ) do
  begin
     if Reg_Valores_Tasas_Instrumento.unidad[i] = 'ANO' then
     begin
        if sOrigen = 'MUL-ORIGEN' then
           begin
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fanos_fraccion ) and  //fanos_enteros GGARCIA 10/07/2006
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fanos_fraccion ) and  //fanos_enteros GGARCIA 10/07/2006
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i]  = sInstrumento )   then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 sOrigen                   := Reg_Valores_Tasas_Instrumento.Origen[i];
                 Break;
              end;
           end
           else
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fanos_fraccion ) and  //fanos_enteros GGARCIA 10/07/2006
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fanos_fraccion ) and  //fanos_enteros GGARCIA 10/07/2006
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i]  = sInstrumento ) and
                 (Reg_Valores_Tasas_Instrumento.Origen[i]       = sOrigen ) then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 Break;
              end;
     end;

     if Reg_Valores_Tasas_Instrumento.unidad[i] = 'MES' then
     begin
        fmeses_enteros := MonthsBetween(dFecha_Calculo, dFecha_Vencimiento);  // 16-06-2012 FI & ES, debido a que funcion calculo_de_dias retorma meses entre 1 y 12
        if sOrigen = 'MUL-ORIGEN' then
           begin
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fmeses_enteros ) and
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fmeses_enteros ) and
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i]  = sInstrumento )  then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 sOrigen                   := Reg_Valores_Tasas_Instrumento.Origen[i];
                 Break;
              end;
           end
           else
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fmeses_enteros ) and
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fmeses_enteros ) and
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i]  = sInstrumento ) and
                 (Reg_Valores_Tasas_Instrumento.Origen[i]       = sOrigen ) then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 Break;
              end;
     end;
     if Reg_Valores_Tasas_Instrumento.unidad[i] = 'DIA' then
     begin
        if sOrigen = 'MUL-ORIGEN' then
         begin
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fDias ) and
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fDias ) and
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i] = sInstrumento ) then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 sOrigen                   := Reg_Valores_Tasas_Instrumento.Origen[i];
                 Break;
              end;
         end
         else
              if (Reg_Valores_Tasas_Instrumento.Dias_Desde[i]  <= fDias ) and
                 (Reg_Valores_Tasas_Instrumento.Dias_Hasta[i]  >= fDias ) and
                 (Reg_Valores_Tasas_Instrumento.Instrumento[i]  = sInstrumento ) and
                 (Reg_Valores_Tasas_Instrumento.Origen[i]       = sOrigen ) then
              begin
                 Leer_Tasa_Instrumento_Mem := Reg_Valores_Tasas_Instrumento.Valor[i];
                 sTipo                     := Reg_Valores_Tasas_Instrumento.Tipo[i];
                 Break;
              end;
     end;
  end;
end;

Procedure Carga_Last_Tasas_Mercado_Optimizado_Mem( sTipo_Proceso : String;
                                                   dFecha : TDatetime );
