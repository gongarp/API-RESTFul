                                       );
end;

Procedure Ordenamiento_Registro_Tasacion_Mem( var Reg_Tasacion : TReg_Tasacion;
                                              iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio,
    fItem_Omd,
    fTasacion   : Double;
    cTransaccion,
    cEmpresa : String;
    dFecha_Tasacion : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Tasacion.fFolio[(Lo + Hi) div 2];

    repeat
      while Reg_Tasacion.fFolio[Lo] < Mid do
            Inc(Lo);
      while Reg_Tasacion.fFolio[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio          := Reg_Tasacion.fFolio[Lo];
         fItem_Omd       := Reg_Tasacion.fItem_Omd[Lo];
         cTransaccion    := Reg_Tasacion.Transaccion[Lo];
         cEmpresa        := Reg_Tasacion.Empresa[Lo];
         fTasacion       := Reg_Tasacion.fTasacion[Lo];
         dFecha_Tasacion := Reg_Tasacion.Fecha_Tasacion[Lo];

         Reg_Tasacion.fFolio[Lo] :=
                       Reg_Tasacion.fFolio[Hi];
         Reg_Tasacion.fItem_Omd[Lo]      :=
                       Reg_Tasacion.fItem_Omd[Hi];
         Reg_Tasacion.Transaccion[Lo]   :=
                       Reg_Tasacion.Transaccion[Hi];
         Reg_Tasacion.Empresa[Lo]       :=
                       Reg_Tasacion.Empresa[Hi];
         Reg_Tasacion.fTasacion[Lo]      :=
                       Reg_Tasacion.fTasacion[Hi];
         Reg_Tasacion.Fecha_Tasacion[Lo]      :=
                       Reg_Tasacion.Fecha_Tasacion[Hi];


         Reg_Tasacion.fFolio[Hi]         := fFolio;
         Reg_Tasacion.fItem_Omd[Hi]      := fItem_Omd;
         Reg_Tasacion.Transaccion[Hi]    := cTransaccion;
         Reg_Tasacion.Empresa[Hi]        := cEmpresa;
         Reg_Tasacion.fTasacion[Hi]      := fTasacion;
         Reg_Tasacion.Fecha_Tasacion[Hi] := dFecha_Tasacion;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Tasacion_Mem(Reg_Tasacion, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Tasacion_Mem(Reg_Tasacion, Lo, iHi);
end;

Procedure Tasacion_Omd_Braiz_Mem( const sEmpresa     : String;
                            const sTransaccion       : String;
                            const sFolio             : String;
                                  fItem_Omd          : Double;
                             var  fValor_Tasacion    : Double;
                             var  dFecha_tasacion    : TDatetime);
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Resultado        : Boolean;
begin
   fValor_Tasacion  := 0;   
   fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Tasacion.fFolio, 1 )-1;
   i := 0;


   Resultado := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
       i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

       if Reg_Tasacion.fFolio[i] = fFolio_Buscado then
       begin
          Resultado := True;
          Break;
       end;

       if  fFolio_Buscado > Reg_Tasacion.fFolio[i] then
          iLimite_Inferior := i + 1
       else
          iLimite_Superior := i - 1;
   end;

   if Resultado then
   begin
      //Retrocedo hasta Primer Folio diferente
      For j := i Downto 0 do
        if Reg_Tasacion.fFolio[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Tasacion.fFolio, 1 )) and
            (Reg_Tasacion.fFolio[i] = fFolio_Buscado) do
      begin
         if (Reg_Tasacion.Transaccion[i]  = sTransaccion) and
            (Reg_Tasacion.fItem_Omd[i]    = fItem_Omd)    and
            (Reg_Tasacion.Empresa[i]      = sEmpresa )    then
         begin
             fValor_Tasacion := Reg_Tasacion.fTasacion[i];
             dFecha_Tasacion := Reg_Tasacion.fecha_Tasacion[i];
         end;

         Inc(i);
      end;
   end;
end;

