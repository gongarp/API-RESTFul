Procedure Ordenamiento_Custodias_Vigentes_Mem( var Reg_Custodia : TReg_Custodia;
                                               iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd      : Double;
    sTransaccion,
    sEmpresa,
    sCustodia      : String;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Custodia.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Custodia.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Custodia.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sEmpresa       := Reg_Custodia.Empresa[Lo];
         sTransaccion   := Reg_Custodia.Transaccion[Lo];
         fFolio_Interno := Reg_Custodia.Folio_Interno[Lo];
         fItem_Omd      := Reg_Custodia.Item_Omd[Lo];
         sCustodia      := Reg_Custodia.Custodia[Lo];

         Reg_Custodia.Empresa[Lo]       :=
                       Reg_Custodia.Empresa[Hi];
         Reg_Custodia.Transaccion[Lo]   :=
                       Reg_Custodia.Transaccion[Hi];
         Reg_Custodia.Folio_Interno[Lo] :=
                       Reg_Custodia.Folio_Interno[Hi];
         Reg_Custodia.Item_Omd[Lo]      :=
                       Reg_Custodia.Item_Omd[Hi];
         Reg_Custodia.Custodia[Lo]      :=
                       Reg_Custodia.Custodia[Hi];

         Reg_Custodia.Empresa[Hi]       := sEmpresa;
         Reg_Custodia.Transaccion[Hi]   := sTransaccion;
         Reg_Custodia.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Custodia.Item_Omd[Hi]      := fItem_Omd;
         Reg_Custodia.Custodia[Hi]      := sCustodia;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Custodias_Vigentes_Mem(Reg_Custodia, iLo, Hi);
    if Lo < iHi then Ordenamiento_Custodias_Vigentes_Mem(Reg_Custodia, Lo, iHi);
end;

Function Custodia_Actual_Mem(  const sEmpresa       : String;
                               const sTransaccion   : String;
                               const sFolio_Interno : String;
                                     fItem_Omd      : Double
                             ) : String;

var i               : Integer;
    j               : Integer;
    iLimite_Inferior,
    iLimite_Superior : Integer;
   fFolio_Interno    : Double;
   bExiste           : Boolean;
begin
  i := 0;
  Custodia_Actual_Mem := '';
  fFolio_Interno      := StrToFloat(sFolio_Interno);
  bExiste             := False;


  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Custodia.Folio_Interno, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Custodia.Folio_Interno[i] = fFolio_Interno then
     begin
        bExiste := True;
        Break;
     end;

     if fFolio_Interno > Reg_Custodia.Folio_Interno[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i - 1;
  end;

//  for  i := 0 to  VarArrayHighBound(Reg_Custodia.Folio_Interno, 1 )-1 do
//  begin
//     if  Reg_Custodia.Folio_Interno[i] = fFolio_Interno then
//     begin
//        bExiste := True;
//        Break;
//     end;
//  end;

  if bExiste then
  begin
     //Retrocedo hasta Primer Folio Igual  por cuestion de fechas
     For j := i Downto 0 do
       if Reg_Custodia.Folio_Interno[J] <> fFolio_Interno then
          Break;

     i := j + 1;
     while (i <= VarArrayHighBound(Reg_Custodia.Folio_Interno , 1 )) and
           (Reg_Custodia.Folio_Interno[i] = fFolio_Interno) do
     begin
         if (Reg_Custodia.Empresa[i]        = sEmpresa )     and
            (Reg_Custodia.Transaccion[i]    = sTransaccion ) and
            (Reg_Custodia.Item_Omd[i]       = fItem_Omd )    then
         begin
           Custodia_Actual_Mem := Reg_Custodia.Custodia[i];
           Break;
        end;
        Inc(i);
     end;
  end;
end;

Procedure Carga_Registros_en_CtaCte_Mem( dFecha_Inicial,
                                         dFecha_Final : TDatetime );
Var i,j : LongInt;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      try
        SQL.Clear;
        SQL.Add('SELECT Count(*) As Num_Regs FROM QS_TES_CTACTE'
               +' WHERE Fecha_Movimiento BETWEEN :Fecha_Inicial AND :Fecha_Final'
               +'   AND Nro_Cupon_Vcto <> 0'
               );
        Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
        Parambyname('Fecha_Final'  ).asDate := dFecha_Final;
        Open;
        i := Round(FieldByName('Num_Regs').AsFloat);
      except
        // Define Array y sale Esto lo hace para las instalaciones
        // donde no existe la tabla, ya que el array debe quedar creado
        // para que no se caiga el valorizador
        Reg_Movimientos_CtaCte.Empresa          := VarArrayCreate([0, 1], varOleStr);
        Reg_Movimientos_CtaCte.Transaccion      := VarArrayCreate([0, 1], varOleStr);
        Reg_Movimientos_CtaCte.Folio_Interno    := VarArrayCreate([0, 1], varOleStr);
        Reg_Movimientos_CtaCte.Nro_Cupon        := VarArrayCreate([0, 1], varDouble);
        Close;
        exit;
      end;

      SQL.Clear;
      SQL.Add('SELECT Transaccion_Omd   '
             +'      ,Folio_Interno_Omd '
             +'      ,Empresa '
             +'      ,Nro_Cupon_Vcto    '
             +'  FROM QS_TES_CTACTE'
             +' WHERE Fecha_Movimiento BETWEEN :Fecha_Inicial AND :Fecha_Final'
             +'   AND Nro_Cupon_Vcto <> 0'
              );
      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Open;

      Reg_Movimientos_CtaCte.Empresa          := VarArrayCreate([0, i], varOleStr);
      Reg_Movimientos_CtaCte.Transaccion      := VarArrayCreate([0, i], varOleStr);
      Reg_Movimientos_CtaCte.Folio_Interno    := VarArrayCreate([0, i], varOleStr);
      Reg_Movimientos_CtaCte.Nro_Cupon        := VarArrayCreate([0, i], varDouble);

//      j := 0;
      For j := 0 to i do
      begin
         Reg_Movimientos_CtaCte.Empresa[j]       := Fieldbyname('Empresa'          ).asString;
         Reg_Movimientos_CtaCte.Transaccion[j]   := Fieldbyname('Transaccion_Omd'  ).asString;
         Reg_Movimientos_CtaCte.Folio_Interno[j] := Fieldbyname('Folio_Interno_Omd').asString;
         Reg_Movimientos_CtaCte.Nro_Cupon[j]     := Fieldbyname('Nro_Cupon_Vcto'   ).AsFloat;
         Next;
         if Eof then
            Break;
      end;
      Close;
  end;
end;

function Existe_Registro_en_CtaCte_Mem( const sEmpresa          : String;
                                        const sTransaccion      : String;
                                        const sFolio            : String;
                                        const fNro_Cupon        : Double) : Boolean;
var i : Integer;
begin
  Result := False;
  if NOT VarIsArray(Reg_Movimientos_CtaCte.Empresa) then
     Exit;

  For  i := 0 to VarArrayHighBound(Reg_Movimientos_CtaCte.Empresa, 1 )-1 do
  begin
     if  (Reg_Movimientos_CtaCte.Empresa[i]       = sEmpresa     ) and
         (Reg_Movimientos_CtaCte.Transaccion[i]   = sTransaccion ) and
         (Reg_Movimientos_CtaCte.Folio_Interno[i] = sFolio       ) and
         (Reg_Movimientos_CtaCte.Nro_Cupon[i]     = fNro_Cupon   ) then
     begin
        Result := True;
        Break;
     end;
  end;
end;

procedure Carga_Tipo_Cambio_Fijo_Mem( sMon_Origen    : String;
                                      sMon_Paridad   : String;
                                      dfecha         : TDateTime;
                                      fTipo_Cambio   : Double);
var i : Integer;
   sTipo_Moneda_Origen,
   sDescripcion_Moneda,
   sUnidad_Conv_Origen :sTRING;
begin
  i := 0;
  if NOT VarIsArray(Reg_Tipo_Cambio_Fijo.Mon_Origen) then
  begin
     Reg_Tipo_Cambio_Fijo.Mon_Origen  := VarArrayCreate([0, 1], varOleStr);
     Reg_Tipo_Cambio_Fijo.Mon_Paridad := VarArrayCreate([0, 1], varOleStr);
     Reg_Tipo_Cambio_Fijo.Fecha       := VarArrayCreate([0, 1], varDate);
     Reg_Tipo_Cambio_Fijo.Tipo_Cambio := VarArrayCreate([0, 1], varDouble);
  end
  else
  begin
    i := VarArrayHighBound(Reg_Tipo_Cambio_Fijo.Mon_Origen, 1 ) + 1;
    VarArrayRedim(Reg_Tipo_Cambio_Fijo.Mon_Origen  ,i);
    VarArrayRedim(Reg_Tipo_Cambio_Fijo.Mon_Paridad ,i);
    VarArrayRedim(Reg_Tipo_Cambio_Fijo.Fecha       ,i);
    VarArrayRedim(Reg_Tipo_Cambio_Fijo.Tipo_Cambio ,i);
  end;
  Datos_Moneda_Mem( Trim(sMon_Origen)
                   ,sTipo_Moneda_Origen
                   ,sDescripcion_Moneda
                   ,sUnidad_Conv_Origen);
  Reg_Tipo_Cambio_Fijo.Mon_Origen[i]    := Trim(sMon_Origen);
  //if (sTipo_Moneda_Origen = 'I')  then
    if (sTipo_Moneda_Origen = 'I') and
       (sMon_Paridad = sUnidad_Conv_Origen)  then
     Reg_Tipo_Cambio_Fijo.Mon_Paridad[i]   := Trim(sMon_Origen)
  else
     Reg_Tipo_Cambio_Fijo.Mon_Paridad[i]   := sMon_Paridad;
  Reg_Tipo_Cambio_Fijo.Fecha[i]         := dfecha;
  Reg_Tipo_Cambio_Fijo.Tipo_Cambio[i]   := fTipo_Cambio;
end;

procedure Elimina_Tipo_Cambio_Fijo_Mem;
begin
  if NOT VarIsArray(Reg_Tipo_Cambio_Fijo.Mon_Origen) then
     exit;
  VarArrayRedim(Reg_Tipo_Cambio_Fijo.Mon_Origen  ,0);
  VarArrayRedim(Reg_Tipo_Cambio_Fijo.Mon_Paridad ,0);
  VarArrayRedim(Reg_Tipo_Cambio_Fijo.Fecha       ,0);
  VarArrayRedim(Reg_Tipo_Cambio_Fijo.Tipo_Cambio ,0);

  VarClear(Reg_Tipo_Cambio_Fijo.Mon_Origen  );
  VarClear(Reg_Tipo_Cambio_Fijo.Mon_Paridad );
  VarClear(Reg_Tipo_Cambio_Fijo.Fecha       );
  VarClear(Reg_Tipo_Cambio_Fijo.Tipo_Cambio );

end;

