       Reg_Excepcion_PROMTAS.Fecha_Termino_Tratam := VarArrayCreate([0, i], varDate);

      i := 0;
      while not eof do
      begin
          // Nuevo: agrego otro registro para fecha de calculo
          Reg_Excepcion_PROMTAS.Codigo_Emisor[i]      := Fieldbyname('Codigo_Emisor').asString;
          Reg_Excepcion_PROMTAS.Codigo_Instrumento[i] := Fieldbyname('Codigo_Instrumento').asString;
          Reg_Excepcion_PROMTAS.Serie[i]              := Fieldbyname('Serie').asString;
          if FindField('Cupon_Desde') <> Nil then
             if Not Fieldbyname('Cupon_Desde').isNull then
