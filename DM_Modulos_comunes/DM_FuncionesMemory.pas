         Parambyname('Origen').asString       := default_codgen('ORIGEN','FI','');
      Open;
      i := Round(FieldByName('Num_Regs').AsFloat);

      SQL.Clear;
      SQL.Add('SELECT a.COD_MONEDA');
      SQL.Add('      ,ORIGEN');
      SQL.Add('      ,TIPO_PARIDAD');
      SQL.Add('      ,MONEDA_PARIDAD');
      SQL.Add('      ,FECHA');
      SQL.Add('      ,DIAS_DESDE');
      SQL.Add('      ,DIAS_HASTA');
      SQL.Add('      ,VALOR');
      SQL.Add('  FROM QS_SYS_MONEDAS    b ');
      SQL.Add('      ,QS_SYS_PERIODO    c ');
      SQL.Add('      ,QS_SYS_VAL_TRAMO  a ');
      SQL.Add(' WHERE c.TIPO_UNIDAD     = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	        = b.UNIDAD_MEDIDA_MON ');
      SQL.Add('   AND c.Tipo_Variacion  = ''D'' ');
      SQL.Add('   AND b.COD_MONEDA      = a.COD_MONEDA ');
      SQL.Add('   AND a.Fecha          >= :Fecha_Inicial ');
      SQL.Add('   AND a.Fecha          <= :Fecha_Final ');
      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND  b.Cod_Moneda   = '''+sMoneda_Indice+'''' );
      if bOrigen then
         SQL.Add(' AND a.Origen        = :Origen ');
      Sql.Add(' ORDER BY a.Fecha ');

      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      if bOrigen then
         Parambyname('Origen').asString       := default_codgen('ORIGEN','FI','');
      Open;

      Reg_Monedas_Tramo.COD_MONEDA      := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Tramo.ORIGEN          := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Tramo.TIPO_DE_PARIDAD := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Tramo.MONEDA_PARIDAD  := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Tramo.FECHA_PARIDAD   := VarArrayCreate([0, i], varDate);
      Reg_Monedas_Tramo.DIAS_DESDE      := VarArrayCreate([0, i], varDouble);
      Reg_Monedas_Tramo.DIAS_HASTA      := VarArrayCreate([0, i], varDouble);
      Reg_Monedas_Tramo.VALOR_MONEDA    := VarArrayCreate([0, i], varDouble);

      For j := 0 to i do
      begin
         Reg_Monedas_Tramo.COD_MONEDA[j]      := Fieldbyname('COD_MONEDA').asString;
         Reg_Monedas_Tramo.ORIGEN[j]          := Fieldbyname('ORIGEN').asString;
         Reg_Monedas_Tramo.TIPO_DE_PARIDAD[j] := Fieldbyname('TIPO_PARIDAD').asString;
         Reg_Monedas_Tramo.MONEDA_PARIDAD[j]  := Fieldbyname('MONEDA_PARIDAD').asString;
         Reg_Monedas_Tramo.FECHA_PARIDAD[j]   := Fieldbyname('FECHA').asDatetime;
         Reg_Monedas_Tramo.DIAS_DESDE[j]      := Fieldbyname('DIAS_DESDE').asFloat;
         Reg_Monedas_Tramo.DIAS_HASTA[j]      := Fieldbyname('DIAS_HASTA').asFloat;
         Reg_Monedas_Tramo.VALOR_MONEDA[j]    := Fieldbyname('VALOR').asFloat;
         Next;
         if Eof then
            Break;
      end;
      Close;
  end;

