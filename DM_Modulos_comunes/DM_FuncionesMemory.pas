procedure Obtiene_Costo_Venta_RV_Mem (const sEmpresa           : String;
                                      const sTransaccion       : String;
                                      const sFolio             : String;
                                      dItem_omd                : Double;
                                      const sNemotecnico       : String;
                                      const sCartera           : String;
                                      var Costo_CPC            : Double;
                                      var Costo_CPC_SinRea     : Double;
                                      var Costo_CPC_UM         : Double;
                                      var Costo_CPC_UM_SinRea  : Double
                                      );
var i : Integer;
begin
   Costo_CPC           := 0;
   Costo_CPC_SinRea    := 0;
   Costo_CPC_UM        := 0;
   Costo_CPC_UM_SinRea := 0;
   For  i := 0 to VarArrayHighBound(Reg_Ventas_RV.sEmpresa, 1 ) do
   begin
      if (sTransaccion = 'VCTO_RV') then
      begin
        if (Reg_Ventas_RV.sEmpresa[i]     = sEmpresa)     and
           (Reg_Ventas_RV.sNemotecnico[i] = sNemotecnico) and
           (Reg_Ventas_RV.sCartera[i]     = sCartera)     and
           (Reg_Ventas_RV.sTransaccion[i] = sTransaccion) then
        begin
           Costo_CPC           := Reg_Ventas_RV.fCosto_Promedio[i];
           Costo_CPC_SinRea    := Reg_Ventas_RV.fCosto_Promedio_SinRea[i];
           Costo_CPC_UM        := Reg_Ventas_RV.fCosto_Promedio_UM[i];
           Costo_CPC_UM_SinRea := Reg_Ventas_RV.fCosto_Promedio_UM_SinRea[i];
           Break;
        end;
      end
      else
        if (Reg_Ventas_RV.sEmpresa[i]     = sEmpresa)     and
           (Reg_Ventas_RV.sTransaccion[i] = sTransaccion) and
           (Reg_Ventas_RV.sFolio[i]       = sFolio)       and
           (Reg_Ventas_RV.fItem_Omd[i]    = dItem_omd)    then
        begin
           Costo_CPC           := Reg_Ventas_RV.fCosto_Promedio[i];
           Costo_CPC_SinRea    := Reg_Ventas_RV.fCosto_Promedio_SinRea[i];
           Costo_CPC_UM        := Reg_Ventas_RV.fCosto_Promedio_UM[i];
           Costo_CPC_UM_SinRea := Reg_Ventas_RV.fCosto_Promedio_UM_SinRea[i];
           Break;
        end;
   end;

end;

procedure Existe_Tasa_base_Mem(const CodigoTasaBase : string;
                               var Result           : Boolean
                               );
var i
//   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
begin
  if Not VarIsArray(Reg_Base_Variable.Cod_Tasa_Base) then
     Carga_Valores_Tasa_base_Variable_Mem; //Carga_Valores_Tasa_base_Mem;

  Result     := False;
//  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Base_Variable.Cod_Tasa_Base, 1 )-1;
  for i := 0 to iLimite_Superior do
  begin
     if Trim(Reg_Base_Variable.Cod_Tasa_Base[i]) = Trim(CodigoTasaBase) then
     begin
        Result := True;
        Break;
     end;
  end;
end;

Procedure Carga_Folios_Tesoreria_Impagos_Mem(  dFecha_Inicial
                                              ,dFecha_Final : TDatetime
                                             );
var i : LongInt ;
begin
  with DMFuncionesMemory.QRY_General do
  begin
    SQL.Clear;
    SQL.Add('SELECT Empresa'
           +'      ,Folio_Interno_Omd'
           +'      ,Transaccion_Omd'
           +'      ,Item_Omd'
           +'      ,NRO_CUPON'
           +'      ,Fecha_Mov'
           +'  FROM qs_tes_egring   '
           +' WHERE fecha_mov  BETWEEN :Fecha_Inicial and :Fecha_Final   '
           + '  AND ( Fecha_Mov    <> Fecha_Pago '
           +'     OR  Fecha_Pago IS NULL'
           +'     OR  MONTO_UM_PAGADO <> MONTO_UM_MOVIMIENTO'
           +'     OR  Cuenta_banco is not null '
           +'     OR  Cuenta_banco <> '''' '
           +'       )'
           +'   AND Transaccion      = ''VCTO'''
           );
    ParamByName( 'Fecha_Inicial' ).AsDate := dFecha_Inicial;
    ParamByName( 'Fecha_Final' ).AsDate   := dFecha_Final;
    Open;

    DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

    Reg_Folio_Tesoreria.Empresa           := VarArrayCreate([0, i], varOleStr);
    Reg_Folio_Tesoreria.Folio_Interno_Omd := VarArrayCreate([0, i], varDouble);
    Reg_Folio_Tesoreria.Transaccion_Omd   := VarArrayCreate([0, i], varOleStr);
    Reg_Folio_Tesoreria.fItem_Omd         := VarArrayCreate([0, i], varDouble);
    Reg_Folio_Tesoreria.NRO_CUPON         := VarArrayCreate([0, i], varDouble);
    Reg_Folio_Tesoreria.Fecha_Mov         := VarArrayCreate([0, i], varDate  );
    i := 0;
    while not eof do
    begin
       Reg_Folio_Tesoreria.Empresa[i]           := Fieldbyname('Empresa').asString;
       Reg_Folio_Tesoreria.Folio_Interno_Omd[i] := Fieldbyname('Folio_Interno_Omd').asFloat;
       Reg_Folio_Tesoreria.Transaccion_Omd[i]   := Fieldbyname('Transaccion_Omd').asString;
       Reg_Folio_Tesoreria.fItem_Omd[i]         := Fieldbyname('Item_Omd').asFloat;
       Reg_Folio_Tesoreria.NRO_CUPON[i]         := Fieldbyname('NRO_CUPON').asFloat;
       Reg_Folio_Tesoreria.Fecha_Mov[i]         := Fieldbyname('Fecha_Mov').asDatetime;
       Inc(i);
       Next;
    end;
    Close;
  end;
  if i <> 0 then
     Ordenamiento_Registro_Folio_Tesoreria_Mem( Reg_Folio_Tesoreria
                                                ,0
                                                ,VarArrayHighBound(Reg_Folio_Tesoreria.Empresa, 1 )-1
                                               );
end;

Procedure Ordenamiento_Registro_Folio_Tesoreria_Mem( var Reg_Folio_Tesoreria : TReg_Folio_Tesoreria;
                                              iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio,
    fItem_Omd,
    fNRO_CUPON  : Double;
    cTransaccion,
    cEmpresa : String;
    dFecha   : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Folio_Tesoreria.Folio_Interno_Omd[(Lo + Hi) div 2];

    repeat
      while Reg_Folio_Tesoreria.Folio_Interno_Omd[Lo] < Mid do
            Inc(Lo);
      while Reg_Folio_Tesoreria.Folio_Interno_Omd[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         cEmpresa        := Reg_Folio_Tesoreria.Empresa[Lo];
         cTransaccion    := Reg_Folio_Tesoreria.Transaccion_Omd[Lo];
         fFolio          := Reg_Folio_Tesoreria.Folio_Interno_Omd[Lo];
         fItem_Omd       := Reg_Folio_Tesoreria.fItem_Omd[Lo];
         fNRO_CUPON      := Reg_Folio_Tesoreria.NRO_CUPON[Lo];
         dFecha          := Reg_Folio_Tesoreria.fecha_Mov[Lo];


         Reg_Folio_Tesoreria.Empresa[Lo]           :=
                       Reg_Folio_Tesoreria.Empresa[Hi];
         Reg_Folio_Tesoreria.Transaccion_Omd[Lo]   :=
                       Reg_Folio_Tesoreria.Transaccion_Omd[Hi];
         Reg_Folio_Tesoreria.Folio_Interno_Omd[Lo] :=
                       Reg_Folio_Tesoreria.Folio_Interno_Omd[Hi];
         Reg_Folio_Tesoreria.fItem_Omd[Lo]         :=
                       Reg_Folio_Tesoreria.fItem_Omd[Hi];
         Reg_Folio_Tesoreria.NRO_CUPON[Lo]         :=
                       Reg_Folio_Tesoreria.NRO_CUPON[Hi];
         Reg_Folio_Tesoreria.fecha_Mov[Lo]         :=
                       Reg_Folio_Tesoreria.fecha_Mov[Hi];


         Reg_Folio_Tesoreria.Empresa[Hi]            := cEmpresa;
         Reg_Folio_Tesoreria.Transaccion_Omd[Hi]    := cTransaccion;
         Reg_Folio_Tesoreria.Folio_Interno_Omd[Hi]  := fFolio;
         Reg_Folio_Tesoreria.fItem_Omd[Hi]          := fItem_Omd;
         Reg_Folio_Tesoreria.NRO_CUPON[Hi]          := fNRO_CUPON;
         Reg_Folio_Tesoreria.fecha_Mov[Hi]          := dFecha;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Folio_Tesoreria_Mem(Reg_Folio_Tesoreria, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Folio_Tesoreria_Mem(Reg_Folio_Tesoreria, Lo, iHi);
end;

Function Verifica_Pago_Omd_Mem(const sEmpresa       : String;
                               const sTransaccion   : String;
                               const sFolio_interno : String;
                               fItem_OMD            : Double;
                               fNro_Cupon           : Double;
                               dFecha               : TDatetime
                               ) : Boolean;
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
begin
   fFolio_Buscado   := StrToFloat( sFolio_interno );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Folio_Tesoreria.Folio_Interno_Omd, 1 )-1;
   i := 0;


   Verifica_Pago_Omd_Mem := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Folio_Tesoreria.Folio_Interno_Omd[i] = fFolio_Buscado then
        begin
           Result := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Folio_Tesoreria.Folio_Interno_Omd[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;
   end;

   if Result then
   begin
      Result := False;
      //Retrocedo hasta Primer Folio Distinto
      For j := i Downto 0 do
        if Reg_Folio_Tesoreria.Folio_Interno_Omd[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Folio_Tesoreria.Folio_Interno_Omd , 1 )) and
            (Reg_Folio_Tesoreria.Folio_Interno_Omd[i] = fFolio_Buscado) do
      begin
         if (Reg_Folio_Tesoreria.Transaccion_Omd[i]  = sTransaccion) and
            (Reg_Folio_Tesoreria.fItem_Omd[i]        = fItem_Omd)    and
//            (Reg_Folio_Tesoreria.fecha_Mov[i]        = dFecha)       and   // Edosan
            (Reg_Folio_Tesoreria.Nro_Cupon[i]        = fNro_Cupon)   and
            (Reg_Folio_Tesoreria.Empresa[i]          = sEmpresa)     then
         begin
            Verifica_Pago_Omd_Mem := True;
            Break;
         end;

         Inc(i);
      end;
   end;
end;

