Procedure Carga_Motivo_Mem( dFecha_Valorizacion : TDatetime );
var i : LongInt;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Close;
      SQL.Clear;

      SQL.Add('SELECT a.* '
             +'  FROM QS_TRA_OMD_MOTIVO a'
             +' WHERE a.Fecha_Desde       = (SELECT MAX(b.FECHA_DESDE)                                  ' // Agregado el 21-03-2012 F.I.
             +'                                FROM QS_TRA_OMD_MOTIVO b                                 '
             +'                               WHERE b.Folio_Interno = a.Folio_Interno                   '
             +'                                 and b.Item_Omd    = a.Item_Omd                          '
             +'                                 and b.Transaccion = a.Transaccion                       '
             +'                                 and b.Empresa     = a.Empresa                           '
             +'                                 AND a.Fecha_Desde <= :Fecha                             '
             +'                                 AND (a.Fecha_Hasta IS NULL OR a.Fecha_Hasta >= :Fecha)  '
             +'                                 )                                                       '
             +'  AND a.folio_interno not in (SELECT e.folio                                             '
             +'				       FROM qs_ctr_anulacion e                                  '
