procedure Carga_Nominales_Pactados_Mercado_Mem( dFecha : TDatetime;
                                                Reg_Parametros : TParametros
                                               );
Var i : LongInt;
    bPrepagos_Pactos  : Boolean;
    bAnticipos_Pactos : Boolean;
    bForward          : Boolean;
    bForward_Curva    : Boolean;
    Result           : Boolean;
    sModulo_Error    : String;
    sString_Error    : String;
    fValor_Paridad1,
    fValor_Paridad2,
    fValor_Paridad   : Double;
    bExiste_Paridad  : Boolean;
    bExiste_Paridad1 : Boolean;
    bExiste_Paridad2 : Boolean;
    sValor          : String;
    sValor_Paridad   : String;
    //ggarcia 22-08-2018
    Result1          : Boolean;
    Result2          : Boolean;
    dFecha_TC        : TDatetime;
    fValor_Pactado_MC : Double;

begin

   i := 0;

   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos( sDriver
                                 ,'QS_TRA_OMD_PREPAGO'
                                 ,sModulo_Error
                                 ,sString_Error
                                 ,bPrepagos_Pactos
                                 ,Result);
   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos( sDriver
                                 ,'QS_TRA_OMD_PREPAGO_PACTO'
                                 ,sModulo_Error
                                 ,sString_Error
                                 ,bAnticipos_Pactos
                                 ,Result);

   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos( sDriver
                                 ,'QS_TRA_FWD'
                                 ,sModulo_Error
                                 ,sString_Error
                                 ,bForward
                                 ,Result);

   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos( sDriver
                                 ,'QS_TRA_FWD_CURVA'
                                 ,sModulo_Error
                                 ,sString_Error
                                 ,bForward_Curva
                                 ,Result);

  WITH DmFuncionesMemory.Qry_General do
  begin
    // Se tuvo que separar en los por vencimiento normal de los prepagados
    // 29-07-2015 G.G. & F.I. Se separan los vencimientos de pactos de los de derivados (swap) ya que la coumna "Valor_Pactado" se obtiene de distintas tablas
    if (Reg_Parametros.iIncluye = 0) or (Reg_Parametros.iIncluye = 2) then
    begin
      SQL.Clear;
      ////////
      // PACTOS
      SQL.Add('SELECT Count(*) as Registros'
             +' FROM QS_TRA_OMD d'
             +' WHERE d.Fecha_Operacion   <= :Fecha_Final'
             +'   AND d.Fecha_Vcto_Pacto BETWEEN :Fecha_Inicial AND :Fecha_Final'
             );
      SQL.Add('   AND d.Empresa IN (SELECT Distinct valor As Empresa                 ');
      SQL.Add('                      FROM QS_SYS_PARAM_PROCESO                       ');
      SQL.Add('                     WHERE proceso   = :proceso                       ');
      SQL.Add('                       AND parametro = ''EMPRESA'')                   ');
      SQL.Add('   AND d.Transaccion in (SELECT b.Codigo_Transaccion'
             +'                               FROM qs_sys_tran_implic b '
             +'                             WHERE b.Codigo_transaccion = d.transaccion'
             +'                               AND b.implicancia in (''PACTO'') )');
      SQL.Add('   AND d.Folio_Interno  not in (SELECT f.Folio '
             +'                               FROM qs_ctr_anulacion f'
             +'                             WHERE f.empresa     = d.empresa'
             +'                               AND f.transaccion = d.Transaccion'
             +'                               AND f.Folio       = d.Folio_interno)     ');
      SQL.Add('   AND d.Folio_Preimpreso <> '' ''                                       ');
      if bPrepagos_Pactos then
      begin
        // No Excluye lo prepagado (F.I. 24-06-2005)
        SQL.Add('   AND d.folio_interno NOT IN ( SELECT g.FOLIO_INTERNO_REL                          ');
        SQL.Add('                                  FROM QS_TRA_OMD_PREPAGO g                         ');
        SQL.Add('                                 WHERE g.FOLIO_INTERNO_REL = d.Folio_Interno        ');
        SQL.Add('                                   AND g.Transaccion_Rel   = d.Transaccion          ');
        SQL.Add('                                   AND g.Empresa_Rel       = d.Empresa              ');
        SQL.Add('                                   AND g.folio_interno NOT IN (SELECT e.folio       ');
        SQL.Add('                                                                 FROM qs_ctr_anulacion e              ');
        SQL.Add('                                                                WHERE e.folio       = g.folio_interno     ');
        SQL.Add('                                                                  AND e.transaccion = g.transaccion   ');
        SQL.Add('                                                                  AND e.empresa     = g.empresa))         ');
      end;
      if bAnticipos_Pactos then
      begin
        // No Excluye lo prepagado (G.G. 27-12-2010)
        SQL.Add('   AND d.folio_interno NOT IN ( SELECT g.FOLIO_INTERNO_REL                          ');
        SQL.Add('                                  FROM QS_TRA_OMD_PREPAGO_PACTO g                         ');
        SQL.Add('                                 WHERE g.FOLIO_INTERNO_REL = d.Folio_Interno        ');
        SQL.Add('                                   AND g.Transaccion_Rel   = d.Transaccion          ');
        SQL.Add('                                   AND g.Empresa_Rel       = d.Empresa              ');
        SQL.Add('                                   AND g.folio_interno NOT IN (SELECT e.folio       ');
        SQL.Add('                                                                 FROM qs_ctr_anulacion e              ');
        SQL.Add('                                                                WHERE e.folio       = g.folio_interno     ');
        SQL.Add('                                                                  AND e.transaccion = g.transaccion   ');
        SQL.Add('                                                                  AND e.empresa     = g.empresa))         ');
      end;

       if Reg_Parametros.bCarteras then
       begin
          Sql.Add( ' AND d.cartera in ( SELECT z.Cartera FROM QS_SYS_PARAM_EMPRESA z'
                                   +' WHERE z.Empresa = d.Empresa'
                                   +'   AND z.Pid     = :Pid'
                                   +' )' );
             Parambyname('Pid').asFloat := Application.Handle;
       end;

       if Reg_Parametros.bEmisores then
       begin
          {
          Sql.Add( ' AND a.Emisor in ( SELECT x.Valor FROM QS_SYS_PARAM_PROCESO x'
                                     +' WHERE x.Parametro = ''STK_EMISOR'''
                                     +'   AND x.Proceso   = :Proceso'
                                     +' )' );
          Parambyname('Proceso').asString := IntToStr(Application.Handle);
          }
          Sql.Add( ' AND d.Empresa = '''' ' ); // solo para que no considere el registro
       end;

       if Reg_Parametros.bInstrumentos then
       begin
          {
          Sql.Add( ' AND a.Instrumento in ( SELECT x.Valor FROM QS_SYS_PARAM_PROCESO x'
                                     +' WHERE x.Parametro = ''STK_INST'''
                                     +'   AND x.Proceso   = :Proceso'
                                     +' )' );
          Parambyname('Proceso').asString := IntToStr(Application.Handle);
          }
          Sql.Add( ' AND d.Empresa = '''' ' ); // solo para que no considere el registro
       end;
       if Reg_Parametros.bSerie then
       begin
         {
         Sql.Add( ' AND a.Serie in ( SELECT z.Valor FROM QS_SYS_PARAM_PROCESO z'
                                 +' WHERE z.Parametro = ''STK_SERIE'''
                                 +'   AND z.Proceso   = :Proceso'
                                 +' )' );
         Parambyname('Proceso').asString := IntToStr(Application.Handle);
         }
         Sql.Add( ' AND d.Empresa = '''' ' ); // solo para que no considere el registro
       end;
       if Reg_Parametros.bNemotecnico then
       begin
         {
         Sql.Add( ' AND a.Nemotecnico in ( SELECT w.Valor FROM QS_SYS_PARAM_PROCESO w'
                                       +' WHERE w.Parametro = ''STK_NEMOS'''
