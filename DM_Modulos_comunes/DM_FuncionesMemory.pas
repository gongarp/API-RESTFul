Procedure Busca_Emision_Implicita_Mem(sNemotecnico    : String;
                                      var fDia         : Double;
                                      var sDia_Refer   : String;
                                      var fDia_Ant_Des : Double;
                                      var fMes         : Double;
                                      var sMes_Refer   : String;
                                      var fMes_Ant_Des : Double;
                                      var fAno         : Double;
                                      var sAno_Refer   : String;
                                      var fAno_Ant_Des : Double;
                                      var sModulo_Err : String;
                                      var sString_Err : String;
                                      var Result      : Boolean);
var i : Integer;
   bEncontrado : Boolean;
begin
  if NOT VarIsArray(Reg_Emision_Implicita.Codigo_Nemotecnico) then
         Carga_Emision_Implicita_Mem;

  Result      := False;
  bEncontrado := False;
   for i := 0 to VarArrayHighBound(Reg_Emision_Implicita.Codigo_Nemotecnico, 1 )-1 do
   begin
     if  Trim(Reg_Emision_Implicita.Codigo_Nemotecnico[i]) = Trim(sNemotecnico) then
     begin
        bEncontrado  := True;
        Result       := True;
        fDia         := Reg_Emision_Implicita.Dia[i];
        sDia_Refer   := Reg_Emision_Implicita.Dia_Refer[i];
        fDia_Ant_Des := Reg_Emision_Implicita.Dia_Ant_Des[i];
        fMes         := Reg_Emision_Implicita.Mes[i];
        sMes_Refer   := Reg_Emision_Implicita.Mes_Refer[i];
        fMes_Ant_Des := Reg_Emision_Implicita.Mes_Ant_Des[i];
        fAno         := Reg_Emision_Implicita.Ano[i];
        sAno_Refer   := Reg_Emision_Implicita.Ano_Refer[i];
        fAno_Ant_Des := Reg_Emision_Implicita.Ano_Ant_Des[i];
        Break;
     end;
   end;

  if NOT bEncontrado then
  begin
    sModulo_Err := ' Emisión Implicita';
    sString_Err := ' No se encontro definición de Emisión Implicita para: '
                   +sNemotecnico;
  end;
end;

procedure Obtiene_Fecha_Emision_Implicita_Mem(sNemotecnico                 : String;
                                              Reg_Fechas                   : TRegistro_Fechas;
                                              var dFecha_Emision_Implicita : TDateTime;
                                              var sModulo_Err              : String;
                                              var sString_Err              : String;
                                              var Result                   : Boolean);
var
  wDia_Emision
 ,wMes_Emision
 ,wAno_Emision : Word;
  wDia_Compra
 ,wMes_Compra
 ,wAno_Compra : Word;

  fDia         : Double;
  sDia_Refer   : String;
  fDia_Ant_Des : Double;
  fMes         : Double;
  sMes_Refer   : String;
  fMes_Ant_Des : Double;
  fAno         : Double;
  sAno_Refer   : String;
  fAno_Ant_Des : Double;
begin
   Result := True;

   Busca_Emision_Implicita_Mem(sNemotecnico
                              ,fDia
                              ,sDia_Refer
                              ,fDia_Ant_Des
                              ,fMes
                              ,sMes_Refer
                              ,fMes_Ant_Des
                              ,fAno
                              ,sAno_Refer
                              ,fAno_Ant_Des
                              ,sModulo_Err
                              ,sString_Err
                              ,Result);
   if NOT Result then
      exit;

   if fDia <> 0 then
      wDia_Emision := Round(fDia)
   else
   begin
     Elemento_Fecha(sDia_Refer
                   ,fDia_Ant_Des
                   ,Reg_Fechas
                   ,wDia_Emision
                   ,sModulo_Err
                   ,sString_Err
                   ,Result);

     if NOT Result then
        exit;
   end;

   if fMes <> 0 then
      wMes_Emision := Round(fMes)
   else
   begin
     Elemento_Fecha(sMes_Refer
                   ,fMes_Ant_Des
                   ,Reg_Fechas
                   ,wMes_Emision
                   ,sModulo_Err
                   ,sString_Err
                   ,Result);

     if NOT Result then
        exit;
   end;

   if fAno <> 0 then
      wAno_Emision := Round(fAno)
   else
   begin
     Elemento_Fecha(sAno_Refer
                   ,fAno_Ant_Des
                   ,Reg_Fechas
                   ,wAno_Emision
                   ,sModulo_Err
                   ,sString_Err
                   ,Result);

     if NOT Result then
        exit;
   end;

   if sAno_Refer = 'ANO_COMPRA' then
   begin
     Try
       DecodeDate(Reg_Fechas.Fecha_Compra
                 ,wAno_Compra
                 ,wMes_Compra
                 ,wDia_Compra)
     Except
       sString_Err := 'Fecha de Compra no valida';
       Result := False;
       exit;
     end;
     if wMes_Emision > wMes_Compra then
        wAno_Emision := wAno_Emision - 1;
   end;

   Try
     dFecha_Emision_Implicita := EncodeDate(wAno_Emision,wMes_Emision,wDia_Emision)
   Except
     sString_Err := 'Error en obtención fecha emisión implicita';
     Result := False;
     exit;
   end;
   Result := True;
end;
