      if Not Result then
      begin
         Carga_Valores_Tasas_Mercado_Mem( dFecha );
         Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Codigo_Nemotecnico, 1 )-1], varOleStr);
         Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Fecha, 1 )-1], varDate);
         Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Valor, 1 )-1], varDouble);
         Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Origen, 1 )-1], varOleStr);
         Reg_LastTasas_Mercado.Codigo_Nemotecnico := Reg_Tasas_Mercado.Codigo_Nemotecnico;
         Reg_LastTasas_Mercado.Fecha              := Reg_Tasas_Mercado.Fecha;
         Reg_LastTasas_Mercado.Valor              := Reg_Tasas_Mercado.Valor;
         Reg_LastTasas_Mercado.Origen             := Reg_Tasas_Mercado.Origen;
         Reg_LastTasas_Mercado.Tipo               := Reg_Tasas_Mercado.Tipo;
         Exit;
      end;

      if sAntes_Despues = 'A' then
         dFecha_Inicial := Resta_dias_corridos(sPais_Tasa,                 // Resta_dias_habiles(sPais_Tasa,
                                               dFecha,
                                               fCantidad
                                               )
      else
         dFecha_Inicial := Suma_dias_corridos(sPais_Tasa,                   // Suma_dias_habiles(sPais_Tasa,
                                              dFecha,
                                              fCantidad
                                              );
      Close;
      {
      Sql.Clear;
      SQL.Add(' SELECT DISTINCT Instrumento FROM QS_FIN_MET_VALUAC'
             +'  WHERE Tipo_Valuac = ''TASAINST'''
             );
      Open;
      sString_Instrumentos := '';
      if Not Fieldbyname('Instrumento').IsNull then
      begin
         if NOT EOF then
            sString_Instrumentos := sString_Instrumentos +' ( '''+Fieldbyname('Instrumento').asString;
         Next;
         While Not Eof do
         begin
            sString_Instrumentos := sString_Instrumentos +''','''+Fieldbyname('Instrumento').asString;
            Next;
         end;
         sString_Instrumentos := sString_Instrumentos + ''' )';
      end
      else
         sString_Instrumentos := '';
      }
      Sql.Clear;
      Sql.Add( ' INSERT INTO QS_FIN_TASA_MERCAD_NEM '
              +' SELECT a.Nemotecnico'
              +'       ,MAX(b.Fecha) as Fecha'
              +'       ,b.Origen'
              +'       ,b.Tipo'
              +'       ,a.Pid'
              +'       ,a.Fecha_creacion'
              +'   FROM QS_FIN_VALORIZ_NEMOS a               '
              +'       ,QS_FIN_TASA_MERCAD b                 '
              +'  WHERE a.pid = :pid'
              +'    AND a.nemotecnico = b.codigo_nemotecnico '
              +'    AND b.Fecha >= :Fecha_Inicial            '
              +'    AND b.Fecha <= :Fecha_Final              ' );

     // if Trim(sString_Instrumentos) <> '' then
     //    Sql.Add ( ' AND a.Instrumento NOT IN + ' + sString_Instrumentos );

      Sql.Add( '  GROUP BY Nemotecnico, Origen, Tipo, a.Pid, a.Fecha_creacion  ' );

      ParamByName('Pid').AsString         := IntToStr(Application.Handle);
      ParamByname('Fecha_Inicial').asDate := dFecha_Inicial;
      ParamByname('Fecha_Final').asDate   := dFecha;

      Prepare;
      ExecSQL;
      Close;
      UnPrepare;
      Close;

      Sql.Clear;
      Sql.Add( ' SELECT a.Nemotecnico'
              +'       ,b.Fecha as Fecha'
              +'       ,b.Valor'
              +'       ,b.Origen'
              +'       ,b.Tipo'
              +'   FROM QS_FIN_TASA_MERCAD_NEM a              '
              +'       ,QS_FIN_TASA_MERCAD b                  '
              +'  WHERE b.codigo_nemotecnico = a.nemotecnico  '
              +'    AND b.Fecha = a.Fecha                     '
              +'    AND a.Pid = :Pid                          '
              );
      Sql.Add ( ' ORDER BY NEMOTECNICO, FECHA DESC ');
      ParamByName('Pid').AsString := IntToStr(Application.Handle);

      try
         Open;
      except on E: EFDDBEngineException do
         begin
            ShowError(E);
            Close;
            Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, 0], varOleStr);
            Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, 0], varDate);
            Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, 0], varDouble);
            Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, 0], varOleStr);
            Reg_LastTasas_Mercado.Tipo               := VarArrayCreate([0, 0], varOleStr);
            Exit;
         end;
      end;


      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;

      Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, i], varOleStr);
      Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, i], varDate);
      Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, i], varDouble);
      Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, i], varOleStr);
      Reg_LastTasas_Mercado.Tipo               := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not EOF do
      begin
         Reg_LastTasas_Mercado.Codigo_Nemotecnico[i] := Fieldbyname('Nemotecnico').asString;
         Reg_LastTasas_Mercado.Fecha[i] := Fieldbyname('Fecha').asDatetime;;
         Reg_LastTasas_Mercado.Valor[i] := Fieldbyname('Valor').asFloat;
         Reg_LastTasas_Mercado.Origen[i]:= Fieldbyname('Origen').asString;
         Reg_LastTasas_Mercado.Tipo[i]  := Fieldbyname('Tipo').asString;
         Next;
         Inc(i);
      end;
      if i > 0 then
         Dec(i);
      VarArrayRedim(Reg_LastTasas_Mercado.Codigo_Nemotecnico, i + 1);
      VarArrayRedim(Reg_LastTasas_Mercado.Fecha, i + 1 );
      VarArrayRedim(Reg_LastTasas_Mercado.Valor, i + 1);
      VarArrayRedim(Reg_LastTasas_Mercado.Origen, i + 1);
      VarArrayRedim(Reg_LastTasas_Mercado.Tipo, i + 1);
      Close;
   end;
end;

Procedure Carga_Last_Tasas_Mercado_Mem( sTipo_Proceso : String;
                                        dFecha : TDatetime );
Var i             : Integer;
   dFecha_Inicial,
   dFecha_Aux     : TDatetime;
   fCantidad,
   fValor         : Double;
   sUnidad,
   //Modulo_Err,
   sNemotecnico,
   sOrigen,
   sTipo,
   sPais_Tasa,
   //String_Err,
   sString_Instrumentos,
   sAntes_Despues : String;
   Result         : Boolean;
begin
   with DMFuncionesMemory.Qry_General do
   begin
      sPais_Tasa     := sPais_Usuario;
      Busca_Proy_Precio_Mem(sTipo_Proceso,
                            fCantidad,
                            sUnidad,
                            sAntes_Despues,
                            Result);
      if Not Result then
      begin
         Carga_Valores_Tasas_Mercado_Mem( dFecha );
         Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Codigo_Nemotecnico, 1 )-1], varOleStr);
         Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Fecha, 1 )-1], varDate);
         Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Valor, 1 )-1], varDouble);
         Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, VarArrayHighBound( Reg_Tasas_Mercado.Origen, 1 )-1], varOleStr);
         Reg_LastTasas_Mercado.Codigo_Nemotecnico := Reg_Tasas_Mercado.Codigo_Nemotecnico;
         Reg_LastTasas_Mercado.Fecha              := Reg_Tasas_Mercado.Fecha;
         Reg_LastTasas_Mercado.Valor              := Reg_Tasas_Mercado.Valor;
         Reg_LastTasas_Mercado.Origen             := Reg_Tasas_Mercado.Origen;
         Reg_LastTasas_Mercado.Tipo               := Reg_Tasas_Mercado.Tipo;
         Exit;
      end;

      if sAntes_Despues = 'A' then
         dFecha_Inicial := Resta_dias_corridos(sPais_Tasa,                 // Resta_dias_habiles(sPais_Tasa,
                                               dFecha,
                                               fCantidad
                                               )
      else
         dFecha_Inicial := Suma_dias_corridos(sPais_Tasa,                   // Suma_dias_habiles(sPais_Tasa,
                                              dFecha,
                                              fCantidad
                                              );
       Close;
       Sql.Clear;
       SQL.Add(' SELECT DISTINCT Instrumento FROM QS_FIN_MET_VALUAC'
              +'  WHERE Tipo_Valuac = ''TASAINST'''
              );
       Open;
       sString_Instrumentos := '';
       if Not Fieldbyname('Instrumento').IsNull then
       begin
          if NOT EOF then
             sString_Instrumentos := sString_Instrumentos +' ( '''+Fieldbyname('Instrumento').asString;
          Next;
          While Not Eof do
          begin
             sString_Instrumentos := sString_Instrumentos +''','''+Fieldbyname('Instrumento').asString;
             Next;
          end;
          sString_Instrumentos := sString_Instrumentos + ''' )';
       end
       else
          sString_Instrumentos := '';

      Close;
      Sql.Clear;
      if sDriver = 'MSSQL' then
         Sql.Add( ' SELECT count(distinct b.Nemotecnico+cast(a.Fecha as CHAR)+cast(a.Valor as CHAR)+a.Origen+a.Tipo) as Nro_Reg')
      else
         Sql.Add( ' SELECT count(distinct b.Nemotecnico||a.Fecha||a.Valor||a.Origen||a.Tipo) as Nro_Reg');

      Sql.Add( '  FROM QS_FIN_TASA_MERCAD a'
              +'      ,QS_TRA_OMD_DET_RF b'
              +' WHERE a.Fecha >= :Fecha_Inicial'
              +'   AND a.Fecha   <= :Fecha_Final'
              +'   AND a.Codigo_Nemotecnico = b.Nemotecnico'
              +'   AND b.Tipo_Instrum <> ''R'''
              );
      if Trim(sString_Instrumentos) <> '' then
         Sql.Add ( ' AND b.Codigo_Instrumento NOT IN + ' + sString_Instrumentos );


      ParamByname('Fecha_Inicial').asDate := dFecha_Inicial;
      ParamByname('Fecha_Final').asDate   := dFecha;
      try
         Open;
      except on E: EFDDBEngineException do
         begin
            ShowError(E);
            Close;
            Exit;
         end;
      end;
//      i := FieldByName('Nro_Reg').asInteger;

      Sql.Clear;
      Sql.Add( ' SELECT DISTINCT b.Nemotecnico'
              +'  ,a.Fecha as Fecha'
              +'  ,a.Valor'
              +'  ,a.Origen'
              +'  ,a.Tipo'
              +' FROM QS_FIN_TASA_MERCAD a'
              +'     ,QS_TRA_OMD_DET_RF b'
              +' WHERE a.Fecha >= :Fecha_Inicial'
              +' AND a.Fecha   <= :Fecha_Final'
              +' AND a.Codigo_Nemotecnico = b.Nemotecnico'
              +' AND b.Tipo_Instrum <> ''R'''
              );
      if Trim(sString_Instrumentos) <> '' then
         Sql.Add ( ' AND b.Codigo_Instrumento NOT IN + ' + sString_Instrumentos );

       Sql.Add( ' ORDER BY Nemotecnico, Origen'  );

       ParamByname('Fecha_Inicial').asDate := dFecha_Inicial;
       ParamByname('Fecha_Final').asDate   := dFecha;
       try
          Open;
       except on E: EFDDBEngineException do
          begin
             ShowError(E);
             Close;
             Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, 0], varOleStr);
             Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, 0], varDate);
             Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, 0], varDouble);
             Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, 0], varOleStr);
             Reg_LastTasas_Mercado.Tipo               := VarArrayCreate([0, 0], varOleStr);
             Exit;
          end;
       end;

       Last;
       i := RecordCount;
       First;
       Reg_LastTasas_Mercado.Codigo_Nemotecnico := VarArrayCreate([0, i], varOleStr);
       Reg_LastTasas_Mercado.Fecha              := VarArrayCreate([0, i], varDate);
       Reg_LastTasas_Mercado.Valor              := VarArrayCreate([0, i], varDouble);
       Reg_LastTasas_Mercado.Origen             := VarArrayCreate([0, i], varOleStr);
       Reg_LastTasas_Mercado.Tipo               := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while not EOF do
       begin
          sNemotecnico := Fieldbyname('Nemotecnico').asString;
          Reg_LastTasas_Mercado.Codigo_Nemotecnico[i] := sNemotecnico;
          dFecha_Aux   := Fieldbyname('Fecha').asDatetime;
          fValor       := Fieldbyname('Valor').asFloat;
          sOrigen      := Fieldbyname('Origen').asString;
          sTipo        := Fieldbyname('Tipo').asString;
          while (Not EOF) and
                (sNemotecnico = Fieldbyname('Nemotecnico').asString) and
                (sOrigen      = Fieldbyname('Origen').asString) do
          begin
             if Fieldbyname('Fecha').asDatetime > dFecha_aux then
             begin
                dFecha_Aux := Fieldbyname('Fecha').asDatetime;
                fValor     := Fieldbyname('Valor').asFloat;
                sOrigen    := Fieldbyname('Origen').asString;
                sTipo      := Fieldbyname('Tipo').asString;
             end;
             Next;
          end;
          Reg_LastTasas_Mercado.Fecha[i] := dFecha_Aux;
          Reg_LastTasas_Mercado.Valor[i] := fValor;
          Reg_LastTasas_Mercado.Origen[i]:= sOrigen;
          Reg_LastTasas_Mercado.Tipo[i]  := sTipo;
          Inc(i);
       end;
       if i > 0 then
          Dec(i);
       VarArrayRedim(Reg_LastTasas_Mercado.Codigo_Nemotecnico, i + 1);
       VarArrayRedim(Reg_LastTasas_Mercado.Fecha, i + 1 );
       VarArrayRedim(Reg_LastTasas_Mercado.Valor, i + 1);
       VarArrayRedim(Reg_LastTasas_Mercado.Origen, i + 1);
       VarArrayRedim(Reg_LastTasas_Mercado.Tipo, i + 1);
       Close;
   end;
end;

Function Lee_LastTasa_mercado_Mem(const sNemotecnico : String;
                               var sOrigen :String;
                               var fValor  :Double;
                               var sTipo   :String) : Boolean;
var i : Integer;
begin

  Result := False;

  fValor  := 0;
  for i := 0 to VarArrayHighBound( Reg_LastTasas_Mercado.Codigo_Nemotecnico, 1 )-1 do
  begin
     if sOrigen = 'MUL-ORIGEN' then
     begin
         if (Reg_LastTasas_Mercado.Codigo_Nemotecnico[i] = sNemotecnico) then
         begin
            fValor := Reg_LastTasas_Mercado.Valor[i];
            sTipo  := Reg_LastTasas_Mercado.Tipo[i];
            sOrigen := Reg_LastTasas_Mercado.Origen[i];
            Result := True;
            Break;
         end;
     end
    else
     if (Reg_LastTasas_Mercado.Codigo_Nemotecnico[i] = sNemotecnico) and
        (Reg_LastTasas_Mercado.Origen[i]             = sOrigen) then
     begin
        fValor := Reg_LastTasas_Mercado.Valor[i];
        sTipo  := Reg_LastTasas_Mercado.Tipo[i];
        Result := True;
        Break;
     end;
  end;
end;

