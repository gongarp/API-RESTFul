        Reg_Valuacion_Sup.VALORIZACION[i] := sVALORIZACION;
        Inc(i);
        Next;
      end;
      Close;
   end;
end;

procedure Busca_Valor_Super_Mem( sPROCESO_Sup,
                                 sEmpresa_Sup,
                                 sCARTERA_Sup,
                                 sPAIS_Sup,
                                 sEMISOR,
                                 sINSTRUMENTO,
                                 sSERIE,
                                 sMOTIVO     : String;
                           Var sVALORIZACION : String );
var sProceso   : String;
    sCartera   : String;
    sEmpresa   : String;
    sPais      : String;
    i          : Integer;
    bValuacion : Boolean;
begin
   /////////////////////////////////////////////////////////////////////////////
   //
   // O J O !!!! Si se hacen cambios en esta funcion hacerlas tambien en la
   //            Nota 13.1 de la circular IFRS. 
   //
   /////////////////////////////////////////////////////////////////////////////

   bValuacion   := False;
   //Verifica si existe valuacion definida por cartera o por proceso
   // Solo ese caso toma en cuenta condicion

   sProceso := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valuacion_Sup.Cartera, 1 )  do
   begin
      if Reg_Valuacion_Sup.Proceso[i] = sProceso then
      begin
         sProceso := sProceso_Sup;
         Break;
      end;
   end;

   sEmpresa := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valuacion_Sup.Empresa, 1 )  do
   begin
      if Reg_Valuacion_Sup.Empresa[i] = sEmpresa then
      begin
         sEmpresa := sEmpresa_Sup;
         Break;
      end;
   end;

   sCartera := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valuacion_Sup.Cartera, 1 )  do
   begin
      if Reg_Valuacion_Sup.Cartera[i] = sCartera_Sup then   // E.S.  18-10-2012  if Reg_Valuacion_Sup.Cartera[i] = sCartera then
      begin
         sCartera := sCartera_Sup;
         Break;
      end;
   end;

   //Verifica si existe valuacion definida por pais
   // Solo ese caso toma en cuenta condicion
   sPais := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valuacion_Sup.Pais, 1 )  do
   begin
      if Reg_Valuacion_Sup.Pais[i] = sPais_Sup then
      begin
         sPais := sPais_Sup;
         Break;
      end;
   end;

   if Not bValuacion then
      for i := 0 to VarArrayHighBound(Reg_Valuacion_Sup.Emisor , 1 )  do
      begin
         if    (Reg_Valuacion_Sup.Emisor[i]      = sEmisor)
           and (Reg_Valuacion_Sup.Instrumento[i] = sInstrumento)
           and (Reg_Valuacion_Sup.Serie[i]       = sSerie) and (sSerie <> '')
           and (Reg_Valuacion_Sup.Motivo[i]      = sMotivo)
           // Proceso
           and (    ((sProceso <> EmptyStr) and (Reg_Valuacion_Sup.Proceso[i] = sProceso) )
                 or ((sProceso =  EmptyStr) and (Reg_Valuacion_Sup.Proceso[i] = EmptyStr))
                )
           // Empresa
           and (    ((sEmpresa <> EmptyStr) and (Reg_Valuacion_Sup.Empresa[i] = sEmpresa) )
                 or ((sEmpresa =  EmptyStr) and (Reg_Valuacion_Sup.Empresa[i] = EmptyStr))
                )
           // Cartera
           and (    ((sCartera <> EmptyStr) and (Reg_Valuacion_Sup.Cartera[i] = sCartera) )
                 or ((sCartera =  EmptyStr) and (Reg_Valuacion_Sup.Cartera[i] = EmptyStr))
                )
           // Pais
           and (    ((sPais <> EmptyStr) and (Reg_Valuacion_Sup.Pais[i] = sPais) )
                 or ((sPais =  EmptyStr) and (Reg_Valuacion_Sup.Pais[i] = EmptyStr))
                )
                then
         begin
            bValuacion := True;
