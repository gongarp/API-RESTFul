procedure Parametros_Margen_Mem(Const sCod_Formula       : String;
                                dFecha             : TDateTime;
                              var RegParamMargen : TRegParamMargen;
                              var Result         : Boolean);
var i : Integer;
begin
  if NOT VarIsArray(Reg_MET_PMARGEN.Cod_Formula) then
     Carga_Valores_Parametros_Margen_Mem;
     // Carga_Valores_Parametros_Margen_Mem( dFecha );
{
  If (Reg_MET_PMARGEN.Fecha_carga[0] <> dFecha) Then
  Begin
     if (Reg_MET_PMARGEN.Fecha_carga[0] <> 0) then
     begin
       VarClear(Reg_MET_PMARGEN.Fecha_Aplica_1);
       VarClear(Reg_MET_PMARGEN.Fecha_Aplica_2);
       VarClear(Reg_MET_PMARGEN.Cod_Valor1);
       VarClear(Reg_MET_PMARGEN.Tasa_Base_1);
       VarClear(Reg_MET_PMARGEN.Interpolacion_1);
       VarClear(Reg_MET_PMARGEN.Periodo_Aplica_D_1);
       VarClear(Reg_MET_PMARGEN.Periodo_Aplica_H_1);
       VarClear(Reg_MET_PMARGEN.Aplica_Flujo_1);
       VarClear(Reg_MET_PMARGEN.Cod_Valor2);
       VarClear(Reg_MET_PMARGEN.Tasa_Base_2);
       VarClear(Reg_MET_PMARGEN.Interpolacion_2);
       VarClear(Reg_MET_PMARGEN.Periodo_Aplica_D_2);
       VarClear(Reg_MET_PMARGEN.Periodo_Aplica_H_2);
       VarClear(Reg_MET_PMARGEN.Aplica_Flujo_2);
       VarClear(Reg_MET_PMARGEN.Operacion);
       VarClear(Reg_MET_PMARGEN.Operacion_1);
       VarClear(Reg_MET_PMARGEN.Operacion_2);
       VarClear(Reg_MET_PMARGEN.Redondeo_Truncado);
       VarClear(Reg_MET_PMARGEN.Numero_Decimales);
       VarClear(Reg_MET_PMARGEN.Constante_1);
       VarClear(Reg_MET_PMARGEN.Constante_2);
       VarClear(Reg_MET_PMARGEN.Tasa_Conversion_1);
       VarClear(Reg_MET_PMARGEN.Tasa_Conversion_2);
       VarClear(Reg_MET_PMARGEN.Fecha_Desde);
       VarClear(Reg_MET_PMARGEN.Fecha_Hasta);
       VarClear(Reg_MET_PMARGEN.Fecha_carga);
     end;
     Carga_Valores_Parametros_Margen_Mem( dFecha );
  end;
}
  Result  := False;
  for i := 0 to VarArrayHighBound( Reg_MET_PMARGEN.Cod_Formula, 1 )-1 do
  begin
     if (Reg_MET_PMARGEN.Cod_Formula[i] = sCod_Formula)  and
        (Reg_MET_PMARGEN.Fecha_Desde[i] <= dFecha) and
        ((Reg_MET_PMARGEN.Fecha_Hasta[i] = 0)
          OR (Reg_MET_PMARGEN.Fecha_Hasta[i] >= dFecha)
         )  then
     begin
        with RegParamMargen do
        begin
           RegParamMargen.Fecha_Aplica_1     := Reg_MET_PMARGEN.Fecha_Aplica_1[i];
           RegParamMargen.Fecha_Aplica_2     := Reg_MET_PMARGEN.Fecha_Aplica_2[i];
           RegParamMargen.Cod_Valor1         := Reg_MET_PMARGEN.Cod_Valor1[i];
           RegParamMargen.Tasa_Base_1        := Reg_MET_PMARGEN.Tasa_Base_1[i];
           RegParamMargen.Interpolacion_1    := Reg_MET_PMARGEN.Interpolacion_1[i];
           RegParamMargen.Periodo_Aplica_D_1 := Reg_MET_PMARGEN.Periodo_Aplica_D_1[i];
           RegParamMargen.Periodo_Aplica_H_1 := Reg_MET_PMARGEN.Periodo_Aplica_H_1[i];
           RegParamMargen.Aplica_Flujo_1     := Reg_MET_PMARGEN.Aplica_Flujo_1[i];
           RegParamMargen.Cod_Valor2         := Reg_MET_PMARGEN.Cod_Valor2[i];
           RegParamMargen.Tasa_Base_2        := Reg_MET_PMARGEN.Tasa_Base_2[i];
           RegParamMargen.Interpolacion_2    := Reg_MET_PMARGEN.Interpolacion_2[i];
           RegParamMargen.Periodo_Aplica_D_2 := Reg_MET_PMARGEN.Periodo_Aplica_D_2[i];
           RegParamMargen.Periodo_Aplica_H_2 := Reg_MET_PMARGEN.Periodo_Aplica_H_2[i];
           RegParamMargen.Aplica_Flujo_2     := Reg_MET_PMARGEN.Aplica_Flujo_2[i];
           RegParamMargen.Operacion          := Reg_MET_PMARGEN.Operacion[i];
           RegParamMargen.Operacion_1        := Reg_MET_PMARGEN.Operacion_1[i];
           RegParamMargen.Operacion_2        := Reg_MET_PMARGEN.Operacion_2[i];

           RegParamMargen.Redondeo_Truncado  := Reg_MET_PMARGEN.Redondeo_Truncado[i];
           RegParamMargen.Numero_Decimales   := Reg_MET_PMARGEN.Numero_Decimales[i];
           RegParamMargen.Constante_1        := Reg_MET_PMARGEN.Constante_1[i];
           RegParamMargen.Constante_2        := Reg_MET_PMARGEN.Constante_2[i];

           RegParamMargen.Tasa_Conversion_1  := Reg_MET_PMARGEN.Tasa_Conversion_1[i];
           RegParamMargen.Tasa_Conversion_2  := Reg_MET_PMARGEN.Tasa_Conversion_2[i];

           RegParamMargen.Fecha_Desde        := Reg_MET_PMARGEN.Fecha_Desde[i]; // LOBO
           RegParamMargen.Fecha_Hasta        := Reg_MET_PMARGEN.Fecha_Hasta[i];

           // RegParamMargen.Fecha_carga        := Reg_MET_PMARGEN.Fecha_carga[i];
        end;
        Result := True;
        Break;
     end;
  end;
end;

procedure Carga_Parametros_Rango_Cpones_Mem;
var i : LongInt;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      SQL.Clear;
      SQL.Add('SELECT COUNT(*) AS Num_Regs '
             +'  FROM QS_FIN_RANGO_CUPONES ');
      Open;
      i := FieldByName('Num_Regs').AsInteger;
      Close;

      SQL.Clear;
      SQL.Add('SELECT * '
             +'  FROM QS_FIN_RANGO_CUPONES'
             +'   ORDER BY Codigo_Formula,Fecha_desde DESC ');
      Open;

      Reg_Met_PRangoCupon.Cod_Formula := VarArrayCreate([0, i], varOleStr);
      Reg_Met_PRangoCupon.Fecha_Desde := VarArrayCreate([0, i], varOleStr );
      Reg_Met_PRangoCupon.Fecha_Hasta := VarArrayCreate([0, i], varOleStr );

      i := 0;
      while not eof do
      begin
         Reg_Met_PRangoCupon.Cod_Formula[i] := Fieldbyname('Codigo_Formula').asString;
         Reg_Met_PRangoCupon.Fecha_Desde[i] := Fieldbyname('Fecha_Desde').asString;
         Reg_Met_PRangoCupon.Fecha_Hasta[i] := Fieldbyname('Fecha_Hasta').asString;
         Next;
         Inc(i);
      end;
      Close;
   end;
end;

procedure Parametros_Rango_Cpones_Mem(Const sCod_Formula : String;
                                      dFecha             : TDateTime;
                                  var RegParamRangoCupon : TRegParamRangoCupon;
                                  var Result             : Boolean);
var i : Integer;
begin

   if NOT VarIsArray(Reg_Met_PRangoCupon.Cod_Formula) then
      Carga_Parametros_Rango_Cpones_Mem;

   Result  := False;
   for i := 0 to VarArrayHighBound( Reg_Met_PRangoCupon.Cod_Formula, 1 )-1 do
   begin
      if (Reg_Met_PRangoCupon.Cod_Formula[i] = sCod_Formula) then
      begin
         with RegParamRangoCupon do
         begin
            RegParamRangoCupon.Fecha_Desde := Reg_Met_PRangoCupon.Fecha_Desde[i];
            RegParamRangoCupon.Fecha_Hasta := Reg_Met_PRangoCupon.Fecha_Hasta[i];
         end;
         Result := True;
         Break;
      end;
   end;
end;

Procedure Carga_Excepcion_Cambiaria_Mem;
var i : LongInt;
    bExcepcionUnicos : Boolean;

begin
     bExcepcionUnicos := False;
     WITH dmFuncionesMemory.Qry_General do
     begin
       Sql.Clear;
       SQL.Add(' SELECT Count(*) as Registros FROM QS_FIN_EXCP_VARCAM'
              );
       Open;
       i := 0;
       if Not Fieldbyname('Registros').IsNull then
          i := Fieldbyname('Registros').asInteger;
       Close;

 // cjf

       Sql.Clear;
       SQL.Add(' SELECT Count(*) as Registros                    ');
       SQL.Add('   FROM qs_fin_instrum b, QS_FIN_FORMULA_PAR c   ');
       SQL.Add('  WHERE c.aplica_factor_correccion = ''S''       ');
       SQL.Add('    AND b.cod_calc_pte_ins = c.codigo_formula    ');
       Open;
       if (FieldByName('Registros').asInteger > 0) then
          bExcepcionUnicos := True;
       Close;

       Sql.Clear;
       SQL.Add(' SELECT Count(*) as Registros                    ');
       SQL.Add('   FROM qs_fin_instrum b, QS_FIN_FORMULA_TIR c   ');
       SQL.Add('  WHERE c.aplica_factor_correccion = ''S''   ');
       SQL.Add('    AND b.cod_calc_pte_ins = c.codigo_formula   ');
       Open;
       if (FieldByName('Registros').asInteger > 0) then
          bExcepcionUnicos := True;
       Close;

       if bExcepcionUnicos then
       begin
         SQL.Clear;
 /////DC  22/07/2016
         SQL.Add(' SELECT COUNT(*) as Registros  ');
         SQL.Add(' FROM (  ');
         SQL.Add(' SELECT c.codigo_formula,   ');
         SQL.Add('        a.emisor,   ');
         SQL.Add('        a.instrumento,   ');
         SQL.Add('        c.Mon_Ind_Correccion,   ');
         SQL.Add('        c.Fecha_Desde_Corr,   ');
         SQL.Add('        c.Fecha_Hasta_Corr   ');
 /////DC  22/07/2016
         SQL.Add(' FROM  qs_tra_omd_det_rf a, qs_fin_instrum b, QS_FIN_FORMULA_PAR c   ');
         SQL.Add(' WHERE a.instrumento      = b.cod_instrumento   ');
         SQL.Add(' and   b.cod_calc_pte_ins = c.codigo_formula   ');
         SQL.Add(' and   c.aplica_factor_correccion = ''S''   ');
         SQL.Add(' GROUP BY c.codigo_formula,   ');
         SQL.Add('          a.emisor,   ');
         SQL.Add('          a.instrumento,   ');
         SQL.Add('          c.Mon_Ind_Correccion,   ');
         SQL.Add('          c.Fecha_Desde_Corr,   ');
         SQL.Add('          c.Fecha_Hasta_Corr   ');
         SQL.Add(' UNION ');
         SQL.Add(' SELECT c.codigo_formula,   ');
         SQL.Add('        a.emisor,   ');
         SQL.Add('        a.instrumento,   ');
         SQL.Add('        c.Mon_Ind_Correccion ,   ');
         SQL.Add('        c.Fecha_Desde_Corr ,   ');
         SQL.Add('        c.Fecha_Hasta_Corr   ');
         SQL.Add(' FROM  qs_tra_omd_det_rf a, qs_fin_instrum b, QS_FIN_FORMULA_TIR c   ');
         SQL.Add(' WHERE a.instrumento = b.cod_instrumento   ');
         SQL.Add(' and   b.cod_calc_pte_ins = c.codigo_formula   ');
         SQL.Add(' and   c.aplica_factor_correccion = ''S''   ');
         SQL.Add(' GROUP BY c.codigo_formula,   ');
         SQL.Add('        a.emisor,   ');
         SQL.Add('        a.instrumento,   ');
         SQL.Add('        c.Mon_Ind_Correccion ,   ');
         SQL.Add('        c.Fecha_Desde_Corr ,   ');
         SQL.Add('        c.Fecha_Hasta_Corr   ');
         if sDriver = 'ORACLE' then
           SQL.Add(' ) ')
         else
           SQL.Add(' ) as REG ');
         Open;

         //ggarcia 19-07-2016
         //if Not Fieldbyname('Registros').IsNull then
         while not eof do
         begin
            i := i + Fieldbyname('Registros').asInteger;
            Next;
          end;
         Close;
       end;


       Reg_Excepcion_Cambiaria.Fecha_Calculo           := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.Codigo_Emisor           := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.Codigo_Instrumento      := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.Serie                   := VarArrayCreate([0, i], varOleStr);
       if Transaccion_Implica(sEmpresa_Usuario,'FECHAVIG') then
          Reg_Excepcion_Cambiaria.Fecha_Vig            := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.Cupon_Desde             := VarArrayCreate([0, i], varDouble);
       Reg_Excepcion_Cambiaria.Cupon_Hasta             := VarArrayCreate([0, i], varDouble);
       Reg_Excepcion_Cambiaria.Ptje_Aplica_Reajuste    := VarArrayCreate([0, i], varDouble);
       Reg_Excepcion_Cambiaria.COD_MONEDA_IND          := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.COD_TRATAM_INICIO       := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.COD_TRATAM_TERMINO      := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.Fecha_Desde             := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.Fecha_Hasta             := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.Fecha_Inicio_Tratam     := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.Fecha_Termino_Tratam    := VarArrayCreate([0, i], varDate);
       Reg_Excepcion_Cambiaria.PAGA_REAJUSTE_CAPITAL   := VarArrayCreate([0, i], varOleStr);
       //ggarcia 12-07-2018
       Reg_Excepcion_Cambiaria.NO_CONSIDERA_EN_INTERES := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.SOLO_APLICA_EN_VCTOS    := VarArrayCreate([0, i], varOleStr);
       Reg_Excepcion_Cambiaria.NO_CONSIDERA_NEGATIVOS  := VarArrayCreate([0, i], varOleStr);

       SQL.Clear;
       SQL.Add('SELECT * FROM QS_FIN_EXCP_VARCAM'
              +' ORDER BY Codigo_Emisor,Fecha_Desde,Fecha_Hasta'
              );
       Prepare;
       Open;

      i := 0;
      // Lo  asignamos fuera del while para que deje fecha aun cuando no existan registros
      //     Reg_Excepcion_Cambiaria.Fecha_Calculo[i]      := dFecha_Calculo;
      while not eof do
      begin
          // Nuevo: agrego otro registro para fecha de calculo
          Reg_Excepcion_Cambiaria.Codigo_Emisor[i]      := Trim(Fieldbyname('Codigo_Emisor').asString);
          Reg_Excepcion_Cambiaria.Codigo_Instrumento[i] := Trim(Fieldbyname('Codigo_Instrumento').asString);
          Reg_Excepcion_Cambiaria.Serie[i]              := Trim(Fieldbyname('Serie').asString);
          if Transaccion_Implica(sEmpresa_Usuario,'FECHAVIG') then
             Reg_Excepcion_Cambiaria.Fecha_Vig[i]       := Fieldbyname('Fecha_Vig').asdatetime;
          if FindField('Cupon_Desde') <> Nil then
             if Not Fieldbyname('Cupon_Desde').isNull then
                Reg_Excepcion_Cambiaria.Cupon_Desde[i]     := Fieldbyname('Cupon_Desde').AsFloat; //Fieldbyname('Cupon_Desde').asString;    PA & DC 03052018

          if FindField('Cupon_Hasta') <> Nil then
             if Not Fieldbyname('Cupon_Hasta').isNull then
                Reg_Excepcion_Cambiaria.Cupon_Hasta[i]     := Fieldbyname('Cupon_Hasta').AsFloat; //Fieldbyname('Cupon_Hasta').asString;    PA & DC 03052018

          Reg_Excepcion_Cambiaria.Ptje_Aplica_Reajuste[i]  := Fieldbyname('Ptje_Aplica_Reajuste').AsFloat;

          Reg_Excepcion_Cambiaria.COD_MONEDA_IND[i]     := Fieldbyname('COD_MONEDA_IND').asString;
          Reg_Excepcion_Cambiaria.COD_TRATAM_INICIO[i]  := Fieldbyname('COD_TRATAM_INICIO').asString;
          Reg_Excepcion_Cambiaria.COD_TRATAM_TERMINO[i] := Fieldbyname('COD_TRATAM_TERMINO').asString;
          Reg_Excepcion_Cambiaria.Fecha_Desde[i]        := Fieldbyname('Fecha_Desde').asdatetime;
