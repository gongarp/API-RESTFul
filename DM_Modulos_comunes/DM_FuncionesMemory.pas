procedure Busca_Rango_Tasa_Mercado_Mem( Codigo_Instrumento  : String;
                                    sNemotecnico        : String;
                                    dFecha_Calculo      : TDatetime;
                                   var fLimite_Inferior : Double;
                                   var fLimite_Superior : Double
                                  );
var i : Integer;
begin

   //ggarcia 20-06-2017
   if NOT VarIsArray(Reg_Rango_Tasas.Instrumento) then
      Carga_Rango_tasas_Mem(dFecha_Calculo);

   // Busco por Instrumento, Nemotecnico
   for i := 0 to VarArrayHighBound(Reg_Rango_Tasas.Instrumento , 1 )  do
   begin
      if ( Reg_Rango_Tasas.Instrumento[i] = Codigo_Instrumento ) and
         ( Reg_Rango_Tasas.Nemotecnico[i] = sNemotecnico )  then
      begin
         fLimite_Inferior := Reg_Rango_Tasas.Valor_Inicial[i];
         fLimite_Superior := Reg_Rango_Tasas.Valor_Final[i];
         Exit;
      end;
   end;

   //Busco Solo por nemotecnico
   for i := 0 to VarArrayHighBound(Reg_Rango_Tasas.Instrumento , 1 )  do
   begin
      if ( Reg_Rango_Tasas.Instrumento[i] = EmptyStr ) and
         ( Reg_Rango_Tasas.Nemotecnico[i] = sNemotecnico )  then
      begin
         fLimite_Inferior := Reg_Rango_Tasas.Valor_Inicial[i];
         fLimite_Superior := Reg_Rango_Tasas.Valor_Final[i];
         Exit;
      end;
   end;

   //Busco Solo por Instrumento
   for i := 0 to VarArrayHighBound(Reg_Rango_Tasas.Instrumento , 1 )  do
   begin
      if ( Reg_Rango_Tasas.Instrumento[i] = Codigo_Instrumento ) and
         ( Reg_Rango_Tasas.Nemotecnico[i] = EmptyStr )  then
      begin
         fLimite_Inferior := Reg_Rango_Tasas.Valor_Inicial[i];
         fLimite_Superior := Reg_Rango_Tasas.Valor_Final[i];
         Exit;
      end;
   end;
end;

