       Reg_Equivalencia_Instrum.TIPO_EMISOR     := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia_Instrum.PAIS_EMISOR     := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia_Instrum.EMISOR          := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia_Instrum.SERIE           := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia_Instrum.CODIGO_EQUIV    := VarArrayCreate([0, i], varOleStr);
       i := 0;
       while not eof do
       begin
          // Nuevo: agrego otro registro para fecha de calculo para verificar vigencia de carga
          Reg_Equivalencia_Instrum.Fecha_Calculo[i]  := dFecha;
          Reg_Equivalencia_Instrum.PROCESO[i]        := Fieldbyname('PROCESO').asString;
