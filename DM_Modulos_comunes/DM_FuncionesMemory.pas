       Close;
     end;
end;

procedure Verifica_Excepcion_PROMTAS_Vigente_Mem
                                          (sCodigo_Emisor           : String;
                                           sCodigo_Instrumento      : String;
                                           sSerie                   : String;
                                           fCupon                   : Double;
                                           dFecha_Calculo           : TDatetime;
                                           var s0Cod_Tratam_Inicio  : String;
                                           var s1Cod_Tratam_Termino : String;
                                           var dFecha_Inicio_Tratamiento  : TDatetime;
                                           var dFecha_Termino_Tratamiento : TDatetime;
                                           var Result               : Boolean);
var i      : Integer;
   //,j      : Integer;
   bExiste : Boolean;
begin
  Result  := False;
  bExiste := False;

  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Excepcion_PROMTAS.Codigo_Emisor) then
     Carga_Excepcion_PROMTAS_Mem;

  for i := 0 to VarArrayHighBound(Reg_Excepcion_Cambiaria.Codigo_Emisor , 1 )  do
  begin
     if  (Reg_Excepcion_PROMTAS.Codigo_Emisor[i]      = sCodigo_Emisor)       and
         (Reg_Excepcion_PROMTAS.Codigo_Instrumento[i] = sCodigo_Instrumento ) and
         (Reg_Excepcion_PROMTAS.Serie[i]              = sSerie )              and
         (Reg_Excepcion_PROMTAS.Fecha_Desde[i]        <= dFecha_Calculo)      and
         ((Reg_Excepcion_PROMTAS.Fecha_Hasta[i]       >= dFecha_Calculo)      or
          (Reg_Excepcion_PROMTAS.Fecha_Hasta[i]       = 0 ))                  and
          (Reg_Excepcion_PROMTAS.Cupon_Desde[i]       <= fCupon )             and
          (Reg_Excepcion_PROMTAS.Cupon_Hasta[i]       >= fCupon )             then
     begin
        s0Cod_Tratam_Inicio        := Reg_Excepcion_PROMTAS.COD_TRATAM_INICIO[i];
        s1Cod_Tratam_Termino       := Reg_Excepcion_PROMTAS.COD_TRATAM_Termino[i];
        dFecha_Inicio_Tratamiento  := Reg_Excepcion_PROMTAS.Fecha_Inicio_Tratam[i];
        dFecha_Termino_Tratamiento := Reg_Excepcion_PROMTAS.Fecha_Termino_Tratam[i];
        bExiste := True;
        Result := True;
        Break;
     end;
  end;

  if NOT bExiste then
  begin
     If (not Result) and (fCupon <> 0) Then
        Verifica_Excepcion_PROMTAS_Vigente_Mem  (sCodigo_Emisor,
                                                 sCodigo_Instrumento,
                                                 sSerie,
                                                 0,
                                                 dFecha_Calculo,
                                                 s0Cod_Tratam_Inicio,
                                                 s1Cod_Tratam_Termino,
                                                 dFecha_Inicio_Tratamiento,
                                                 dFecha_Termino_Tratamiento,
                                                 Result);
  end;
end;

