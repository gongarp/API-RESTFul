                                           ,sClasif_Riesgo_B
                                           ,sOperacion
                                           ,sAplica_Equivalencia
                                           ,sTipo_Instrum  : String;
                                        Var sModulo_Error : String;
                                        Var sString_Error : String
                                           ) : Boolean;
var fNro_Riesgo_A
   ,fNro_Riesgo_B
   ,fFactor_A
   ,fFactor_B
//   ,fNro_A
//   ,fNro_B
   ,fNivel_A
   ,fNivel_B
   ,fValor_Riesgo_A
   ,fValor_Riesgo_B   : Double;
   sTipo_Plazo : String;
begin
   sModulo_Error := 'Operación Clasif. Riesgo ';
   Result := False;

   // Cambio a Corto o Largo Plazo si Corresponde
   if sAplica_Equivalencia = 'S' then
   begin

      ////  ANALIZA CLASIFICACION B

      Busca_Datos_Clasif_Riesgo_Mem('', // TIPO
                                    sClasif_Riesgo_B,
                                    fNro_Riesgo_B,
                                    fFactor_B,
                                    sTipo_Plazo,
                                    fValor_Riesgo_B,
                                    fNivel_B
                                    );
      // Clasificacion es de largo plazo y el instrumento es de corto plazo por lo tanto cambio
      // equivalencia a corto plazo
      if sTipo_Plazo = 'L' then
         if sTipo_Instrum <> 'S' then
           Busca_Clasif_Equiv_Mem(fNivel_B
                                 ,'C' // Corto Plazo
                                 ,sClasif_Riesgo_B
                                 );

      // Clasificacion es de CORTO plazo y el instrumento es de LARGO plazo por lo tanto cambio
      // equivalencia a LARGO PLAZO
      if sTipo_Plazo = 'C' then
         if sTipo_Instrum = 'S' then
           Busca_Clasif_Equiv_Mem(fNivel_B
                                 ,'L' // Corto Plazo
                                 ,sClasif_Riesgo_B
                                 );

        //// ANALIZA CLASIFICACION A

      Busca_Datos_Clasif_Riesgo_Mem('', // TIPO
                                    sClasif_Riesgo_A,
                                    fNro_Riesgo_A,
                                    fFactor_B,
                                    sTipo_Plazo,
                                    fValor_Riesgo_A,
                                    fNivel_A
                                    );
      // Clasificacion es de largo plazo y el instrumento es de corto plazo por lo tanto cambio
      // equivalencia a corto plazo
      if sTipo_Plazo = 'L' then
         if sTipo_Instrum <> 'S' then
           Busca_Clasif_Equiv_Mem(fNivel_A
                                 ,'C' // Corto Plazo
                                 ,sClasif_Riesgo_A
                                 );

      // Clasificacion es de CORTO plazo y el instrumento es de LARGO plazo por lo tanto cambio
      // equivalencia a LARGO PLAZO
      if sTipo_Plazo = 'C' then
         if sTipo_Instrum = 'S' then
           Busca_Clasif_Equiv_Mem(fNivel_A
                                 ,'L' // Corto Plazo
                                 ,sClasif_Riesgo_A
                                 );
      
   end;

   Busca_Datos_Clasif_Riesgo_Mem( '', // TIPO
                                  sClasif_Riesgo_A,
                                  fNro_Riesgo_A,
                                  fFactor_A,
                                  sTipo_Plazo,
                                  fValor_Riesgo_A,
                                  fNivel_A
                                 );

   Busca_Datos_Clasif_Riesgo_Mem( '', // TIPO
                                  sClasif_Riesgo_B,
                                  fNro_Riesgo_B,
                                  fFactor_B,
                                  sTipo_Plazo,
                                  fValor_Riesgo_B,
                                  fNivel_B
                                 );
   if sOperacion = '=' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A = fValor_Riesgo_B )
   else if sOperacion = '<' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A  < fValor_Riesgo_B )
   else if sOperacion = '<=' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A <= fValor_Riesgo_B )
   else if sOperacion = '>' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A > fValor_Riesgo_B )
   else if sOperacion = '>=' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A >= fValor_Riesgo_B )
   else if sOperacion = '<>' then
      Aplica_Operacion_Clasif_Riesgo_Mem := ( fValor_Riesgo_A <> fValor_Riesgo_B );
end;

{
Procedure Carga_Valores_Clasif_Riesgo_Mem_251( dFecha : TDatetime );
var i : LongInt;
    sCOD_EMP_SERIE,
    sCOD_INST_SERIE,
    sSERIE_CLASIF,
    sCLASIF_SERIE  : String;
    dFecha_Aux     : Tdatetime;
    dFecha_Max     : Tdatetime;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT  COD_EMP_SERIE'
       +',COD_INST_SERIE'
       +',MAX(F_CLASIF_SERIE) as F_CLASIF_SERIE'
       +',CLASIF_SERIE'
       +' FROM QS_FIN_CL_RIESGOS'
       +' WHERE F_CLASIF_SERIE <= :Fecha'
       +'  AND ( SERIE_CLASIF = '' '''
       +'    OR  SERIE_CLASIF is NULL )'
       +'  AND ORIGEN = :Origen '
       +' GROUP BY'
       +'     COD_EMP_SERIE'
       +'    ,COD_INST_SERIE'
       +'    ,CLASIF_SERIE'
       +' ORDER BY'
       +'     COD_EMP_SERIE'
       +'    ,COD_INST_SERIE'
       +'    ,CLASIF_SERIE'
        );

      Parambyname('Fecha').asDatetime := dFecha;
      Parambyname('Origen').asString  := default_codgen('AGENCIACLA','FI','');

      Open;

       i := RecordCount;

       Reg_Clasif_Riesgo_251.COD_EMP_SERIE  := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_251.COD_INST_SERIE := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_251.CLASIF_SERIE   := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_251.F_CLASIF_SERIE := VarArrayCreate([0, i], varDate);

       i := 0;
       while Not eof do
       begin
          sCOD_EMP_SERIE  := Fieldbyname('COD_EMP_SERIE').asString;
          sCOD_INST_SERIE := Fieldbyname('COD_INST_SERIE').asString;

          Reg_Clasif_Riesgo_251.COD_EMP_SERIE[i]  := sCOD_EMP_SERIE;
          Reg_Clasif_Riesgo_251.COD_INST_SERIE[i] := sCOD_INST_SERIE;

          dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
          sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;
          while (not Eof) and
                (sCOD_EMP_SERIE  = Fieldbyname('COD_EMP_SERIE').asString )  and
                (sCOD_INST_SERIE = Fieldbyname('COD_INST_SERIE').asString)  do
          begin
             if Fieldbyname('F_CLASIF_SERIE').asDatetime >= dFecha_aux then
             begin
                dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
                sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;
             end;
             Next;
          end;
          Reg_Clasif_Riesgo_251.CLASIF_SERIE[i]   := sCLASIF_SERIE;
          Reg_Clasif_Riesgo_251.F_CLASIF_SERIE[i] := dFecha_Aux;

          Inc(i);
       end;

       if i > 0 then
          Dec(i);
       Close;
   end;
end;
 }

 {
 procedure Busca_Clasif_Riesgo_Mem_251(const sEmisor            : String;
                                      const sInstrumento       : String;
                                      const sSerie             : String;
                                      var sClasificacion  : String
                                     );
var i       : Integer;
    bExiste,
    bEmisor_Pagador : Boolean;
    sEmisor_Pagador : String;
    dFecha : Tdatetime;
begin
   bExiste := False;
   sClasificacion := '';
   for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo.COD_EMP_SERIE, 1 )-1 do
   begin
      if (Reg_Clasif_Riesgo.COD_EMP_SERIE[i]  = sEmisor)       and
         (Reg_Clasif_Riesgo.COD_INST_SERIE[i] = sInstrumento)  and
         (Reg_Clasif_Riesgo.SERIE_CLASIF[i]   = sSerie)  then
      begin
         sClasificacion := Reg_Clasif_Riesgo.CLASIF_SERIE[i];
         bExiste        := True;
         Break;
      end;
   end;

   if Not bExiste then
   begin
      dFecha := 0;
      bEmisor_Pagador := False;
      Emisor_Pagador_Mem( dFecha,   // Va sin Valor, hay k enviarle la fecha del proceso, Edosan
                          sEmisor,
                          sInstrumento,
                          sEmisor_Pagador,
                          bEmisor_Pagador
                         );
      if bEmisor_Pagador then
         Busca_Clasif_Riesgo_Mem_251( sEmisor_Pagador,
                                      sInstrumento,
                                      sSerie,
                                      sClasificacion
                                     );
   end;
end;
}
procedure Busca_Clasif_Equiv_Mem( fNivel_Equiv   : Double;
                                  sTipo_Plazo    : String;
                              var sCodigo_Clasif : String
                                 );
Var
  i : Integer;
begin
   for i := 0 to VarArrayHighBound(Reg_Nro_Riesgo.Codigo, 1 )-1 do
   begin
      if ( Reg_Nro_Riesgo.Nivel[i]      = fNivel_Equiv ) and
         ( Reg_Nro_Riesgo.Tipo_Plazo[i] = sTipo_Plazo  ) then
      begin
         sCodigo_Clasif := Reg_Nro_Riesgo.Codigo[i];
         Break;
      end;
   end;
end;

procedure Carga_Dividendos_Impagos_Mem( dFecha  : TDatetime );
Var i : LongInt;
begin
  WITH DmFuncionesMemory.Qry_General do
  begin
    SQL.Clear;
    Sql.Add( ' SELECT COUNT(*) as Registros'
            +' FROM QS_RES_PROVISION'
            +' WHERE empresa       = :empresa'
            +'   AND Fecha_Cierre  = :Fecha_Cierre'
            );
    Parambyname('Empresa').AsString        := sEmpresa_Usuario;
    Parambyname('Fecha_Cierre').asDate := dFecha;
    Open;

    i := 0;
    if NOT Fieldbyname('Registros').IsNull then
       i := Fieldbyname('Registros').asInteger;

    Close;
    SQL.Clear;
    Sql.Add( ' SELECT Cartera'
            +'       ,Transaccion'
            +'       ,Folio_Interno'
            +'       ,Item_Omd'
            +'       ,DIVIDENDO_IMPAGO_UM'
            +'       ,DIVIDENDO_IMPAGO_MC'
            +'       ,PROVISION_UM'
            +'       ,PROVISION_MC'
            +'       ,VALOR_TASACION_UM'
            +'       ,NRO_DIVIDENDOS_IMP'
            +'       ,FECHA_RETASACION'
            +'       ,FECHA_PRIMER_DIV'
            +' FROM QS_RES_PROVISION'
            +' WHERE Fecha_Cierre  = :Fecha_Cierre'
            +'   AND empresa       = :empresa'
            );
    Parambyname('Empresa').AsString        := sEmpresa_Usuario;
    Parambyname('Fecha_Cierre').asDate := dFecha;
    Open;

    Reg_Dividendos_Imp.cartera             := VarArrayCreate([0, i], varOleStr);
    Reg_Dividendos_Imp.Transaccion         := VarArrayCreate([0, i], varOleStr);
    Reg_Dividendos_Imp.Folio_Interno       := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.Item_Omd            := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.PROVISION_UM        := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.PROVISION_MC        := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.VALOR_TASACION_UM   := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP  := VarArrayCreate([0, i], varDouble);
    Reg_Dividendos_Imp.FECHA_RETASACION    := VarArrayCreate([0, i], varDate);
    Reg_Dividendos_Imp.FECHA_PRIMER_DIV    := VarArrayCreate([0, i], varDate);

     i := 0;
     while not eof do
     begin
        Reg_Dividendos_Imp.cartera[i]             := Fieldbyname('Cartera').asString;
        Reg_Dividendos_Imp.Transaccion[i]         := Fieldbyname('Transaccion').asString;
        Reg_Dividendos_Imp.Folio_Interno[i]       := Fieldbyname('Folio_Interno').asFloat;
        Reg_Dividendos_Imp.Item_Omd[i]            := Fieldbyname('Item_Omd').asFloat;
        Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[i] := Fieldbyname('DIVIDENDO_IMPAGO_UM').asFloat;
        Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[i] := Fieldbyname('DIVIDENDO_IMPAGO_MC').asFloat;
        Reg_Dividendos_Imp.PROVISION_UM[i]        := Fieldbyname('PROVISION_UM').asFloat;
        Reg_Dividendos_Imp.PROVISION_MC[i]        := Fieldbyname('PROVISION_MC').asFloat;
        Reg_Dividendos_Imp.VALOR_TASACION_UM[i]   := Fieldbyname('VALOR_TASACION_UM').asFloat;
        Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[i]  := Fieldbyname('NRO_DIVIDENDOS_IMP').asFloat;
        Reg_Dividendos_Imp.FECHA_RETASACION[i]    := Fieldbyname('FECHA_RETASACION').asdatetime;
        Reg_Dividendos_Imp.FECHA_PRIMER_DIV[i]    := Fieldbyname('FECHA_PRIMER_DIV').asdatetime;
        Inc(i);
        Next;
     end;
     Close;
  end;

  //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
  if i <> 0 then
     Ordenamiento_Dividendos_Impagos_Mem( Reg_Dividendos_Imp
                                        ,0
                                        ,VarArrayHighBound(Reg_Dividendos_Imp.Folio_Interno, 1 )-1
                                        );
end;

Procedure Ordenamiento_Dividendos_Impagos_Mem( var Reg_Dividendos_Imp : TReg_Dividendos_Imp;
                                                    iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd,
    fDIVIDENDO_IMPAGO_UM,
    fDIVIDENDO_IMPAGO_MC,
    fPROVISION_UM,
    fPROVISION_MC,
    fVALOR_TASACION_UM,
    fNRO_DIVIDENDOS_IMP : Double;
    dFECHA_RETASACION,
    dFECHA_PRIMER_DIV   : Tdatetime;
    sTransaccion,
    sCartera       : String;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Dividendos_Imp.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Dividendos_Imp.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Dividendos_Imp.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sCartera             := Reg_Dividendos_Imp.Cartera[Lo];
         sTransaccion         := Reg_Dividendos_Imp.Transaccion[Lo];
         fFolio_Interno       := Reg_Dividendos_Imp.Folio_Interno[Lo];
         fItem_Omd            := Reg_Dividendos_Imp.Item_Omd[Lo];
         fDIVIDENDO_IMPAGO_UM := Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[Lo];
         fDIVIDENDO_IMPAGO_MC := Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[Lo];
         fPROVISION_UM        := Reg_Dividendos_Imp.PROVISION_UM[Lo];
         fPROVISION_MC        := Reg_Dividendos_Imp.PROVISION_MC[Lo];
         fVALOR_TASACION_UM   := Reg_Dividendos_Imp.VALOR_TASACION_UM[Lo];
         fNRO_DIVIDENDOS_IMP  := Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[Lo];
         dFECHA_RETASACION    := Reg_Dividendos_Imp.FECHA_RETASACION[Lo];
         dFECHA_PRIMER_DIV    := Reg_Dividendos_Imp.FECHA_PRIMER_DIV[Lo];

         Reg_Dividendos_Imp.Cartera[Lo]       :=
                       Reg_Dividendos_Imp.cartera[Hi];
         Reg_Dividendos_Imp.Transaccion[Lo]   :=
                       Reg_Dividendos_Imp.Transaccion[Hi];
         Reg_Dividendos_Imp.Folio_Interno[Lo] :=
                       Reg_Dividendos_Imp.Folio_Interno[Hi];
         Reg_Dividendos_Imp.Item_Omd[Lo]      :=
                       Reg_Dividendos_Imp.Item_Omd[Hi];
         Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[Lo]      :=
                       Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[Hi];
         Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[Lo]      :=
                       Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[Hi];
         Reg_Dividendos_Imp.PROVISION_UM[Lo]      :=
                       Reg_Dividendos_Imp.PROVISION_UM[Hi];
         Reg_Dividendos_Imp.PROVISION_MC[Lo]      :=
                       Reg_Dividendos_Imp.PROVISION_MC[Hi];
         Reg_Dividendos_Imp.VALOR_TASACION_UM[Lo]      :=
                       Reg_Dividendos_Imp.VALOR_TASACION_UM[Hi];
         Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[Lo]      :=
                       Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[Hi];
         Reg_Dividendos_Imp.FECHA_RETASACION[Lo]      :=
                       Reg_Dividendos_Imp.FECHA_RETASACION[Hi];
         Reg_Dividendos_Imp.FECHA_PRIMER_DIV[Lo]      :=
                       Reg_Dividendos_Imp.FECHA_PRIMER_DIV[Hi];

         Reg_Dividendos_Imp.Cartera[Hi]         := sCartera;                       
         Reg_Dividendos_Imp.Transaccion[Hi]     := sTransaccion;
         Reg_Dividendos_Imp.Folio_Interno[Hi]   := fFolio_Interno;
         Reg_Dividendos_Imp.Item_Omd[Hi]        := fItem_Omd;
         Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[Hi] := fDIVIDENDO_IMPAGO_UM;
         Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[Hi] := fDIVIDENDO_IMPAGO_MC;
         Reg_Dividendos_Imp.PROVISION_UM[Hi]        := fPROVISION_UM;
         Reg_Dividendos_Imp.PROVISION_MC[Hi]        := fPROVISION_MC;
         Reg_Dividendos_Imp.VALOR_TASACION_UM[Hi]   := fVALOR_TASACION_UM;
         Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[Hi]  := fNRO_DIVIDENDOS_IMP;
         Reg_Dividendos_Imp.FECHA_RETASACION[Hi]    := dFECHA_RETASACION;
         Reg_Dividendos_Imp.FECHA_PRIMER_DIV[Hi]    := dFECHA_PRIMER_DIV;
         
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Dividendos_Impagos_Mem(Reg_Dividendos_Imp, iLo, Hi);
    if Lo < iHi then Ordenamiento_Dividendos_Impagos_Mem(Reg_Dividendos_Imp, Lo, iHi);
end;

procedure Busca_Valor_Div_Impagos_Mem( sEmpresa,
                                       sCARTERA,
                                       sTransaccion,
                                       sFolio_Interno : String;
                                       fItem_Omd      : Double;
                                       dFECHA         : TDatetime;
                                   Var fMonto_Impago_UM : Double;
                                   Var fMonto_Impago_MC : Double;
                                   Var fProvision_UM    : Double;
                                   Var fProvision_MC    : Double;
                                   Var fValor_Retasacion   : Double;
                                   Var fNro_Cuotas_Impagas : Double;
                                   Var dFecha_Retasacion : Tdatetime;
                                   Var dFecha_Primer_Dividendo : Tdatetime
                                       );
var i,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
begin
   fMonto_Impago_UM    := 0;
   fMonto_Impago_MC    := 0;
   fProvision_UM       := 0;
   fProvision_MC       := 0;
   fValor_Retasacion   := 0;
   fNro_Cuotas_Impagas := 0;
   dFecha_Retasacion   := 0;
   dFecha_Primer_Dividendo := 0;
   
   fFolio_Buscado   := StrToFloat( sFolio_Interno );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Dividendos_Imp.Folio_Interno, 1 )-1;

   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
      i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

      if (Reg_Dividendos_Imp.Folio_Interno[i] = fFolio_Buscado) and
         (Reg_Dividendos_Imp.Transaccion[i]   = sTransaccion)   and
         (Reg_Dividendos_Imp.Item_Omd[i]      = fItem_Omd)      and
         (Reg_Dividendos_Imp.cartera[i]       = sCartera)       then
      begin
         fMonto_Impago_UM    := Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_UM[i];
         fMonto_Impago_MC    := Reg_Dividendos_Imp.DIVIDENDO_IMPAGO_MC[i];
         fProvision_UM       := Reg_Dividendos_Imp.Provision_UM[i];
         fProvision_MC       := Reg_Dividendos_Imp.Provision_MC[i];
         fValor_Retasacion   := Reg_Dividendos_Imp.VALOR_TASACION_UM[i];
         fNro_Cuotas_Impagas := Reg_Dividendos_Imp.NRO_DIVIDENDOS_IMP[i];
         dFecha_Retasacion   := Reg_Dividendos_Imp.Fecha_Retasacion[i];
         dFecha_Primer_Dividendo := Reg_Dividendos_Imp.FECHA_PRIMER_DIV[i];
         Break;
      end;

      if  fFolio_Buscado > Reg_Dividendos_Imp.Folio_Interno[i] then
         iLimite_Inferior := i + 1
      else
         iLimite_Superior := i - 1;
   end;
end;

Procedure Carga_Estado_Mem( dFecha_Valorizacion : TDatetime );
var i : LongInt;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT * '
             +'  FROM QS_TRA_OMD_ESTADO a'
             +' WHERE a.Fecha_Desde <= :Fecha'
             +'  AND (a.Fecha_Hasta IS NULL OR a.Fecha_Hasta >= :Fecha)'
             +'  AND a.Fecha_Desde = ( SELECT  MAX(b.Fecha_Desde)'
             +'                  FROM QS_TRA_OMD_ESTADO  b'
             +'                 WHERE a.Empresa      = b.Empresa'
             +'                  AND a.Cartera       = b.Cartera'
             +'                  AND a.Transaccion   = b.Transaccion'
             +'                  AND a.Folio_Interno = b.Folio_Interno'
             +'                  AND a.Item_Omd      = b.Item_Omd'
             +'                  AND b.Fecha_Desde <= :Fecha'
             +'                  AND (b.Fecha_Hasta >= :Fecha OR b.Fecha_Hasta IS NULL )'
             +'                      )'
             );
      ParamByName('Fecha').AsDate := dFecha_Valorizacion;
      Open;
      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Estado.Empresa       := VarArrayCreate([0, i], varOleStr);
      Reg_Estado.Transaccion   := VarArrayCreate([0, i], varOleStr);
      Reg_Estado.Folio_Interno := VarArrayCreate([0, i], varDouble);
      Reg_Estado.Item_Omd      := VarArrayCreate([0, i], varDouble);      
      Reg_Estado.Fecha_Hora    := VarArrayCreate([0, i], varDate);
      Reg_Estado.Fecha_Desde   := VarArrayCreate([0, i], varDate);
      Reg_Estado.Fecha_Hasta   := VarArrayCreate([0, i], varDate);
      Reg_Estado.Cod_Estado    := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Estado.Empresa[i]       := Fieldbyname('Empresa').asString;
         Reg_Estado.Transaccion[i]   := Fieldbyname('Transaccion').asString;
         Reg_Estado.Folio_Interno[i] := Fieldbyname('Folio_Interno').asFloat;
         Reg_Estado.Item_Omd[i]      := Fieldbyname('Item_Omd').asFloat;         
         Reg_Estado.Fecha_Hora[i]    := Fieldbyname('Fecha_Hora').asDatetime;
         Reg_Estado.Fecha_Desde[i]   := Fieldbyname('Fecha_Desde').asDatetime;
         Reg_Estado.Fecha_Hasta[i]   := Fieldbyname('Fecha_Hasta').asDatetime;
         Reg_Estado.Cod_Estado[i]    := Fieldbyname('Cod_Estado').asString;
         Next;
         Inc(i);
      end;
      Close;
   end;

  //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
  if i <> 0 then
     Ordenamiento_Estado_Operacion_Mem(  Reg_Estado
                                       ,0
                                       ,VarArrayHighBound(Reg_Estado.Folio_Interno, 1 )-1
                                      );

end;

Procedure Ordenamiento_Estado_Operacion_Mem( var Reg_Estado : TReg_Estado;
                                            iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno ,
    fItem_Omd  : Double;
    sTransaccion,
    sEmpresa,
    sCod_Estado      : String;
    dFecha_Hora,
    dFecha_Desde,
    dFecha_Hasta : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Estado.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Estado.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Estado.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sEmpresa           := Reg_Estado.Empresa[Lo];
         sTransaccion       := Reg_Estado.Transaccion[Lo];
         fFolio_Interno     := Reg_Estado.Folio_Interno[Lo];
         fItem_Omd          := Reg_Estado.Item_Omd[Lo];
         dFecha_Hora        := Reg_Estado.Fecha_Hora[Lo];
         dFecha_Desde       := Reg_Estado.Fecha_Desde[Lo];
         dFecha_Hasta       := Reg_Estado.Fecha_Hasta[Lo];
         sCod_Estado        := Reg_Estado.Cod_Estado[Lo];

         Reg_Estado.Empresa[Lo]       :=
                       Reg_Estado.Empresa[Hi];
         Reg_Estado.Transaccion[Lo]   :=
                       Reg_Estado.Transaccion[Hi];
         Reg_Estado.Folio_Interno[Lo] :=
                       Reg_Estado.Folio_Interno[Hi];
         Reg_Estado.Item_Omd [Lo]     :=
                       Reg_Estado.Item_Omd [Hi];
         Reg_Estado.Fecha_Hora[Lo]    :=
                       Reg_Estado.Fecha_Hora[Hi];
         Reg_Estado.Fecha_Desde[Lo]   :=
                       Reg_Estado.Fecha_Desde[Hi];
         Reg_Estado.Fecha_Hasta[Lo]   :=
                       Reg_Estado.Fecha_Hasta[Hi];
         Reg_Estado.Cod_Estado[Lo]   :=
                       Reg_Estado.Cod_Estado[Hi];

         Reg_Estado.Empresa[Hi]       := sEmpresa;
         Reg_Estado.Transaccion[Hi]   := sTransaccion;
         Reg_Estado.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Estado.Item_Omd[Hi]      := fItem_Omd;
         Reg_Estado.Fecha_Hora[Hi]    := dFecha_Hora;
         Reg_Estado.Fecha_Desde[Hi]   := dFecha_Desde;
         Reg_Estado.Fecha_Hasta[Hi]   := dFecha_Hasta;
         Reg_Estado.Cod_estado[Hi]    := sCod_Estado;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Estado_Operacion_Mem(Reg_Estado, iLo, Hi);
    if Lo < iHi then Ordenamiento_Estado_Operacion_Mem(Reg_Estado, Lo, iHi);
end;

Function Busca_Estado_Mem(  const sEmpresa       : String;
                            const sTransaccion   : String;
                            const sFolio_Interno : String;
                                  fItem_Omd      : Double                            
                          ) : String;

var i
   ,j
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
   fFolio_Interno    : Double;
   bExiste           : Boolean;
begin
  bExiste := False;
  Busca_Estado_Mem := '';
  fFolio_Interno      := StrToFloat(sFolio_Interno);

  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Estado.Folio_Interno, 1 )-1;
  i := 0;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Estado.Folio_Interno[i] = fFolio_Interno then
     begin
        bExiste := True;
        Break;
     end;

     if fFolio_Interno > Reg_Estado.Folio_Interno[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i -1;
  end;

  if bExiste then
  begin
     //Retrocedo hasta Primer Folio Igual  por cuestion de fechas
     For j := i Downto 0 do
       if Reg_Estado.Folio_Interno[J] <> fFolio_Interno then
          Break;

     i := j + 1;
     while (i <= VarArrayHighBound(Reg_Estado.Folio_Interno , 1 )) and
           (Reg_Estado.Folio_Interno[i] = fFolio_Interno) do
     begin
        if  (Reg_Estado.Empresa[i]       = sEmpresa     ) and
            (Reg_Estado.Transaccion[i]   = sTransaccion ) and
            (Reg_Estado.Folio_Interno[i] = fFolio_Interno) and
            (Reg_Estado.Item_Omd[i]      = fItem_Omd )  then
        begin
           Busca_Estado_Mem := Reg_Estado.Cod_Estado[i];
           Break;
        end;
        Inc(i);
     end;
  end;
end;

