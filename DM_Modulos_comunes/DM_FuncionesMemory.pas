Procedure Carga_Gastos_en_Costo_Mem;
Var i : LongInt;
begin

   with DmFuncionesMemory.QRY_General do
   begin
      SQL.Clear;
      SQL.Add('SELECT * FROM QS_FIN_GASTOS_EN_COSTO ');
      try
        Open;
        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
      except
        i:= 0;
      end;

      Reg_Gastos_en_Costo.EMPRESA           := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.PROCESO           := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.CARTERA           := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.TIPO_INSTRUMENTO  := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.MOTIVO_INVERSION  := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.CODIGO_GASTOS     := VarArrayCreate([0, i], varOleStr);
      Reg_Gastos_en_Costo.FECHA_DESDE       := VarArrayCreate([0, i], varDate);
      Reg_Gastos_en_Costo.FECHA_HASTA       := VarArrayCreate([0, i], varDate);
      i := 0;
      while not eof do
      begin
         Reg_Gastos_en_Costo.EMPRESA[i]           := Fieldbyname('EMPRESA').asString;
         Reg_Gastos_en_Costo.PROCESO[i]           := Fieldbyname('PROCESO').asString;
         Reg_Gastos_en_Costo.CARTERA[i]           := Fieldbyname('CARTERA').asString;
         Reg_Gastos_en_Costo.TIPO_INSTRUMENTO[i]  := Fieldbyname('TIPO_INSTRUMENTO').asString;
         Reg_Gastos_en_Costo.MOTIVO_INVERSION[i]  := Fieldbyname('MOTIVO_INVERSION').asString;
         Reg_Gastos_en_Costo.CODIGO_GASTOS[i]     := Fieldbyname('CODIGO_GASTOS').asString;
         Reg_Gastos_en_Costo.FECHA_DESDE[i]       := Fieldbyname('Fecha_Desde').AsDateTime;
         Reg_Gastos_en_Costo.FECHA_HASTA[i]       := Fieldbyname('Fecha_Hasta').AsDateTime;
         Inc(i);
         Next;
      end;
      Close;
   end;
end;

procedure Busca_Gastos_en_Costo_Mem( xEmpresa            : String;
                                     xProceso            : String;
                                     xCartera            : String;
                                     sTipo_Instrumento   : String;
                                     sMotivo_Inversion   : String;
                                     dFecha              : TDateTime;
                                     var sCODIGO_GASTOS  : String;
                                     var bGasto_En_Costo : Boolean);

var sEmpresa : String;
    sProceso : String;
    sCartera : String;
    i        : Integer;
begin

   if NOT VarIsArray(Reg_Gastos_en_Costo.Empresa) then
     Carga_Gastos_en_Costo_Mem;

   bGasto_En_Costo   := False;
   sCODIGO_GASTOS    := '';

   // Verifica si existe definida por Empresa
   // SI NO EXISTE LO SACA Y NO ITERA PARA EL RESTO
   sEmpresa := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.EMPRESA, 1 )  do
   begin
      if Reg_Gastos_en_Costo.Empresa[i] = xEmpresa then
      begin
         sEmpresa := xEmpresa;
         Break;
      end;
   end;

   if (sEmpresa = EmptyStr) or
      (sEmpresa = '') then
      exit;


   // Verifica si existe definida por proceso
   // SI NO EXISTE LO SACA Y NO ITERA PARA EL RESTO
   sProceso := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.PROCESO, 1 )  do
   begin
      if Reg_Gastos_en_Costo.Proceso[i] = xProceso then
      begin
         sProceso := xProceso;
         Break;
      end;
   end;

   if (sProceso = EmptyStr) or
      (sProceso = '') then
      exit;

   // Verifica si existe definicion por cartera
   // Solo ese caso toma en cuenta condicion
   // Si no existe definicion para la cartera enviada como parametro
   // realizara la busqueda de registros con la cartera = '' (emptystr)
   sCartera := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.Cartera, 1 )  do
   begin
      if    ( Reg_Gastos_en_Costo.Cartera[i] = xCartera ) and
            ( Reg_Gastos_en_Costo.Proceso[i] = sProceso ) and
            ( Reg_Gastos_en_Costo.Empresa[i] = sEmpresa ) then
            
      begin
         sCartera := xCartera;
         Break;
      end;
   end;

   // Busca Tipo_instrumento y Motivo_Inversion
   for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.Proceso , 1 )  do
   begin
      if    (Reg_Gastos_en_Costo.TIPO_INSTRUMENTO[i] = sTipo_Instrumento)
        and (Reg_Gastos_en_Costo.MOTIVO_INVERSION[i] = sMotivo_Inversion)

        and (dFecha  >= Reg_Gastos_en_Costo.FECHA_DESDE[i])
        and ((dFecha <= Reg_Gastos_en_Costo.FECHA_HASTA[i])
         OR  (Reg_Gastos_en_Costo.FECHA_HASTA[i] = StrToDateTime(Fecha_Nula) ))

        // Empresa
        and  (Reg_Gastos_en_Costo.Empresa[i] = sEmpresa)
        // Proceso
        and  (Reg_Gastos_en_Costo.Proceso[i] = sProceso)
        // Cartera
        and  ( (Reg_Gastos_en_Costo.Cartera[i] = sCartera)
              or ((sCartera =  EmptyStr) and (Reg_Gastos_en_Costo.Cartera[i] = EmptyStr))     // Solo sin definicion de cartera
             )
             then
      begin
         bGasto_En_Costo := True;
         Break;
      end;
   end;

   // Busca Tipo_instrumento Sin Motivo_Inversion definido

   if Not bGasto_En_Costo then
      for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.Proceso , 1 )  do
      begin
         if    (Reg_Gastos_en_Costo.TIPO_INSTRUMENTO[i] = sTipo_Instrumento)
           and (Reg_Gastos_en_Costo.MOTIVO_INVERSION[i] = EmptyStr)

           and (dFecha  >= Reg_Gastos_en_Costo.FECHA_DESDE[i])
           and ((dFecha <= Reg_Gastos_en_Costo.FECHA_HASTA[i])
            OR  (Reg_Gastos_en_Costo.FECHA_HASTA[i] = StrToDateTime(Fecha_Nula) ))

           // Empresa
           and  (Reg_Gastos_en_Costo.Empresa[i] = sEmpresa)
           // Proceso
           and  (Reg_Gastos_en_Costo.Proceso[i] = sProceso)
           // Cartera
           and  ( (Reg_Gastos_en_Costo.Cartera[i] = sCartera)
                 or ((sCartera =  EmptyStr) and (Reg_Gastos_en_Costo.Cartera[i] = EmptyStr))     // Solo sin definicion de cartera
                )
                then
         begin
            bGasto_En_Costo := True;
            Break;
         end;
      end;

   // Busca Tipo_instrumento en blanco y con Motivo_Inversion definido

   if Not bGasto_En_Costo then
      for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.Proceso , 1 )  do
      begin
         if    (Reg_Gastos_en_Costo.TIPO_INSTRUMENTO[i] = EmptyStr)
           and (Reg_Gastos_en_Costo.MOTIVO_INVERSION[i] = sMotivo_Inversion)

           and (dFecha  >= Reg_Gastos_en_Costo.FECHA_DESDE[i])
           and ((dFecha <= Reg_Gastos_en_Costo.FECHA_HASTA[i])
            OR  (Reg_Gastos_en_Costo.FECHA_HASTA[i] = StrToDateTime(Fecha_Nula) ))

           // Empresa
           and  (Reg_Gastos_en_Costo.Empresa[i] = sEmpresa)
           // Proceso
           and  (Reg_Gastos_en_Costo.Proceso[i] = sProceso)
           // Cartera
           and  ( (Reg_Gastos_en_Costo.Cartera[i] = sCartera)
                 or ((sCartera =  EmptyStr) and (Reg_Gastos_en_Costo.Cartera[i] = EmptyStr))     // Solo sin definicion de cartera
                )
                then
         begin
            bGasto_En_Costo := True;
            Break;
         end;
      end;

   // Caso para todos ....
   // Busca Tipo_instrumento en blanco y con Motivo_Inversion en blanco

   if Not bGasto_En_Costo then
      for i := 0 to VarArrayHighBound(Reg_Gastos_en_Costo.Proceso , 1 )  do
      begin
         if    (Reg_Gastos_en_Costo.TIPO_INSTRUMENTO[i] = EmptyStr)
           and (Reg_Gastos_en_Costo.MOTIVO_INVERSION[i] = EmptyStr)

           and (dFecha  >= Reg_Gastos_en_Costo.FECHA_DESDE[i])
           and ((dFecha <= Reg_Gastos_en_Costo.FECHA_HASTA[i])
            OR  (Reg_Gastos_en_Costo.FECHA_HASTA[i] = StrToDateTime(Fecha_Nula) ))

           // Empresa
           and  (Reg_Gastos_en_Costo.Empresa[i] = sEmpresa)
           // Proceso
           and  (Reg_Gastos_en_Costo.Proceso[i] = sProceso)
           // Cartera
           and  ( (Reg_Gastos_en_Costo.Cartera[i] = sCartera)
                 or ((sCartera =  EmptyStr) and (Reg_Gastos_en_Costo.Cartera[i] = EmptyStr))     // Solo sin definicion de cartera
                )
                then
         begin
            bGasto_En_Costo := True;
            Break;
         end;
      end;

    if Not bGasto_En_Costo then
       Exit;

    sCODIGO_GASTOS := Reg_Gastos_en_Costo.CODIGO_GASTOS[i];
end;

Procedure Carga_Valores_de_Cambio_Tramo_Mem(dFecha_Inicial : TDatetime;
                                            dFecha_Final   : TDatetime;
                                            sMoneda_Indice : String );
Var i,j : LongInt;
begin
   with DmFuncionesMemory.Qry_ValTramo do
   begin
      SQL.Clear;
      SQL.Add('SELECT Count(*) As Num_Regs ');
      SQL.Add('  FROM QS_SYS_MONEDAS    b ');
      SQL.Add('      ,QS_SYS_PERIODO    c ');
      SQL.Add('      ,QS_SYS_VAL_TRAMO  a ');
      SQL.Add(' WHERE c.TIPO_UNIDAD     = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	        = b.UNIDAD_MEDIDA_MON ');
      //SQL.Add('   AND b.Cod_Moneda     <> ''IPC'' ');   // Los Cargo Aparte
      //SQL.Add('   AND b.Cod_Moneda     <> ''UF'' ');
      SQL.Add('   AND c.Tipo_Variacion  = ''D'' ');
      SQL.Add('   AND b.COD_MONEDA      = a.COD_MONEDA ');
      SQL.Add('   AND a.Fecha          >= :Fecha_Inicial ');
      SQL.Add('   AND a.Fecha          <= :Fecha_Final ');
      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND  b.Cod_Moneda    = '''+sMoneda_Indice+'''' );
      SQL.Add('   AND a.Origen          = :Origen ');

      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Parambyname('Origen').asString          := default_codgen('ORIGEN','FI','');
      Open;
      i := Round(FieldByName('Num_Regs').AsFloat);

      SQL.Clear;
      SQL.Add('SELECT a.COD_MONEDA');
      SQL.Add('      ,TIPO_PARIDAD');
      SQL.Add('      ,MONEDA_PARIDAD');
      SQL.Add('      ,FECHA');
      SQL.Add('      ,DIAS_DESDE');
      SQL.Add('      ,DIAS_HASTA');
      SQL.Add('      ,VALOR');
      SQL.Add('      ,ORIGEN');
      SQL.Add('  FROM QS_SYS_MONEDAS    b ');
      SQL.Add('      ,QS_SYS_PERIODO    c ');
      SQL.Add('      ,QS_SYS_VAL_TRAMO  a ');
      SQL.Add(' WHERE c.TIPO_UNIDAD     = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	        = b.UNIDAD_MEDIDA_MON ');
      //SQL.Add('   AND b.Cod_Moneda     <> ''IPC'' ');   // Los Cargo Aparte
      //SQL.Add('   AND b.Cod_Moneda     <> ''UF'' ');
