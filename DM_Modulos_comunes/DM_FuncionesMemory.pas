Procedure Ordenamiento_Registro_Prohi_Folios_Mem( var Reg_Proh_Folio : TReg_Proh_Folio;
                                              iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio,
    fItem_Omd   : Double;
    sTransaccion,
    sEmpresa,
    sCartera   : String;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Proh_Folio.fFolio[(Lo + Hi) div 2];

    repeat
      while Reg_Proh_Folio.fFolio[Lo] < Mid do
            Inc(Lo);
      while Reg_Proh_Folio.fFolio[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio          := Reg_Proh_Folio.fFolio[Lo];
         fItem_Omd       := Reg_Proh_Folio.fItem_Omd[Lo];
         sTransaccion    := Reg_Proh_Folio.Transaccion[Lo];
         sEmpresa        := Reg_Proh_Folio.Empresa[Lo];
         sCartera        := Reg_Proh_Folio.Cartera[Lo];         

         Reg_Proh_Folio.fFolio[Lo] :=
                       Reg_Proh_Folio.fFolio[Hi];
         Reg_Proh_Folio.fItem_Omd[Lo]      :=
                       Reg_Proh_Folio.fItem_Omd[Hi];
         Reg_Proh_Folio.Transaccion[Lo]   :=
                       Reg_Proh_Folio.Transaccion[Hi];
         Reg_Proh_Folio.Empresa[Lo]       :=
                       Reg_Proh_Folio.Empresa[Hi];
         Reg_Proh_Folio.Cartera[Lo]       :=
                       Reg_Proh_Folio.Cartera[Hi];

         Reg_Proh_Folio.fFolio[Hi]           := fFolio;
         Reg_Proh_Folio.fItem_Omd[Hi]        := fItem_Omd;
         Reg_Proh_Folio.Transaccion[Hi]      := sTransaccion;
         Reg_Proh_Folio.Empresa[Hi]          := sEmpresa;
         Reg_Proh_Folio.Cartera[Hi]          := sCartera;         
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Prohi_Folios_Mem(Reg_Proh_Folio, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Prohi_Folios_Mem(Reg_Proh_Folio, Lo, iHi);

end;

Function Busca_Prohibicion_Folios_Mem( const sEmpresa    : String;
                                       const sCartera     : String;
                                       const sTransaccion : String;
                                       const sFolio       : String;
                                       fItem_Omd          : Double) : Boolean;

var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Resultado        : Boolean;
begin
   Result := False;
   fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Proh_Folio.fFolio, 1 )-1;

   Resultado := False;
   i := 0;

   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Proh_Folio.fFolio[i] = fFolio_Buscado then
        begin
           Resultado := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Proh_Folio.fFolio[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;
   end;

   if Resultado then
   begin
      //Retrocedo hasta Primer Folio diferente
      For j := i Downto 0 do
        if Reg_Proh_Folio.fFolio[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Proh_Folio.fFolio, 1 )) and
            (Reg_Proh_Folio.fFolio[i] = fFolio_Buscado) do
      begin
         if (Reg_Proh_Folio.Transaccion[i]  = sTransaccion) and
            (Reg_Proh_Folio.fItem_Omd[i]    = fItem_Omd)    and
            (Reg_Proh_Folio.Cartera[i]      = sCartera)     and            
            (Reg_Proh_Folio.Empresa[i]      = sEmpresa )    then
             Result := True;

         Inc(i);
      end;
   end;
end;

