Procedure Carga_IpcBR_Mem( dFecha_Calculo : TDatetime );
var i : LongInt;
    dFecha_Aux : TDatetime;
    aa,
    mm,
    dd         : Word;
begin

     DecodeDate( dFecha_Calculo, aa, mm,dd );

     mm := mm +1;
     if mm > 12 then
     begin
        mm := 1;
        aa := aa +1;
     end;
     dd := ultimo_dia_mes( mm, aa );

     dFecha_Aux := encodedate(aa,mm,dd );  // E.S. 05-11-2014 Es para agregarle un mes al IPC, pues cuando existe una operacion PM cuya fecha de pago
                                           // pasa para el mes siguiente, no encuentra el IPC del mes anterior porque este es cargado con fecha tope la fecha de calculo
     WITH DMFuncionesMemory.QRY_General do
     begin
       Close;
       Sql.Clear;
       SQL.Add('SELECT Fecha_Paridad'
             +'      ,Valor_Moneda'
             +'  FROM QS_SYS_VAL_CAMBIO'
             +' WHERE Fecha_Paridad  <= :Fecha'
             +'   AND Cod_Moneda      = ''IPC'''
             +'   AND TIPO_DE_PARIDAD = ''BC'''
             +' ORDER BY Fecha_Paridad'
             );
//       Parambyname('Fecha').asDatetime := dFecha_Calculo;  // E.S. 05-11-2014
       Parambyname('Fecha').asDate := dFecha_Aux;
       Open;

//        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;

       Reg_Ipc.Fecha_Paridad := VarArrayCreate([0, i], varDate);
       Reg_Ipc.Valor_Moneda  := VarArrayCreate([0, i], varDouble);

       i := 0;
       while not eof do
       begin
          Reg_Ipc.Fecha_Paridad[i] := Fieldbyname('Fecha_Paridad').asDatetime;
          Reg_Ipc.Valor_Moneda[i]  := Fieldbyname('Valor_Moneda').asFloat;
          Inc(i);
          Next;
       end;
       Close;
    end;
end;

Procedure Busca_Ipc_Mem(   dFecha : TDatetime;
                      var fValor : Double;
                      var Result : Boolean
                      );
var i
   ,iLimite_Inferior
   ,iLimite_Superior : Integer;
begin
  Result := False;
  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Ipc.Fecha_Paridad, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if Reg_Ipc.Fecha_Paridad[i] = dFecha then
     begin
        fValor := Reg_Ipc.Valor_Moneda[i];
        Result := True;
        Break;
     end;

     if dFecha > Reg_Ipc.Fecha_Paridad[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i - 1;
  end;

end;

Procedure Carga_Tasa_Morosidad_CreditosF251(dFecha_Proceso : TDateTime);
var i : Integer;
begin
    WITH DmFuncionesMemory.Qry_General do
    begin
        sql.Clear;
        sql.add('SELECT count(*) as Nro_Reg ');
        sql.add('  FROM QS_SUP_MATRIZ_MOROSIDAD_CRED ');
        sql.add(' WHERE fecha   = (SELECT max(fecha) ');
        sql.add('                    FROM QS_SUP_MATRIZ_MOROSIDAD_CRED ');
        sql.add('                   WHERE fecha   <= :fecha_proceso) ');
        ParamByname('fecha_proceso').asDate := dFecha_Proceso;
        Open;
        i := 0;
        if not eof then i := Fieldbyname('Nro_Reg').asInteger;
        Close;
        Reg_TasaMorosidadCreditosF251.Instrumento := VarArrayCreate([0, i], varOleStr);
        Reg_TasaMorosidadCreditosF251.Fecha       := VarArrayCreate([0, i], varDate);
        Reg_TasaMorosidadCreditosF251.Dias_Desde  := VarArrayCreate([0, i], varDouble);
        Reg_TasaMorosidadCreditosF251.Dias_Hasta  := VarArrayCreate([0, i], varDouble);
        Reg_TasaMorosidadCreditosF251.Tasa        := VarArrayCreate([0, i], varDouble);

        sql.Clear;
        sql.add('SELECT * ');
        sql.add('  FROM QS_SUP_MATRIZ_MOROSIDAD_CRED ');
        sql.add(' WHERE fecha   = (SELECT max(fecha) ');
        sql.add('                    FROM QS_SUP_MATRIZ_MOROSIDAD_CRED ');
        sql.add('                   WHERE fecha   <= :fecha_proceso) ');
        ParamByname('fecha_proceso').asDate := dFecha_Proceso;
        open;
        For i := 0 to VarArrayHighBound( Reg_TasaMorosidadCreditosF251.Instrumento, 1 ) do
        begin
          if Fieldbyname('Porc_Castigo').asFloat <> 0 Then
          begin
             Reg_TasaMorosidadCreditosF251.Instrumento[i] := Fieldbyname('Instrumento').AsString;
             Reg_TasaMorosidadCreditosF251.Fecha[i]       := Fieldbyname('Fecha').AsDateTime;
             Reg_TasaMorosidadCreditosF251.Dias_Desde[i]  := Fieldbyname('Dias_Desde').asFloat;
             Reg_TasaMorosidadCreditosF251.Dias_Hasta[i]  := Fieldbyname('Dias_Hasta').asFloat;
             Reg_TasaMorosidadCreditosF251.Tasa[i]        := Fieldbyname('Porc_Castigo').asFloat;
          end;
          Next;
        end;
        Close;
    end;
end;

Procedure Busca_Tasa_Morosidad_CreditosF251(dFecha_Proceso      : TDateTime;
                                            sInstrumento        : String;
                                            fDias_Morosidad     : Double;
                                            Var Dias_Desde      : Double;
                                            Var Dias_Hasta      : Double;
                                            Var Tasa            : Double;
                                            Var Result          : Boolean );
var i : Integer;
begin
    Result := False;

    if NOT VarIsArray(Reg_TasaMorosidadCreditosF251.Instrumento) then
       Carga_Tasa_Morosidad_CreditosF251(dFecha_Proceso);

    Tasa   := 0;
    For i := 0 to VarArrayHighBound( Reg_TasaMorosidadCreditosF251.Instrumento, 1 ) do
    begin
       if (sInstrumento   = Reg_TasaMorosidadCreditosF251.Instrumento[i]) Then
          if ( fDias_Morosidad >= Reg_TasaMorosidadCreditosF251.Dias_Desde[i])    and
             ( (fDias_Morosidad <= Reg_TasaMorosidadCreditosF251.Dias_Hasta[i]) or
               (Reg_TasaMorosidadCreditosF251.Dias_Hasta[i] = 0)                  ) Then
          begin
             Dias_Desde  := Reg_TasaMorosidadCreditosF251.Dias_Desde[i];
             Dias_Hasta  := Reg_TasaMorosidadCreditosF251.Dias_Hasta[i];
             Tasa        := Reg_TasaMorosidadCreditosF251.Tasa[i];
             Result      := True;
             break;
          end;
    end;
end;

procedure Carga_Nominales_Vendidos_Mem(  sEmpresa : String;
                                         dFecha   : TDatetime
                                         );
Var i : LongInt;
begin
  WITH DmFuncionesMemory.Qry_General do
  begin
    Close;
    SQL.Clear;
    SQL.Add('SELECT Count(*) as Registros'
           +' FROM QS_TRA_OMD_DET_RF a, '
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           =  :Empresa'
           +'   AND d.Folio_Interno     = a.Folio_Interno '
           +'   AND d.Transaccion       = a.Transaccion '
           +'   AND d.empresa           = a.empresa '
           +'   AND a.Tipo_Instrum      <> ''R'''
           +'   AND d.Fecha_Operacion   <= :Fecha'
           );
    SQL.Add('   AND a.Transaccion not in (SELECT b.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic b '
           +'                             WHERE b.Codigo_transaccion = a.transaccion'
           //+'                               AND b.implicancia = '''+'PACTO'+''')');  //ggarcia 22-05-2015
           +'                               AND b.implicancia IN (''PACTO'',''MARGEN''))');
    SQL.Add('   AND a.Transaccion     in (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'VENTA'+''')');
    SQL.Add('   AND a.Transaccion NOT in (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'DERIVADO'+''')');
    SQL.Add('   AND a.Folio_Interno not in (SELECT f.Folio '
           +'                               FROM qs_ctr_anulacion f'
           +'                             WHERE f.empresa     = a.empresa'
           +'                               AND f.transaccion = a.Transaccion'
           +'                               AND f.Folio       = a.Folio_interno)');
    ParamByName('Empresa').AsString     := sEmpresa;
    ParamByName('Fecha').AsDate     := dFecha;
    Open;

    i := 0;
    if Not Fieldbyname('Registros').IsNull then
       i := Fieldbyname('Registros').asInteger - 1;

    Close;
    SQL.Clear;
    SQL.Add('SELECT a.valor_nominal'
           +' ,a.Folio_Interno_Rel'
           +' ,a.Transaccion_Rel'
           +' ,a.Item_Omd_Rel'
           +' ,d.Fecha_Operacion'
           +' ,d.Fecha_De_Pago '
           +' FROM QS_TRA_OMD_DET_RF a, '
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           =  :Empresa'
           +'   AND d.Folio_Interno     = a.Folio_Interno '
           +'   AND d.Transaccion       = a.Transaccion '
           +'   AND d.empresa           = a.empresa '
           +'   AND a.Tipo_Instrum      <> ''R'''
           +'   AND d.Fecha_Operacion   <= :Fecha'
             );
    SQL.Add('   AND a.Transaccion not in (SELECT b.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic b '
           +'                             WHERE b.Codigo_transaccion = a.transaccion'
           //+'                               AND b.implicancia = '''+'PACTO'+''')');  //ggarcia 22-05-2015
           +'                               AND b.implicancia IN (''PACTO'',''MARGEN''))');
    SQL.Add('   AND a.Transaccion     in (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'VENTA'+''')');
    SQL.Add('   AND a.Transaccion NOT in (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'DERIVADO'+''')');
    SQL.Add('   AND a.Folio_Interno not in (SELECT f.Folio '
           +'                               FROM qs_ctr_anulacion f'
           +'                             WHERE f.empresa     = a.empresa'
           +'                               AND f.transaccion = a.Transaccion'
           +'                               AND f.Folio       = a.Folio_interno)');
     ParamByName('Empresa').AsString     := sEmpresa;
     ParamByName('Fecha').AsDate     := dFecha;
     Open;

     Reg_Nominales_Vendidos.Folio_Interno_Rel := VarArrayCreate([0, i], varDouble);
     Reg_Nominales_Vendidos.Item_Omd_Rel      := VarArrayCreate([0, i], varDouble);
     Reg_Nominales_Vendidos.Transaccion_Rel   := VarArrayCreate([0, i], varOleStr);
     Reg_Nominales_Vendidos.Valor_Nominal     := VarArrayCreate([0, i], varDouble);
     Reg_Nominales_Vendidos.Fecha_Operacion   := VarArrayCreate([0, i], varDate);
     Reg_Nominales_Vendidos.Fecha_De_Pago     := VarArrayCreate([0, i], varDate);

     i := 0;
     While Not Eof do
     begin
         Reg_Nominales_Vendidos.Folio_Interno_Rel[i] := Fieldbyname('Folio_Interno_Rel').asFloat;
         Reg_Nominales_Vendidos.Item_Omd_Rel[i]      := Fieldbyname('Item_Omd_Rel').asFloat;
         Reg_Nominales_Vendidos.Transaccion_Rel[i]   := Fieldbyname('Transaccion_Rel').asString;
         Reg_Nominales_Vendidos.Valor_Nominal[i]     := Fieldbyname('Valor_Nominal').asFloat;
         Reg_Nominales_Vendidos.Fecha_Operacion[i]   := Fieldbyname('Fecha_Operacion').asDatetime;
         Reg_Nominales_Vendidos.Fecha_De_Pago[i]     := Fieldbyname('Fecha_De_Pago').asDatetime;
         Inc(i);
         Next;
     end;
     Close;
  end;

  //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
  if i <> 0 then
     Ordenamiento_Registro_Nominales_Vendidos_Mem(Reg_Nominales_Vendidos
                                                 ,0
                                                 //,VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel, 1 )-1
                                                 ,VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel, 1 ) // ES 19-05-2022
                                                 );
end;

Procedure Ordenamiento_Registro_Nominales_Vendidos_Mem( var Reg_Nominales_Vendidos : TReg_Nominales_Vendidos;
                                                    iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno_Rel,
    fItem_Omd_Rel,
    fValor_Nominal   : Double;
    cTransaccion_Rel : String;
    dFecha_Operacion : TDatetime;
    dFecha_Pago      : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Nominales_Vendidos.Folio_Interno_Rel[(Lo + Hi) div 2];

    repeat
      while Reg_Nominales_Vendidos.Folio_Interno_Rel[Lo] < Mid do
            Inc(Lo);
      while Reg_Nominales_Vendidos.Folio_Interno_Rel[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio_Interno_Rel := Reg_Nominales_Vendidos.Folio_Interno_Rel[Lo];
         fItem_Omd_Rel      := Reg_Nominales_Vendidos.Item_Omd_Rel[Lo];
         cTransaccion_Rel   := Reg_Nominales_Vendidos.Transaccion_Rel[Lo];
         fValor_Nominal     := Reg_Nominales_Vendidos.Valor_Nominal[Lo];
         dFecha_Operacion   := Reg_Nominales_Vendidos.Fecha_Operacion[Lo];
         dFecha_Pago        := Reg_Nominales_Vendidos.Fecha_de_Pago[Lo];

         Reg_Nominales_Vendidos.Folio_Interno_Rel[Lo] :=
                       Reg_Nominales_Vendidos.Folio_Interno_Rel[Hi];
         Reg_Nominales_Vendidos.Item_Omd_Rel[Lo]      :=
                       Reg_Nominales_Vendidos.Item_Omd_Rel[Hi];
         Reg_Nominales_Vendidos.Transaccion_Rel[Lo]   :=
                       Reg_Nominales_Vendidos.Transaccion_Rel[Hi];
         Reg_Nominales_Vendidos.Valor_Nominal[Lo]     :=
                       Reg_Nominales_Vendidos.Valor_Nominal[Hi];
         Reg_Nominales_Vendidos.Fecha_Operacion[Lo]   :=
                       Reg_Nominales_Vendidos.Fecha_Operacion[Hi];
         Reg_Nominales_Vendidos.Fecha_de_Pago[Lo]   :=
                       Reg_Nominales_Vendidos.Fecha_de_Pago[Hi];


         Reg_Nominales_Vendidos.Folio_Interno_Rel[Hi] := fFolio_Interno_Rel;
         Reg_Nominales_Vendidos.Item_Omd_Rel[Hi]      := fItem_Omd_Rel;
         Reg_Nominales_Vendidos.Transaccion_Rel[Hi]   := cTransaccion_Rel;
         Reg_Nominales_Vendidos.Valor_Nominal[Hi]     := fValor_Nominal;
         Reg_Nominales_Vendidos.Fecha_Operacion[Hi]   := dFecha_Operacion;
         Reg_Nominales_Vendidos.Fecha_de_Pago[Hi]     := dFecha_Pago;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Nominales_Vendidos_Mem(Reg_Nominales_Vendidos, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Nominales_Vendidos_Mem(Reg_Nominales_Vendidos, Lo, iHi);
end;

procedure Determina_Nominales_Vendidos_Mem(dFecha_Calculo,
                                           dFecha_Servidor,
                                           dFecha_Dia          :TDateTime;
                                           const sEmpresa        :String;
                                           const sTransaccion    :String;
                                           const sFolio          :String;
                                           dItem_omd       :Double;
                                       var Nominales_Ventas: Double;
                                       var Nominales_Ventas_Reales: Double;
                                       var Nominales_Ventas_Dia: Double);
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Result           : Boolean;
begin

  if NOT VarIsArray(Reg_Nominales_Vendidos.Transaccion_Rel) then
     Carga_Nominales_Vendidos_Mem(sEmpresa
                                 ,dFecha_Calculo
                                  );

   Nominales_Ventas := 0;
   Nominales_Ventas_Reales := 0;
   Nominales_Ventas_Dia    := 0;
   i := 0;

   if sFolio = '' then
      fFolio_Buscado   := 0
   else
      fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   //iLimite_Superior := VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel, 1 )-1;
   iLimite_Superior := VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel, 1 );

   Result := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
      i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

      if Reg_Nominales_Vendidos.Folio_Interno_Rel[i] = fFolio_Buscado then
      begin
         Result := True;
         Break;
      end;

      if  fFolio_Buscado > Reg_Nominales_Vendidos.Folio_Interno_Rel[i] then
         iLimite_Inferior := i + 1
      else
         iLimite_Superior := i - 1;
   end;

   if Result then
   begin
      //Retrocedo hasta Primer Folio diferente
      For j := i Downto 0 do
        if Reg_Nominales_Vendidos.Folio_Interno_Rel[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel , 1 )) and
            (Reg_Nominales_Vendidos.Folio_Interno_Rel[i] = fFolio_Buscado) do
      begin
         if (Reg_Nominales_Vendidos.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Vendidos.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Vendidos.Fecha_Operacion[i]   <= dFecha_Calculo)  then
             Nominales_Ventas := Nominales_Ventas + Reg_Nominales_Vendidos.Valor_Nominal[i];

         if (Reg_Nominales_Vendidos.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Vendidos.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Vendidos.Fecha_Operacion[i]   <= dFecha_Servidor)  then
             Nominales_Ventas_Reales := Nominales_Ventas_Reales + Reg_Nominales_Vendidos.Valor_Nominal[i];

         if (Reg_Nominales_Vendidos.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Vendidos.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Vendidos.Fecha_De_Pago[i]      >= dFecha_Dia)  and        // Se agrega lo de fecha de pago para que aparescan los cupones en la qs_tes_egring mientras no se alla pagado la OMD de venta F.I. 30-11-2011
            (Reg_Nominales_Vendidos.Fecha_Operacion[i]    <= dFecha_Dia)  then
             Nominales_Ventas_Dia := Nominales_Ventas_Dia + Reg_Nominales_Vendidos.Valor_Nominal[i];

         Inc(i);
      end;
   end;
   Nominales_Ventas := Abs(Nominales_Ventas);
   Nominales_Ventas_Reales := Abs(Nominales_Ventas_Reales);
   Nominales_Ventas_Dia    := Abs(Nominales_Ventas_Dia);
end;

