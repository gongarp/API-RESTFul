procedure Busca_Clasif_EmisorInstrumentoMotivo( dFecha             : TDatetime;
                                                const sEmisor      : String;
                                                const sInstrumento : String;
                                                const sMotivo      : String;
                                                var sCodigo_Clasif    : String ;
                                                var fClasificacion    : Double;
                                                var fClasificacion_CP : Double;
                                                var sClasificacion    : String;
                                                var sClasificacion_CP : String;
                                                var Result            : Boolean
                                                );
var
   i          : Integer;
begin
  if NOT VarIsArray(Reg_Clasif_EmiInstMot.EMISOR) then
     Carga_Clasif_EmisorInstrumentoMotivo( dFecha );

  Result         := False;
  for i := 0 to VarArrayHighBound( Reg_Clasif_EmiInstMot.EMISOR, 1 )-1 do
  begin
    if (Reg_Clasif_EmiInstMot.EMISOR[i]      = sEmisor)       and
       (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = sInstrumento)  and
       (Reg_Clasif_EmiInstMot.MOTIVO[i]      = sMotivo)       then
      Result:= True
    else
      if (Reg_Clasif_EmiInstMot.EMISOR[i]      = sEmisor)       and
         (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = sInstrumento)  and
         (Reg_Clasif_EmiInstMot.MOTIVO[i]      = EmptyStr)       then
        Result:= True
      else
        if (Reg_Clasif_EmiInstMot.EMISOR[i]      = sEmisor)       and
           (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = EmptyStr)  and
           (Reg_Clasif_EmiInstMot.MOTIVO[i]      = sMotivo)       then
          Result:= True
        else
          if (Reg_Clasif_EmiInstMot.EMISOR[i]      = sEmisor)   and
             (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = EmptyStr)  and
             (Reg_Clasif_EmiInstMot.MOTIVO[i]      = EmptyStr)  then
            Result:= True
          else
            if (Reg_Clasif_EmiInstMot.EMISOR[i]      = EmptyStr)       and
               (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = sInstrumento)  and
               (Reg_Clasif_EmiInstMot.MOTIVO[i]      = sMotivo)       then
              Result:= True
            else
              if (Reg_Clasif_EmiInstMot.EMISOR[i]      = EmptyStr)       and
                 (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = sInstrumento)  and
                 (Reg_Clasif_EmiInstMot.MOTIVO[i]      = EmptyStr)       then
                Result:= True
              else
                if (Reg_Clasif_EmiInstMot.EMISOR[i]      = EmptyStr)       and
                   (Reg_Clasif_EmiInstMot.INSTRUMENTO[i] = EmptyStr)       and
                   (Reg_Clasif_EmiInstMot.MOTIVO[i]      = sMotivo)       then
                  Result:= True;

    if Result then
    begin
      sCodigo_Clasif    := Reg_Clasif_EmiInstMot.CODIGO_CLASIF[i];
      fClasificacion    := Reg_Clasif_EmiInstMot.CLASIFICACION[i];
      fClasificacion_CP := Reg_Clasif_EmiInstMot.CLASIFICACION_CP[i];
      sClasificacion    := Reg_Clasif_EmiInstMot.DESC_CLASIFICACION[i];
      sClasificacion_CP := Reg_Clasif_EmiInstMot.DESC_CLASIFICACION_CP[i];
      Break;
    end;
  end;

end;

