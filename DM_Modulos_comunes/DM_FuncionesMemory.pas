   Result := False;

   if NOT VarIsArray(Reg_Param_Proceso.Proceso) then
      Carga_Param_Proceso_Mem(sProceso);

   for i := 0 to VarArrayHighBound(Reg_Param_Proceso.Proceso , 1 )  do
   begin
      if (Reg_Param_Proceso.Proceso[i]   = sProceso) and
         (Reg_Param_Proceso.parametro[i] = sParametro) and
         (Reg_Param_Proceso.Valor[i]     = sValor) then
      begin
          Result := True;
          Exit;
      end;
   end;
end;
