Function Busca_valor_cambio_tramo_interpola_Mem(const sCodigo        : String;
                                                const fPlazo         : Double;
                                                const dFecha_Proceso : TDatetime;
                                                var   fValor_Tasa    : Double) : Boolean;
var i
   ,j             : Integer;
   bExiste        : Boolean;
   fDias_Menor    : Double;
   fDias_Mayor    : Double;
   fTasa_Menor    : Double;
   fTasa_Mayor    : Double;
   bresult        : Boolean;
begin
  Result := False;
  bresult := true;
  fValor_Tasa := 0;
  bExiste := False;
  j:= 1;

  if NOT VarIsArray(Reg_ValCam_Tramo_Interpolacion.Codigo) then
     Carga_valor_cambio_tramo_interpola_Mem( dFecha_Proceso );

  for i := 0 to  VarArrayHighBound(Reg_ValCam_Tramo_Interpolacion.Codigo, 1 )-1 do
  begin
     if (Reg_ValCam_Tramo_Interpolacion.Codigo[i]  = sCodigo) and
        (Reg_ValCam_Tramo_Interpolacion.Desde[i]  <= fPlazo) then
     begin
        bExiste := True;
        j := i;
//        Break;
     end;
  end;

  if bExiste then
  begin
//     bExiste := False;
     i:=j;
     fDias_Menor := Reg_ValCam_Tramo_Interpolacion.Desde[i];
     fTasa_Menor := Reg_ValCam_Tramo_Interpolacion.Valor[i];

     if fDias_Menor = fPlazo then
     begin
       fValor_Tasa := fTasa_Menor;
       Result := True;
     end
     else  // lee segundo tramo para interpolar...
     begin
       fDias_Mayor := 0;
       fTasa_Mayor := 0;
       j := i;
       while (j <= VarArrayHighBound(Reg_ValCam_Tramo_Interpolacion.Codigo , 1 )) and
             (Reg_ValCam_Tramo_Interpolacion.Codigo[j] = sCodigo) do
       begin
         if (Reg_ValCam_Tramo_Interpolacion.Desde[j] > fPlazo)     then
           begin
             bresult := True;
             fDias_Mayor := Reg_ValCam_Tramo_Interpolacion.Desde[j];
             fTasa_Mayor := Reg_ValCam_Tramo_Interpolacion.Valor[j];
             Break;
          end;
          Inc(j);
       end;

       if bresult then
       begin
         if ( (fDias_Mayor - fDias_Menor) <> 0 ) then
         begin
            fValor_Tasa := fTasa_Menor + ( ( fPlazo - fDias_Menor) * ( fTasa_Mayor - fTasa_Menor ) / ( fDias_Mayor - fDias_Menor ) );
            Result := True;
         end
       end
     end;
  end;
end;

Procedure Carga_Deterioro_Adicional_Mem( dFecha_Proceso : TDatetime );
var i : LongInt;
begin

   with DmFuncionesMemory.Qry_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT Fecha_Desde '
             +'      ,Fecha_Hasta '
             +'      ,Nemotecnico '
             +'      ,Base '
             +'      ,Porcentaje '
             +'  FROM QS_FIN_NEM_DETERIORO_ADIC '
             +' WHERE Fecha_Desde  <= :Fecha '
             +'   AND (Fecha_Hasta >= :Fecha OR Fecha_Hasta Is Null) '
             +' ORDER BY Fecha_Desde, Nemotecnico '
             );
      ParamByName('Fecha').AsDate := dFecha_Proceso;
      Open;

      try
        Open;
        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
      except
        i := 0;
      end;

      Reg_Deterioro_Adicional.Fecha_Desde   := VarArrayCreate([0, i], varDate);
      Reg_Deterioro_Adicional.Fecha_Hasta   := VarArrayCreate([0, i], varDate);
      Reg_Deterioro_Adicional.Nemotecnico   := VarArrayCreate([0, i], varOleStr);
      Reg_Deterioro_Adicional.Base          := VarArrayCreate([0, i], varOleStr);
      Reg_Deterioro_Adicional.Porcentaje    := VarArrayCreate([0, i], varDouble);

      i := 0;
      while not eof do
      begin
         Reg_Deterioro_Adicional.Fecha_Desde[i] := Fieldbyname('Fecha_Desde').AsDateTime;
         Reg_Deterioro_Adicional.Fecha_Hasta[i] := Fieldbyname('Fecha_Hasta').AsDateTime;
         Reg_Deterioro_Adicional.Nemotecnico[i] := Fieldbyname('Nemotecnico').asString;
         Reg_Deterioro_Adicional.Base[i]        := Fieldbyname('Base').asString;
         Reg_Deterioro_Adicional.Porcentaje[i]  := Fieldbyname('Porcentaje').asFloat;
         Next;
         Inc(i);
      end;
      Close;
   end;

end;

procedure Buscar_Deterioro_Adicional_Mem(const dFecha         : TDatetime;
                                         const sNemotecnico   : String;
                                           var sBase          : String;
                                           var fPorcentaje    : Double;
                                           var bResult        : Boolean);
var i : Integer;
begin
   bResult := False;
   sBase := '';
   fPorcentaje := 0;

   if NOT VarIsArray(Reg_Deterioro_Adicional.Nemotecnico) then
      Carga_Deterioro_Adicional_Mem( dFecha );

   for i := 0 to VarArrayHighBound(Reg_Deterioro_Adicional.Nemotecnico, 1 )  do
   begin
      if (Reg_Deterioro_Adicional.Nemotecnico[i]   = sNemotecnico)     and
         (Reg_Deterioro_Adicional.Fecha_Desde[i]  <= dFecha)           and
         ((Reg_Deterioro_Adicional.Fecha_Hasta[i]  = Fecha_Nula) or
          (Reg_Deterioro_Adicional.Fecha_Hasta[i] >= dFecha)) then
      begin
         sBase        := Reg_Deterioro_Adicional.Base[i];
         fPorcentaje  := Reg_Deterioro_Adicional.Porcentaje[i];
         bResult := True;
         Break;
      end;
   end;
 end;

Procedure Carga_Loss_Given_Default(dFecha_Proceso : TDateTime);
var i : Integer;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT a.*'
             +'  FROM QS_FIN_LOSS_GIVEN_DEFAULT a '
             +' WHERE a.Fecha_Vigencia = (SELECT max(a.Fecha_Vigencia) '
             +'                             FROM QS_FIN_LOSS_GIVEN_DEFAULT a '
             +'                            WHERE a.Fecha_Vigencia <= :Fecha ) ');
      ParamByName('Fecha').AsDateTime       := dFecha_Proceso;
      Open;

      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;

      Reg_Loss_Given_Default.Clasif_Riesgo := VarArrayCreate([0, i], varOleStr);
      Reg_Loss_Given_Default.Nodo          := VarArrayCreate([0, i], varDouble);
      Reg_Loss_Given_Default.LGD           := VarArrayCreate([0, i], varDouble);
      i := 0;
      while not eof do
      begin
        Reg_Loss_Given_Default.Clasif_Riesgo[i] := trim(FieldByName('Clasif_Nemotec').AsString);
        Reg_Loss_Given_Default.Nodo[i]          := FieldByName('Nodo').AsFloat;
        Reg_Loss_Given_Default.LGD[i]           := FieldByName('LGD').AsFloat;
        Inc(i);
        Next;
      end;
      close;
   end;
end;

Procedure Busca_Loss_Given_Default(dFecha_Proceso : TDateTime;
                                   sClasif_Riesgo : string;
                                   fNodo          : Double;
                               var fLGD           : Double;
                               var bResult        : Boolean);
var i : Integer;
begin
   bResult := False;

   if NOT VarIsArray(Reg_Loss_Given_Default.Clasif_Riesgo) then
      Carga_Loss_Given_Default(dFecha_Proceso);

   for i := 0 to VarArrayHighBound(Reg_Loss_Given_Default.Clasif_Riesgo, 1)  do
   begin
      if (Reg_Loss_Given_Default.Clasif_Riesgo[i] = sClasif_Riesgo) and
         (Reg_Loss_Given_Default.Nodo[i]          = fNodo) then
      begin
        bResult := True;
        fLGD    := Reg_Loss_Given_Default.LGD[i];
        Exit;
      end;
   end;
end;

end.


