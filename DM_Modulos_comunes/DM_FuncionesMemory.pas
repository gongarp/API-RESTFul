function default_codgen_Mem(Const sCod_General : String;
                            Const sSistema     : String;
                                  sTransaccion : String) : String;
Var
  Flag_Leer,
  bExiste   : Boolean;
  i         : Integer;
begin

 if Not VarIsArray(Reg_default_codgen.COD_GENERAL) then
    Carga_Valores_Default_Cod_General_Mem;
    
 Flag_Leer := True;
 bExiste   := False;
 WHILE Flag_Leer do
 begin
    if (sTransaccion = ' ') or
       (sTransaccion = '')  then
        sTransaccion := ' ';

    For i := 0 to VarArrayHighBound( Reg_default_codgen.COD_GENERAL, 1 ) do
    begin
       if (Reg_default_codgen.COD_GENERAL[i] = sCod_General) and
          (Reg_default_codgen.Sistema[i]     = sSistema)     and
          (trim(Reg_default_codgen.Transaccion[i]) = trim(sTransaccion)) then
       begin
          bExiste := True;
          Break;
       end;
    end;

    if Not bExiste then
       Result := ' '
    else
    begin
       Result    := Reg_default_codgen.Cod_Detail[i];
       Flag_Leer := False;
    end;

    if sTransaccion = ' ' then
       Flag_Leer := False
    else
       sTransaccion := ' ';

 end;//While
end;

