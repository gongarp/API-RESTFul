Procedure Carga_Carteras_Mem;
Var i : LongInt;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT * FROM QS_FIN_CARTERAS'
             +' ORDER BY Cod_Cartera'
             );
      Open;
      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Carteras.COD_EMPRESA    := VarArrayCreate([0, i], varOleStr);
      Reg_Carteras.Cod_Cartera    := VarArrayCreate([0, i], varOleStr);
      Reg_Carteras.DESCRIPCION    := VarArrayCreate([0, i], varOleStr);
      Reg_Carteras.TIPO_CARTERA   := VarArrayCreate([0, i], varOleStr);
      Reg_Carteras.GRUPO_CONSOL   := VarArrayCreate([0, i], varDouble);
      Reg_Carteras.COD_ENT_CLI    := VarArrayCreate([0, i], varOleStr);
      Reg_Carteras.Moneda_Cartera := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
        Reg_Carteras.COD_Empresa[i]    := Fieldbyname('COD_Empresa').asString;
        Reg_Carteras.Cod_Cartera[i]    := Fieldbyname('COD_CARTERA').asString;
        Reg_Carteras.DESCRIPCION[i]    := Fieldbyname('DESCRIPCION').asString;
        Reg_Carteras.TIPO_CARTERA[i]   := Fieldbyname('TIPO_CARTERA').asString;
        Reg_Carteras.GRUPO_CONSOL[i]   := Fieldbyname('GRUPO_CONSOL').asFloat;
        Reg_Carteras.COD_ENT_CLI[i]    := Fieldbyname('COD_ENT_CLI').asString;
        Reg_Carteras.Moneda_Cartera[i] := Fieldbyname('MONEDA_CARTERA').asString;
        Next;
        Inc(i);
      end;
      close;
  end;
end;

procedure Leer_Cartera_Mem(const sEmpresa   : String;
                           const sCartera   : String;
                           var sDescripcion : String;
                           var sIdentidadCli: String;
                           var sMoneda_Cartera : String;
                           var Result       : Boolean);
var i,
    iLimite_Superior : Integer;
begin
   Result := False;
   sDescripcion := '';

   if NOT VarIsArray(Reg_Carteras.Cod_Cartera) then
      Carga_Carteras_Mem;

