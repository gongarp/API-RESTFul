Procedure Carga_LastValores_de_Cambio_Tramo_Mem(dFecha_Inicial : TDatetime;
                                                dFecha_Final   : TDatetime;
                                                sMoneda_Indice : String;
                                                sTipo_Proceso  : String );
Var i,j : LongInt;
//   dFecha_Ini,
   dFecha_Fin,
   dFecha         : TDatetime;
   fCantidad      : Double;
   sUnidad,
   sPais_Tasa,
   sAntes_Despues : String;
   Result         : Boolean;
begin
   if VarIsArray(Reg_LastMonedas_Tramo.COD_MONEDA) then
      exit;

   dFecha := dFecha_Final;
   with DmFuncionesMemory.Qry_ValTramo do
   begin
      sPais_Tasa     := sPais_Usuario;
      Busca_Proy_Precio_Mem(sTipo_Proceso,
                            fCantidad,
                            sUnidad,
                            sAntes_Despues,
                            Result);
      if Not Result then
      begin
         if NOT VarIsArray(Reg_Monedas_Tramo.COD_MONEDA) then
             Carga_Valores_de_Cambio_Tramo_Mem(dFecha_Inicial - 3 // Desface porque si proyecta y es fin de semana
                                              ,dFecha_Final + 5
                                              ,''
                                              ,False);

         Reg_LastMonedas_Tramo.COD_MONEDA         := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.COD_MONEDA, 1 )-1], varOleStr);
         Reg_LastMonedas_Tramo.ORIGEN             := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.ORIGEN, 1 )-1], varOleStr);
         Reg_LastMonedas_Tramo.TIPO_DE_PARIDAD    := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.TIPO_DE_PARIDAD, 1 )-1], varOleStr);
         Reg_LastMonedas_Tramo.MONEDA_PARIDAD     := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.MONEDA_PARIDAD, 1 )-1], varOleStr);
         Reg_LastMonedas_Tramo.FECHA_PARIDAD      := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.FECHA_PARIDAD, 1 )-1], varDate);
         Reg_LastMonedas_Tramo.DIAS_DESDE         := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.DIAS_DESDE, 1 )-1], varDouble);
         Reg_LastMonedas_Tramo.DIAS_HASTA         := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.DIAS_HASTA, 1 )-1], varDouble);
         Reg_LastMonedas_Tramo.VALOR_MONEDA       := VarArrayCreate([0, VarArrayHighBound( Reg_Monedas_Tramo.VALOR_MONEDA, 1 )-1], varDouble);

         Reg_LastMonedas_Tramo.COD_MONEDA         := Reg_Monedas_Tramo.COD_MONEDA;
         Reg_LastMonedas_Tramo.ORIGEN             := Reg_Monedas_Tramo.ORIGEN;
         Reg_LastMonedas_Tramo.TIPO_DE_PARIDAD    := Reg_Monedas_Tramo.TIPO_DE_PARIDAD;
         Reg_LastMonedas_Tramo.MONEDA_PARIDAD     := Reg_Monedas_Tramo.MONEDA_PARIDAD;
         Reg_LastMonedas_Tramo.FECHA_PARIDAD      := Reg_Monedas_Tramo.FECHA_PARIDAD;
         Reg_LastMonedas_Tramo.DIAS_DESDE         := Reg_Monedas_Tramo.DIAS_DESDE;
         Reg_LastMonedas_Tramo.DIAS_HASTA         := Reg_Monedas_Tramo.DIAS_HASTA;
         Reg_LastMonedas_Tramo.VALOR_MONEDA       := Reg_Monedas_Tramo.VALOR_MONEDA;

         Exit;
      end;

      if sAntes_Despues = 'A' then
      begin
         dFecha_Fin := dFecha;
//         dFecha_Ini := Resta_dias_corridos(sPais_Tasa,                 // Resta_dias_habiles(sPais_Tasa,
//                                          dFecha,
//                                          fCantidad
//                                          );
      end
      else
      begin
//         dFecha_Ini := dFecha;
         dFecha_Fin := Suma_dias_corridos(sPais_Tasa,                   // Suma_dias_habiles(sPais_Tasa,
                                          dFecha,
                                          fCantidad
                                          );
      end;

      SQL.Clear;
      SQL.Add('SELECT a.COD_MONEDA');
      SQL.Add('      ,a.TIPO_PARIDAD');
      SQL.Add('      ,a.MONEDA_PARIDAD');
      SQL.Add('      ,a.FECHA');
      SQL.Add('      ,a.DIAS_DESDE');
      SQL.Add('      ,a.DIAS_HASTA');
      SQL.Add('      ,a.VALOR');
      SQL.Add('      ,a.ORIGEN');
      SQL.Add('  FROM QS_SYS_MONEDAS    b ');
      SQL.Add('      ,QS_SYS_PERIODO    c ');
      SQL.Add('      ,QS_SYS_VAL_TRAMO  a ');
      SQL.Add(' WHERE c.TIPO_UNIDAD     = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	        = b.UNIDAD_MEDIDA_MON ');
      SQL.Add('   AND c.Tipo_Variacion  = ''D'' ');
      SQL.Add('   AND b.COD_MONEDA      = a.COD_MONEDA ');
      SQL.Add('   AND a.fecha = (SELECT max(x.fecha)  ');
			SQL.Add('	                	 FROM QS_SYS_MONEDAS    d ');
			SQL.Add('		                     ,QS_SYS_PERIODO    e  ');
			SQL.Add('		                     ,QS_SYS_VAL_TRAMO  x  ');
		  SQL.Add('		                WHERE x.Cod_Moneda      = a.Cod_Moneda ');
 		  SQL.Add('		                	AND x.MONEDA_PARIDAD  = a.MONEDA_PARIDAD ');
			SQL.Add('	                    and e.TIPO_UNIDAD     = d.TIPO_UNI_VARIACION ');
			SQL.Add('	                    AND e.UNIDAD	        = d.UNIDAD_MEDIDA_MON  ');
			SQL.Add('	                    AND e.Tipo_Variacion  = ''D''   ');
			SQL.Add('	                    AND d.COD_MONEDA      = x.COD_MONEDA ');
			SQL.Add('	                    AND x.Fecha          <= :Fecha_Final) ');
      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND  b.Cod_Moneda    = '''+sMoneda_Indice+'''' );
      Sql.Add(' ORDER BY a.cod_moneda,a.Fecha ');
      Parambyname('Fecha_Final').asDate   := dFecha_Fin;

      Open;
      Last;
      i := RecordCount;
      First;

      Reg_LastMonedas_Tramo.COD_MONEDA      := VarArrayCreate([0, i], varOleStr);
      Reg_LastMonedas_Tramo.ORIGEN          := VarArrayCreate([0, i], varOleStr);
      Reg_LastMonedas_Tramo.TIPO_DE_PARIDAD := VarArrayCreate([0, i], varOleStr);
      Reg_LastMonedas_Tramo.MONEDA_PARIDAD  := VarArrayCreate([0, i], varOleStr);
      Reg_LastMonedas_Tramo.FECHA_PARIDAD   := VarArrayCreate([0, i], varDate);
      Reg_LastMonedas_Tramo.DIAS_DESDE      := VarArrayCreate([0, i], varDouble);
      Reg_LastMonedas_Tramo.DIAS_HASTA      := VarArrayCreate([0, i], varDouble);
      Reg_LastMonedas_Tramo.VALOR_MONEDA    := VarArrayCreate([0, i], varDouble);

      For j := 0 to i do
      begin
         Reg_LastMonedas_Tramo.COD_MONEDA[j]      := Fieldbyname('COD_MONEDA').asString;
         Reg_LastMonedas_Tramo.ORIGEN[j]          := Fieldbyname('ORIGEN').asString;
         Reg_LastMonedas_Tramo.TIPO_DE_PARIDAD[j] := Fieldbyname('TIPO_PARIDAD').asString;
         Reg_LastMonedas_Tramo.MONEDA_PARIDAD[j]  := Fieldbyname('MONEDA_PARIDAD').asString;
         Reg_LastMonedas_Tramo.FECHA_PARIDAD[j]   := Fieldbyname('FECHA').asDatetime;
         Reg_LastMonedas_Tramo.DIAS_DESDE[j]      := Fieldbyname('DIAS_DESDE').asFloat;
         Reg_LastMonedas_Tramo.DIAS_HASTA[j]      := Fieldbyname('DIAS_HASTA').asFloat;
         Reg_LastMonedas_Tramo.VALOR_MONEDA[j]    := Fieldbyname('VALOR').asFloat;
         Next;
         if Eof then
            Break;
      end;
      Close;
   end;
end;

Procedure Carga_Valores_de_Cambio_Tramo_Mem(dFecha_Inicial : TDatetime;
                                            dFecha_Final   : TDatetime;
                                            sMoneda_Indice : String;
                                            bOrigen        : Boolean);
Var i,j : LongInt;
begin
   with DmFuncionesMemory.Qry_ValTramo do
   begin
      SQL.Clear;
      SQL.Add('SELECT Count(*) As Num_Regs ');
      SQL.Add('  FROM QS_SYS_MONEDAS    b ');
      SQL.Add('      ,QS_SYS_PERIODO    c ');
      SQL.Add('      ,QS_SYS_VAL_TRAMO  a ');
      SQL.Add(' WHERE c.TIPO_UNIDAD     = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	        = b.UNIDAD_MEDIDA_MON ');
      SQL.Add('   AND c.Tipo_Variacion  = ''D'' ');
      SQL.Add('   AND b.COD_MONEDA      = a.COD_MONEDA ');
      SQL.Add('   AND a.Fecha          >= :Fecha_Inicial ');
      SQL.Add('   AND a.Fecha          <= :Fecha_Final ');
      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND b.Cod_Moneda     = '''+sMoneda_Indice+'''' );
