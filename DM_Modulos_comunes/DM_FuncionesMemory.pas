      Reg_Nro_Riesgo.Factor       := VarArrayCreate([0, i], varDouble);
      Reg_Nro_Riesgo.Valor_Riesgo := VarArrayCreate([0, i], varDouble);
      Reg_Nro_Riesgo.Tipo_Plazo   := VarArrayCreate([0, i], varOleStr);
      Reg_Nro_Riesgo.Nivel        := VarArrayCreate([0, i], varDouble);
