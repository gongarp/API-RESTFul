procedure Busca_Datos_Clasif_Riesgo_Mem( const sTipo_clasif  : String;
                                  const sCodigo : String;
                                    var Nro_Riesgo    : Double;
                                    var Factor        : Double;
                                    var sTipo_Plazo   : String;
                                    var fValor_Riesgo : Double;
                                    var fNivel        : Double
                                    );
Var
  i
  ,iLimite_Superior : Integer;
begin
   if NOT VarIsArray(Reg_Nro_Riesgo.Codigo) then
      Carga_Nro_Clasif_Riesgo;

   Nro_Riesgo := 0;
   Factor     := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Nro_Riesgo.Codigo, 1 )-1;
   for i := 0 to iLimite_Superior do
   begin
      if Trim( sTipo_clasif ) <> '' then
      begin
         if ( Reg_Nro_Riesgo.Codigo[i]      = sCodigo )     and
            ( Reg_Nro_Riesgo.Tipo_Clasif[i] = sTipo_clasif) then
         begin
            Nro_Riesgo    := Reg_Nro_Riesgo.Nro_Riesgo[i];
            Factor        := Reg_Nro_Riesgo.Factor[i];
            fValor_Riesgo := Reg_Nro_Riesgo.Valor_Riesgo[i];
            sTipo_Plazo   := Reg_Nro_Riesgo.Tipo_Plazo[i];
            fNivel        := Reg_Nro_Riesgo.Nivel[i];
            Break;
         end;
      end
      else
      begin
         if  Reg_Nro_Riesgo.Codigo[i] = sCodigo then
         begin
            Nro_Riesgo    := Reg_Nro_Riesgo.Nro_Riesgo[i];
            Factor        := Reg_Nro_Riesgo.Factor[i];
            fValor_Riesgo := Reg_Nro_Riesgo.Valor_Riesgo[i];
            sTipo_Plazo   := Reg_Nro_Riesgo.Tipo_Plazo[i];
            fNivel        := Reg_Nro_Riesgo.Nivel[i];
            Break;
         end;
      end;
   end;
end;

