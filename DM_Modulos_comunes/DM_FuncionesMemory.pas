Procedure Carga_Recupero_Inst_Mem(dFecha :TDateTime);
var i : LongInt;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT a.*,b.elemento as Instrumento'
             +'  FROM QS_FIN_RECUPERO_INSTRUMENTO a '
             +'      ,QS_SYS_CLASIF_OBJ           b '
             +' WHERE a.Fecha_Vigencia = (SELECT max(a.Fecha_Vigencia) '
             +'                             FROM QS_FIN_RECUPERO_INSTRUMENTO a '
             +'                            WHERE a.Fecha_Vigencia <= :Fecha ) '
             +'  AND b.objeto        = ''INSTRUM'' '
             +'  AND b.codigo_clasif = a.clasif_instrum '
             +'  AND b.nodo          = a.Nodo ');
      SQL.Add('UNION ');
      SQL.Add('SELECT a.*,'' '' as Instrumento '
             +' FROM QS_FIN_RECUPERO_INSTRUMENTO a '
             +'WHERE a.Fecha_Vigencia = (SELECT max(a.Fecha_Vigencia) '
             +'                            FROM QS_FIN_RECUPERO_INSTRUMENTO a '
             +'                           WHERE a.Fecha_Vigencia <= :Fecha ) '
             +'  AND a.clasif_instrum = '' '' '
             +'  AND a.Nodo           = 0 ');
      ParamByName('Fecha').AsDateTime       := dFecha;
      Open;

      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;

      Reg_Recupero_Instrum.Instrumento := VarArrayCreate([0, i], varOleStr);
      Reg_Recupero_Instrum.Recupero    := VarArrayCreate([0, i], varDouble);
      i := 0;
      while not eof do
      begin
        Reg_Recupero_Instrum.Instrumento[i] := trim(FieldByName('Instrumento').AsString);
        Reg_Recupero_Instrum.Recupero[i]    := FieldByName('Recupero').AsFloat;
        Inc(i);
        Next;
      end;
      close;
   end;
end;

Procedure Busca_Recupero_Inst_Mem(dFecha       :TDateTime;
                                  sInstrumento :String;
                              var fRecupero    :Double;
                              var bResult      :Boolean);
var i : Integer;
begin
   bResult := False;

   if NOT VarIsArray(Reg_Recupero_Instrum.Instrumento) then
      Carga_Recupero_Inst_Mem(dFecha);

   for i := 0 to VarArrayHighBound(Reg_Recupero_Instrum.Instrumento, 1)  do
   begin
      if (Reg_Recupero_Instrum.Instrumento[i] = sInstrumento) then
      begin
        bResult   := True;
        fRecupero := Reg_Recupero_Instrum.Recupero[i];
        Exit;
      end;
   end;
   if not bResult then
   begin
      for i := 0 to VarArrayHighBound(Reg_Recupero_Instrum.Instrumento, 1)  do
      begin
         if (Reg_Recupero_Instrum.Instrumento[i] = ' ') or (Reg_Recupero_Instrum.Instrumento[i] = '') then
         begin
           bResult   := True;
           try
           fRecupero := Reg_Recupero_Instrum.Recupero[i];
           except
              fRecupero := 0;
           end;
           Exit;
         end;
      end;
   end;
end;

Procedure Carga_Deterioro_Cl_Riesgo(dFecha_Proceso1 : TDateTime;
                                    dFecha_Proceso2 : TDateTime);
var i : Integer;
begin
   with dmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT max(a.Fecha_Vigencia) as Fecha_Vigencia '
             +'      ,a.Clasif_Riesgo '
             +'      ,:Fecha1 as Fecha_Cierre'
             +'  FROM QS_FIN_DETERIORO_CL_RIESGO a '
             +' WHERE a.Fecha_Vigencia <= :Fecha1 '
             +' GROUP BY a.Clasif_Riesgo ');
      if dFecha_Proceso2 <> dFecha_Proceso1 then
      begin
        SQL.Add(' UNION ');
        SQL.Add('SELECT max(a.Fecha_Vigencia) as Fecha_Vigencia '
               +'      ,a.Clasif_Riesgo '
               +'      ,:Fecha2 as Fecha_Cierre'
               +'  FROM QS_FIN_DETERIORO_CL_RIESGO a '
               +' WHERE a.Fecha_Vigencia <= :Fecha2 '
               +' GROUP BY a.Clasif_Riesgo ');
      end;
      ParamByName('Fecha1').AsDateTime       := dFecha_Proceso1;
      if dFecha_Proceso2 <> dFecha_Proceso1 then
         ParamByName('Fecha2').AsDateTime    := dFecha_Proceso2;
      Open;

      DmFuncionesMemory.QRY_General.last;
      i := DmFuncionesMemory.QRY_General.RecordCount;
      DmFuncionesMemory.QRY_General.first;

      Reg_Deterioro_Cl_Riesgo.Fecha         := VarArrayCreate([0, i], varDate);
      Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo := VarArrayCreate([0, i], varOleStr);
      Reg_Deterioro_Cl_Riesgo.Stage_1_PD    := VarArrayCreate([0, i], varDouble);
      Reg_Deterioro_Cl_Riesgo.Stage_2_PD    := VarArrayCreate([0, i], varDouble);
      Reg_Deterioro_Cl_Riesgo.Long_Term_PD  := VarArrayCreate([0, i], varDouble);
      i := 0;

      while not eof do
      begin
        with dmFuncionesMemory.Qry_General2 do
        begin
           Sql.Clear;
           SQL.Add('SELECT a.*'
                  +'  FROM QS_FIN_DETERIORO_CL_RIESGO a '
                  +' WHERE a.Fecha_Vigencia = :Fecha '
                  +'   AND a.Clasif_Riesgo  = :Clasif_Riesgo '
                  +' ORDER BY Long_Term_PD ');
           ParamByName('Fecha').AsDateTime       := dmFuncionesMemory.Qry_General.FieldByName('Fecha_Vigencia').AsDateTime;
           ParamByName('Clasif_Riesgo').AsString := dmFuncionesMemory.Qry_General.FieldByName('Clasif_Riesgo').AsString;
           Open;
           while not eof do
           begin
             Reg_Deterioro_Cl_Riesgo.Fecha[i]         := dmFuncionesMemory.Qry_General.FieldByName('Fecha_Cierre').AsDateTime;
             Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[i] := trim(FieldByName('Clasif_Riesgo').AsString);
             Reg_Deterioro_Cl_Riesgo.Stage_1_PD[i]    := FieldByName('Stage_1_PD').AsFloat;
             Reg_Deterioro_Cl_Riesgo.Stage_2_PD[i]    := FieldByName('Stage_2_PD').AsFloat;
             Reg_Deterioro_Cl_Riesgo.Long_Term_PD[i]  := FieldByName('Long_Term_PD').AsFloat;
             Inc(i);
             Next;
           end;
           Close;
        end;
        Next;
      end;
      close;
   end;

   //Ordeno el Registro por Long_Term_PD
   if i <> 0 then
     Ordenamiento_Deterioro_Cl_Riesgo_Mem(Reg_Deterioro_Cl_Riesgo
                                         ,0
                                         ,VarArrayHighBound(Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo, 1 )-1);
end;

Procedure Ordenamiento_Deterioro_Cl_Riesgo_Mem(var Reg_Deterioro_Cl_Riesgo : TReg_Deterioro_Cl_Riesgo;
                                               iLo, iHi: Integer);
var
    Lo, Hi : Integer;
    Mid    : Double;
    dFecha         : TDateTime;
    sClasif_Riesgo : string;
    fStage_1_PD    : double;
    fStage_2_PD    : double;
    fLong_Term_PD  : double;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Deterioro_Cl_Riesgo.Long_Term_PD[(Lo + Hi) div 2];

    repeat
      while Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Lo] < Mid do
            Inc(Lo);
      while Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         dFecha         := Reg_Deterioro_Cl_Riesgo.Fecha[Lo];
         sClasif_Riesgo := Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[Lo];
         fStage_1_PD    := Reg_Deterioro_Cl_Riesgo.Stage_1_PD[Lo];
         fStage_2_PD    := Reg_Deterioro_Cl_Riesgo.Stage_2_PD[Lo];
         fLong_Term_PD  := Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Lo];

         Reg_Deterioro_Cl_Riesgo.Fecha[Lo]         := Reg_Deterioro_Cl_Riesgo.Fecha[Hi];
         Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[Lo] := Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[Hi];
         Reg_Deterioro_Cl_Riesgo.Stage_1_PD[Lo]    := Reg_Deterioro_Cl_Riesgo.Stage_1_PD[Hi];
         Reg_Deterioro_Cl_Riesgo.Stage_2_PD[Lo]    := Reg_Deterioro_Cl_Riesgo.Stage_2_PD[Hi];
         Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Lo]  := Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Hi];

         Reg_Deterioro_Cl_Riesgo.Fecha[Hi]         := dFecha;
         Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[Hi] := sClasif_Riesgo;
         Reg_Deterioro_Cl_Riesgo.Stage_1_PD[Hi]    := fStage_1_PD;
         Reg_Deterioro_Cl_Riesgo.Stage_2_PD[Hi]    := fStage_2_PD;
         Reg_Deterioro_Cl_Riesgo.Long_Term_PD[Hi]  := fLong_Term_PD;

         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Deterioro_Cl_Riesgo_Mem(Reg_Deterioro_Cl_Riesgo, iLo, Hi);
    if Lo < iHi then Ordenamiento_Deterioro_Cl_Riesgo_Mem(Reg_Deterioro_Cl_Riesgo, Lo, iHi);
end;

