             Reg_Excepcion_Cambiaria.Fecha_Hasta[i]        := 0
          else
             Reg_Excepcion_Cambiaria.Fecha_Hasta[i]        := Fieldbyname('Fecha_Hasta').asdatetime;
          Reg_Excepcion_Cambiaria.Fecha_Inicio_Tratam[i]  := Fieldbyname('Fecha_Inicio_Tratam').asdatetime;
          Reg_Excepcion_Cambiaria.Fecha_Termino_Tratam[i] := Fieldbyname('Fecha_Termino_Tratam').asdatetime;
          if (Fieldbyname('PAGA_REAJUSTE_CAPITAL').AsString = 'SI') then
             Reg_Excepcion_Cambiaria.PAGA_REAJUSTE_CAPITAL[i] := 'SI'
          else
             Reg_Excepcion_Cambiaria.PAGA_REAJUSTE_CAPITAL[i] := 'NO';
          //ggarcia 12-07-2018
          if (Fieldbyname('NO_CONSIDERA_EN_INTERES').AsString = 'SI') then
