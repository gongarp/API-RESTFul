  Emisor_Pagador_Mem( dFecha,
                      sEmisor,
                      sInstrumento,
                      sEmisor_Pagador,
                      bEmisor_Pagador
                     );
  if (bEmisor_Pagador) and
     (sEmisor <> sEmisor_Pagador) then
  begin
     Busca_Clasif_Riesgo_EmpCla_Mem(sEmisor_Pagador,
                             sInstrumento,
                             sSerie,
                             dFecha,
                             bObliga_Clasif_Instrum,
                             sOrigen,
                             sClasificacion,
                             fFactor_Riesgo,
                             sEmisor_Pagador,
                             sEmpresa_Clasif
                             );
     if sClasificacion <> '' then
        Exit;   // Sale unicamente si encontró, de lo contrario, sigue buscando clasificación para el emisor original
  end;

  if bObliga_Clasif_Instrum then
  begin
     dFecha_aux     := StrToDate('01/01/1800');
     for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE, 1 )-1 do
     begin
       if (Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE[i]    = sEmisor)       and
          (Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE[i]   = sInstrumento)  and
          (Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]  <= dFecha)        and
          (Reg_Clasif_Riesgo_EmpCla.ORIGEN[i]           = sOrigen)       then
       begin
          if (dFecha_aux < Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]) then
          begin
             sClasificacion := Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE[i];
             dFecha_aux     := Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i];
             sEmpresa_Clasif:= Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP[i];
             Result         := True;
          end;
       end;
     end;
  end;

  //Busco Emisor, Instrumento, serie
  dFecha_aux     := StrToDate('01/01/1800');
  for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE, 1 )-1 do
  begin
     try
     if (Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE[i]    = sEmisor)       and
        (Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE[i]   = sInstrumento)  and
        (Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF[i]     = sSerie)        and
        (Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]  <= dFecha)        and
        (Reg_Clasif_Riesgo_EmpCla.ORIGEN[i]           = sOrigen)       then
     begin
        if (dFecha_aux < Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]) then
        begin
           sClasificacion := Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE[i];
           dFecha_aux     := Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i];
           sEmpresa_Clasif:= Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP[i];
           Result         := True;
        end;
     end;
     except
     end;
  end;
  //if Result then
  //   Exit;

  //Busco Emisor, Instrumento
  if Not Result then
  begin
     dFecha_aux     := StrToDate('01/01/1800');
     for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE, 1 )-1 do
     begin
        if (Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE[i]    = sEmisor)       and
           (Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE[i]   = sInstrumento)  and
           (Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF[i]     = EmptyStr)      and
           (Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]  <= dFecha)        and
           (Reg_Clasif_Riesgo_EmpCla.ORIGEN[i]           = sOrigen)       then
        begin
           if (dFecha_aux < Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]) then
           begin
              sClasificacion := Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE[i];
              dFecha_aux     := Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i];
              sEmpresa_Clasif:= Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP[i];
              Result         := True;
           end;
        end;
     end;
     //if Result then
     //   Exit;
  end;

  //Busco Emisor
  if Not Result then
  begin
     dFecha_aux     := StrToDate('01/01/1800');
     for i := 0 to VarArrayHighBound( Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE, 1 )-1 do
     begin
        if (Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE[i]= sEmisor)           and
           (Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE[i]   = EmptyStr)      and
           (Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF[i]     = EmptyStr)      and
           (Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]  <= dFecha)        and
           (Reg_Clasif_Riesgo_EmpCla.ORIGEN[i]           = sOrigen)       then
        begin
           if (dFecha_aux < Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i]) then
           begin
              sClasificacion := Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE[i];
              dFecha_aux     := Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i];
              sEmpresa_Clasif:= Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP[i];
              Result         := True;
           end;
        end;
     end;
     //if Result then
     //   Exit;
  end;

  if Result then
     Busca_Datos_Clasif_Riesgo_Mem( '' ,  // TIPO
                                    sClasificacion,
                                    fNro_Riesgo,
                                    fFactor_Riesgo,
                                    sTipo_Plazo,
                                    fValor_Nivel,
                                    fNivel
                                  );
end;
}


