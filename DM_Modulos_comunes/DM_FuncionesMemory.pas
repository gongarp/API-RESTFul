      Reg_Motivo_OMD.Empresa       := VarArrayCreate([0, i], varOleStr);
      Reg_Motivo_OMD.Transaccion   := VarArrayCreate([0, i], varOleStr);
      Reg_Motivo_OMD.Folio_Interno := VarArrayCreate([0, i], varDouble);
      Reg_Motivo_OMD.Item_Omd      := VarArrayCreate([0, i], varDouble);
      Reg_Motivo_OMD.Fecha_Hora    := VarArrayCreate([0, i], varDate);
      Reg_Motivo_OMD.Fecha_Desde   := VarArrayCreate([0, i], varDate);
      Reg_Motivo_OMD.Fecha_Hasta   := VarArrayCreate([0, i], varDate);
      Reg_Motivo_OMD.Cod_Motivo    := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Motivo_OMD.Empresa[i]       := Fieldbyname('Empresa').asString;
         Reg_Motivo_OMD.Transaccion[i]   := Fieldbyname('Transaccion').asString;
         Reg_Motivo_OMD.Folio_Interno[i] := Fieldbyname('Folio_Interno').asFloat;
         Reg_Motivo_OMD.Item_Omd[i]      := Fieldbyname('Item_Omd').asFloat;
         Reg_Motivo_OMD.Fecha_Hora[i]    := Fieldbyname('Fecha_Hora').asDatetime;
         Reg_Motivo_OMD.Fecha_Desde[i]   := Fieldbyname('Fecha_Desde').asDatetime;
         Reg_Motivo_OMD.Fecha_Hasta[i]   := Fieldbyname('Fecha_Hasta').asDatetime;
         Reg_Motivo_OMD.Cod_Motivo[i]    := Fieldbyname('Cod_Motivo').asString;
         Next;
         Inc(i);
      end;
   end;

  //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
  if i <> 0 then
     Ordenamiento_Motivo_OMD_Mem(  Reg_Motivo_OMD
                                  ,0
                                  ,VarArrayHighBound(Reg_Motivo_OMD.Folio_Interno, 1 )-1
                                );

