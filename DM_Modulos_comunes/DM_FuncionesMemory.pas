          else
             Reg_Excepcion_Cambiaria.NO_CONSIDERA_EN_INTERES[i] := 'NO';
          if (Fieldbyname('SOLO_APLICA_EN_VCTOS').AsString = 'SI') then
             Reg_Excepcion_Cambiaria.SOLO_APLICA_EN_VCTOS[i] := 'SI'
          else
             Reg_Excepcion_Cambiaria.SOLO_APLICA_EN_VCTOS[i] := 'NO';
          if (Fieldbyname('NO_CONSIDERA_NEGATIVOS').AsString = 'SI') then
             Reg_Excepcion_Cambiaria.NO_CONSIDERA_NEGATIVOS[i] := 'SI'
          else
             Reg_Excepcion_Cambiaria.NO_CONSIDERA_NEGATIVOS[i] := 'NO';

          Next;
          Inc(i);
       end;
       Close;

       // cjf
       // Incorpora los instruemnto unicos a varcam
       if bExcepcionUnicos then
       begin
         SQL.Clear;
         SQL.Add(' SELECT DISTINCT c.codigo_formula,   ');
         SQL.Add('                 a.emisor as Codigo_Emisor,   ');
         SQL.Add('                 a.instrumento as Codigo_Instrumento,   ');
         SQL.Add('                 '' '' as serie,   ');
         SQL.Add('                 1 as Cupon_Desde,   ');
         SQL.Add('                 1 as Cupon_Hasta,   ');
         SQL.Add('                 c.Mon_Ind_Correccion as COD_MONEDA_IND,   ');
         SQL.Add('                 c.Fecha_Desde_Corr as COD_TRATAM_INICIO,   ');
         SQL.Add('                 c.Fecha_Hasta_Corr as COD_TRATAM_TERMINO,   ');
