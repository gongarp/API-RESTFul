Procedure Busca_Closest_1y_Pd(dFecha_Proceso  : TDateTime;
                              fPd_At_Purchase : Double;
                          var fLong_Term_PD   : Double;
                          var sClasif_Riesgo  : String;
                          var bResult         : Boolean);
var i : Integer;
    fDif1 :Double;
    fDif2 :Double;
    fLong_Term_PD_Ant  :Double;
    sClasif_Riesgo_Ant :string;
begin
   bResult := False;
   fLong_Term_PD  := 0;
   sClasif_Riesgo := '';

   //if NOT VarIsArray(Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo) then  //ggarcia 25-05-2022 la cargo cada vez ya que no puedo cargar a distintas fechas
   //   Carga_Deterioro_Cl_Riesgo(dFecha_Proceso);

   fLong_Term_PD_Ant := 0;
   for i := 0 to VarArrayHighBound(Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo, 1)  do
   begin
      if (Reg_Deterioro_Cl_Riesgo.Fecha[i] = dFecha_Proceso) then
      begin
        fDif1 := StrToFloat(FormatFloat('##########.000000000000',Reg_Deterioro_Cl_Riesgo.Long_Term_PD[i] - fPd_At_Purchase));
        if fDif1 >= 0 then
        begin
          fDif2 := StrToFloat(FormatFloat('##########.000000000000',Reg_Deterioro_Cl_Riesgo.Long_Term_PD[i] - fLong_Term_PD_Ant));
          if fPd_At_Purchase > (fLong_Term_PD_Ant + (fDif2 / 2))  then
          begin
             fLong_Term_PD  := Reg_Deterioro_Cl_Riesgo.Long_Term_PD[i];
             sClasif_Riesgo := Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[i];
          end
          else
          begin
             fLong_Term_PD  := fLong_Term_PD_Ant;
             sClasif_Riesgo := sClasif_Riesgo_Ant;
          end;
          bResult   := True;
          Exit;
        end;
        fLong_Term_PD_Ant  := Reg_Deterioro_Cl_Riesgo.Long_Term_PD[i];
        sClasif_Riesgo_Ant := Reg_Deterioro_Cl_Riesgo.Clasif_Riesgo[i];
      end;
   end;
end;

