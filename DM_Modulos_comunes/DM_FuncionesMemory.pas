      Reg_Descriptores.COD_CALC_TIR_D[j]     := FieldByName('COD_CALC_TIR_D').AsString;
      Reg_Descriptores.OPCION_PREPAGO[j]     := FieldByName('OPCION_PREPAGO').AsString;
