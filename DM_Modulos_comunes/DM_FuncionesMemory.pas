Procedure Carga_Tipo_Emisor_Mem( dFecha : Tdatetime );
Var
  i : Integer;
begin
  WITH DMFuncionesMemory.QRY_General do
  begin
     SQL.Clear;
      SQL.Add('SELECT a.Codigo_Identidad'
             +'      ,a.Tipo_Emisor'
             +'      ,b.Desc_Detail As Descripcion'
             +'  FROM QS_FIN_EMISOR_TIPO a'
             +'      ,QS_SYS_COD_DET b'
             +' WHERE Fecha_Desde <= :Fecha'
             +'   AND (Fecha_Hasta IS NULL OR'
             +'        Fecha_Hasta >= :Fecha)'
             +'   AND b.Cod_general = ''TIPEMI'''
             +'   AND b.Cod_detail  = a.Tipo_Emisor'
             +' ORDER BY Codigo_Identidad'
             );
      ParamByName('Fecha').AsDate := dFecha;
      Open;

      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Tipo_Emisor.Codigo_Identidad := VarArrayCreate([0, i], varOleStr);
      Reg_Tipo_Emisor.Tipo_Emisor      := VarArrayCreate([0, i], varOleStr);
      Reg_Tipo_Emisor.Descripcion      := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Tipo_Emisor.Codigo_Identidad[i] := FieldByName('Codigo_Identidad').asString;
         Reg_Tipo_Emisor.Tipo_Emisor[i]      := FieldByName('Tipo_Emisor').asString;
         Reg_Tipo_Emisor.Descripcion[i]      := FieldByName('Descripcion').asString;
         Next;
         Inc(i);
      end;
       Close;
       UnPrepare;
   end;  // With
end;

procedure Tipo_Emisor_Mem(const sEmisor     : String;
                         dFecha             : TDatetime;
                         var sTipo_Emisor   : String;
                         var sDescripcion   : String;
                         var flag_Encontro   : Boolean);
Var
  i : Integer;
begin

  if NOT VarIsArray(Reg_Tipo_Emisor.Tipo_Emisor) then
     Carga_Tipo_Emisor_Mem( dFecha  );

  Flag_Encontro    := False;
  for i := 0 to VarArrayHighBound(Reg_Tipo_Emisor.Tipo_Emisor, 1 )-1 do
  begin
     if  Reg_Tipo_Emisor.Codigo_Identidad[i] = sEmisor then
     begin
        Flag_Encontro   := True;
        sTipo_Emisor    := Reg_Tipo_Emisor.Tipo_Emisor[i];
        sDescripcion    := Reg_Tipo_Emisor.Descripcion[i];
        Break;
     end;
  end;
end;

Procedure Carga_Registro_Mercado_Mem( sEmpresa      : String;
                                      dFecha_Cierre : Tdatetime
                                     );
Var i : LongInt;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT Cartera'
             +'      ,Transaccion'
             +'      ,Folio_interno'
             +'      ,Item_OMD'
             +'      ,fecha_Last_Cierre'
             +'      ,Sum(Valor_Nominal) as Valor_Nominal'
             +'      ,Sum(Valor_Pte_Mc_I_Cpa) as Valor_Pte_Mc_I_Cpa'
             +'      ,Sum(Valor_Pte_Mc_I_Mer) as Valor_Pte_Mc_I_Mer'
             +'  FROM QS_RES_MERCADO'
             +' WHERE Fecha_Cierre = :Fecha_Cierre'
             +'   AND Empresa      = :Empresa'
             +' GROUP BY  Cartera'
             +'      ,Transaccion'
             +'      ,Folio_interno'
             +'      ,Item_OMD'
             +'      ,fecha_Last_Cierre'
             );
      Parambyname('Fecha_Cierre').asDate := dFecha_Cierre;
      Parambyname('Empresa').asString    := sEmpresa;
      Open;
      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Folio_Mdo.Cartera          := VarArrayCreate([0, i], varOleStr);
      Reg_Folio_Mdo.Transaccion      := VarArrayCreate([0, i], varOleStr);
      Reg_Folio_Mdo.Folio_Interno    := VarArrayCreate([0, i], varDouble);
      Reg_Folio_Mdo.Item_OMD         := VarArrayCreate([0, i], varDouble);
      Reg_Folio_Mdo.Valor_Nominal    := VarArrayCreate([0, i], varDouble);
      Reg_Folio_Mdo.Valor_Pte_I_Cpa  := VarArrayCreate([0, i], varDouble);
      Reg_Folio_Mdo.Valor_Pte_I_Mer  := VarArrayCreate([0, i], varDouble);
      Reg_Folio_Mdo.fecha_Last_Cierre:= VarArrayCreate([0, i], varDouble);

      i := 0;
      while not eof do
      begin
         Reg_Folio_Mdo.Cartera[i]       := Fieldbyname('cartera').asString;
         Reg_Folio_Mdo.Transaccion[i]   := Fieldbyname('Transaccion').asString;
         Reg_Folio_Mdo.Folio_Interno[i] := Fieldbyname('Folio_Interno').asString;
         Reg_Folio_Mdo.Item_OMD[i]      := Fieldbyname('Item_Omd').asFloat;
         Reg_Folio_Mdo.Valor_Nominal[i] := Fieldbyname('Valor_Nominal').asFloat;
         Reg_Folio_Mdo.Valor_Pte_I_Cpa[i]   := Fieldbyname('Valor_Pte_Mc_I_Cpa').asFloat;
         Reg_Folio_Mdo.Valor_Pte_I_Mer[i]   := Fieldbyname('Valor_Pte_Mc_I_Mer').asFloat;
         Reg_Folio_Mdo.fecha_Last_Cierre[i] := Fieldbyname('fecha_Last_Cierre').asDatetime;

         Next;
         Inc(i);
      end;
      //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
      if i <> 0 then
         Ordenamiento_registro_Mdo_Mem(  Reg_Folio_Mdo
                                     ,0
                                     ,VarArrayHighBound(Reg_Folio_Mdo.Folio_Interno, 1 )-1
                                    );
      Close;
  end;
end;

Procedure Ordenamiento_Registro_Mdo_Mem( var Reg_Folio_Mdo : TReg_Folio_Mdo;
                                           iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd,
    fValor_Pte_I_Cpa,
    fValor_Pte_I_Mer,
    fValor_Nominal : Double;
    sTransaccion,
    sCartera  : String;
    dFecha_last_Cierre : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Folio_Mdo.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Folio_Mdo.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Folio_Mdo.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sCartera           := Reg_Folio_Mdo.Cartera[Lo];
         sTransaccion       := Reg_Folio_Mdo.Transaccion[Lo];
         fFolio_Interno     := Reg_Folio_Mdo.Folio_Interno[Lo];
         fItem_Omd          := Reg_Folio_Mdo.Item_Omd[Lo];
         fValor_Nominal     := Reg_Folio_Mdo.Valor_Nominal[Lo];
         fValor_Pte_I_Cpa   := Reg_Folio_Mdo.Valor_Pte_I_Cpa[Lo];
         fValor_Pte_I_Mer   := Reg_Folio_Mdo.Valor_Pte_I_Mer[Lo];
         dFecha_last_Cierre := Reg_Folio_Mdo.Fecha_last_Cierre[Lo];

         Reg_Folio_Mdo.Cartera[Lo]       :=
                       Reg_Folio_Mdo.Cartera[Hi];
         Reg_Folio_Mdo.Transaccion[Lo]   :=
                       Reg_Folio_Mdo.Transaccion[Hi];
         Reg_Folio_Mdo.Folio_Interno[Lo] :=
                       Reg_Folio_Mdo.Folio_Interno[Hi];
         Reg_Folio_Mdo.Item_Omd[Lo]      :=
                       Reg_Folio_Mdo.Item_Omd[Hi];
         Reg_Folio_Mdo.Valor_Nominal[Lo] :=
                       Reg_Folio_Mdo.Valor_Nominal[Hi];
         Reg_Folio_Mdo.Valor_Pte_I_Cpa[Lo]:=
                       Reg_Folio_Mdo.Valor_Pte_I_Cpa[Hi];
         Reg_Folio_Mdo.Valor_Pte_I_Mer[Lo]:=
                       Reg_Folio_Mdo.Valor_Pte_I_Mer[Hi];
         Reg_Folio_Mdo.Fecha_Last_Cierre[Lo]:=
                       Reg_Folio_Mdo.Fecha_Last_Cierre[Hi];


         Reg_Folio_Mdo.Cartera[Hi]         := scartera;
         Reg_Folio_Mdo.Transaccion[Hi]     := sTransaccion;
         Reg_Folio_Mdo.Folio_Interno[Hi]   := fFolio_Interno;
         Reg_Folio_Mdo.Item_Omd[Hi]        := fItem_Omd;
         Reg_Folio_Mdo.Valor_Nominal[Hi]   := fValor_Nominal;
         Reg_Folio_Mdo.Valor_Pte_I_Cpa[Hi] := fValor_Pte_I_Cpa;         
         Reg_Folio_Mdo.Valor_Pte_I_Mer[Hi] := fValor_Pte_I_Mer;
         Reg_Folio_Mdo.Fecha_last_Cierre[Hi] := dFecha_Last_Cierre;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Mdo_Mem(Reg_Folio_Mdo, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Mdo_Mem(Reg_Folio_Mdo, Lo, iHi);
end;

Function Existe_Registro_Mercado_Mem(const sCartera       : String;
                                     const sTransaccion   : String;
                                     const sFolio_interno : String;
                                     fItem_OMD            : Double;
                                     var  fValor_Nominal  : Double;
                                     var  fValor_Pte_I_Cpa: Double;
                                     var  fValor_Pte_I_Mer: Double;
                                     var  dFecha_Last_Mdo : Tdatetime
                                     ) : Boolean;
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
begin
   fValor_Nominal   := 0;
   fFolio_Buscado   := StrToFloat( sFolio_interno );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Folio_Mdo.Folio_Interno, 1 )-1;
   i := 0;


   Result := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Folio_Mdo.Folio_Interno[i] = fFolio_Buscado then
        begin
           Result := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Folio_Mdo.Folio_Interno[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;
   end;

   if Result then
   begin
      Result := False;
      //Retrocedo hasta Primer Folio Distinto
      For j := i Downto 0 do
        if Reg_Folio_Mdo.Folio_Interno[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Folio_Mdo.Folio_Interno , 1 )) and
            (Reg_Folio_Mdo.Folio_Interno[i] = fFolio_Buscado) do
      begin
         if (Reg_Folio_Mdo.Transaccion[i]  = sTransaccion) and
            (Reg_Folio_Mdo.Item_Omd[i]     = fItem_Omd)    and
            (Reg_Folio_Mdo.Cartera[i]      = sCartera)  then
         begin
            Existe_Registro_Mercado_Mem := True;
            fValor_Nominal   := Reg_Folio_Mdo.Valor_Nominal[i];
            fValor_Pte_I_Cpa := Reg_Folio_Mdo.Valor_Pte_I_Cpa[i];            
            fValor_Pte_I_Mer := Reg_Folio_Mdo.Valor_Pte_I_Mer[i];
            dFecha_Last_Mdo  := Reg_Folio_Mdo.Fecha_last_Cierre[i];
            Break;
         end;

         Inc(i);
      end;
   end;
end;

Procedure Carga_Nro_Clasif_Riesgo;
