procedure Carga_Dias_Feriados_Mem;
var i : Integer;
begin
  With dmFuncionesMemory.Qry_General do
  begin
    SQL.Clear;
    SQL.Add('SELECT *'
           +'  FROM QS_SYS_FERIADOS'
           +' ORDER BY CODIGO_DIVISION '
           );
    Open;

    DmFuncionesMemory.QRY_General.last;
    i := DmFuncionesMemory.QRY_General.RecordCount;
    DmFuncionesMemory.QRY_General.first;

    Reg_Dias_Feriados.Codigo_Division := VarArrayCreate([0, i], varOleStr);
    Reg_Dias_Feriados.Ano_Feriado     := VarArrayCreate([0, i], varDouble);
    Reg_Dias_Feriados.Mes_Feriado     := VarArrayCreate([0, i], varDouble);
    Reg_Dias_Feriados.Dia_Feriado     := VarArrayCreate([0, i], varDouble);

    i := 0;
    while not eof do
    begin
       Reg_Dias_Feriados.Codigo_Division[i] := Fieldbyname('Codigo_Division').asString;
       Reg_Dias_Feriados.Ano_Feriado[i]     := Fieldbyname('Ano_Feriado').asFloat;
       Reg_Dias_Feriados.Mes_Feriado[i]     := Fieldbyname('Mes_Feriado').asFloat;
       Reg_Dias_Feriados.Dia_Feriado[i]     := Fieldbyname('Dia_Feriado').asFloat;
       Next;
       Inc(i);
    end;
    Close;
    Unprepare;
  end;
end;

function Feriado_Mem(sCodigo_Division : String;
                     dFecha           : TDatetime) : Boolean;
var
  wano,
  wmes,
  wdia : word;
  i    : Integer;
begin
  Result := False;
  if sCodigo_Division = EmptyStr then
     Exit;

  if NOT VarIsArray(Reg_Dias_Feriados.Codigo_Division) then   
     Carga_Dias_Feriados_Mem;

  decodedate(dFecha,wano,wmes,wdia);

  for i := 0 to  VarArrayHighBound(Reg_Dias_Feriados.Codigo_Division, 1 ) do
  begin
     if ( (Reg_Dias_Feriados.Ano_Feriado[i] = 0) or (Reg_Dias_Feriados.Ano_Feriado[i] = wAno) ) and
          (Reg_Dias_Feriados.Mes_Feriado[i] = wMes) and
          (Reg_Dias_Feriados.Dia_Feriado[i] = wDia) and
          (Reg_Dias_Feriados.Codigo_Division[i] = sCodigo_Division) then
     begin
       Result := True;
       Break;
     end;
  end;
end;

Procedure Carga_Valores_EquivalenciaSBS( dFecha : TDatetime);
var i : LongInt;
begin
     WITH DMFuncionesMemory.QRY_General do
     begin
       Close;
       Sql.Clear;
       SQL.Add('SELECT * FROM QS_SYS_EQUIVALEN_SBS'
             +' WHERE Fecha_Desde  <= :Fecha'
             +'  AND (Fecha_Hasta IS NULL OR Fecha_Hasta >= :Fecha)'
              );
      Sql.Add(' ORDER BY Codigo_Proceso'
             +'  ,Codigo_Sistema'
             );
       Parambyname('Fecha').asDate := dFecha;
       Open;

       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount + 1;
        DmFuncionesMemory.QRY_General.first;
       Reg_EquivalenciaSBS.Fecha_Calculo   := VarArrayCreate([0, i], varDate);
       Reg_EquivalenciaSBS.Codigo_Proceso  := VarArrayCreate([0, i], varOleStr);
       Reg_EquivalenciaSBS.Codigo_Objeto   := VarArrayCreate([0, i], varOleStr);
       Reg_EquivalenciaSBS.Codigo_Sistema  := VarArrayCreate([0, i], varOleStr);
       Reg_EquivalenciaSBS.Codigo_Equiv    := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while not eof do
       begin
          // Nuevo: agrego otro registro para fecha de calculo para verificar vigencia de carga
          Reg_EquivalenciaSBS.Fecha_Calculo[i]  := dFecha;
          Reg_EquivalenciaSBS.Codigo_Proceso[i] := Fieldbyname('Codigo_Proceso').asString;
          Reg_EquivalenciaSBS.Codigo_Objeto[i]  := Fieldbyname('Codigo_Objeto').asString;
          Reg_EquivalenciaSBS.Codigo_Sistema[i] := Fieldbyname('Codigo_Sistema').asString;
          Reg_EquivalenciaSBS.Codigo_Equiv[i]   := Fieldbyname('Codigo_Equiv').asString;
          Inc(i);
          Next;
       end;
       Close;
    end;
end;

Procedure Busca_Equivalencia_MemSBS(const sCodigo_Proceso : String;
                                    const sCodigo_Objeto  : String;
                                    const sCodigo_Sistema : String;
                                    const dFecha_Calculo  : TDateTime;
                                    var sCodigo_Equiv  : String;
                                    var Result : Boolean );
var i : Integer;
begin
  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_EquivalenciaSBS.Codigo_Proceso) then
     Carga_Valores_EquivalenciaSBS( dFecha_Calculo );

  // Si la fecha no corresponde la vuelve a cargar
  if Reg_EquivalenciaSBS.Fecha_Calculo[0] <> dFecha_Calculo then
     Carga_Valores_EquivalenciaSBS( dFecha_Calculo );

  Result := False;
  for i := 0  to VarArrayHighBound(Reg_EquivalenciaSBS.Codigo_Proceso, 1 )-1 do
  begin
     if (Reg_EquivalenciaSBS.Codigo_Proceso[i] = sCodigo_Proceso) and
        (Reg_EquivalenciaSBS.Codigo_Objeto[i]  = sCodigo_Objeto)  and
        (Reg_EquivalenciaSBS.Codigo_sistema[i] = sCodigo_Sistema) and
        //ggarcia 14-12-2016 si la equivalencia es blaco o nulo devuelve false tambien
        (Reg_EquivalenciaSBS.Codigo_Equiv[i]   <> ' ')            and
        (Reg_EquivalenciaSBS.Codigo_Equiv[i]   <> null)           then
     begin
        sCodigo_Equiv := Reg_EquivalenciaSBS.Codigo_Equiv[i];
        Result := True;
        Break;
     end;
  end;
end;

Procedure Carga_Valores_Equivalencia( dFecha : TDatetime);
var i : LongInt;
begin
     WITH DMFuncionesMemory.QRY_General do
     begin
       Close;
       Sql.Clear;
       SQL.Add('SELECT * FROM QS_SYS_EQUIVALEN a'
             +' WHERE  a.Fecha_desde IN ( SELECT MAX(b.Fecha_desde)'
            + '                            FROM QS_SYS_EQUIVALEN b'
            + '                           WHERE a.Codigo_Objeto  = b.Codigo_Objeto'
            + '                             AND a.Codigo_Proceso = b.Codigo_Proceso'
            + '                             AND a.Codigo_Sistema = b.Codigo_Sistema'
            // ggarcia 25-01-2013 se agregan estas dos condiciones ya que no funcionaba cuando habian dos equivalencias
            //                    la primera con fecha hasta y la segunda sin fecha hasta
            + '                             AND b.Fecha_Desde    <= :Fecha'
            + '                             AND (b.Fecha_Hasta >= :Fecha OR b.Fecha_Hasta IS NULL) )'
              );
      Sql.Add(' ORDER BY Codigo_Proceso'
             +'  ,Codigo_Sistema'
             );
       Parambyname('Fecha').asDate := dFecha;
       Open;

//       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount + 1;
//        DmFuncionesMemory.QRY_General.first;
       Reg_Equivalencia.Fecha_Calculo   := VarArrayCreate([0, i], varDate);
       Reg_Equivalencia.Codigo_Proceso  := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia.Codigo_Objeto   := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia.Codigo_Sistema  := VarArrayCreate([0, i], varOleStr);
       Reg_Equivalencia.Codigo_Equiv    := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while not eof do
       begin
          // Nuevo: agrego otro registro para fecha de calculo para verificar vigencia de carga
          Reg_Equivalencia.Fecha_Calculo[i]  := dFecha;
          Reg_Equivalencia.Codigo_Proceso[i] := Trim(Fieldbyname('Codigo_Proceso').asString);
          Reg_Equivalencia.Codigo_Objeto[i]  := Trim(Fieldbyname('Codigo_Objeto').asString);
          Reg_Equivalencia.Codigo_Sistema[i] := Trim(Fieldbyname('Codigo_Sistema').asString);
          Reg_Equivalencia.Codigo_Equiv[i]   := Trim(Fieldbyname('Codigo_Equiv').asString);
          Inc(i);
          Next;
       end;
       Close;
    end;
end;

Procedure Busca_Equivalencia_Mem( const sCodigo_Proceso : String;
                              const sCodigo_Objeto  : String;
                              const sCodigo_Sistema : String;
                              const dFecha_Calculo  : TDateTime;
                              var sCodigo_Equiv  : String;
                              var Result : Boolean );
var i : Integer;
begin
  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Equivalencia.Codigo_Proceso) then
     Carga_Valores_Equivalencia( dFecha_Calculo );

  // Si la fecha no corresponde la vuelve a cargar
  if Reg_Equivalencia.Fecha_Calculo[0] <> dFecha_Calculo then
     Carga_Valores_Equivalencia( dFecha_Calculo );

  Result := False;
  for i := 0  to VarArrayHighBound(Reg_Equivalencia.Codigo_Proceso, 1 )-1 do
  begin
     if (Reg_Equivalencia.Codigo_Proceso[i] = sCodigo_Proceso) and
        (Reg_Equivalencia.Codigo_Objeto[i]  = sCodigo_Objeto)  and
        (Reg_Equivalencia.Codigo_sistema[i] = sCodigo_Sistema) and
        //ggarcia 14-12-2016 si la equivalencia es blaco o nulo devuelve false tambien
        (Reg_Equivalencia.Codigo_Equiv[i]   <> ' ')            and
        (Reg_Equivalencia.Codigo_Equiv[i]   <> null)           then
     begin
        sCodigo_Equiv := Reg_Equivalencia.Codigo_Equiv[i];
        Result := True;
        Break;
     end;
  end;
end;

