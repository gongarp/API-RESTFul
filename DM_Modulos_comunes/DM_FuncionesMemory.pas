         SQL.Add(' WHERE a.instrumento = b.cod_instrumento   ');
         SQL.Add(' and   b.cod_calc_pte_ins = c.codigo_formula   ');
         SQL.Add(' and   c.aplica_factor_correccion = ''S''   ');
         SQL.Add(' UNION ');
         SQL.Add(' SELECT DISTINCT c.codigo_formula,   ');
         SQL.Add('                 a.emisor as Codigo_Emisor,   ');
         SQL.Add('                 a.instrumento as Codigo_Instrumento,   ');
         SQL.Add('                 '' '' as serie,   ');
         SQL.Add('                 1 as Cupon_Desde,   ');
         SQL.Add('                 1 as Cupon_Hasta,   ');
         SQL.Add('                 c.Mon_Ind_Correccion as COD_MONEDA_IND,   ');
         SQL.Add('                 c.Fecha_Desde_Corr as COD_TRATAM_INICIO,   ');
         SQL.Add('                 c.Fecha_Hasta_Corr as COD_TRATAM_TERMINO,   ');
         SQL.Add('                 0 as Fecha_Desde ,   ');
         SQL.Add('                 0 as Fecha_Hasta,   ');
         SQL.Add('                 '' '' as Fecha_Inicio_Tratam,   ');
         SQL.Add('                 '' '' as Fecha_Termino_Tratam   ');
         SQL.Add(' FROM  qs_tra_omd_det_rf a, qs_fin_instrum b, QS_FIN_FORMULA_TIR c   ');
         SQL.Add(' WHERE a.instrumento = b.cod_instrumento   ');
         SQL.Add(' and   b.cod_calc_pte_ins = c.codigo_formula   ');
         SQL.Add(' and   c.aplica_factor_correccion = ''S''   ');
         Open;

         while not eof do
         begin
            Reg_Excepcion_Cambiaria.Codigo_Emisor[i]      := Trim(Fieldbyname('Codigo_Emisor').asString);
            Reg_Excepcion_Cambiaria.Codigo_Instrumento[i] := Trim(Fieldbyname('Codigo_Instrumento').asString);
            Reg_Excepcion_Cambiaria.Serie[i]              := Trim(Fieldbyname('Serie').asString);
            if Transaccion_Implica(sEmpresa_Usuario,'FECHAVIG') then
               Reg_Excepcion_Cambiaria.Fecha_Vig[i]       := Fieldbyname('Fecha_Vig').asdatetime;
            if FindField('Cupon_Desde') <> Nil then
               if Not Fieldbyname('Cupon_Desde').isNull then
                  Reg_Excepcion_Cambiaria.Cupon_Desde[i]     := Fieldbyname('Cupon_Desde').AsFloat;     //Fieldbyname('Cupon_Desde').asString;     PA & DC 03052018

            if FindField('Cupon_Hasta') <> Nil then
               if Not Fieldbyname('Cupon_Hasta').isNull then
                  Reg_Excepcion_Cambiaria.Cupon_Hasta[i]     := Fieldbyname('Cupon_Hasta').AsFloat;  //Fieldbyname('Cupon_Hasta').asString;     PA & DC 03052018


            Reg_Excepcion_Cambiaria.Ptje_Aplica_Reajuste[i]  := 100;

            Reg_Excepcion_Cambiaria.COD_MONEDA_IND[i]     := Trim(Fieldbyname('COD_MONEDA_IND').asString);
            Reg_Excepcion_Cambiaria.COD_TRATAM_INICIO[i]  := Trim(Fieldbyname('COD_TRATAM_INICIO').asString);
            Reg_Excepcion_Cambiaria.COD_TRATAM_TERMINO[i] := Trim(Fieldbyname('COD_TRATAM_TERMINO').asString);

            Reg_Excepcion_Cambiaria.Fecha_Desde[i]        := 0;
            Reg_Excepcion_Cambiaria.Fecha_Hasta[i]        := 0;

            Reg_Excepcion_Cambiaria.Fecha_Inicio_Tratam[i]  := 0;
            Reg_Excepcion_Cambiaria.Fecha_Termino_Tratam[i] := 0;
            Next;
            Inc(i);
         end;
         Close;
       end;
     end;
end;
