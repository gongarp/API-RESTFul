procedure leer_valor_cambio_tramo_Mem(const sMon_Origen  : String;
                                      const sMon_Paridad : String;
                                      sTipo_Paridad      : String;
                                      dfecha             : TDatetime;
                                      fdias              : Double;
                                      var fParidad       : Double;
                                      var Result         : Boolean);
var
 sTipo_Moneda,
 sTipo_Unidad,
 sUnidad,
 sTipo_Variacion,
 sUnidad_Conversion : String;
 aux_pchar : Array[0..250] of Char;
 bResult   : Boolean;

begin
   Result := True;
   Busca_Valores_Monedas_Periodo_Mem(sMon_Origen
                                    ,sUnidad_Conversion
                                    ,sTipo_Moneda
                                    ,sTipo_Unidad
                                    ,sUnidad
                                    ,sTipo_Variacion
                                    );


   // ggarcia 07-11-2023
   if (sTipo_Moneda = 'M') and
      (sMon_Origen  = sMon_Paridad) then
   begin
      Result   := true;
      fParidad := 1;
      exit;
   end;


   {Busco la fecha de paridad}
   if sTipo_Variacion <> 'D' then
   begin
      if NOT leer_fecha_periodo(sTipo_Unidad
                               ,sUnidad
                               ,sTipo_Variacion
                               ,dfecha) then
      begin
         strpcopy(aux_pchar
                 ,'(Mem) Error en definición de período para: '''+sMon_Origen+''''
                 +#10'con fecha: '+datetostr(dfecha_Periodo));
         Application.MessageBox(aux_pchar
                              ,'Valor Paridad'
                              ,mb_OK);
         Result := False;
         exit;
      end;
   end
   else
      dfecha_Periodo := dfecha;

   {Busco Paridad}
   Buscar_Valor_Cambio_Tramo_Mem(sMon_Origen
                                ,sTipo_Paridad
                                ,sMon_Paridad
                                ,sTipo_Moneda
                                ,dfecha_Periodo
                                ,fdias
                                ,fParidad
                                ,bResult);

   if (not bResult) and (Transaccion_Implica('FORWARD','INTERPOLAC')) then
      Buscar_valor_cambio_tramo_interpola(sMon_Origen
                                         ,sTipo_Paridad
                                         ,sMon_Paridad
                                         ,sTipo_Moneda
                                         ,dfecha_Periodo
                                         ,fdias
                                         ,fParidad
                                         ,bResult);
////DC17/11/2021
   if (not bResult) then
   begin
     Buscar_LastValor_Cambio_Tramo_Mem(sMon_Origen
                                      ,sTipo_Paridad
                                      ,sMon_Paridad
                                      ,sTipo_Moneda
                                      ,dfecha_Periodo
                                      ,fdias
                                      ,fParidad
                                      ,bResult);

     if (not bResult) and (Transaccion_Implica('FORWARD','INTERPOLAC')) then
        Buscar_Lastvalor_cambio_tramo_interpola(sMon_Origen
                                               ,sTipo_Paridad
                                               ,sMon_Paridad
                                               ,sTipo_Moneda
                                               ,dfecha_Periodo
                                               ,fdias
                                               ,fParidad
                                               ,bResult);
   end;
///DC17/11/2021


   Result := bResult;
//   if (Not bResult)  or
//      (fParidad = 0) then
   if (Not bResult) then
   begin
      {Busco a reves (solo una vez por re_llamado}
      if (sTipo_Moneda = 'M') and NOT re_llamado then
      begin
         re_llamado := True;
         leer_valor_cambio_tramo_Mem(sMon_Paridad,
                                     sMon_Origen,
                                     sTipo_Paridad,
                                     dfecha,
                                     fdias,
                                     fParidad,
                                     Result);
         if Result then
            if fParidad <> 0 then
               fParidad := 1 / fParidad
            else
               fParidad := 0;
         re_llamado := False;
      end
      else
      begin
         Result := False;
         fParidad := 0;
         if sTipo_Moneda = 'T' then
            if bResult then
               Result := True;
      end
   end;

   // ggarcia 16-03-2015 Debe permitir valores en cero.
   {if (sTipo_Moneda = 'M') and
      (fParidad = 0)       then
      Result := False;
   }
end;

