         Reg_Valuacion.PROCESO[i]        := Fieldbyname('Proceso').asString;
         Reg_Valuacion.CARTERA[i]        := Fieldbyname('Cartera').asString;
         Reg_Valuacion.PAIS[i]           := Fieldbyname('Pais').asString;
         Reg_Valuacion.EMISOR[i]         := Fieldbyname('Emisor').asString;
         Reg_Valuacion.INSTRUMENTO[i]    := Fieldbyname('Instrumento').asString;
         Reg_Valuacion.MONEDA_INSTRUM[i] := Fieldbyname('Moneda_Instrum').asString;
         Reg_Valuacion.SERIE[i]          := Fieldbyname('Serie').asString;
         Reg_Valuacion.MOTIVO[i]         := Fieldbyname('Motivo').asString;
         Reg_Valuacion.TIPO_VALUAC[i]    := Fieldbyname('Tipo_Valuac').asString;
         Reg_Valuacion.FECHA_DESDE[i]    := Fieldbyname('Fecha_Desde').AsDateTime;
         Reg_Valuacion.FECHA_HASTA[i]    := Fieldbyname('Fecha_Hasta').AsDateTime;
         Reg_Valuacion.FORMULA_PTE[i]    := Fieldbyname('Formula_Pte').asString;
         Reg_Valuacion.ORIGEN[i]         := Fieldbyname('Origen').asString;
         Reg_Valuacion.BASE_PRECIO[i]    := Fieldbyname('Base_Precio').asFloat;
         Reg_Valuacion.MON_IND[i]        := Fieldbyname('Mon_Ind').asString;
         Reg_Valuacion.TRANSACCION[i]    := Fieldbyname('Transaccion').asString;
         Reg_Valuacion.TASA_BASE[i]      := Fieldbyname('Tasa_Base_TabDesarr').asString;
         Reg_Valuacion.CODIGO_FORMULA[i] := Fieldbyname('Codigo_Formula_TabDesarr').asString;
         Inc(i);
         Next;
      end;
      Close;
   end;
end;

procedure Busca_Valuacion_Mem(Reg_Val_In       : TRegistro_Valoriza_In;
                              var sTipo_Valuac : String;
                              var sFormula_Pte : String;
                              var fBase_Precio : Double;
                              var sMon_Ind     : String;
                              var sOrigen      : String;
                              var bValuacion   : Boolean);

var sTasa_Base      : string;
    sCodigo_Formula : string;
begin
    sTasa_Base      := '';
    sCodigo_Formula := '';

    Busca_Valuacion_Mem(Reg_Val_In
                       ,sTipo_Valuac
                       ,sFormula_Pte
                       ,fBase_Precio
                       ,sMon_Ind
                       ,sOrigen
                       ,sTasa_Base
                       ,sCodigo_Formula
                       ,bValuacion);

end;

procedure Busca_Valuacion_Mem(Reg_Val_In          : TRegistro_Valoriza_In;
                              var sTipo_Valuac    : String;
                              var sFormula_Pte    : String;
                              var fBase_Precio    : Double;
                              var sMon_Ind        : String;
                              var sOrigen         : String;
                              var sTasa_Base      : string;
                              var sCodigo_Formula : string;
                              var bValuacion      : Boolean) overload;
var sProceso     : String;
    sTransaccion : String;
    sCartera     : String;
    sPais        : String;
    i            : Integer;
    y            : Integer;
    icant        : Integer;
begin

   sTipo_Valuac := '';
   sFormula_Pte := '';
   fBase_Precio := 0;
   sMon_Ind     := '';
   sOrigen      := '';
   sTasa_Base   := '';
   sCodigo_Formula := '';


   if NOT VarIsArray(Reg_Valuacion.Proceso) then
      Carga_Metodos_Valuacion_Mem;

   icant := VarArrayHighBound(Reg_Valuacion.Proceso, 1);

   bValuacion   := False;
   //Verifica si existe valuacion definida por proceso
   // Solo ese caso toma en cuenta condicion
   sProceso := EmptyStr;
   for i := 0 to icant  do
   begin
      if Reg_Valuacion.Proceso[i] = Trim(Reg_Val_In.Proceso_Valuacion) then
      begin
         sProceso := Trim(Reg_Val_In.Proceso_Valuacion);
         Break;
      end;
   end;

   if (sProceso = EmptyStr) or
      (sProceso = '') then
      exit;

   //Verifica si existe valuacion definida por cartera
   // Solo ese caso toma en cuenta condicion
   sCartera := EmptyStr;
   for i := 0 to icant  do
   begin
      if    ( Reg_Valuacion.Cartera[i] = Trim(Reg_Val_In.Cartera) )
        and (    ((sProceso <> EmptyStr) and (Reg_Valuacion.Proceso[i] = sProceso) )
              or ((sProceso =  EmptyStr) and (Reg_Valuacion.Proceso[i] = EmptyStr))
            ) then
      begin
         sCartera := Trim(Reg_Val_In.Cartera);
         Break;
      end;
   end;

   //Verifica si existe valuacion definida por transaccion
   // Solo ese caso toma en cuenta condicion
   sTransaccion := EmptyStr;
   if Trim(Reg_Val_In.Transaccion) <> '' then  // 17-01-2019
     for i := 0 to icant  do
     begin
        if    ( Reg_Valuacion.Transaccion[i] = Trim(Reg_Val_In.Transaccion) )
          and (    ((sProceso <> EmptyStr) and (Reg_Valuacion.Proceso[i] = sProceso) )
                or ((sProceso =  EmptyStr) and (Reg_Valuacion.Proceso[i] = EmptyStr))
              ) then
        begin
           sTransaccion := Trim(Reg_Val_In.Transaccion);
           Break;
        end;
     end;


   //Verifica si existe valuacion definida por pais
   // Solo ese caso toma en cuenta condicion
   sPais := EmptyStr;
   for i := 0 to icant  do
   begin
      if    (     Reg_Valuacion.Pais[i] = Trim(Reg_Val_In.Pais_Titulo) )
        and (    ((sProceso <> EmptyStr) and (Reg_Valuacion.Proceso[i] = sProceso) )
              or ((sProceso =  EmptyStr) and (Reg_Valuacion.Proceso[i] = EmptyStr))
            ) then

      begin
         sPais := Trim(Reg_Val_In.Pais_Titulo);
         Break;
      end;
   end;

   for y := 1 to 2 do
   begin

   // Busco Valuacion para Emisor, Instrumento, Serie y Motivo
   if Not bValuacion then
      for i := 0 to icant  do
      begin
         if    (Reg_Valuacion.Serie[i]       = Trim(Reg_Val_In.sSerie))
           and (Reg_Valuacion.Emisor[i]      = Trim(Reg_Val_In.sEmisor))
           and (Reg_Valuacion.Instrumento[i] = Trim(Reg_Val_In.sInstrumento))
           and (Reg_Valuacion.Motivo[i]      = Trim(Reg_Val_In.Motivo_Operacion))
           and (    ((y = 1) and (Reg_Valuacion.Moneda_Instrum[i] = Trim(Reg_Val_In.sUnidadMonetaria)) )
                 or ((y = 2) and (Reg_Valuacion.Moneda_Instrum[i] = EmptyStr))
                )

           and (Reg_Val_In.dFechaCalculo >= Reg_Valuacion.FECHA_DESDE[i])
           and ((Reg_Val_In.dFechaCalculo <= Reg_Valuacion.FECHA_HASTA[i])
           OR   (Reg_Valuacion.FECHA_HASTA[i] = StrToDateTime(Fecha_Nula) ))

           // Proceso
           and (    ((sProceso <> EmptyStr) and (Reg_Valuacion.Proceso[i] = sProceso) )
                 or ((sProceso =  EmptyStr) and (Reg_Valuacion.Proceso[i] = EmptyStr))
                )
           // Transaccion
           and (    ((sTransaccion <> EmptyStr) and (Reg_Valuacion.Transaccion[i] = sTransaccion) )
                 or ((sTransaccion =  EmptyStr) and (Reg_Valuacion.Transaccion[i] = EmptyStr))
                )
           // Cartera
           and (    ((sCartera <> EmptyStr) and (Reg_Valuacion.Cartera[i] = sCartera) )
                 or ((sCartera =  EmptyStr) and (Reg_Valuacion.Cartera[i] = EmptyStr))
                )
           // Pais
           and (    ((sPais <> EmptyStr) and (Reg_Valuacion.Pais[i] = sPais) )
                 or ((sPais =  EmptyStr) and (Reg_Valuacion.Pais[i] = EmptyStr))
                )

                then
         begin
            bValuacion := True;
            Break;
         end;
      end;

   // Busco Valuacion para Emisor,Instrumento y Serie
   if Not bValuacion then
      for i := 0 to icant  do
      begin
         if    (Reg_Valuacion.Serie[i]       = Trim(Reg_Val_In.sSerie))
           and (Reg_Valuacion.Emisor[i]      = Trim(Reg_Val_In.sEmisor))
           and (Reg_Valuacion.Instrumento[i] = Trim(Reg_Val_In.sInstrumento))
           and (Reg_Valuacion.Motivo[i]      = EmptyStr)
