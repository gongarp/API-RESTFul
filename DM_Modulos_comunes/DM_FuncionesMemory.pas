     While Not Eof do
     begin
        Reg_Nemotecnicos_RV.Codigo_Instrumento[i] := Fieldbyname('Codigo_Instrumento').asString;
        Reg_Nemotecnicos_RV.Codigo_Nemotecnico[i] := Fieldbyname('Codigo_Nemotecnico').asString;
        Reg_Nemotecnicos_RV.DESCRIPCION[i]        := Fieldbyname('DESCRIPCION').asString;
        Reg_Nemotecnicos_RV.Codigo_Identidad[i]   := Fieldbyname('Codigo_Identidad').asString;
        Reg_Nemotecnicos_RV.SERIE[i]              := Fieldbyname('SERIE').asString;
        Reg_Nemotecnicos_RV.FECHA_DESDE[i]        := Fieldbyname('FECHA_DESDE').asDatetime;
        Reg_Nemotecnicos_RV.SECTOR[i]             := Fieldbyname('SECTOR').asString;
        Reg_Nemotecnicos_RV.TIPO[i]               := Fieldbyname('TIPO').asString;
        Reg_Nemotecnicos_RV.TASA_BASE[i]          := Fieldbyname('TASA_BASE').asString;
        Reg_Nemotecnicos_RV.FORMULA[i]            := Fieldbyname('FORMULA').asString;
        Reg_Nemotecnicos_RV.PAIS[i]               := Fieldbyname('PAIS').asString;
        Reg_Nemotecnicos_RV.RUN[i]                := Fieldbyname('RUN').asString;
        Reg_Nemotecnicos_RV.MONEDA[i]             := Fieldbyname('MONEDA').asString;
        if Fieldbyname('Fecha_Vencimiento').IsNull then
          Reg_Nemotecnicos_RV.Fecha_Vencimiento[i]  := 0
        else
          Reg_Nemotecnicos_RV.Fecha_Vencimiento[i]  := Fieldbyname('Fecha_Vencimiento').asDatetime;

        inc(i);
        Next;
     end;
     Close;
  end;
end;

procedure Datos_Nemotecnico_Mem(sNemotecnico : String;
                            var sEmisor      : String;
                            var sInstrumento : String;
                            var sSerie       : String;
                            var sSector      : String;
                            var sPais        : String;
                            var sRun         : String;
                            var sMoneda      : String;
                            var dFecha_Emision : Tdatetime;
                            var dFecha_Vencimiento : Tdatetime;
                            var bResultado   : Boolean
                            );
var i : Integer;
begin
   bResultado := False;
   For  i := 0 to VarArrayHighBound(Reg_Nemotecnicos_RV.Codigo_Nemotecnico, 1 ) do
   begin
      if  Reg_Nemotecnicos_RV.Codigo_Nemotecnico[i] = sNemotecnico  then
      begin
         sEmisor        := Reg_Nemotecnicos_RV.Codigo_Identidad[i];
         sInstrumento   := Reg_Nemotecnicos_RV.Codigo_Instrumento[i];
         sSerie         := Reg_Nemotecnicos_RV.Serie[i];
         sSector        := Reg_Nemotecnicos_RV.Sector[i];
         sPais          := Reg_Nemotecnicos_RV.Pais[i];
         sRun           := Reg_Nemotecnicos_RV.Run[i];
         sMoneda        := Reg_Nemotecnicos_RV.Moneda[i];
         dFecha_Emision := Reg_Nemotecnicos_RV.FECHA_DESDE[i];
         dFecha_Vencimiento := Reg_Nemotecnicos_RV.FECHA_VENCIMIENTO[i];
         bResultado := True;
         Break;
      end;
   end;
end;

