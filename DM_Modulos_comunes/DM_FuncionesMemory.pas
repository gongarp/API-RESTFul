function Metodo_Sin_Tasa_Referencia_Mem(const sFormula : String;
                                        dFecha_Calculo : Tdatetime
                                        ) : String;
var i  : Integer;
begin
  Result  := '';

  if NOT VarIsArray(Reg_Metodo_Sin_Tasa_Referencia.Cod_Formula) then
     Carga_Valores_Metodo_Sin_Tasa_Referencia_Mem;

  for i := 0 to VarArrayHighBound( Reg_Metodo_Sin_Tasa_Referencia.Cod_Formula, 1 )-1 do 
  begin
     if (Reg_Metodo_Sin_Tasa_Referencia.Cod_Formula[i] = sFormula
        ) and
        ( (Reg_Metodo_Sin_Tasa_Referencia.Fecha_Desde[i]  <= dFecha_Calculo ) or
          (Reg_Metodo_Sin_Tasa_Referencia.Fecha_Hasta[i]  >= dFecha_Calculo ) or
          (Reg_Metodo_Sin_Tasa_Referencia.Fecha_Hasta[i] = Null )
        )  then
     begin
        Result := Reg_Metodo_Sin_Tasa_Referencia.Metodo_Sin_T_Ref[i];
        Break;
     end;
  end;
end;

