Procedure Carga_Clasificaciones_Mem;
var i : LongInt ;
begin
    with DMFuncionesMemory.QRY_General do
    begin
      SQL.Clear;
      SQL.Add('select a.Codigo_Clasif                     ');
      SQL.Add('      ,a.Objeto                            ');
      SQL.Add('      ,a.elemento                          ');
      SQL.Add('      ,b.descripcion_Nodo                  ');
      SQL.Add('  from qs_sys_clasif_obj a                 ');
      SQL.Add('      ,qs_sys_est_cla b                    ');
      SQL.Add('  where b.Codigo_Objeto = a.Codigo_Clasif  ');
      SQL.Add('    and b.Nodo = a.Nodo                    ');
      Open;

      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
      Reg_Clasificacion.Codigo_Clasif := VarArrayCreate([0, i], varOleStr);
      Reg_Clasificacion.Objeto        := VarArrayCreate([0, i], varOleStr);
      Reg_Clasificacion.Elemento      := VarArrayCreate([0, i], varOleStr);
      Reg_Clasificacion.Descripcion   := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Clasificacion.Codigo_Clasif[i] := Fieldbyname('Codigo_Clasif').asString;
         Reg_Clasificacion.Objeto[i]        := Fieldbyname('Objeto').asString;
         Reg_Clasificacion.Elemento[i]      := Fieldbyname('elemento').asString;
         Reg_Clasificacion.Descripcion[i]   := Fieldbyname('descripcion_Nodo').asString;
