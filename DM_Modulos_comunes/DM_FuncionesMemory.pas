Function Busca_Motivo_OMD_Mem(  const sEmpresa       : String;
                                const sTransaccion   : String;
                                const sFolio_Interno : String;
                                      fItem_Omd      : Double;
                                dFecha_Desde   : TDatetime
                             ) : String;
var i
   ,j             : Integer;
   fFolio_Interno : Double;
   bExiste        : Boolean;
begin
  Busca_Motivo_OMD_Mem := '';
  fFolio_Interno       := StrToFloat(sFolio_Interno);

  if NOT VarIsArray(Reg_Motivo_OMD.Folio_Interno) then
     Carga_Motivo_Mem( dFecha_Desde );

  for i := 0 to  VarArrayHighBound(Reg_Motivo_OMD.Folio_Interno, 1 )-1 do
  begin
     if Reg_Motivo_OMD.Folio_Interno[i] = fFolio_Interno then
     begin
        bExiste := True;
        Break;
     end;
  end;

  if bExiste then
  begin
     //Retrocedo hasta Primer Folio Igual  por cuestion de fechas
     For j := i Downto 0 do
       if Reg_Motivo_OMD.Folio_Interno[J] <> fFolio_Interno then
          Break;

     i := j + 1;
     while (i <= VarArrayHighBound(Reg_Motivo_OMD.Folio_Interno , 1 )) and
           (Reg_Motivo_OMD.Folio_Interno[i] = fFolio_Interno) do
     begin
       if (Reg_Motivo_OMD.Empresa[i]          = sEmpresa ) and
            (Reg_Motivo_OMD.Transaccion[i]    = sTransaccion ) and
            (Reg_Motivo_OMD.Item_Omd[i]       = fItem_Omd ) and
            ( (Reg_Motivo_OMD.Fecha_Desde[i]  <= dFecha_Desde ) or
              (Reg_Motivo_OMD.Fecha_Hasta[i]  >= dFecha_Desde ) or
              (Reg_Motivo_OMD.Fecha_Hasta[i] = Null )
            )  then
         begin
           Busca_Motivo_OMD_Mem := Reg_Motivo_OMD.Cod_Motivo[i];
           Break;
        end;
        Inc(i);
     end;
  end;
end;

Procedure Ordenamiento_Motivo_OMD_Mem( var Reg_Motivo_OMD : TReg_Motivo;
                                       iLo, iHi: Integer
                                      );
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd      : Double;
    sTransaccion,
    sEmpresa,
    sCod_Motivo    : String;
    dFecha_Hora,
    dFecha_Desde,
    dFecha_Hasta : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Motivo_OMD.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Motivo_OMD.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Motivo_OMD.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sEmpresa           := Reg_Motivo_OMD.Empresa[Lo];
         sTransaccion       := Reg_Motivo_OMD.Transaccion[Lo];
         fFolio_Interno     := Reg_Motivo_OMD.Folio_Interno[Lo];
         fItem_Omd          := Reg_Motivo_OMD.Item_Omd[Lo];
         dFecha_Hora        := Reg_Motivo_OMD.Fecha_Hora[Lo];
         dFecha_Desde       := Reg_Motivo_OMD.Fecha_Desde[Lo];
         dFecha_Hasta       := Reg_Motivo_OMD.Fecha_Hasta[Lo];
         sCod_motivo        := Reg_Motivo_OMD.Cod_motivo[Lo];

         Reg_Motivo_OMD.Empresa[Lo]       :=
                       Reg_Motivo_OMD.Empresa[Hi];
         Reg_Motivo_OMD.Transaccion[Lo]   :=
                       Reg_Motivo_OMD.Transaccion[Hi];
         Reg_Motivo_OMD.Folio_Interno[Lo] :=
                       Reg_Motivo_OMD.Folio_Interno[Hi];
         Reg_Motivo_OMD.Item_Omd[Lo]      :=
                       Reg_Motivo_OMD.Item_Omd[Hi];
         Reg_Motivo_OMD.Fecha_Hora[Lo]    :=
                       Reg_Motivo_OMD.Fecha_Hora[Hi];
         Reg_Motivo_OMD.Fecha_Desde[Lo]   :=
                       Reg_Motivo_OMD.Fecha_Desde[Hi];
         Reg_Motivo_OMD.Fecha_Hasta[Lo]   :=
                       Reg_Motivo_OMD.Fecha_Hasta[Hi];
         Reg_Motivo_OMD.Cod_motivo[Lo]   :=
                       Reg_Motivo_OMD.Cod_motivo[Hi];

         Reg_Motivo_OMD.Empresa[Hi]       := sEmpresa;
         Reg_Motivo_OMD.Transaccion[Hi]   := sTransaccion;
         Reg_Motivo_OMD.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Motivo_OMD.Item_Omd[Hi]      := fItem_Omd;
         Reg_Motivo_OMD.Fecha_Hora[Hi]    := dFecha_Hora;
         Reg_Motivo_OMD.Fecha_Desde[Hi]   := dFecha_Desde;
         Reg_Motivo_OMD.Fecha_Hasta[Hi]   := dFecha_Hasta;
         Reg_Motivo_OMD.Cod_motivo[Hi]    := sCod_motivo;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Motivo_OMD_Mem(Reg_Motivo_OMD, iLo, Hi);
    if Lo < iHi then Ordenamiento_Motivo_OMD_Mem(Reg_Motivo_OMD, Lo, iHi);
end;
}


