Procedure Carga_Metodo_Calcula_Tasa_Basica( dFecha  : TDateTime);
var i : Integer;
begin
   WITH dmFuncionesMemory.Qry_General do
     begin
       SQL.Clear;
       SQL.Add('SELECT *');
       SQL.Add('  FROM Qs_Fin_Met_TBasica');
       SQL.Add(' WHERE Fecha_Desde <= :Fecha');
       SQL.Add('   AND (Fecha_Hasta IS NULL OR Fecha_Hasta >= :Fecha)');
       Sql.Add(' ORDER BY Cod_Formula' );
       ParamByName('Fecha' ).AsDate := dFecha;
       Open;

       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

       Reg_Metodo_Tasa_Basica.Cod_Formula   := VarArrayCreate([0, i], varOleStr);
       Reg_Metodo_Tasa_Basica.METODO        := VarArrayCreate([0, i], varOleStr);
       Reg_Metodo_Tasa_Basica.Dias_Promedio := VarArrayCreate([0, i], varDouble);
       Reg_Metodo_Tasa_Basica.Codigo_Tasa   := VarArrayCreate([0, i], varOleStr);
       Reg_Metodo_Tasa_Basica.Mon_Nac_Ext   := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while not eof do
       begin
           Reg_Metodo_Tasa_Basica.Cod_Formula[i]    := Fieldbyname('Cod_Formula').asString;
           Reg_Metodo_Tasa_Basica.METODO[i]         := Fieldbyname('METODO').asString;
           Reg_Metodo_Tasa_Basica.Dias_Promedio[i]  := Fieldbyname('Dias_Promedio').asFloat;
           Reg_Metodo_Tasa_Basica.Codigo_Tasa[i]    := Fieldbyname('Codigo_Tasa').asString;
           Reg_Metodo_Tasa_Basica.Mon_Nac_Ext[i]    := Fieldbyname('Mon_Nac_Ext').asString;
           Inc(i);
           Next;
       end;

       Close;
       UnPrepare;
     end;
end;

function Metodo_Calculo_Tasa_Basica_Mem( sFormula       : String;
