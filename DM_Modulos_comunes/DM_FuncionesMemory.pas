function Pais_Para_CodGeo_Mem( sCodGeo : String) : String;
var
  ant_CodGeo : String;
  Buscar     : Boolean;
begin
   if NOT VarIsArray(Reg_Division_Geografica.COD_DESC_DIVISION) then
     Carga_Valores_Division_Geografica_Mem;
     
   Buscar := True;
   While Buscar do
   begin
     ant_CodGeo := sCodGeo;
     Division_Geografica_Padre_Mem(sCodGeo
                                  ,Buscar);
     if ant_CodGeo = sCodGeo then
        Buscar := False;
   end;
   Result := sCodGeo;
end;

procedure Division_Geografica_Padre_Mem(var sCodigo_Division : String;
                                        var Result           : Boolean);
var i  : Integer;
begin
  Result := False;
  for i := 0  to  VarArrayHighBound(Reg_Division_Geografica.COD_DESC_DIVISION, 1 )-1 do
  begin
     if Reg_Division_Geografica.COD_DESC_DIVISION[i] = sCodigo_Division then
     begin
        sCodigo_Division := Reg_Division_Geografica.IN__COD_DESC_DIVIS[i];
        Result := True;
        Break;
     end;
  end;
  
  if Reg_Division_Geografica.IN__COD_DESC_DIVIS[i] = 'TOP' then
  begin
     sCodigo_Division := Reg_Division_Geografica.COD_DESC_DIVISION[i];
     Result := True;
  end;

end;

