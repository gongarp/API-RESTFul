      Close;
      Unprepare;
    end;
end;

Procedure Clasificaciones_Mem(Const sObjeto                   : String;
                              Const sElemento                 : String;
                              Const sTipo_Clasificacion       : String;
                              Var   sDescrpcion_Clasificacion : String;
                              Var Result                      : Boolean);
var i      : Integer;
Begin
  Result           := False;
  if NOT VarIsArray(Reg_Clasificacion.Objeto) then
         Carga_Clasificaciones_Mem;

  for i := 0 to VarArrayHighBound(Reg_Clasificacion.Objeto , 1 )  do
  begin
     if (Reg_Clasificacion.Codigo_Clasif[i] = sTipo_Clasificacion) and
        (Reg_Clasificacion.Objeto[i]        = sObjeto            ) and
