Procedure Duration_Fijo_Mem(Const sInstrumento   : String;
                            dFecha_Calculo : TDateTime;
                            Var fDuration  : Double;
                            Var Result         : Boolean);
var //iLimite_Inferior
   //,iLimite_Superior
    i      : Integer;
   dFecha_Desde,
   dFecha_Hasta    : TDatetime;
   fValor_Duration : Double;
Begin
  fValor_Duration := 0;
  dFecha_Desde    := 0;
  dFecha_Hasta    := 0;

  if NOT VarIsArray(Reg_Duration_Fijo.Cod_Instrumento) then
     Carga_Valores_Duration_Fijo_Mem;

  Result           := False;
  for i := 0 TO VarArrayHighBound(Reg_Duration_Fijo.Cod_Instrumento, 1 )-1 do
  begin
     if  Reg_Duration_Fijo.Cod_Instrumento[i] = sInstrumento then
     begin
        Result          := True;
        dFecha_Desde    := Reg_Duration_Fijo.Fecha_Desde[i];
        dFecha_Hasta    := Reg_Duration_Fijo.Fecha_Hasta[i];
        fValor_Duration := Reg_Duration_Fijo.Valor_Duration[i];
        Break;
     end;
  end;

  If Result Then
  Begin
     If dFecha_Hasta = Null Then
        If dFecha_Calculo >= dFecha_Desde Then
        Begin
           Result := True;
           fDuration := fValor_Duration;
        End
     Else
        If (dFecha_Calculo >= dFecha_Desde) And
           (dFecha_Calculo <= dFecha_Hasta) Then
        Begin
           Result := True;
           fDuration := fValor_Duration;
        End;
  end;
end;

