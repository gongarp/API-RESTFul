Procedure Carga_Venta_Diferida_Mem(dFecha   : TDateTime;
                                   sEmpresa : String);
var i : LongInt;
begin
   try
     with DmFuncionesMemory.QRY_General do
     begin
       SQL.Clear;
       SQL.Add('SELECT a.* '
              +'  FROM QS_GAAP_VENTA_DIF a '
              +' WHERE a.EMPRESA       = :EMPRESA '
              +'   AND a.FECHA_DESDE  <= :FECHA_DESDE '
              +'   AND (a.FECHA_HASTA >= :FECHA_DESDE OR a.FECHA_HASTA IS NULL) ');

       ParamByName('EMPRESA').asString       := sEmpresa;
       ParamByName('FECHA_DESDE').AsDate := dfecha;

       Open;
       i := RecordCount;
       Reg_venta_dif.Transaccion  := VarArrayCreate([0, i], varOleStr);
       Reg_venta_dif.Fecha_Desde  := VarArrayCreate([0, i], varOleStr);
       Reg_venta_dif.Motivo_Inver := VarArrayCreate([0, i], varOleStr);
       Reg_venta_dif.Motivo_OMD   := VarArrayCreate([0, i], varOleStr);
       Reg_venta_dif.Empresa      := VarArrayCreate([0, i], varOleStr);
       i := 0;
       while not eof do
       begin
          Reg_venta_dif.Transaccion[i]  := Fieldbyname('Transaccion').asString;
          Reg_venta_dif.Fecha_Desde[i]  := Fieldbyname('Fecha_Desde').asString;
          Reg_venta_dif.Motivo_Inver[i] := Fieldbyname('Motivo_Inversion').asString;
          Reg_venta_dif.Motivo_OMD[i]   := Fieldbyname('Motivo_OMD').asString;
          Reg_venta_dif.Empresa[i]      := Fieldbyname('Empresa').asString;
          Inc(i);
          Next;
       end;
       Close;
     end;
   except
     i := 1;
     Reg_venta_dif.Transaccion  := VarArrayCreate([0, i], varOleStr);
     Reg_venta_dif.Fecha_Desde  := VarArrayCreate([0, i], varOleStr);
     Reg_venta_dif.Motivo_Inver := VarArrayCreate([0, i], varOleStr);
     Reg_venta_dif.Motivo_OMD   := VarArrayCreate([0, i], varOleStr);
     Reg_venta_dif.Empresa      := VarArrayCreate([0, i], varOleStr);
   end;
end;

procedure Busca_Venta_Diferida_Mem(dFecha_Calculo : TDateTime;
                                   sEmpresa       : String;
                                   sTransaccion   : String;
                                   sMotivo_Inver  : String;
                                   sMotivo_OMD    : String;
                               var Result         : Boolean);
var i : Integer;
begin
  Result := False;

  if NOT VarIsArray(Reg_venta_dif.Motivo_Inver) then
     Carga_Venta_Diferida_Mem(dFecha_Calculo,sEmpresa);

  for i := 0 to VarArrayHighBound(Reg_venta_dif.Motivo_Inver , 1 )  do
  begin
    if (Reg_venta_dif.Transaccion[i]  = sTransaccion) and
       (Reg_venta_dif.Motivo_Inver[i] = sMotivo_Inver) and
       (Reg_venta_dif.Motivo_OMD[i]   = sMotivo_OMD) then
    begin
      Result := True;
      Exit;
    end
    else
    begin
      if (Reg_venta_dif.Transaccion[i]  = sTransaccion) and
         (Reg_venta_dif.Motivo_Inver[i] = sMotivo_Inver) and
         (Reg_venta_dif.Motivo_OMD[i]   = EmptyStr) then
      begin
        Result := True;
        Exit;
      end;
    end;
  end;
end;


