{
Procedure Carga_Valores_Clasif_Riesgo_EmpCla_Mem( dFecha : TDatetime );
var i : LongInt;
    sCOD_EMP_SERIE,
    sCOD_INST_SERIE,
    sSERIE_CLASIF,
    sCLASIF_SERIE  : String;
    sCLASIF_EMP    : String;
    dFecha_Aux     : Tdatetime;
    sOrigen        : String;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
 // Hay que cargar todas las categorias para que despues pueda encontrar la que corresponde, Edosan
      SQL.Add('SELECT COD_EMP_SERIE'
             +'      ,COD_INST_SERIE'
             +'      ,SERIE_CLASIF'
             +'      ,F_CLASIF_SERIE'
             +'      ,CLASIF_SERIE'
             +'      ,CLASIF_EMP'
             +'      ,ORIGEN'
             +'  FROM QS_FIN_CL_RIESGOS'
             +' WHERE F_CLASIF_SERIE <= :Fecha'
             +' ORDER BY COD_EMP_SERIE'
             +'         ,COD_INST_SERIE '
             +'         ,SERIE_CLASIF'
             +'         ,F_CLASIF_SERIE DESC'    // Edosan CLASIF_SERIE
             );
       Parambyname('Fecha').asDatetime := dFecha;
       Open;

       i := RecordCount;

       Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE  := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF   := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE := VarArrayCreate([0, i], varDate);
       Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE   := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP     := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_Riesgo_EmpCla.ORIGEN         := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while Not eof do
       begin
          sCOD_EMP_SERIE  := Fieldbyname('COD_EMP_SERIE').asString;
          sCOD_INST_SERIE := Fieldbyname('COD_INST_SERIE').asString;
          sSERIE_CLASIF   := Fieldbyname('SERIE_CLASIF').asString;
          sOrigen         := Fieldbyname('ORIGEN').asString;

          Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE[i]  := sCOD_EMP_SERIE;
          Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE[i] := trim(sCOD_INST_SERIE);    // Se le agrego trim con fecha 10-11-2005 ya que no encontraba con un blanco en el bice
          Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF[i]   := trim(sSERIE_CLASIF);
          Reg_Clasif_Riesgo_EmpCla.ORIGEN[i]         := trim(sORIGEN);


          dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
          sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;
          sCLASIF_EMP   := Fieldbyname('CLASIF_EMP').asString;
          Next;
          Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE[i]   := sCLASIF_SERIE;
          Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE[i] := dFecha_Aux;
          Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP[i]     := sCLASIF_EMP;

          Inc(i);
       end;

       if i > 0 then
          Dec(i);

       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.COD_EMP_SERIE , i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.COD_INST_SERIE, i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.SERIE_CLASIF  , i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.CLASIF_SERIE  , i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.F_CLASIF_SERIE, i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.CLASIF_EMP    , i + 1);
       VarArrayRedim(Reg_Clasif_Riesgo_EmpCla.ORIGEN        , i + 1);
       Close;
   end;
end;
 }

