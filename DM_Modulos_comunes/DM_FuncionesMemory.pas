procedure Carga_RegDes_Mem(sTipo_Instrumento : String;
                           sEmisor           : String;
                           sInstrumento      : String;
                           sSerie            : String;
                           sUnidadMonetaria  : String;
                           fTasaEmision      : Double;
                           var RegDes        : TReg_Descriptor;
                           var sModulo_Err   : String;
                           var sString_Err   : String;
                           var Result        : Boolean);
var
  sSi_No_Descriptor : String;
begin
  if sTipo_Instrumento = 'U' then
  begin
    Leer_Instrumento_Mem(sInstrumento,
                         sSi_No_Descriptor,
                         RegDes.Tasa_Valor_PAR,    // Ojo recupero datos en
                         RegDes.Tasa_Valor_PTE,    // el registro descriptor
                         RegDes.Cod_Calc_PAR_D,    // para no generar mas variables
                         RegDes.Cod_Calc_TIR_D,    // Solo es un paso
                         Result);

    if NOT Result then
    begin
      sString_Err := 'No existe definición para instrumento: '
                    +sInstrumento;
      Result := False;
      exit;
    end;

    RegDes.Codigo_Emisor      := sEmisor;
    RegDes.Codigo_Instrumento := sInstrumento;
    RegDes.Serie              := sSerie;
    RegDes.Unidad_Mon         := sUnidadMonetaria;
    RegDes.Tasa_Emision       := fTasaEmision;
    RegDes.BASE_ORIGINAL      := 100;
    RegDes.BASE_CONVERSION    := 100;
    RegDes.Nro_Cupones        := 1;
  end
  else  // Instrumento Seriado
    Carga_Descriptor_Mem(sEmisor,
                         sInstrumento,
                         sSerie,
                         RegDes,
                         sModulo_Err,
                         sString_Err,
                         Result);
end;

procedure Carga_Valores_Desagio_Mem;
var i : Integer;
begin
   WITH DMFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      Sql.Add('SELECT Count(*) as NumReg '
             +' FROM QS_FIN_DESAGIO'
             );
      Open;
      i := Fieldbyname('NumReg').asInteger;
      Reg_Desagio.Pais            := VarArrayCreate([0, i], varOleStr);
      Reg_Desagio.Instrumento     := VarArrayCreate([0, i], varOleStr);
      Reg_Desagio.Emisor          := VarArrayCreate([0, i], varOleStr);
      Reg_Desagio.Serie           := VarArrayCreate([0, i], varOleStr);
      Reg_Desagio.Fecha_Desde     := VarArrayCreate([0, i], varDate);
      Reg_Desagio.Fecha_Hasta     := VarArrayCreate([0, i], varDate);
      Reg_Desagio.Codigo_Tasa     := VarArrayCreate([0, i], varOleStr);
      Reg_Desagio.Valor_Tasa      := VarArrayCreate([0, i], varDouble);
      Reg_Desagio.Operador_Logico := VarArrayCreate([0, i], varOleStr);
      Close;

      SQL.Clear;
      SQL.Add('SELECT * FROM QS_FIN_DESAGIO'
             );
      Open;


      if Not Fieldbyname('Pais').isNull then
      begin
         i := 0;
         while not eof do
         begin
           Reg_Desagio.Pais[i]            := Fieldbyname('Pais').asString;
           Reg_Desagio.Instrumento[i]     := Fieldbyname('Instrumento').asString;
           Reg_Desagio.Emisor[i]          := Fieldbyname('Emisor').asString;
           Reg_Desagio.Serie[i]           := Fieldbyname('Serie').asString;
           Reg_Desagio.Fecha_Desde[i]     := Fieldbyname('Fecha_Desde').AsDateTime;
           Reg_Desagio.Fecha_Hasta[i]     := Fieldbyname('Fecha_Hasta').AsDateTime;
           Reg_Desagio.Codigo_Tasa[i]     := Fieldbyname('Codigo_Tasa').asString;
           Reg_Desagio.Valor_Tasa[i]      := Fieldbyname('Valor_Tasa').asFloat;
           Reg_Desagio.Operador_Logico[i] := Fieldbyname('Operador_Logico').asString;
           Inc(i);
           Next;
         end;
      end;
      Close;
   end;
end;

procedure analiza_desagio_Mem(sEmisor                     : String;
                              sInstrumento                : String;
                              sSerie                      : String;
                              sCodigo_Tasa                : String;
                              iDiasBaseTasa               : Integer;
                              sTipoInteresTasa            : String;
                              iBaseMensualTasa            : Integer;
                              sTipoCalculoDiasTasa        : String;
                              dFecDesPeriodo              : TDateTime;
                              dFecHasPeriodo              : TDateTime;
                              fValor_Tasa                 : Double;
                              var dInicio                 : TDateTime;
                              var dTermino                : TDateTime;
                              var iVigenciaValorDesagio   : Integer;
                              var fValor_Tasa_new         : Double;
                              var sModulo_Err             : String;
                              var sString_Err             : String;
                              var bDesagio                : Boolean;
                              var Result                  : Boolean);

var
  sNew_Tasa        : String;
  sOperador_logico : String;

  iBaseDiasDesagio        : Integer;
  sTipoInteresDesagio,
  sPais_Tasa              : String;
  iBaseMensualDesagio     : Integer;
  sTipoCalculoDiasDesagio : String;
  iVigenciaMesesDesagio   : Integer;

  sTipo                   : String;
  fPeriodo                : Double;
  //fItem_Dir_Emisor        : Double;
  sAnualidad              : String;
  fBase_Porcen            : Double;
  sTipo_New               : String;
  fPeriodo_New            : Double;
  sAnualidad_New          : String;
  fBase_Porcen_New        : Double;
  //i         : Integer;
begin


    if Reg_Desagio.Fecha_Hasta = EncodeDate(1899,12,30) then
       dTermino := dFecHasPeriodo
    else
       dTermino := Reg_Desagio.Fecha_Hasta;


    Obtener_Base_Conversion(sCodigo_Tasa
                           ,sTipo
                           ,fPeriodo
                           ,sAnualidad
                           ,fBase_Porcen
                           ,sModulo_Err
                           ,sString_Err
                           ,Result);
    if NOT Result then
       exit;

    Obtener_Base_Conversion(sNew_Tasa
                           ,sTipo_New
                           ,fPeriodo_New
                           ,sAnualidad_New
                           ,fBase_Porcen_New
                           ,sModulo_Err
                           ,sString_Err
                           ,Result);
    if NOT Result then
       exit;

    conversion_tasas(sTipo_New
                    ,fPeriodo_New
                    ,sAnualidad_New
                    ,fBase_Porcen_New
                    ,sTipo
                    ,fPeriodo
                    ,sAnualidad
                    ,fBase_Porcen
                    ,fValor_Tasa_New
                    ,sModulo_Err
                    ,sString_Err
                    ,Result);

    if NOT Result then
       exit;

    Obtener_Tasa_base(sNew_Tasa
                     ,iBaseDiasDesagio
                     ,sTipoInteresDesagio
                     ,iBaseMensualDesagio
                     ,sTipoCalculoDiasDesagio
                     ,iVigenciaValorDesagio
                     ,iVigenciaMesesDesagio
                     ,sPais_Tasa
                     ,sModulo_err
                     ,sString_err
                     ,Result);

    if NOT Result then
       exit;

    Convierte_Base(iBaseDiasDesagio
                  ,sTipoInteresDesagio
                  ,fValor_Tasa_New
                  ,iDiasBaseTasa
                  ,sTipoInteresTasa
                  ,fValor_Tasa_New
                  ,sModulo_Err
                  ,sString_Err
                  ,Result);

    if NOT Result then
       exit;

    if dInicio < dFecDesPeriodo then
       dInicio := dFecDesPeriodo;

    if dTermino > dFecHasPeriodo then
       dTermino := dFecHasPeriodo;

    if sOperador_Logico = '>' then
       if fValor_Tasa > fValor_Tasa_New then
          bDesagio         := True;

    if sOperador_Logico = '<' then
       if fValor_Tasa < fValor_Tasa_New then
          bDesagio         := True;
end;

Procedure Busca_Desagio_Mem ( sEmisor                     : String;
                              sInstrumento                : String;
                              sSerie                      : String;
                              dFecDesPeriodo              : TDateTime;
                              dFecHasPeriodo              : TDateTime;
                              var sCodigo_Tasa            : String;
                              var fValor_Tasa             : Double;
                              var sOperador_Logico        : String;
                              var dFecha_Inicio           : TDateTime;
                              var dFecha_Termino          : TDateTime;
                              var Result                  : Boolean);
var
   fItem_Dir_Emisor   : Double;
   sCodigo_Geo_Emisor,
   sPais     : String;
   bEncontro : Boolean;
   i         : Integer;
begin
   Result    := False;
   bEncontro := False;

   if Not VarIsArray(Reg_Desagio.Serie) then
      Carga_Valores_Desagio_Mem;

   if (VarArrayHighBound(Reg_Desagio.Serie , 1 ) = 0) then
      Exit;

   if Not VarIsArray(Reg_Item_Direccion_Identidad.Item_Dir) then
      Carga_Item_Direccion_Identidad_Mem( dFecDesPeriodo);

   if Not VarIsArray(Reg_Division_Geografica.COD_DESC_DIVISION) then
      Carga_Valores_Division_Geografica_Mem;

   fItem_Dir_Emisor   := default_direccion_Mem( sEmisor
                                               ,dFecDesPeriodo);
   sCodigo_Geo_Emisor := Codigo_Geo_IdDir_Mem( sEmisor
                                              ,fItem_Dir_Emisor);
   sPais              := Pais_Para_CodGeo_Mem(sCodigo_Geo_Emisor);

   for i := 0 to VarArrayHighBound(Reg_Desagio.Serie , 1 )  do
   begin
      if  (Reg_Desagio.Serie[i]         = sSerie)
        And (Reg_Desagio.Pais[i]        = sPais)
        And (Reg_Desagio.Emisor[i]      = sEmisor)
        And (Reg_Desagio.Instrumento[i] = sInstrumento)
        And (((Reg_Desagio.Fecha_Desde[i] <= dFecDesPeriodo) AND ((Reg_Desagio.Fecha_Hasta[i] > dFecDesPeriodo)))
          OR ((Reg_Desagio.Fecha_Desde[i] >= dFecDesPeriodo) AND (Reg_Desagio.Fecha_Desde[i] < dFecHasPeriodo))
            ) then
      begin
         bEncontro := True;
         Break;
      end;

   end;

   if Not bEncontro then
      for i := 0 to VarArrayHighBound(Reg_Desagio.Serie , 1 )  do
      begin
         if  (Reg_Desagio.Serie[i]         = EmptyStr)
           And (Reg_Desagio.Pais[i]        = sPais)
           And (Reg_Desagio.Emisor[i]      = sEmisor)
           And (Reg_Desagio.Instrumento[i] = sInstrumento)
           And (((Reg_Desagio.Fecha_Desde[i] <= dFecDesPeriodo) AND ((Reg_Desagio.Fecha_Hasta[i] > dFecDesPeriodo)))
             OR ((Reg_Desagio.Fecha_Desde[i] >= dFecDesPeriodo) AND (Reg_Desagio.Fecha_Desde[i] < dFecHasPeriodo))
               ) then
         begin
            bEncontro := True;
            Break;
         end;
      end;

   if Not bEncontro then
      for i := 0 to VarArrayHighBound(Reg_Desagio.Serie , 1 )  do
      begin
         if  (Reg_Desagio.Serie[i]         = EmptyStr)
           And (Reg_Desagio.Pais[i]        = sPais)
           And (Reg_Desagio.Emisor[i]      = EmptyStr)
           And (Reg_Desagio.Instrumento[i] = sInstrumento)
           And (((Reg_Desagio.Fecha_Desde[i] <= dFecDesPeriodo) AND ((Reg_Desagio.Fecha_Hasta[i] > dFecDesPeriodo)))
             OR ((Reg_Desagio.Fecha_Desde[i] >= dFecDesPeriodo) AND (Reg_Desagio.Fecha_Desde[i] < dFecHasPeriodo))
               ) then
         begin
            bEncontro := True;
            Break;
         end;
      end;

   if Not bEncontro then
      for i := 0 to VarArrayHighBound(Reg_Desagio.Serie , 1 )  do
      begin
         if  (Reg_Desagio.Serie[i]         = EmptyStr)
           And (Reg_Desagio.Pais[i]        = sPais)
           And (Reg_Desagio.Emisor[i]      = EmptyStr)
           And (Reg_Desagio.Instrumento[i] = EmptyStr)
           And (Reg_Desagio.Pais[i]       <> EmptyStr)
           And (((Reg_Desagio.Fecha_Desde[i] <= dFecDesPeriodo) AND ((Reg_Desagio.Fecha_Hasta[i] > dFecDesPeriodo)))
             OR ((Reg_Desagio.Fecha_Desde[i] >= dFecDesPeriodo) AND (Reg_Desagio.Fecha_Desde[i] < dFecHasPeriodo))
               ) then
         begin
            bEncontro := True;
            Break;
         end;
      end;

    Result := bEncontro;
    if Not bEncontro then
       Exit;

    sCodigo_Tasa     := Reg_Desagio.Codigo_Tasa[i];
    dFecha_Inicio    := Reg_Desagio.Fecha_Desde[i];
    dFecha_Termino   := Reg_Desagio.Fecha_Hasta[i];
    fValor_Tasa      := Reg_Desagio.Valor_Tasa[i];
    sOperador_Logico := Reg_Desagio.Operador_Logico[i];
end;

procedure Carga_Base_Conversion_Mem;
var
    i              : Integer;
begin
   with dmFuncionesMemory.Qry_General do
  begin
     Sql.clear;
     Sql.Add('SELECT Cod_Tasa_Base'
            +'      ,Tipo'
            +'      ,Periodo_Pago'
            +'      ,Anualidad'
            +'      ,Base_Porcentual'
            +'  FROM QS_FIN_TASA_CONVER'
            +' ORDER BY Cod_Tasa_Base'
            );
//     Prepare;
     Open;

//     dmComunInversiones.QRY_General.last;
        i := dmFuncionesMemory.QRY_General.RecordCount;
//        dmComunInversiones.QRY_General.first;

     Reg_Tasa_Conver.Cod_Tasa_Base   := VarArrayCreate([0, i], varOleStr);
     Reg_Tasa_Conver.Tipo            := VarArrayCreate([0, i], varOleStr);
     Reg_Tasa_Conver.Periodo_Pago    := VarArrayCreate([0, i], varDouble);
     Reg_Tasa_Conver.Anualidad       := VarArrayCreate([0, i], varOleStr);
     Reg_Tasa_Conver.Base_Porcentual := VarArrayCreate([0, i], varDouble);

     i := 0;
     while not eof do
     begin
        Reg_Tasa_Conver.Cod_Tasa_Base[i]  := FieldByName('Cod_Tasa_Base').AsString;;
        Reg_Tasa_Conver.Tipo[i]           := FieldByName('Tipo').AsString;
        Reg_Tasa_Conver.Periodo_Pago[i]   := FieldByName('Periodo_Pago').AsFloat;
        Reg_Tasa_Conver.Anualidad[i]      := FieldByName('Anualidad').AsString;
        Reg_Tasa_Conver.Base_Porcentual[i]:= FieldByName('Base_Porcentual').AsFloat;

        Inc(i);
        Next;
     end;
     Close;
  end;
end;

procedure Obtener_Base_Conversion_Mem(sCod_Tasa_Base       : String;
                                    var sTipo              : String;
                                    var fPeriodo_Pago      : Double;
                                    var sAnualidad         : String;
                                    var fBase_Porcen       : Double;
                                    var sModulo_Err        : String;
                                    var sString_Err        : String;
                                    var Result             : Boolean);
var
   i : Integer;
begin
  Result        := False;

  if NOT VarIsArray(Reg_Tasa_Conver.Cod_Tasa_Base) then
     Carga_Base_Conversion_Mem;

  fBase_Porcen  := 0;
  fPeriodo_Pago := 0;
  for i := 0 to VarArrayHighBound(Reg_Tasa_Conver.Cod_Tasa_Base, 1 ) do
  begin
     if Reg_Tasa_Conver.Cod_Tasa_Base[i] = trim(sCod_Tasa_Base) then
     begin
        sTipo         := Reg_Tasa_Conver.Tipo[i];
        fPeriodo_Pago := Reg_Tasa_Conver.Periodo_Pago[i];
        sAnualidad    := Reg_Tasa_Conver.Anualidad[i];
        fBase_Porcen  := Reg_Tasa_Conver.Base_Porcentual[i];

        Result := True;
        Break;
     end;
  end;

  if Not Result then
  begin
    sModulo_Err := ' Base Conversion Tasa';
    sString_Err := ' No se encontro Base de Conversión para : '
                   +sCod_Tasa_Base;
    exit;
  end;

  if fBase_Porcen = 0 then
  begin
    sModulo_Err := ' Base Conversion Tasa';
    sString_Err := ' Error en definición de base porcentual para tasa : '
                   +sCod_Tasa_Base+#10
                   +'Base no puede ser igual a 0';
    Result := False;
    exit;
  end;


  if fPeriodo_Pago = 0 then
  begin
    sModulo_Err := 'Base Conversion Tasa';
    sString_Err := 'Error en definición de periodo para tasa : '
                   +sCod_Tasa_Base+#10
                   +'Periodo no puede ser igual a 0';
    Result := False;
    exit;
  end;
end;

