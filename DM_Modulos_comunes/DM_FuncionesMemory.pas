Procedure Ordenamiento_Motivo_Operacion_Mem( var Reg_Motivo : TReg_Motivo;
                                        iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd      : Double;
    sTransaccion,
    sEmpresa,
    sCod_Motivo    : String;
    dFecha_Hora,
    dFecha_Desde,
    dFecha_Hasta : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Motivo.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Motivo.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Motivo.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         sEmpresa           := Reg_Motivo.Empresa[Lo];
         sTransaccion       := Reg_Motivo.Transaccion[Lo];
         fFolio_Interno     := Reg_Motivo.Folio_Interno[Lo];
         fItem_Omd          := Reg_Motivo.Item_Omd[Lo];
         dFecha_Hora        := Reg_Motivo.Fecha_Hora[Lo];
         dFecha_Desde       := Reg_Motivo.Fecha_Desde[Lo];
         dFecha_Hasta       := Reg_Motivo.Fecha_Hasta[Lo];
         sCod_motivo        := Reg_Motivo.Cod_motivo[Lo];

         Reg_Motivo.Empresa[Lo]       :=
                       Reg_Motivo.Empresa[Hi];
         Reg_Motivo.Transaccion[Lo]   :=
                       Reg_Motivo.Transaccion[Hi];
         Reg_Motivo.Folio_Interno[Lo] :=
                       Reg_Motivo.Folio_Interno[Hi];
         Reg_Motivo.Item_Omd[Lo]      :=
                       Reg_Motivo.Item_Omd[Hi];
         Reg_Motivo.Fecha_Hora[Lo]    :=
                       Reg_Motivo.Fecha_Hora[Hi];
         Reg_Motivo.Fecha_Desde[Lo]   :=
                       Reg_Motivo.Fecha_Desde[Hi];
         Reg_Motivo.Fecha_Hasta[Lo]   :=
                       Reg_Motivo.Fecha_Hasta[Hi];
         Reg_Motivo.Cod_motivo[Lo]   :=
                       Reg_Motivo.Cod_motivo[Hi];

         Reg_Motivo.Empresa[Hi]       := sEmpresa;
         Reg_Motivo.Transaccion[Hi]   := sTransaccion;
         Reg_Motivo.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Motivo.Item_Omd[Hi]      := fItem_Omd;
         Reg_Motivo.Fecha_Hora[Hi]    := dFecha_Hora;
         Reg_Motivo.Fecha_Desde[Hi]   := dFecha_Desde;
         Reg_Motivo.Fecha_Hasta[Hi]   := dFecha_Hasta;
         Reg_Motivo.Cod_motivo[Hi]    := sCod_motivo;
         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Motivo_Operacion_Mem(Reg_Motivo, iLo, Hi);
    if Lo < iHi then Ordenamiento_Motivo_Operacion_Mem(Reg_Motivo, Lo, iHi);
end;

procedure Determina_Nominales_Vendidos_Por_Dia_Mem(dFecha_Dia    : TDateTime;
                                               const sEmpresa        : String;
                                               const sTransaccion    : String;
                                               const sFolio          : String;
                                               dItem_omd       : Double;
                                               var Nominales_Ventas    : Double);
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
    Result           : Boolean;
begin
   Nominales_Ventas := 0;
   fFolio_Buscado   := StrToFloat( sFolio );
   iLimite_Inferior := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel, 1 )-1;
   i := 0;


   Result := False;
   //Ubico Folio
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Nominales_Vendidos.Folio_Interno_Rel[i] = fFolio_Buscado then
        begin
           Result := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Nominales_Vendidos.Folio_Interno_Rel[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;

   end;

   if Result then
   begin
      //Retrocedo hasta Primer Folio Igual
      For j := i Downto 0 do
        if Reg_Nominales_Vendidos.Folio_Interno_Rel[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Nominales_Vendidos.Folio_Interno_Rel , 1 )) and
            (Reg_Nominales_Vendidos.Folio_Interno_Rel[i] = fFolio_Buscado) do
      begin
         if (Reg_Nominales_Vendidos.Transaccion_Rel[i]    = sTransaccion) and
            (Reg_Nominales_Vendidos.Item_Omd_Rel[i]       = dItem_Omd)    and
            (Reg_Nominales_Vendidos.Fecha_Operacion[i]    = dFecha_Dia)  then
             Nominales_Ventas := Nominales_Ventas + Reg_Nominales_Vendidos.Valor_Nominal[i];

         Inc(i);
      end;
   end;
   Nominales_Ventas := redondeo(Nominales_Ventas,10);
end;

