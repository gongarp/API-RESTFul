Procedure Carga_Clasifica_Var_Mem;
Var i : LongInt;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      SQL.Clear;
      SQL.Add('SELECT a.* ,b.descripcion_nodo ');
      SQL.Add('  FROM QS_FIN_CLASIFICA_VAR a  ');
      SQL.Add('  ,QS_SYS_EST_CLA b            ');
      SQL.Add('  WHERE b.Codigo_Objeto = a.Cod_Clasif ');
      SQL.Add('  AND b.Nodo =a.clasificacion ');
      Open;
      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Clasifica_Var.INSTRUMENTO   := VarArrayCreate([0, i], varOleStr);
      Reg_Clasifica_Var.MONEDA        := VarArrayCreate([0, i], varOleStr);
      Reg_Clasifica_Var.EMISOR        := VarArrayCreate([0, i], varOleStr);
      Reg_Clasifica_Var.COD_CLASIF    := VarArrayCreate([0, i], varOleStr);
      Reg_Clasifica_Var.CLASIFICACION := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
        Reg_Clasifica_Var.INSTRUMENTO[i]   := Fieldbyname('Cod_Instrumento').asString;
        Reg_Clasifica_Var.MONEDA[i]        := Fieldbyname('Moneda').asString;
        Reg_Clasifica_Var.EMISOR[i]        := Fieldbyname('Emisor').asString;
        Reg_Clasifica_Var.COD_CLASIF[i]    := Fieldbyname('Cod_Clasif').asString;
        Reg_Clasifica_Var.CLASIFICACION[i] := Fieldbyname('descripcion_nodo').asString;
        Inc(i);
        Next;
      end;
      Close;
   end;
end;

Function Busca_Clasfica_Var_Mem(sInstrumento :String;
                                sMoneda      :String;
                                sEmisor      :String;
                                sCod_Clasif  :String) :String;
var bClasifica     : Boolean;
var i : Integer;
begin
   bClasifica := False;
   i := 0;


  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Clasifica_Var.Instrumento) then
     Carga_Clasifica_Var_Mem;

   // Busco Valuacion para Instrumento, Moneda y Emisor
   if Not bClasifica then
      for i := 0 to VarArrayHighBound(Reg_Clasifica_Var.Instrumento , 1 )  do
      begin
         if (Reg_Clasifica_Var.Instrumento[i] = sInstrumento) and
            (Reg_Clasifica_Var.Moneda[i]      = sMoneda)      and
            (Reg_Clasifica_Var.Emisor[i]      = sEmisor)      and
            (Reg_Clasifica_Var.Cod_Clasif[i]  = scod_Clasif)  then
         begin
            bClasifica := True;
            Break;
         end;
      end;

   // Busco Clasificacion para Instrumento y Moneda
   if Not bClasifica then
      for i := 0 to VarArrayHighBound(Reg_Clasifica_Var.Instrumento , 1 )  do
      begin
         if (Reg_Clasifica_Var.Instrumento[i] = sInstrumento) and
            (Reg_Clasifica_Var.Moneda[i]      = sMoneda)      and
            (Reg_Clasifica_Var.Emisor[i]      = EmptyStr)     and
            (Reg_Clasifica_Var.Cod_Clasif[i]  = scod_Clasif)  then
         begin
