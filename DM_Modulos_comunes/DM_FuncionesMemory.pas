Procedure Carga_Def_Valor_Contable_Mem( dFecha : Tdatetime );
Var i : LongInt;
    sEmpresa,
    sCartera,
    sTipo_Contab,
    sTipo_Instrumento,
    sMotivo_Inv,
    sMotivo_OMD,
    sValor_Contable : String;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      SQL.Clear;
      SQL.Add('SELECT * FROM QS_CON_DEF_VAL_CONT'
             +' WHERE Fecha_Desde <= :Fecha'
             +'  AND (Fecha_Hasta IS NULL OR Fecha_Hasta >= :Fecha)');
      Parambyname('Fecha').asDate := dFecha;
      Open;
      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

      Reg_Valor_Contable.Empresa          := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.CARTERA          := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.TIPO_INSTRUMENTO := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.TIPO_CONTAB      := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.MOTIVO_INV       := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.MOTIVO_OMD       := VarArrayCreate([0, i], varOleStr);
      Reg_Valor_Contable.VALOR_CONTABLE   := VarArrayCreate([0, i], varOleStr);
      i := 0;
      while not eof do
      begin
//Empresa
        if Fieldbyname('Empresa').IsNull then
           sEmpresa := ''
        else
           sEmpresa := Fieldbyname('Empresa').asString;
// Cartera
        if Fieldbyname('Cartera').IsNull then
           sCartera := ''
        else
           sCartera := Fieldbyname('Cartera').asString;
// Tipo_Contab
        if Fieldbyname('Tipo_Contab').IsNull then
           sTipo_Contab := ''
        else
           sTipo_Contab := Fieldbyname('Tipo_Contab').asString;
// Tipo_Contab
        if Fieldbyname('Tipo_Inversion').IsNull then
           sTipo_Instrumento := ''
        else
           sTipo_Instrumento := Fieldbyname('Tipo_Inversion').asString;
//Motivo_Inv
        if Fieldbyname('Motivo_Inv').IsNull then
           sMotivo_Inv := ''
        else
           sMotivo_Inv := Fieldbyname('Motivo_Inv').asString;
//Motivo_OMD
        if Fieldbyname('Motivo_OMD').IsNull then
           sMotivo_OMD := ''
        else
           sMotivo_OMD := Fieldbyname('Motivo_OMD').asString;
//Valor_Contable
        if Fieldbyname('Valor_Contable').IsNull then
           sValor_Contable := ''
        else
           sValor_Contable := Fieldbyname('Valor_Contable').asString;

        Reg_Valor_Contable.Empresa[i]          := sEmpresa;
        Reg_Valor_Contable.CARTERA[i]          := sCartera;
        Reg_Valor_Contable.TIPO_CONTAB[i]      := sTipo_Contab;
        Reg_Valor_Contable.TIPO_INSTRUMENTO[i] := sTipo_Instrumento;
        Reg_Valor_Contable.MOTIVO_INV[i]       := sMotivo_Inv;
        Reg_Valor_Contable.MOTIVO_OMD[i]       := sMotivo_OMD;
        Reg_Valor_Contable.VALOR_CONTABLE[i]   := sValor_Contable;
        Inc(i);
        Next;
      end;
      Close;
   end;
end;

procedure Busca_Def_Valor_Contabler_Mem( dFecha          : TDateTime;
                                         sEmpresa_Sup,
                                         sCARTERA_Sup,
                                         sTIPO_CONTAB_Sup,
                                         sTIPO_INSTRUMENTO_Sup,
                                         sMOTIVO_INV,
                                         sMOTIVO_OMD     : String;
                                     Var sVALOR_CONTABLE : String
                                       );
var sCartera          : String;
    sEmpresa          : String;
    sTipo_Contab      : String;
    sTipo_Instrumento : String;
    i                 : Integer;
    bValuacion        : Boolean;
begin
   if NOT VarIsArray(Reg_Valor_Contable.Empresa) then
      Carga_Def_Valor_Contable_Mem(dFecha);

   bValuacion   := False;
   //Verifica si existe valuacion definida por cartera o por proceso
   // Solo ese caso toma en cuenta condicion

   sEmpresa := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Empresa, 1 )  do
   begin
      if Reg_Valor_Contable.Empresa[i] = sEmpresa_Sup then   //ggarcia 11-07-2013 if Reg_Valor_Contable.Empresa[i] = sEmpresa then
      begin
         sEmpresa := sEmpresa_Sup;
         Break;
      end;
   end;

   sCartera := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Cartera, 1 )  do
   begin
      if Reg_Valor_Contable.Cartera[i] = sCartera_Sup then  //ggarcia 11-07-2013  if Reg_Valor_Contable.Cartera[i] = sCartera then
      begin
         sCartera := sCartera_Sup;
         Break;
      end;
   end;

   //Verifica si existe valuacion definida por Tipo Contabilidad
   // Solo ese caso toma en cuenta condicion
   sTipo_Contab := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Tipo_Contab, 1 )  do
   begin
      if Reg_Valor_Contable.Tipo_Contab[i] = sTipo_Contab_Sup then
      begin
         sTipo_Contab := sTipo_Contab_Sup;
         Break;
      end;
   end;

   sTipo_Instrumento := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Tipo_Instrumento, 1 )  do
   begin
      if Reg_Valor_Contable.Tipo_Instrumento[i] = sTipo_Instrumento_Sup then
      begin
         sTipo_Instrumento := sTipo_Instrumento_Sup;
         Break;
      end;
   end;

   if Not bValuacion then
      for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Empresa , 1 )  do
      begin
         if    (Reg_Valor_Contable.Motivo_Inv[i]      = sMotivo_Inv)
           // Empresa
           and (    ((sEmpresa <> EmptyStr) and (Reg_Valor_Contable.Empresa[i] = sEmpresa) )
                 or ((sEmpresa =  EmptyStr) and (Reg_Valor_Contable.Empresa[i] = EmptyStr))
                )
           // Cartera
           and (    ((sCartera <> EmptyStr) and (Reg_Valor_Contable.Cartera[i] = sCartera) )
                 or ((sCartera =  EmptyStr) and (Reg_Valor_Contable.Cartera[i] = EmptyStr))
                )
           // Tipo_Contab
           and (    ((sTipo_Contab <> EmptyStr) and (Reg_Valor_Contable.Tipo_Contab[i] = sTipo_Contab) )
                 or ((sTipo_Contab =  EmptyStr) and (Reg_Valor_Contable.Tipo_Contab[i] = EmptyStr))
                )
           // Tipo_Instrum
           and (    ((sTipo_Instrumento <> EmptyStr) and (Reg_Valor_Contable.Tipo_Instrumento[i] = sTipo_Instrumento) )
                 or ((sTipo_Instrumento =  EmptyStr) and (Reg_Valor_Contable.Tipo_Instrumento[i] = EmptyStr))
                )
                then
         begin
            bValuacion := True;
            Break;
         end;
      end;

   // Busco Valuacion para Motivo_OMD
   if Not bValuacion then
      for i := 0 to VarArrayHighBound(Reg_Valor_Contable.Empresa , 1 )  do
      begin
         if    (Reg_Valor_Contable.Motivo_OMD[i]      = sMotivo_OMD)
           // Empresa
           and (    ((sEmpresa <> EmptyStr) and (Reg_Valor_Contable.Empresa[i] = sEmpresa) )
                 or ((sEmpresa =  EmptyStr) and (Reg_Valor_Contable.Empresa[i] = EmptyStr))
                )
           // Cartera
           and (    ((sCartera <> EmptyStr) and (Reg_Valor_Contable.Cartera[i] = sCartera) )
                 or ((sCartera =  EmptyStr) and (Reg_Valor_Contable.Cartera[i] = EmptyStr))
                )
           // Tipo_Contab
           and (    ((sTipo_Contab <> EmptyStr) and (Reg_Valor_Contable.Tipo_Contab[i] = sTipo_Contab) )
                 or ((sTipo_Contab =  EmptyStr) and (Reg_Valor_Contable.Tipo_Contab[i] = EmptyStr))
                )
           // Tipo_Instrum
           and (    ((sTipo_Instrumento <> EmptyStr) and (Reg_Valor_Contable.Tipo_Instrumento[i] = sTipo_Instrumento) )
                 or ((sTipo_Instrumento =  EmptyStr) and (Reg_Valor_Contable.Tipo_Instrumento[i] = EmptyStr))
                )
                then
         begin
            bValuacion := True;
            Break;
         end;
      end;

   if Not bValuacion then
      Exit;

   sVALOR_CONTABLE := Reg_Valor_Contable.VALOR_CONTABLE[i];
end;

Procedure Carga_Formula_Tasas_Mem(dFecha : TDateTime);
var i : LongInt;
begin
   try
      with DmFuncionesMemory.QRY_General do
      begin
         SQL.Clear;
         SQL.Add('SELECT a.* '
                +'  FROM QS_SYS_MON_FORMULA a '
                +' WHERE a.FECHA_DESDE = (SELECT MAX(b.FECHA_DESDE) '
                +'                          FROM QS_SYS_MON_FORMULA b '
                +'                         WHERE b.COD_MONEDA   = a.COD_MONEDA '
                +'                           AND b.FECHA_DESDE <= :FECHA_DESDE) ');
         ParamByName('FECHA_DESDE').AsDate := dfecha;
         Open;
         DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
         Reg_Formula_Tasas.Cod_Moneda  := VarArrayCreate([0, i], varOleStr);
         Reg_Formula_Tasas.Fecha_Desde := VarArrayCreate([0, i], varOleStr);
         Reg_Formula_Tasas.Cod_Formula := VarArrayCreate([0, i], varOleStr);
         i := 0;
         while not eof do
         begin
            Reg_Formula_Tasas.Cod_Moneda[i]  := Fieldbyname('Cod_Moneda').asString;
            Reg_Formula_Tasas.Fecha_Desde[i] := Fieldbyname('Fecha_Desde').asString;
            Reg_Formula_Tasas.Cod_Formula[i] := Fieldbyname('Cod_Formula').asString;
            Inc(i);
            Next;
         end;
         Close;
      end;
   except
      i := 1;
      Reg_Formula_Tasas.Cod_Moneda  := VarArrayCreate([0, i], varOleStr);
      Reg_Formula_Tasas.Fecha_Desde := VarArrayCreate([0, i], varOleStr);
      Reg_Formula_Tasas.Cod_Formula := VarArrayCreate([0, i], varOleStr);
   end;
end;

procedure Busca_Formula_Tasas_Mem(dFecha_Calculo : TDateTime;
                                  sCod_Moneda    : String;
                              var sCod_Formula   : String;
                              var Result        : Boolean);
var i : Integer;
begin
   Result := False;

   if NOT VarIsArray(Reg_Formula_Tasas.Cod_Moneda) then
      Carga_Formula_Tasas_Mem(dFecha_Calculo);

   for i := 0 to VarArrayHighBound(Reg_Formula_Tasas.Cod_Moneda , 1 )  do
   begin
      if (Reg_Formula_Tasas.Cod_Moneda[i] = sCod_Moneda) then
      begin
          sCod_Formula := Reg_Formula_Tasas.Cod_Formula[i];
          Result     := True;
          Exit;
      end;
   end;
end;

Procedure Carga_Clasif_EmisorInstrumentoMotivo( dFecha : TDatetime );
var i : LongInt;

begin
   with DmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT COUNT(*) As NumRegs  '
             +'  FROM QS_TALANX_CLASIFICACION'
             +' WHERE  FECHA_DESDE <= :Fecha'
             +'   AND (FECHA_HASTA >= :Fecha OR FECHA_HASTA IS NULL) '
             );
      Parambyname('Fecha').asDate := dFecha;
      Open;
      i := FieldByName('NumRegs').AsInteger;
      Close;

      Sql.Clear;
      SQL.Add('SELECT A.EMISOR                                               ');
      SQL.Add('      ,A.INSTRUMENTO                                          ');
      SQL.Add('      ,A.MOTIVO                                               ');
      SQL.Add('      ,A.FECHA_DESDE                                          ');
      SQL.Add('      ,A.FECHA_HASTA                                          ');
      SQL.Add('      ,A.CODIGO_CLASIF                                        ');
      SQL.Add('      ,A.CLASIFICACION                                        ');
      SQL.Add('      ,A.CLASIFICACION_CP                                     ');
      SQL.Add('      ,B.DESCRIPCION_NODO AS DESC_CLASIFICACION               ');
      SQL.Add('      ,C.DESCRIPCION_NODO AS DESC_CLASIFICACION_CP            ');
      SQL.Add('   FROM QS_TALANX_CLASIFICACION A                              ');
      SQL.Add('        LEFT JOIN QS_SYS_EST_CLA B                            ');
      SQL.Add('        ON B.CODIGO_OBJETO = A.CODIGO_CLASIF                  ');
      SQL.Add('           AND B.NODO = A.CLASIFICACION                       ');
      SQL.Add('        LEFT JOIN QS_SYS_EST_CLA C                            ');
      SQL.Add('        ON C.CODIGO_OBJETO = A.CODIGO_CLASIF                  ');
      SQL.Add('           AND C.NODO = A.CLASIFICACION_CP                    ');
      SQL.Add('      WHERE A.FECHA_DESDE <= :Fecha  AND                      ');
      SQL.Add('        (A.FECHA_HASTA >= :Fecha OR A.FECHA_HASTA IS NULL)    ');
      SQL.Add('        ORDER BY A.FECHA_DESDE                                ');
      SQL.Add('        ,A.EMISOR DESC                                        ');
      SQL.Add('        ,A.INSTRUMENTO DESC                                   ');
      SQL.Add('        ,A.MOTIVO DESC                                        ');


       Parambyname('Fecha').asDate := dFecha;
       Open;


       Reg_Clasif_EmiInstMot.EMISOR           := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_EmiInstMot.INSTRUMENTO      := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_EmiInstMot.MOTIVO           := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_EmiInstMot.FECHA_DESDE      := VarArrayCreate([0, i], varDate);
       Reg_Clasif_EmiInstMot.CODIGO_CLASIF    := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_EmiInstMot.CLASIFICACION    := VarArrayCreate([0, i], varDouble);
       Reg_Clasif_EmiInstMot.CLASIFICACION_CP := VarArrayCreate([0, i], varDouble);
       Reg_Clasif_EmiInstMot.DESC_CLASIFICACION    := VarArrayCreate([0, i], varOleStr);
       Reg_Clasif_EmiInstMot.DESC_CLASIFICACION_CP := VarArrayCreate([0, i], varOleStr);

       i := 0;
       while Not eof do
       begin
          Reg_Clasif_EmiInstMot.EMISOR[i]           := Fieldbyname('EMISOR'          ).asString;
