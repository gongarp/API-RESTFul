Procedure Ordenamiento_Registro_Stock_Mem( var Reg_Folio_Stock : TReg_Folio_Stock;
                                           iLo, iHi: Integer);
var
    Lo, Hi, Mid : Integer;
    fFolio_Interno,
    fItem_Omd,
    sTransaccion,
    sEmpresa : String;
    //dFecha_Operacion : TDatetime;
begin
    Lo  := iLo;
    Hi  := iHi;
    Mid := Reg_Folio_Stock.Folio_Interno[(Lo + Hi) div 2];

    repeat
      while Reg_Folio_Stock.Folio_Interno[Lo] < Mid do
            Inc(Lo);
      while Reg_Folio_Stock.Folio_Interno[Hi] > Mid do
            Dec(Hi);

      if Lo <= Hi then
      begin
         fFolio_Interno := Reg_Folio_Stock.Folio_Interno[Lo];
         fItem_Omd      := Reg_Folio_Stock.Item_Omd[Lo];
         sTransaccion   := Reg_Folio_Stock.Transaccion[Lo];
         sEmpresa       := Reg_Folio_Stock.Empresa[Lo];


        { dFecha_Operacion  := Reg_Folio_Stock.Fecha_Operacion[Lo];
         dFecha_Vcto_pacto := Reg_Folio_Stock.Fecha_Vcto_pacto[Lo];
         sNemotecnico      := Reg_Folio_Stock.Nemotecnico[Lo];
         sTasa_Base_par    := Reg_Folio_Stock.Tasa_Base_par[Lo];
         sTasa_Base_Tir    := Reg_Folio_Stock.Tasa_Base_Tir[Lo];
         sCartera          := Reg_Folio_Stock.Cartera[Lo];
         sMoneda_Pacto     := Reg_Folio_Stock.Moneda_Pacto[Lo];
         sCustodia         := Reg_Folio_Stock.Custodia[Lo];
         sTipo_Instrum     := Reg_Folio_Stock.Tipo_Instrum[Lo];
         sTasa_Base_Pacto  := Reg_Folio_Stock.Tasa_Base_Pacto[Lo];
         fTasa_pacto       := Reg_Folio_Stock.Tasa_pacto[Lo];
         fValor_Nominal    := Reg_Folio_Stock.Valor_Nominal[Lo];
         }
         Reg_Folio_Stock.Folio_Interno[Lo] :=
                       Reg_Folio_Stock.Folio_Interno[Hi];
         Reg_Folio_Stock.Item_Omd[Lo]      :=
                       Reg_Folio_Stock.Item_Omd[Hi];
         Reg_Folio_Stock.Transaccion[Lo]   :=
                       Reg_Folio_Stock.Transaccion[Hi];
         Reg_Folio_Stock.Empresa[Lo]       :=
                       Reg_Folio_Stock.Empresa[Hi];


//    prueba
        { Reg_Folio_Stock.Fecha_Operacion[Lo] :=
                       Reg_Folio_Stock.Fecha_Operacion[Hi];
         Reg_Folio_Stock.Fecha_Vcto_pacto[Lo]      :=
                       Reg_Folio_Stock.Fecha_Vcto_pacto[Hi];
         Reg_Folio_Stock.Nemotecnico[Lo]   :=
                       Reg_Folio_Stock.Nemotecnico[Hi];
         Reg_Folio_Stock.Tasa_Base_par[Lo]       :=
                       Reg_Folio_Stock.Tasa_Base_par[Hi];
         Reg_Folio_Stock.Tasa_Base_Tir[Lo] :=
                       Reg_Folio_Stock.Tasa_Base_Tir[Hi];
         Reg_Folio_Stock.Cartera[Lo]      :=
                       Reg_Folio_Stock.Cartera[Hi];
         Reg_Folio_Stock.Moneda_Pacto[Lo]   :=
                       Reg_Folio_Stock.Moneda_Pacto[Hi];
         Reg_Folio_Stock.Custodia[Lo]       :=
                       Reg_Folio_Stock.Custodia[Hi];
         Reg_Folio_Stock.Tipo_Instrum[Lo] :=
                       Reg_Folio_Stock.Tipo_Instrum[Hi];
         Reg_Folio_Stock.Tasa_Base_Pacto[Lo]      :=
                       Reg_Folio_Stock.Tasa_Base_Pacto[Hi];
         Reg_Folio_Stock.Tasa_pacto[Lo]   :=
                       Reg_Folio_Stock.Tasa_pacto[Hi];
         Reg_Folio_Stock.Valor_Nominal[Lo]       :=
                       Reg_Folio_Stock.Valor_Nominal[Hi];

         }

         Reg_Folio_Stock.Folio_Interno[Hi] := fFolio_Interno;
         Reg_Folio_Stock.Item_Omd[Hi]      := fItem_Omd;
         Reg_Folio_Stock.Transaccion[Hi]   := sTransaccion;
         Reg_Folio_Stock.Empresa[Hi]       := sEmpresa;
         //Prueba
        { Reg_Folio_Stock.Fecha_Operacion[Hi]  := dFecha_Operacion;
         Reg_Folio_Stock.Fecha_Vcto_pacto[Hi] := dFecha_Vcto_pacto;
         Reg_Folio_Stock.Nemotecnico[Hi]      := sNemotecnico;
         Reg_Folio_Stock.Tasa_Base_par[Hi]    := sTasa_Base_par;
         Reg_Folio_Stock.Tasa_Base_Tir[Hi]    := sTasa_Base_Tir;
         Reg_Folio_Stock.Cartera[Hi]          := sCartera;
         Reg_Folio_Stock.Moneda_Pacto[Hi]     := sMoneda_Pacto;
         Reg_Folio_Stock.Custodia[Hi]         := sCustodia;
         Reg_Folio_Stock.Tipo_Instrum[Hi]     := sTipo_Instrum;
         Reg_Folio_Stock.Tasa_Base_Pacto[Hi]  := sTasa_Base_Pacto;
         Reg_Folio_Stock.Tasa_pacto[Hi]       := fTasa_pacto;
         Reg_Folio_Stock.Valor_Nominal[Hi]    := fValor_Nominal;
         }

         Inc(Lo);
         Dec(Hi);
      end;
    until Lo > Hi;
    if Hi > iLo then Ordenamiento_Registro_Stock_Mem(Reg_Folio_Stock, iLo, Hi);
    if Lo < iHi then Ordenamiento_Registro_Stock_Mem(Reg_Folio_Stock, Lo, iHi);
end;

Function Existe_Registro_Stock_Mem(const sEmpresa       : String;
                                    const sTransaccion   : String;
                                    const sFolio_interno : String;
                                    fItem_OMD            : Double
                                    ) : Boolean;
var i,
    j,
    iLimite_Inferior,
    iLimite_Superior : Integer;
    fFolio_Buscado   : Double;
begin
   fFolio_Buscado   := StrToFloat( sFolio_interno );
   iLimite_Inferior := 0;
   i := 0;
   iLimite_Superior := VarArrayHighBound(Reg_Folio_Stock.Folio_Interno, 1 )-1;

   Result := False;
   //Ubico Folio e Item
   while iLimite_Inferior <= iLimite_Superior do
   begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Folio_Stock.Folio_Interno[i] = fFolio_Buscado then
        begin
           Result := True;
           Break;
        end;

        if  fFolio_Buscado > Reg_Folio_Stock.Folio_Interno[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i - 1;
   end;

   if Result then
   begin
      Result := False;
      //Retrocedo hasta Primer Folio Distinto
      For j := i Downto 0 do
        if Reg_Folio_Stock.Folio_Interno[J] <> fFolio_Buscado then
           Break;

      i := j + 1;
      while (i <= VarArrayHighBound(Reg_Folio_Stock.Folio_Interno , 1 )) and
            (Reg_Folio_Stock.Folio_Interno[i] = fFolio_Buscado) do
      begin
         if (Reg_Folio_Stock.Transaccion[i]  = sTransaccion) and
            (Reg_Folio_Stock.Item_Omd[i]     = fItem_Omd)    and
            (Reg_Folio_Stock.Empresa[i]      = sEmpresa)  then
         begin
            Existe_Registro_Stock_Mem := True;
            Break;
         end;

         Inc(i);
      end;
   end;
end;

