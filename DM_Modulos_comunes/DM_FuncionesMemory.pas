Procedure Carga_Metodos_Amortizacion_IncDec_Mem;
Var i : LongInt;
begin

   with DmFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add(' SELECT * FROM QS_FIN_MET_AMORTIZ_INCDEC ' );
      try
        Open;
        DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;
      except
        i:= 0;
      end;

      Reg_Amortizacion_IncDec.PROCESO           := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.CARTERA           := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.EMISOR            := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.INSTRUMENTO       := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.SERIE             := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.NEMOTECNICO       := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.MOTIVO_INVERSION  := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.TIPO_AMORTIZACION := VarArrayCreate([0, i], varOleStr);
      Reg_Amortizacion_IncDec.FECHA_DESDE       := VarArrayCreate([0, i], varDate);
      Reg_Amortizacion_IncDec.FECHA_HASTA       := VarArrayCreate([0, i], varDate);
      i := 0;
      while not eof do
      begin
         Reg_Amortizacion_IncDec.PROCESO[i]           := Fieldbyname('Proceso').asString;
         Reg_Amortizacion_IncDec.CARTERA[i]           := Fieldbyname('Cartera').asString;
         Reg_Amortizacion_IncDec.EMISOR[i]            := Fieldbyname('Emisor').asString;
         Reg_Amortizacion_IncDec.INSTRUMENTO[i]       := Fieldbyname('Instrumento').asString;
         Reg_Amortizacion_IncDec.SERIE[i]             := Fieldbyname('Serie').asString;
         Reg_Amortizacion_IncDec.NEMOTECNICO[i]       := Fieldbyname('Nemotecnico').asString;
         Reg_Amortizacion_IncDec.MOTIVO_INVERSION[i]  := Fieldbyname('Motivo_inversion').asString;
         Reg_Amortizacion_IncDec.TIPO_AMORTIZACION[i] := Fieldbyname('Tipo_Amortizacion').asString;
         Reg_Amortizacion_IncDec.FECHA_DESDE[i]       := Fieldbyname('Fecha_Desde').AsDateTime;
         Reg_Amortizacion_IncDec.FECHA_HASTA[i]       := Fieldbyname('Fecha_Hasta').AsDateTime;
         Inc(i);
         Next;
      end;
      Close;
   end;
end;

procedure Busca_Met_Amortizacion_IncDec_Mem( Reg_Val_In             : TRegistro_Valoriza_In;
                                             var sTipo_Amortizacion : String;
                                             var bAmortizacion         : Boolean);

var sProceso   : String;
    sCartera   : String;
    i          : Integer;
begin

  if NOT VarIsArray(Reg_Amortizacion_IncDec.Serie) then
     Carga_Metodos_Amortizacion_IncDec_Mem;

   bAmortizacion   := False;
   // Verifica si existe definida por proceso
   // SI NO EXISTE LO SACA Y NO ITERA PARA EL RESTO
   sProceso := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Amortizacion_IncDec.Serie, 1 )  do
   begin
      if Reg_Amortizacion_IncDec.Proceso[i] = Trim(Reg_Val_In.Proceso_Valuacion) then
      begin
         sProceso := Trim(Reg_Val_In.Proceso_Valuacion);
         Break;
      end;
   end;

   if (sProceso = EmptyStr) or
      (sProceso = '') then
      exit;

   //Verifica si existe definicion por cartera
   // Solo ese caso toma en cuenta condicion
   // Si no existe definicion para la cartera enviada como parametro
   // realizara la busqueda de registros con la cartera = '' (emptystr)
   sCartera := EmptyStr;
   for i := 0 to VarArrayHighBound(Reg_Amortizacion_IncDec.Cartera, 1 )  do
   begin
      if    ( Reg_Amortizacion_IncDec.Cartera[i] = Reg_Val_In.Cartera ) and
            ( Reg_Amortizacion_IncDec.Proceso[i] = sProceso           )  then
      begin
         sCartera := Trim(Reg_Val_In.Cartera);
         Break;
      end;
   end;

   // Busca Nemotecnico con Motivo_Inversion
   for i := 0 to VarArrayHighBound(Reg_Amortizacion_IncDec.Serie , 1 )  do
   begin
      if    (Reg_Amortizacion_IncDec.Nemotecnico[i]      = Trim(Reg_Val_In.Nemotecnico))
        and (Reg_Amortizacion_IncDec.Motivo_Inversion[i] = Trim(Reg_Val_In.Motivo_Operacion))

