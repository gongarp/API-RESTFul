procedure Busca_Clasif_Riesgo_Origen_Mem(const sEmisor_par      : String;
                                         const sInstrumento     : String;
                                         sSerie                 : String;
                                         sNemotecnico           : String;
                                         dFecha                 : TDateTime;
                                         var sOrigen            : String;
                                         var sTipo_Clasif       : String;
                                         bObliga_Clasif_Instrum : Boolean;
                                         var sClasificacion     : String;
                                         var dFecha_Clasif      : TDateTime;
                                         var fFactor_Riesgo     : Double;
                                         var sEmisor_Pagador    : String);
var i,j             : Integer;
    fNro_Riesgo,
    fValor_Nivel,
    fNivel          : Double;
    Result,
    bEmisor_Pagador : Boolean;
    sTipo_Plazo     : String;
    dFecha_aux      : TDateTime;
    sEmisor         : String;
//    dFecha_gg       : TDateTime;
    sClasif         : String;
begin
  dFecha_aux := 0;

  if NOT VarIsArray(Reg_Clasif_Riesgo.COD_EMP_SERIE) then
     Carga_Valores_Clasif_Riesgo_Mem( dFecha );

  Result         := False;
  sEmisor        := sEmisor_par;
  sClasificacion := '';
  if sSerie = '' then
     sSerie      := ' ';

  sEmisor_Pagador := sEmisor;
  bEmisor_Pagador := False;
  Emisor_Pagador_Mem(dFecha,
                     sEmisor,
                     sInstrumento,
                     sEmisor_Pagador,
                     bEmisor_Pagador);
  if (bEmisor_Pagador) and
     (sEmisor <> sEmisor_Pagador) then
  begin
     if (sClasificacion = '') and (sString_EmisorPagador = '') then
        sString_EmisorPagador := ' ( '''+sEmisor+''','''+sEmisor_Pagador+ ''' )'
     else
     begin
       if BuscaStr(sString_EmisorPagador,sEmisor_Pagador) then
       begin
          sClasificacion := '  ';
          Exit;
       end;
       j := Length(sString_EmisorPagador);
       sString_EmisorPagador := copy(sString_EmisorPagador,1,j-2);
       sString_EmisorPagador := sString_EmisorPagador +','''+sEmisor_Pagador+ ''' )';
     end;

     Busca_Clasif_Riesgo_Origen_Tipo_Mem(sEmisor_Pagador,
                                         sInstrumento,
                                         sSerie,
                                         sNemotecnico,
                                         dFecha,
                                         sOrigen,
                                         sTipo_Clasif,
                                         bObliga_Clasif_Instrum,
                                         sClasificacion,
                                         fFactor_Riesgo,
                                         sEmisor_Pagador);
