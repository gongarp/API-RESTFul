Procedure Carga_Valores_Nivel_Riesgo_Mem( dFecha : TDatetime );
var i : LongInt;
    sCOD_EMP_SERIE,
    sCOD_INST_SERIE,
    sSERIE_CLASIF,
    sCLASIF_SERIE  : String;
    dFecha_Aux     : Tdatetime;
begin
   with DmFuncionesMemory.Qry_General do
   begin
      Sql.Clear;
      SQL.Add('SELECT  COD_EMP_SERIE'
             +',COD_INST_SERIE'
             +',SERIE_CLASIF'
             +',MAX(F_CLASIF_SERIE) as F_CLASIF_SERIE'
             +',CLASIF_SERIE'
             +' FROM QS_FIN_CL_RIESGOS_NIVEL'
             +' WHERE F_CLASIF_SERIE <= :Fecha'
             +' GROUP BY'
             +'     COD_EMP_SERIE'
             +'    ,COD_INST_SERIE'
             +'    ,SERIE_CLASIF'
             +'    ,CLASIF_SERIE'
             +' ORDER BY'
             +'     COD_EMP_SERIE'
             +'    ,COD_INST_SERIE'
             +'    ,SERIE_CLASIF'
             +'    ,CLASIF_SERIE'

              );
       Parambyname('Fecha').asDate := dFecha;
       Open;

       DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
        DmFuncionesMemory.QRY_General.first;

       Reg_Nivel_Riesgo.COD_EMP_SERIE  := VarArrayCreate([0, i], varOleStr);
       Reg_Nivel_Riesgo.COD_INST_SERIE := VarArrayCreate([0, i], varOleStr);
       Reg_Nivel_Riesgo.SERIE_CLASIF   := VarArrayCreate([0, i], varOleStr);
       Reg_Nivel_Riesgo.CLASIF_SERIE   := VarArrayCreate([0, i], varOleStr);
       Reg_Nivel_Riesgo.F_CLASIF_SERIE := VarArrayCreate([0, i], varDate);

       i := 0;
       while Not eof do
       begin
          sCOD_EMP_SERIE  := Fieldbyname('COD_EMP_SERIE').asString;
          sCOD_INST_SERIE := Fieldbyname('COD_INST_SERIE').asString;
          sSERIE_CLASIF   := Fieldbyname('SERIE_CLASIF').asString;

          Reg_Nivel_Riesgo.COD_EMP_SERIE[i]  := sCOD_EMP_SERIE;
          Reg_Nivel_Riesgo.COD_INST_SERIE[i] := sCOD_INST_SERIE;
          Reg_Nivel_Riesgo.SERIE_CLASIF[i]   := sSERIE_CLASIF;

          dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
          sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;
          while (not Eof) and
                (sCOD_EMP_SERIE  = Fieldbyname('COD_EMP_SERIE').asString )  and
                (sCOD_INST_SERIE = Fieldbyname('COD_INST_SERIE').asString)  and
                (sSERIE_CLASIF   = Fieldbyname('SERIE_CLASIF').asString  )  do
          begin
             if Fieldbyname('F_CLASIF_SERIE').asDatetime > dFecha_aux then
             begin
                dFecha_Aux    := Fieldbyname('F_CLASIF_SERIE').asDatetime;
                sCLASIF_SERIE := Fieldbyname('CLASIF_SERIE').asString;
             end;
             Next;
          end;
          Reg_Nivel_Riesgo.CLASIF_SERIE[i]   := sCLASIF_SERIE;
          Reg_Nivel_Riesgo.F_CLASIF_SERIE[i] := dFecha_Aux;

          Inc(i);
       end;

       if i > 0 then
          Dec(i);

       VarArrayRedim(Reg_Nivel_Riesgo.COD_EMP_SERIE , i + 1);
       VarArrayRedim(Reg_Nivel_Riesgo.COD_INST_SERIE, i + 1);
       VarArrayRedim(Reg_Nivel_Riesgo.SERIE_CLASIF  , i + 1);
       VarArrayRedim(Reg_Nivel_Riesgo.CLASIF_SERIE  , i + 1);
       VarArrayRedim(Reg_Nivel_Riesgo.F_CLASIF_SERIE, i + 1);
       Close;
   end;
end;

procedure Busca_Nivel_Riesgo_Mem(const sEmisor            : String;
                                 const sInstrumento       : String;
                                  sSerie             : String;
                                  dFecha             : TDateTime;
                                 var sClasificacion : String);
var i      : Integer;
//    Result : Boolean;
begin
//  Result         := False;
  sClasificacion := EmptyStr;

  if NOT VarIsArray(Reg_Nivel_Riesgo.COD_EMP_SERIE) then
     Carga_Valores_Nivel_Riesgo_Mem( dFecha );

  //Busco Emisor, Instrumento, serie
  for i := 0 to VarArrayHighBound( Reg_Nivel_Riesgo.COD_EMP_SERIE, 1 )-1 do
  begin
     if (Reg_Nivel_Riesgo.COD_EMP_SERIE[i]    = sEmisor)       and
        (Reg_Nivel_Riesgo.COD_INST_SERIE[i]   = sInstrumento)  and
        (Reg_Nivel_Riesgo.SERIE_CLASIF[i]     = sSerie)        then
     begin
        sClasificacion := Reg_Nivel_Riesgo.CLASIF_SERIE[i];
        Exit;
     end;
  end;

  //Busco Emisor, Instrumento
  for i := 0 to VarArrayHighBound( Reg_Nivel_Riesgo.COD_EMP_SERIE, 1 )-1 do
  begin
     if (Reg_Nivel_Riesgo.COD_EMP_SERIE[i]    = sEmisor)       and
        (Reg_Nivel_Riesgo.COD_INST_SERIE[i]   = sInstrumento)  then
     begin
        sClasificacion := Reg_Nivel_Riesgo.CLASIF_SERIE[i];
        Exit;
     end;
  end;

  //Busco Emisor
  for i := 0 to VarArrayHighBound( Reg_Nivel_Riesgo.COD_EMP_SERIE, 1 )-1 do
  begin
     if Reg_Nivel_Riesgo.COD_EMP_SERIE[i]= sEmisor then
     begin
        sClasificacion := Reg_Nivel_Riesgo.CLASIF_SERIE[i];
        Exit;
     end;
  end;
end;

