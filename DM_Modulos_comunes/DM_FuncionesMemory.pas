Procedure Busca_Prob_Deterioro_Nemo_Mem(dFecha          :TDateTime;
                                        sNemotecnico    :String;
                                    var fProb_Deterioro :Double;
                                    var bResult         :Boolean);
var i : Integer;
begin
   bResult := False;
   fProb_Deterioro := 0;

   if NOT VarIsArray(Reg_Prob_Deterioro_Nemo.Nemotecnico) then
      Carga_Prob_Deterioro_Nemo_Mem(dFecha);

   for i := 0 to VarArrayHighBound(Reg_Prob_Deterioro_Nemo.Nemotecnico, 1)  do
   begin
