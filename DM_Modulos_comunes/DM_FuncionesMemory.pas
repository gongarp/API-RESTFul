Procedure Carga_Descriptor_Mem(const sEmisor      : String;
                                     sInstrumento : String;
                               const sSerie       : String;
                              var Registro     : TReg_descriptor;
                              var Modulo_Err   : String;
                              var String_Err   : String;
                              var Result       : Boolean );
var i
   ,j
   ,iLimite_Superior : Integer;
   bExiste,
   bExiste_Excepcion : Boolean;
   fPtje_Aplica_Reajuste : Double;
   sCodigo_MondInd,
   s0Cod_Tratam_Inicio,
   s1Cod_Tratam_Termino : String;
   dFecha_Inicio_Tratamiento,
   dFecha_Termino_Tratamiento : Tdatetime;
   //CodigoTasaBase             : String;
   FECHA_DESDE                : TdateTime;
   FECHA_HASTA                : TdateTime;
   TIPO_CALCULO_DIAS          : String;
   COD_TRATAM_INICIO          : String;
   COD_TRATAM_TERMINO         : String;
   TASA_DEPENDE_PERIODOS      : String;
   sBASE_SEGUN_ANO            : String;
   Aux_Modulo_Err             : String;
   Aux_String_Err             : String;
   bDias_Base_Variables       : Boolean;
   fPeriodos                  : Double;

begin
  Result  := False;
  bExiste := False;

  //Hago excepcion para CBR
  if sInstrumento = 'CBR' then
     sInstrumento := 'BR';

  WITH Registro do
  begin
//     iLimite_Inferior := 0;
     iLimite_Superior := VarArrayHighBound(Reg_Descriptores.CODIGO_Instrumento, 1 )-1;
     for i := 0 to iLimite_Superior do
     begin
        if Reg_Descriptores.CODIGO_Instrumento[i] = sInstrumento then
        begin
          bExiste := True;
          Break
        end;
     end;
    { While iLimite_Inferior <= iLimite_Superior do      // falla con instrumento con GUION
     begin
        i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

        if Reg_Descriptores.CODIGO_Instrumento[i] = sInstrumento then
        begin
          bExiste := True;
          Break
        end;

        if sInstrumento > Reg_Descriptores.CODIGO_Instrumento[i] then
           iLimite_Inferior := i + 1
        else
           iLimite_Superior := i -1;

     end;}

     if bExiste then
     begin
         //Retrocedo hasta Primera Serie Diferente
         For j := i Downto 0 do
           if Reg_Descriptores.CODIGO_Instrumento[J] <> sInstrumento then
              Break;

         i := j + 1;
         while (i <= VarArrayHighBound(Reg_Descriptores.Codigo_Instrumento, 1 )) and
               (Reg_Descriptores.Codigo_Instrumento[i] = sInstrumento ) do
         begin
             //Caso BR
             if ( sInstrumento = 'BR') then
             begin
                if ( Reg_Descriptores.CODIGO_INSTRUMENTO[i] = sInstrumento) and
                   ( Reg_Descriptores.Serie[i] = sSerie ) then
                begin
                   Result := True;
                   Break;
                end
             end
             else
             begin
                if ( Reg_Descriptores.CODIGO_EMISOR[i]      = sEmisor ) and
                   ( Reg_Descriptores.CODIGO_INSTRUMENTO[i] = sInstrumento ) and
                   ( Reg_Descriptores.Serie[i] = sSerie ) then
                begin
                   Result := True;
                   Break;
                end;
             end;
             Inc(i);
         end;

         if Result then
         begin
            CODIGO_EMISOR      := Reg_Descriptores.CODIGO_EMISOR[i];
            CODIGO_INSTRUMENTO := Reg_Descriptores.CODIGO_INSTRUMENTO[i];
            SERIE              := Reg_Descriptores.SERIE[i];
            SERIE_BOLSA        := Reg_Descriptores.SERIE_BOLSA[i];
            FECHA_EMISION      := Reg_Descriptores.FECHA_EMISION[i];
            TASA_EMISION       := Reg_Descriptores.TASA_EMISION[i];
            TASA_EFECTIVA      := Reg_Descriptores.TASA_EFECTIVA[i];
            TASA_VALOR_PAR     := Reg_Descriptores.TASA_VALOR_PAR[i];
            TASA_VALOR_PTE     := Reg_Descriptores.TASA_VALOR_PTE[i];
            UNIDAD_MON         := Reg_Descriptores.UNIDAD_MON[i];
            PLAZO_EN_ANOS      := Reg_Descriptores.PLAZO_EN_ANOS[i];
            TIPO_AMORTIZAC     := Reg_Descriptores.TIPO_AMORTIZAC[i];
            NRO_CUPONES        := Reg_Descriptores.NRO_CUPONES[i];
            PERIODO_PAGO       := Reg_Descriptores.PERIODO_PAGO[i];
            TIPO_VENCIMIENTO   := Reg_Descriptores.TIPO_VENCIMIENTO[i];
            DIA_VENCIMIENTO    := Reg_Descriptores.DIA_VENCIMIENTO[i];
            DECIMAL_AJUSTE     := Reg_Descriptores.DECIMAL_AJUSTE[i];
            TIPO_AJUSTE        := Reg_Descriptores.TIPO_AJUSTE[i];
            BASE_ORIGINAL      := Reg_Descriptores.BASE_ORIGINAL[i];
            BASE_CONVERSION    := Reg_Descriptores.BASE_CONVERSION[i];
            COD_CALC_PAR_D     := Reg_Descriptores.COD_CALC_PAR_D[i];
            COD_CALC_TIR_D     := Reg_Descriptores.COD_CALC_TIR_D[i];
            COD_CALC_PAR_D_Old := Reg_Descriptores.COD_CALC_PAR_D[i];
            COD_CALC_TIR_D_Old := Reg_Descriptores.COD_CALC_TIR_D[i];
            OPCION_PREPAGO     := Reg_Descriptores.OPCION_PREPAGO[i];
            FECHA_PREPAGO      := Reg_Descriptores.FECHA_PREPAGO[i];
            PRECIO_PREPAGO     := Reg_Descriptores.PRECIO_PREPAGO[i];
            TASA_FLOTANTE      := Reg_Descriptores.TASA_FLOTANTE[i];
            TIPO_NOMINALES     := Reg_Descriptores.TIPO_NOMINALES[i];
            FECHAS_SINO        := Reg_Descriptores.FECHAS_SINO[i];
            TIPO_PAGO          := Reg_Descriptores.TIPO_PAGO[i];
            PERIODO_GRACIA     := Reg_Descriptores.PERIODO_GRACIA[i];
            fCupones_Cortados  := 0;
            Variacion_Cambiaria   := False;

            // Se agrega if por tasa flotante el 03-01-2008
            // No tiene sentido que vaya a leer a la tabla si no es tasa flotanrte (MULTIPLES TASAS)
            if TASA_FLOTANTE = 'S' then
            begin
               WITH DMFuncionesMemory.QRY_General do
               begin
                 Close;
                 SQL.Clear;
                 SQL.Add('SELECT COUNT(*) As Num_Regs                        ');
                 SQL.Add('  FROM QS_FIN_DEF_DESFLOT                          ');
                 SQL.Add(' WHERE SERIE              = :Serie                 ');
                 SQL.Add('   AND CODIGO_INSTRUMENTO = :Instrumento           ');
                 SQL.Add('   AND CODIGO_IDENTIDAD   = :Emisor                ');
                 SQL.Add('   AND TIPO_TASA is NOT NULL                       ');
                 if (sDriver = 'ORACLE') then
                    SQL.Add('   AND TIPO_TASA <> '' ''                         ')
                 else
                    SQL.Add('   AND TIPO_TASA <> ''''                          ');

                 ParamByName('Emisor'     ).AsString := sEmisor;
                 ParamByName('Instrumento').AsString := sInstrumento;
                 ParamByName('Serie'      ).AsString := sSerie;

                 Open;
                 if FieldByName('Num_Regs').AsInteger = 0 then
                    bSin_Tasa_en_Flujos := True
                 else
                    bSin_Tasa_en_Flujos := False;
                 Close;
               end;
            end
            else
              bSin_Tasa_en_Flujos := True;

            //Verifico si tiene excepcion cambiaria
            Verifica_Excepcion_Variacion_Cambiaria_Mem( Reg_Descriptores.CODIGO_EMISOR[i]
                                                       ,Reg_Descriptores.CODIGO_INSTRUMENTO[i]
                                                       ,Reg_Descriptores.SERIE[i]
                                                       ,0
                                                       ,fPtje_Aplica_Reajuste
                                                       ,sCodigo_MondInd
                                                       ,s0Cod_Tratam_Inicio
                                                       ,s1Cod_Tratam_Termino
                                                       ,dFecha_Inicio_Tratamiento
                                                       ,dFecha_Termino_Tratamiento
                                                       ,bExiste_Excepcion);
            if bExiste_Excepcion then
               Variacion_Cambiaria := True;

            Leer_Tasa_base_Variable_Mem(TASA_VALOR_PAR
                                          ,FECHA_DESDE
                                          ,FECHA_HASTA
                                          ,TIPO_CALCULO_DIAS
                                          ,COD_TRATAM_INICIO
                                          ,COD_TRATAM_TERMINO
                                          ,TASA_DEPENDE_PERIODOS
                                          ,sBASE_SEGUN_ANO
                                          ,Aux_Modulo_Err
                                          ,Aux_String_Err
                                          ,bDias_Base_Variables);

            if bDias_Base_Variables then
               if TASA_DEPENDE_PERIODOS = 'S' then
               begin
                  if PERIODO_PAGO = 0 then
                     fPeriodos := 1
                  else
                    fPeriodos := 12 / PERIODO_PAGO;
                  TASA_EFECTIVA := TASA_EFECTIVA / fPeriodos;
               end;
         end;
     end;

     If not Result then
     begin
        Modulo_Err := 'Lectura de Descriptor';
        String_Err := 'No existe descriptor para: '
                      +sEmisor+' - '
                      +sInstrumento+' - '
                      +sSerie;
     end;
  end;
end;
