function Redondeo_Moneda_Mem(const sCod_Moneda     : String;
                             dFecha_Redondeo : TDatetime;
                             fValor_Original : Double) : Double;
Var
  fDecimal_Ajuste : Integer;
  sTipo_Ajuste    : String;
  flag_Encontro   : Boolean;
  i
  ,iLimite_Inferior
  ,iLimite_Superior : Integer;
begin
  if NOT VarIsArray(Reg_Redondeo_Monedas.Cod_Moneda) then
     Carga_Valores_Redondeo_Monedas_Mem(dFecha_Redondeo);

  fDecimal_Ajuste  := 0;
  Flag_Encontro    := False;
  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Redondeo_Monedas.Cod_Moneda, 1 )-1;
  While iLimite_Inferior <= iLimite_Superior do
  begin
     i := Trunc((iLimite_Inferior+iLimite_Superior)/2);

     if  Reg_Redondeo_Monedas.Cod_Moneda[i] = sCod_Moneda then
     begin
        Flag_Encontro   := True;
        fDecimal_Ajuste := Reg_Redondeo_Monedas.Decimal_Ajuste[i];
        sTipo_Ajuste    := Reg_Redondeo_Monedas.Tipo_Ajuste_Mon[i];
        Break;
     end;

     if sCod_Moneda > Reg_Redondeo_Monedas.Cod_Moneda[i] then
        iLimite_Inferior := i + 1
     else
        iLimite_Superior := i -1;

  end;

 if NOT Flag_Encontro then
     Result := fValor_Original
 else
    if sTipo_Ajuste = 'R' then
       Result := Redondeo(fValor_Original,fDecimal_Ajuste)//RoundD(fValor_Original,fDecimal_Ajuste) 
    else
       Result := Truncado(fValor_Original,fDecimal_Ajuste);
end;

Procedure Carga_Valores_Redondeo_Monedas_Mem( dFecha : Tdatetime );
Var
  i               : Integer;
begin
  //Ojo que esta carga puede fallar por la fecha desde ajuste
  WITH DMFuncionesMemory.QRY_General do
  begin
     Close;
     SQL.Clear;
      // D.C. & F.I. 06-08-2015
      // Se detecto que estaba cargando redondeos que ya no estan vigentes
      SQL.Add('SELECT a.Cod_Moneda'
             +'      ,a.Decimal_Ajuste'
             +'      ,a.Tipo_Ajuste_Mon'
             +'  FROM QS_SYS_MON_REDON a'
             +' WHERE a.Fecha_Desde_Ajuste = (SELECT MAX(b.Fecha_desde_Ajuste)'
             +' 		   	      FROM QS_SYS_MON_REDON b'
             +' 		   	      WHERE b.Cod_Moneda = a.Cod_Moneda '
             +' 		   	      AND b.Fecha_Desde_Ajuste <= :Fecha_Desde_Ajuste )'
             +' ORDER BY a.Cod_Moneda'
             );
      ParamByName('Fecha_Desde_Ajuste').AsDate := dFecha;
      Open;

//      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;

      Reg_Redondeo_Monedas.Cod_Moneda       := VarArrayCreate([0, i], varOleStr);
      Reg_Redondeo_Monedas.Decimal_Ajuste   := VarArrayCreate([0, i], varDouble);
      Reg_Redondeo_Monedas.Tipo_Ajuste_Mon  := VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Redondeo_Monedas.Cod_Moneda[i]      := FieldByName('Cod_Moneda').asString;
         Reg_Redondeo_Monedas.Decimal_Ajuste[i]  := FieldByName('Decimal_Ajuste').asFloat;
         Reg_Redondeo_Monedas.Tipo_Ajuste_Mon[i] := FieldByName('Tipo_Ajuste_Mon').asString;
         Next;
         Inc(i);
      end;
       Close;
       UnPrepare;
   end;  // With
end;

procedure leer_valor_cambio2_Mem(const sMon_Origen  : String;
                                 const sMon_Paridad  : String;
                                 sTipo_Paridad : String;
                                 dfecha        : TDatetime;
                                 var fParidad  : Double;
                                 var Result    : Boolean);
var
 sTipo_Moneda,
 sTipo_Unidad,
 sUnidad,
 sTipo_Variacion,
 sUnidad_Conversion : String;
 aux_pchar : Array[0..250] of Char;
 bResult   : Boolean;

begin
     Result := True;
     Busca_Valores_Monedas_Periodo_Mem( sMon_Origen
                                      ,sUnidad_Conversion
                                      ,sTipo_Moneda
                                      ,sTipo_Unidad
                                      ,sUnidad
                                      ,sTipo_Variacion
                                     );

    if (sTipo_Moneda = 'M') and
       (sMon_Origen  = sMon_Paridad) then
    begin
      fParidad := 1;
      exit;
    end;


    if sTipo_Variacion <> 'D' then
       {Busco la fecha de paridad}
    begin
       if NOT leer_fecha_periodo(sTipo_Unidad
                                ,sUnidad
                                ,sTipo_Variacion
                                ,dfecha) then
       begin
          strpcopy(aux_pchar
                  ,'(Mem) Error en definición de período para: '''+sMon_Origen+''''
                  +#10'con fecha: '+datetostr(dfecha_Periodo));

          Application.MessageBox(aux_pchar
                               ,'Valor Paridad'
                               ,mb_OK);

         Result := False;
         exit;
       end;
    end
    else
       dfecha_Periodo := dfecha;

    {Busco Paridad}

  {  swhere_part := ' WHERE Fecha_Paridad = :pfecha'
                 +'   AND  Cod_moneda      = '''+sMon_Origen+''''
                 +'   AND  Tipo_De_Paridad = '''+sTipo_Paridad+'''';

    if sTipo_Moneda = 'M' then
       swhere_part := swhere_part
                  +' AND Moneda_Paridad = '''+sMon_Paridad+'''';
   }
    Buscar_Valor_Cambio_Mem( sMon_Origen
                             ,sTipo_Paridad
                             ,sMon_Paridad
                             ,sTipo_Moneda
                             ,dfecha_Periodo
                             ,False  // Busca en memoria y luego en la tabla fisica
                             ,fParidad
                             ,bResult);
    Result := bResult;

    if (Not bResult) or
       (fParidad = 0) then
    begin
      {Busco a reves (solo una vez por re_llamado}
       if (sTipo_Moneda = 'M') and NOT re_llamado then
       begin
         re_llamado := True;

         leer_valor_cambio2_Mem(sMon_Paridad,
                                   sMon_Origen,
                                   sTipo_Paridad,
                                   dfecha,
                                   fParidad,
                                   Result);
         if Result then
            if fParidad <> 0 then
               fParidad := 1 / fParidad
            else
               fParidad := 0;
         re_llamado := False;
       end
       else
       begin
         Result := False;
         fParidad := 0;
         if sTipo_Moneda = 'T' then
            if bResult then //NOT FieldByName('Valor_Moneda').IsNull then
               Result := True;
       end
    end;

    if (sTipo_Moneda = 'M') AND
       (fParidad = 0)        then
        Result := False;
end;

procedure  Buscar_Valor_Cambio_Mem( const sCod_Moneda     :String;
                                    const sTipo_Paridad   :String;
                                    const sMoneda_Paridad :String;
                                    const sTipo_Moneda    :String;
                                    dFecha_Paridad  :TDatetime;
                                    const bSoloMemoria    :Boolean;
                                    var fValor            :Double;
                                    var bResult           : Boolean);
var i : Integer;
begin
   bResult := False;
   if sCod_Moneda = 'UF' then
      Busca_UF_Mem( dFecha_Paridad,
                    fValor,
                    bResult
                  )
   else if sCod_Moneda = 'IPC' then
      Busca_Ipc_Mem( dFecha_Paridad,
                     fValor,
                     bResult
                    )
       else
       begin
           if NOT VarIsArray(Reg_Monedas.COD_MONEDA) then
           begin
              i := 0;
              Reg_Monedas.COD_MONEDA      := VarArrayCreate([0, i], varOleStr);
              Reg_Monedas.TIPO_DE_PARIDAD := VarArrayCreate([0, i], varOleStr);
              Reg_Monedas.MONEDA_PARIDAD  := VarArrayCreate([0, i], varOleStr);
              Reg_Monedas.FECHA_PARIDAD   := VarArrayCreate([0, i], varDate);
              Reg_Monedas.VALOR_MONEDA    := VarArrayCreate([0, i], varDouble);
              Reg_Monedas.TIPO            := VarArrayCreate([0, i], varOleStr);
           end
          else
          for i := 0 to VarArrayHighBound(Reg_Monedas.COD_MONEDA,1)  do
          begin
             if (sTipo_Moneda = 'M')  then
             begin
                if    (Reg_Monedas.COD_MONEDA[i]      = sCod_Moneda)
                 and  (Reg_Monedas.TIPO_DE_PARIDAD[i] = sTipo_Paridad)
                 and  (Reg_Monedas.MONEDA_PARIDAD[i]  = sMoneda_Paridad)
                 and  (Reg_Monedas.FECHA_PARIDAD[i]   = dFecha_Paridad) then
                begin
                   fValor  := Reg_Monedas.Valor_Moneda[i];
                   bResult := True;
                   Break;
                end;
             end
             else
             begin
                if     (Reg_Monedas.COD_MONEDA[i]      = sCod_Moneda)
                  and  (Reg_Monedas.TIPO_DE_PARIDAD[i] = sTipo_Paridad)
                  and  (Reg_Monedas.FECHA_PARIDAD[i]   = dFecha_Paridad) then
                begin
                   fValor  := Reg_Monedas.Valor_Moneda[i];
                   bResult := True;
                   Break;
                end;
             end;
          end;
       end;

   if (Not bResult) and (NOT bSoloMemoria) Then
      leer_valor_cambio2(sCod_Moneda,
                        sMoneda_Paridad,
                        sTipo_Paridad,
                        dFecha_Paridad,
                        fValor,
                        bResult);

end;


Procedure Busca_Valores_Monedas_Periodo_Mem( const sMon_Origen       : String;
                                         var  sUnidad_Conversion : String;
                                         var  sTipo_Moneda       : String;
                                         var  sTipo_Unidad       : String;
                                         var  sUnidad            : String;
                                         var  sTipo_Variacion    : String
                                       );
var i
   ,iLimite_Superior : Integer;
begin
  // Si no sido creada la crea y la carga
  if NOT VarIsArray(Reg_Monedas_Periodo.Cod_Moneda) then
     Carga_Valores_Monedas_Periodo_Mem;

//  iLimite_Inferior := 0;
  iLimite_Superior := VarArrayHighBound(Reg_Monedas_Periodo.Cod_Moneda, 1 )-1;
  For  i := 0 to iLimite_Superior do
  begin
     if  Reg_Monedas_Periodo.Cod_Moneda[i] = sMon_Origen then
     begin
        sUnidad_Conversion := Reg_Monedas_Periodo.Unidad_Conversion[i];
        sTipo_Moneda       := Reg_Monedas_Periodo.Tipo_Moneda[i];
        sTipo_Unidad       := Reg_Monedas_Periodo.Tipo_Unidad[i];
        sUnidad            := Reg_Monedas_Periodo.Unidad[i];
        sTipo_Variacion    := Reg_Monedas_Periodo.Tipo_Variacion[i];
        Break;
     end;
  end;
end;

procedure Carga_Valores_Monedas_Periodo_Mem;
var i : longInt;
begin
  WITH DMFuncionesMemory.QRY_General do
  begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT a.Cod_Moneda'
             +'      ,a.Unidad_Conversion'
             +'      ,a.Tipo_moneda As Tipo_Moneda'
             +'      ,a.Descripcion_Moneda'
             +'      ,b.Tipo_Unidad As Tipo_Unidad'
             +'      ,b.Unidad      As Unidad'
             +'      ,b.Tipo_Variacion As Tipo_Variacion'
             +'  FROM QS_SYS_MONEDAS a'
             +'      ,QS_SYS_PERIODO b'
             +' WHERE a.Tipo_Uni_Variacion = b.Tipo_Unidad'
             +'   AND a.Unidad_Medida_Mon  = b.Unidad'
             +' ORDER BY Cod_Moneda'
             );
      Open;

//      DmFuncionesMemory.QRY_General.last;
        i := DmFuncionesMemory.QRY_General.RecordCount;
//        DmFuncionesMemory.QRY_General.first;

      Reg_Monedas_Periodo.Cod_Moneda        := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Unidad_Conversion := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Tipo_Moneda       := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Tipo_Unidad       := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Unidad            := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Tipo_Variacion    := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas_Periodo.Descripcion_Moneda:= VarArrayCreate([0, i], varOleStr);

      i := 0;
      while not eof do
      begin
         Reg_Monedas_Periodo.Cod_Moneda[i]        := FieldByName('Cod_Moneda').AsString;
         Reg_Monedas_Periodo.Unidad_Conversion[i] := FieldByName('Unidad_Conversion').AsString;
         Reg_Monedas_Periodo.Tipo_Moneda[i]       := FieldByName('Tipo_Moneda').AsString;
         Reg_Monedas_Periodo.Tipo_Unidad[i]       := FieldByName('Tipo_Unidad').AsString;
         Reg_Monedas_Periodo.Unidad[i]            := FieldByName('Unidad').AsString;
         Reg_Monedas_Periodo.Tipo_Variacion[i]    := FieldByName('Tipo_Variacion').AsString;
         Reg_Monedas_Periodo.Descripcion_Moneda[i]:= FieldByName('Descripcion_Moneda').AsString;
         Next;
         Inc(i);
      end;

      Close;
      UnPrepare;
    end;
end;

Procedure Carga_Valores_de_Cambio_Mem( dFecha_Inicial
                                      ,dFecha_Final   : TDatetime;
                                       sMoneda_Indice : String
                                      );
Var i,j : LongInt;
begin
   with DmFuncionesMemory.QRY_General do
   begin
      Close;
      SQL.Clear;
      SQL.Add('SELECT Count(*) As Num_Regs            ');
      SQL.Add('  FROM QS_SYS_MONEDAS    b             ');
      SQL.Add('      ,QS_SYS_PERIODO    c             ');
      SQL.Add('      ,QS_SYS_VAL_CAMBIO a             ');
      SQL.Add(' WHERE c.TIPO_UNIDAD = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	 = b.UNIDAD_MEDIDA_MON     ');
      SQL.Add('   AND b.Cod_Moneda   <> ''IPC''            ');   // Los Cargo Aparte
      SQL.Add('   AND b.Cod_Moneda   <> ''UF''             ');
      SQL.Add('   AND c.Tipo_Variacion = ''D''             ');
      SQL.Add('   AND b.COD_MONEDA = a.COD_MONEDA          ');
      SQL.Add('   AND a.Fecha_Paridad >= :Fecha_Inicial    ');
      SQL.Add('   AND a.Fecha_Paridad <= :Fecha_Final      ');

      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND  b.Cod_Moneda   = '''+sMoneda_Indice+'''' );

      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Open;
      i := Round(FieldByName('Num_Regs').AsFloat);

      SQL.Clear;
      SQL.Add('SELECT b.COD_MONEDA ');
      SQL.Add('      ,a.TIPO_DE_PARIDAD');
      SQL.Add('      ,a.MONEDA_PARIDAD');
      SQL.Add('      ,a.FECHA_PARIDAD');
      SQL.Add('      ,a.VALOR_MONEDA');
      SQL.Add('      ,a.TIPO');
      SQL.Add('  FROM QS_SYS_MONEDAS    b             ');
      SQL.Add('      ,QS_SYS_PERIODO    c             ');
      SQL.Add('      ,QS_SYS_VAL_CAMBIO a             ');
      SQL.Add(' WHERE c.TIPO_UNIDAD = b.TIPO_UNI_VARIACION ');
      SQL.Add('   AND c.UNIDAD	 = b.UNIDAD_MEDIDA_MON     ');
      SQL.Add('   AND b.Cod_Moneda   <> ''IPC''            ');   // Los Cargo Aparte
      SQL.Add('   AND b.Cod_Moneda   <> ''UF''             ');
      SQL.Add('   AND c.Tipo_Variacion = ''D''             ');
      SQL.Add('   AND b.COD_MONEDA = a.COD_MONEDA          ');
      SQL.Add('   AND a.Fecha_Paridad >= :Fecha_Inicial    ');
      SQL.Add('   AND a.Fecha_Paridad <= :Fecha_Final      ');

      if trim(sMoneda_Indice) <> '' then
         Sql.Add(' AND  b.Cod_Moneda   = '''+sMoneda_Indice+'''' );

      Sql.Add(' ORDER BY a.Fecha_Paridad');
      Parambyname('Fecha_Inicial').asDate := dFecha_Inicial;
      Parambyname('Fecha_Final').asDate   := dFecha_Final;
      Open;


      Reg_Monedas.COD_MONEDA      := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas.TIPO_DE_PARIDAD := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas.MONEDA_PARIDAD  := VarArrayCreate([0, i], varOleStr);
      Reg_Monedas.FECHA_PARIDAD   := VarArrayCreate([0, i], varDate);
      Reg_Monedas.VALOR_MONEDA    := VarArrayCreate([0, i], varDouble);
      Reg_Monedas.TIPO            := VarArrayCreate([0, i], varOleStr);

      // j := 0;
      For j := 0 to i do
      begin
         Reg_Monedas.COD_MONEDA[j]      := Fieldbyname('COD_MONEDA').asString;
         Reg_Monedas.TIPO_DE_PARIDAD[j] := Fieldbyname('TIPO_DE_PARIDAD').asString;
         Reg_Monedas.MONEDA_PARIDAD[j]  := Fieldbyname('MONEDA_PARIDAD').asString;
         Reg_Monedas.FECHA_PARIDAD[j]   := Fieldbyname('FECHA_PARIDAD').asDatetime;
         Reg_Monedas.VALOR_MONEDA[j]    := Fieldbyname('VALOR_MONEDA').asFloat;
         Reg_Monedas.TIPO[j]            := Fieldbyname('TIPO').asString;
         Next;
         if Eof then
            Break;
      end;
      Close;
  end;
end;

