begin
   bHayFwd := False;

   sImplicancia_Venta    := LLena_String_Implicancia('VENTA');
   sImplicancia_Pacto    := LLena_String_Implicancia('PACTO' );
   sImplicancia_Margen   := LLena_String_Implicancia('MARGEN');

   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos(sDriver
                                ,'QS_TRA_OMD_PREPAGO_PACTO'
                                ,sModulo_Error
                                ,sString_Error
                                ,bAnticipos_Pactos
                                ,Result);
  WITH DmFuncionesMemory.Qry_General do
  begin

    try
       SQL.Clear;
       SQL.Add('SELECT Empresa '
              +'  FROM QS_TRA_FWD ');
       Open;
       bforward := true;
    except
       bforward := false;
    end;

    SQL.Clear;
    SQL.Add('SELECT Count(*) as Registros'
           +' FROM QS_TRA_OMD_DET_RF a,'
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           = :Empresa '
           +'   AND d.Folio_Interno     = a.Folio_Interno '
           +'   AND d.Transaccion       = a.Transaccion '
           +'   AND d.empresa           = a.empresa '
           +'   AND a.Tipo_Instrum      <> ''R'''
           +'   AND d.Fecha_Operacion   <= :Fecha'
             );
    SQL.Add('   AND a.Transaccion in (SELECT b.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic b '
           +'                             WHERE b.Codigo_transaccion = a.transaccion'
           // ggarcia 22-05-2015
           //+'                               AND b.implicancia = '''+'PACTO'+''')');
           +'                               AND b.implicancia IN (''PACTO'',''MARGEN''))');
    SQL.Add('   AND a.Transaccion   In (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'VENTA'+''')');
    SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
           +'                               FROM qs_ctr_anulacion f'
           +'                             WHERE f.empresa     = a.empresa'
           +'                               AND f.transaccion = a.Transaccion'
           +'                               AND f.Folio       = a.Folio_interno)'
           );

    // 12-02-2015 F.I.
    if bAnticipos_Pactos then
    begin
      SQL.Add('   AND a.folio_interno NOT IN (SELECT g.FOLIO_INTERNO_REL                   ');
      SQL.Add('                                 FROM QS_TRA_OMD_PREPAGO_PACTO g            ');
      SQL.Add('                                WHERE g.FOLIO_INTERNO_REL = a.Folio_Interno ');
      SQL.Add('                                  AND g.Transaccion_Rel   = a.Transaccion   ');
      SQL.Add('                                  AND g.Empresa_Rel       = a.Empresa       ');
      SQL.Add('                                  AND g.Fecha_Prepago    <= :Fecha          ');
      SQL.Add('                                  AND g.folio_interno NOT IN (SELECT e.folio                         ');
      SQL.Add('                                                                FROM qs_ctr_anulacion e              ');
      SQL.Add('                                                               WHERE e.folio       = g.folio_interno ');
      SQL.Add('                                                                 AND e.transaccion = g.transaccion   ');
      SQL.Add('                                                                 AND e.empresa     = g.empresa))     ');
    end;

    ParamByName('Empresa').AsString     := sEmpresa;
    ParamByName('Fecha').AsDate     := dFecha;
    Open;
    i := 0;
    if Not Fieldbyname('Registros').IsNull then
    begin
       i := Fieldbyname('Registros').asInteger;
       bHayPacto := True;
    end
    else
       bHayPacto := False;


    SQL.Clear;
    SQL.Add('SELECT Count(*) as Registros'
           +' FROM QS_TRA_OMD_DET_RF a,'
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           = :Empresa '
           +'   AND d.Folio_Interno     = a.Folio_Interno '
           +'   AND d.Transaccion       = a.Transaccion '
           +'   AND d.empresa           = a.empresa '
           +'   AND a.Tipo_Instrum      <> ''R'''
           //ggarcia 01-06-2016
           //+'   AND a.Item_OMD          = 1 '
           +'   AND a.Item_OMD          <> 2'
           +'   AND d.Fecha_Operacion   <= :Fecha'
           +'   AND (a.folio_interno_rel is not null and a.folio_interno_rel <> '' '') '
              );
    SQL.Add('   AND a.Transaccion in (SELECT b.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic b '
           +'                             WHERE b.Codigo_transaccion = a.transaccion'
           +'                               AND b.implicancia = '''+'DERIVADO'+''')');
    SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
           +'                               FROM qs_ctr_anulacion f'
           +'                             WHERE f.empresa     = a.empresa'
           +'                               AND f.transaccion = a.Transaccion'
           +'                               AND f.Folio       = a.Folio_interno)'
           );
    if bAnticipos_Pactos then
    begin
      SQL.Add('   AND a.folio_interno NOT IN (SELECT g.FOLIO_INTERNO_REL                   ');
      SQL.Add('                                 FROM QS_TRA_OMD_PREPAGO_PACTO g            ');
      SQL.Add('                                WHERE g.FOLIO_INTERNO_REL = a.Folio_Interno ');
      SQL.Add('                                  AND g.Transaccion_Rel   = a.Transaccion   ');
      SQL.Add('                                  AND g.Empresa_Rel       = a.Empresa       ');
      SQL.Add('                                  AND g.Fecha_Prepago    <= :Fecha          ');
      SQL.Add('                                  AND g.folio_interno NOT IN (SELECT e.folio                         ');
      SQL.Add('                                                                FROM qs_ctr_anulacion e              ');
      SQL.Add('                                                               WHERE e.folio       = g.folio_interno ');
      SQL.Add('                                                                 AND e.transaccion = g.transaccion   ');
      SQL.Add('                                                                 AND e.empresa     = g.empresa))     ');
    end;
    ParamByName('Empresa').AsString     := sEmpresa;
    ParamByName('Fecha').AsDate     := dFecha;
    Open;
    if ((Not Fieldbyname('Registros').IsNull) AND (Fieldbyname('Registros').AsFloat > 0)) then
    begin
       i := i + Fieldbyname('Registros').asInteger;
       bHayDerivado := True;
    end
    else
       bHayDerivado := False;

    if bforward then
    begin
       SQL.Clear;
       SQL.Add('SELECT Count(*) as Registros'
              +' FROM QS_TRA_FWD_DET_GARANTIA a, '
              +'      QS_TRA_FWD              d'
              +' WHERE a.Empresa           = :Empresa'
              +'   AND d.Folio_Interno     = a.Folio_Interno '
              +'   AND d.Transaccion       = a.Transaccion '
              +'   AND d.empresa           = a.empresa '
              +'   AND a.Tipo_Inversion    <> ''RV'''
              +'   AND d.Fecha_Operacion   <= :Fecha');
       SQL.Add('   AND a.Transaccion   In (SELECT c.Codigo_Transaccion'
              +'                               FROM qs_sys_tran_implic c '
              +'                             WHERE c.Codigo_transaccion = a.transaccion'
//              +'                               AND c.implicancia in ('''+'VENTA'+''','''+'COMPRA'+''') )');    DC 11/10/2017 esto se inhibio pq no hubo control de calidad considera compras y ventas
              +'                               AND c.implicancia = '''+'VENTA'+''')');
       SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
              +'                               FROM qs_ctr_anulacion f'
              +'                             WHERE f.empresa     = a.empresa'
              +'                               AND f.transaccion = a.Transaccion'
              +'                               AND f.Folio       = a.Folio_interno)');
       ParamByName('Empresa').AsString     := sEmpresa;
       ParamByName('Fecha').AsDate     := dFecha;
       Open;
       if ((Not Fieldbyname('Registros').IsNull) AND (Fieldbyname('Registros').AsFloat > 0)) then
       begin
          i := i + Fieldbyname('Registros').asInteger;
          bHayFwd := True;
       end
       else
          bHayFwd := False;
    end;

    Close;
    SQL.Clear;

    if bHayPacto then
    begin
          SQL.Clear;
          SQL.Add('SELECT a.Cartera'
                 +'      ,a.valor_nominal'
                 +'      ,a.Folio_Interno_Rel'
                 +'      ,a.Transaccion_Rel'
                 +'      ,a.Item_Omd_Rel'
                 +'      ,d.Fecha_Operacion'
                 +'      ,d.Fecha_Vcto_Pacto'
                 +'      ,a.Valor_Pactado_UM'
                 +'      ,a.Valor_Pactado_MC'
                 +'      ,a.Transaccion'
                 +'      ,a.Folio_Interno'
                 +'      ,a.Item_Omd'
                 +'  FROM QS_TRA_OMD d'
                 +'      ,QS_TRA_OMD_DET_RF a'
                 +' WHERE d.Empresa           = :Empresa '
                 +'   AND d.Fecha_Operacion   <= :Fecha'  );
          SQL.Add('   AND (d.Transaccion IN '+sImplicancia_Pacto+ ' OR '+' d.Transaccion IN '+sImplicancia_Margen+')' );
          SQL.Add('   AND d.Transaccion IN '+sImplicancia_Venta );
          SQL.Add('   AND a.Folio_Interno     = d.Folio_Interno '
                 +'   AND a.Transaccion       = d.Transaccion '
                 +'   AND a.empresa           = d.empresa '
                 +'   AND a.Tipo_Instrum      <> ''R'''
                   );
{
          SQL.Add('   AND d.Transaccion in (SELECT b.Codigo_Transaccion'
                 +'                               FROM qs_sys_tran_implic b '
                 +'                             WHERE b.Codigo_transaccion = d.transaccion'
                 // ggarcia 22-05-2015
                 //+'                               AND b.implicancia = '''+'PACTO'+''')');
                 +'                               AND b.implicancia IN (''PACTO'',''MARGEN''))');
          SQL.Add('   AND a.Transaccion   In (SELECT c.Codigo_Transaccion'
                 +'                               FROM qs_sys_tran_implic c '
                 +'                             WHERE c.Codigo_transaccion = d.transaccion'
                 +'                               AND c.implicancia = '''+'VENTA'+''')');
}
          SQL.Add('   AND d.Folio_Interno  NOT IN (SELECT f.Folio '
                 +'                                  FROM qs_ctr_anulacion f'
                 +'                                 WHERE f.empresa     = d.empresa'
                 +'                                   AND f.transaccion = d.Transaccion'
                 +'                                   AND f.Folio       = d.Folio_interno)');

          // 12-02-2015 F.I.
          if bAnticipos_Pactos then
          begin
            SQL.Add('   AND d.folio_interno NOT IN (SELECT g.FOLIO_INTERNO_REL                   ');
            SQL.Add('                                 FROM QS_TRA_OMD_PREPAGO_PACTO g            ');
            SQL.Add('                                WHERE g.FOLIO_INTERNO_REL = d.Folio_Interno ');
            SQL.Add('                                  AND g.Transaccion_Rel   = d.Transaccion   ');
            SQL.Add('                                  AND g.Empresa_Rel       = d.Empresa       ');
            SQL.Add('                                  AND g.Fecha_Prepago    <= :Fecha          ');
            SQL.Add('                                  AND g.folio_interno NOT IN (SELECT e.folio                         ');
            SQL.Add('                                                                FROM qs_ctr_anulacion e              ');
            SQL.Add('                                                               WHERE e.folio       = g.folio_interno ');
            SQL.Add('                                                                 AND e.transaccion = g.transaccion   ');
            SQL.Add('                                                                 AND e.empresa     = g.empresa))     ');
          end;
    end;

    if bHayDerivado then
    begin
        if bHayPacto then
           SQL.Add(' UNION ');
        SQL.Add('SELECT a.Cartera'
               +' ,a.valor_nominal'
               +' ,a.Folio_Interno_Rel'
               +' ,a.Transaccion_Rel'
               +' ,a.Item_Omd_Rel'
               +' ,d.Fecha_Operacion'
               +' ,d.Fecha_Vcto_Pacto'
               +' ,a.Valor_Invertido_UM asValor_Pactado_UM'
               +' ,a.Valor_Invertido_MC asValor_Pactado_MC'
               +' ,a.Transaccion'
               +' ,a.Folio_Interno'
               +' ,a.Item_Omd'
               +' FROM QS_TRA_OMD_DET_RF a,'
               +'      QS_TRA_OMD d'
               +' WHERE a.Empresa           = :Empresa '
               +'   AND d.Folio_Interno     = a.Folio_Interno '
               +'   AND d.Transaccion       = a.Transaccion '
               +'   AND d.empresa           = a.empresa '
               +'   AND a.Tipo_Instrum      <> ''R'''
               //ggarcia 01-06-2016
               //+'   AND a.Item_OMD          = 1 '
               +'   AND a.Item_OMD          <> 2'
               +'   AND d.Fecha_Operacion   <= :Fecha'
               +'   AND (a.folio_interno_rel is not null and a.folio_interno_rel <> '' '') '
               );
        SQL.Add('   AND a.Transaccion in (SELECT b.Codigo_Transaccion'
               +'                               FROM qs_sys_tran_implic b '
               +'                             WHERE b.Codigo_transaccion = a.transaccion'
               +'                               AND b.implicancia = '''+'DERIVADO'+''')');
        SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
               +'                               FROM qs_ctr_anulacion f'
               +'                             WHERE f.empresa     = a.empresa'
               +'                               AND f.transaccion = a.Transaccion'
               +'                               AND f.Folio       = a.Folio_interno)');
        if bAnticipos_Pactos then
        begin
          SQL.Add('   AND a.folio_interno NOT IN (SELECT g.FOLIO_INTERNO_REL                   ');
          SQL.Add('                                 FROM QS_TRA_OMD_PREPAGO_PACTO g            ');
          SQL.Add('                                WHERE g.FOLIO_INTERNO_REL = a.Folio_Interno ');
          SQL.Add('                                  AND g.Transaccion_Rel   = a.Transaccion   ');
          SQL.Add('                                  AND g.Empresa_Rel       = a.Empresa       ');
          SQL.Add('                                  AND g.Fecha_Prepago    <= :Fecha          ');
          SQL.Add('                                  AND g.folio_interno NOT IN (SELECT e.folio                         ');
          SQL.Add('                                                                FROM qs_ctr_anulacion e              ');
          SQL.Add('                                                               WHERE e.folio       = g.folio_interno ');
          SQL.Add('                                                                 AND e.transaccion = g.transaccion   ');
          SQL.Add('                                                                 AND e.empresa     = g.empresa))     ');
        end;
        ParamByName('Empresa').AsString     := sEmpresa;
        ParamByName('Fecha').AsDate     := dFecha;
    end;

    if bforward AND bHayFwd then
    begin
        if bHayPacto OR bHayDerivado then
           SQL.Add(' UNION ');
       SQL.Add('SELECT d.Cartera'
             +' ,a.valor_nominal'
             +' ,a.Folio_Interno_Rel'
             +' ,a.Transaccion_Rel'
             +' ,a.Item_Omd_Rel'
             +' ,d.Fecha_Operacion'
             +' ,d.Fecha_Vcto as Fecha_Vcto_Pacto'
             +' ,a.Monto_Asignado as Valor_Pactado_UM'
             +' ,a.Monto_Asignado as Valor_Pactado_MC'
             +' ,a.Transaccion'
             +' ,a.Folio_Interno'
             +' ,a.Item_Omd'
             +' FROM QS_TRA_FWD_DET_GARANTIA a, '
             +'      QS_TRA_FWD              d'
             +' WHERE a.Empresa           =  :Empresa'
             +'   AND d.Folio_Interno     = a.Folio_Interno '
             +'   AND d.Transaccion       = a.Transaccion '
             +'   AND d.empresa           = a.empresa '
             +'   AND a.Tipo_Inversion    <> ''RV'''
             +'   AND d.Fecha_Operacion   <= :Fecha'
//             +'   and d.fecha_vcto        > :Fecha '    DC 29/11/2017 se inhibio pq no hubo control de calidad
               );
      SQL.Add('   AND a.Transaccion   In (SELECT c.Codigo_Transaccion'
             +'                               FROM qs_sys_tran_implic c '
             +'                             WHERE c.Codigo_transaccion = a.transaccion'
//             +'                               AND c.implicancia in ('''+'VENTA'+''','''+'COMPRA'+''') )');      DC 11/10/2017  se inhibio pq no hubo control de calidad
             +'                                AND c.implicancia = ''VENTA'') ');
      SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
             +'                               FROM qs_ctr_anulacion f'
             +'                             WHERE f.empresa     = a.empresa'
             +'                               AND f.transaccion = a.Transaccion'
             +'                               AND f.Folio       = a.Folio_interno)');
    end;

    if bHayPacto OR bHayDerivado OR bHayFwd then
    begin
       ParamByName('Empresa').AsString     := sEmpresa;
       ParamByName('Fecha').AsDate     := dFecha;
       Open;
    end;

    Reg_Nominales_Pactados.Cartera           := VarArrayCreate([0, i], varOleStr);
    Reg_Nominales_Pactados.Folio_Interno_Rel := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Item_Omd_Rel      := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Transaccion_Rel   := VarArrayCreate([0, i], varOleStr);
    Reg_Nominales_Pactados.Valor_Nominal     := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Fecha_Operacion   := VarArrayCreate([0, i], varDate);
    Reg_Nominales_Pactados.Fecha_Vcto_Pacto  := VarArrayCreate([0, i], varDate);
    Reg_Nominales_Pactados.Valor_Pactado_UM  := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Valor_Pactado_MC  := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Transaccion       := VarArrayCreate([0, i], varOleStr);
    Reg_Nominales_Pactados.Folio_Interno     := VarArrayCreate([0, i], varDouble);
    Reg_Nominales_Pactados.Item_Omd          := VarArrayCreate([0, i], varDouble);

    if bHayPacto OR bHayDerivado OR bHayFwd then
    begin
          i := 0;
          While Not Eof do
          begin
              if (Fieldbyname('Transaccion').asString = 'VRCNC') or
                 (Fieldbyname('Transaccion').asString = 'FWDV' ) or
                 (Fieldbyname('Transaccion').asString = 'S'    ) or
                 (Fieldbyname('Transaccion').asString = 'MARGEN') then
              begin
                 Reg_Nominales_Pactados.Folio_Interno_Rel[i] := Fieldbyname('Folio_Interno_Rel').asFloat;
                 Reg_Nominales_Pactados.Item_Omd_Rel[i]      := Fieldbyname('Item_Omd_Rel').asFloat;
                 Reg_Nominales_Pactados.Transaccion_Rel[i]   := Fieldbyname('Transaccion_Rel').asString;
              end;
              Reg_Nominales_Pactados.Cartera[i]           := Fieldbyname('Cartera').asString;
              Reg_Nominales_Pactados.Valor_Nominal[i]     := Fieldbyname('Valor_Nominal').asFloat;
              Reg_Nominales_Pactados.Fecha_Operacion[i]   := Fieldbyname('Fecha_Operacion').asDatetime;
              Reg_Nominales_Pactados.Fecha_Vcto_Pacto[i]  := Fieldbyname('Fecha_Vcto_Pacto').asDatetime;
              Reg_Nominales_Pactados.Valor_Pactado_UM[i]  := Fieldbyname('Valor_Pactado_UM').asFloat;
              Reg_Nominales_Pactados.Valor_Pactado_MC[i]  := Fieldbyname('Valor_Pactado_MC').asFloat;
              Reg_Nominales_Pactados.Transaccion[i]       := Fieldbyname('Transaccion').asString;
              Reg_Nominales_Pactados.Folio_Interno[i]     := Fieldbyname('Folio_Interno').asFloat;
              Reg_Nominales_Pactados.Item_Omd[i]          := Fieldbyname('Item_Omd').asFloat;
              Inc(i);
              Next;
          end;
          Close;
        end;

        //Ordeno el Registro por Folio_Interno(Metodo Quick Sort)
        if i <> 0 then
           Ordenamiento_Registro_Nominales_Pactados_Mem(  Reg_Nominales_Pactados
                                                        ,0
                                                        ,VarArrayHighBound(Reg_Nominales_Pactados.Folio_Interno_Rel, 1 )-1
                                                       );
  end;
end;

procedure Carga_Nominales_Pactados_Mem( sEmpresa : String;
                                        dFecha   : TDatetime
                                       );
var i         : Integer;
    bforward  : Boolean;
    bAnticipos_Pactos : Boolean;
    sModulo_Error     : String;
    sString_Error     : String;
    Result            : Boolean;
begin
   // Verifica si esta la tabla en la BD
   Existe_Tabla_en_Base_de_datos(sDriver
                                ,'QS_TRA_OMD_PREPAGO_PACTO'
                                ,sModulo_Error
                                ,sString_Error
                                ,bAnticipos_Pactos
                                ,Result);
  WITH DmFuncionesMemory.Qry_General do
  begin

    try
       SQL.Clear;
       SQL.Add('SELECT Empresa '
              +'  FROM QS_TRA_FWD ');
       Open;
       bforward := true;
    except
       bforward := false;
    end;

    SQL.Clear;
    SQL.Add('SELECT Count(*) as Registros'
           +' FROM QS_TRA_OMD_DET_RF a, '
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           =  :Empresa'
           +'   AND d.Folio_Interno     = a.Folio_Interno '
           +'   AND d.Transaccion       = a.Transaccion '
           +'   AND d.empresa           = a.empresa '
           +'   AND a.Tipo_Instrum      <> ''R'''
           +'   AND d.Fecha_Operacion   <= :Fecha'
             );
    SQL.Add('   AND a.Transaccion in (SELECT b.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic b '
           +'                             WHERE b.Codigo_transaccion = a.transaccion'
           +'                               AND b.implicancia = '''+'PACTO'+''')');
    SQL.Add('   AND a.Transaccion   In (SELECT c.Codigo_Transaccion'
           +'                               FROM qs_sys_tran_implic c '
           +'                             WHERE c.Codigo_transaccion = a.transaccion'
           +'                               AND c.implicancia = '''+'VENTA'+''')');
    SQL.Add('   AND a.Folio_Interno  not in (SELECT f.Folio '
           +'                               FROM qs_ctr_anulacion f'
           +'                             WHERE f.empresa     = a.empresa'
           +'                               AND f.transaccion = a.Transaccion'
           +'                               AND f.Folio       = a.Folio_interno)'
           );
///dc 11/06/2015
    if bAnticipos_Pactos then
    begin
      SQL.Add('   AND a.folio_interno NOT IN (SELECT g.FOLIO_INTERNO_REL                   ');
      SQL.Add('                                 FROM QS_TRA_OMD_PREPAGO_PACTO g            ');
      SQL.Add('                                WHERE g.FOLIO_INTERNO_REL = a.Folio_Interno ');
      SQL.Add('                                  AND g.Transaccion_Rel   = a.Transaccion   ');
      SQL.Add('                                  AND g.Empresa_Rel       = a.Empresa       ');
      SQL.Add('                                  AND g.Fecha_Prepago    <= :Fecha          ');
      SQL.Add('                                  AND g.folio_interno NOT IN (SELECT e.folio                         ');
      SQL.Add('                                                                FROM qs_ctr_anulacion e              ');
      SQL.Add('                                                               WHERE e.folio       = g.folio_interno ');
      SQL.Add('                                                                 AND e.transaccion = g.transaccion   ');
      SQL.Add('                                                                 AND e.empresa     = g.empresa))     ');
    end;
///dc 11/06/2015
    ParamByName('Empresa').AsString     := sEmpresa;
    ParamByName('Fecha').AsDate     := dFecha;
    Open;
    i := 0;
    if Not Fieldbyname('Registros').IsNull then
       i := Fieldbyname('Registros').asInteger;

    SQL.Clear;
    SQL.Add('SELECT Count(*) as Registros'
           +' FROM QS_TRA_OMD_DET_RF a, '
           +'      QS_TRA_OMD d'
           +' WHERE a.Empresa           =  :Empresa'
