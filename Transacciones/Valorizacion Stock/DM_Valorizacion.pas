                                 fSaldo_Insoluto_MC     : Double;
                                 fValor_Pte_MC_TC_Cpa   : Double;
                                 Var Resultado          : Boolean);
var
  fYears,
  fMonths: Double;
begin
   fYears      := Int(fPlazo_al_Vcto);//fdias / 365.25;
   fMonths     := Int( frac(fPlazo_al_Vcto) *12  );//(fYears - trunc(fyears)) * 12;
   sPlazo_vcto := ''''+formatfloat('00',fYears)+'/'+formatfloat('00',fMonths);;//formatfloat('00',fYears)+'/'+formatfloat('00',fMonths);
   Resultado   := True;
   with DMValorizacion do
   begin
      Tmp_Stock.Insert;
      Tmp_StockEmpresa.asString             := sEmpresa;
      Tmp_StockTransaccion.asString         := sTransaccion;
      Tmp_StockFolio_interno.asString       := sFolio_Interno;
      Tmp_StockItem_OMD.asFloat             := fItem_Omd;
      Tmp_StockFecha_Operacion.AsDateTime   := dFecha_Operacion;
      Tmp_Stockfecha_stock.AsDateTime       := dFecha_Stock;
      Tmp_StockNemotecnico.asString         := sNemotecnico;
      Tmp_StockEmisor.asString              := sEmisor;
      Tmp_StockInstrumento.asString         := sInstrumento;
      Tmp_StockSerie.asString               := sSerie;
      Tmp_StockFecha_Emision.AsDateTime     := dFecha_Emision;
      Tmp_StockFecha_Vencimiento.AsDateTime := dFecha_Vencimiento;
      Tmp_StockValor_Nominal.asFloat        := fValor_Nominal;
      Tmp_StockValor_Nominal_Calculo.asFloat:= fValor_Nominal_Calculo;
      Tmp_StockTasa_Emision.asFloat         := fTasa_Emision;
      Tmp_StockTasa_Mercado.asFloat         := fTasa_Mercado;
      Tmp_StockMoneda_Instrum.asString      := sMoneda_Instrum;
      Tmp_StockTasa_Base_par.asString       := sTasa_Base_par;
      Tmp_StockTasa_Base_Tir.asString       := sTasa_Base_Tir;
      Tmp_StockValor_Pte_um_Cpa.asFloat     := fValor_Pte_um_Cpa;
      Tmp_StockValor_Pte_mc_Cpa.asFloat     := fValor_Pte_mc_Cpa;
      Tmp_StockPorcen_Valor_Par.asFloat     := fPorcen_Valor_Par;
      Tmp_StockCartera.asString             := sCartera;
      Tmp_StockMoneda_Pacto.asString        := sMoneda_Pacto;
      Tmp_StockTasa_pacto.asFloat           := fTasa_pacto;
      Tmp_StockTasa_Base_Pacto.asString     := sTasa_Base_Pacto;
      Tmp_StockFecha_Vcto_pacto.AsDateTime  := dFecha_Vcto_pacto;
      Tmp_StockTipo_Nominales.asString      := sTipo_Nominales;
      Tmp_StockCustodia.asString            := sCustodia;
      Tmp_StockPlazo_al_Vcto.asFloat        := fPlazo_al_Vcto;
      Tmp_StockTipo_Instrum.asString        := sTipo_Instrum;
      Tmp_StockValor_Pte_um_Mdo.asFloat     := fValor_Pte_um_Mdo;
      Tmp_StockValor_Pte_mc_Mdo.asFloat     := fValor_Pte_mc_Mdo;
      Tmp_StockTasa_Mercado_Mdo.asFloat     := fTasa_Mercado_Mdo;
      Tmp_StockDuration.asFloat             := fDuration;
      Tmp_StockPlazo_Vcto.asString          := sPlazo_Vcto;
      Tmp_StockDiferencia.asFloat           := fDiferencia;
      Tmp_StockValorizacion_Mixta.asFloat   := fValorizacion_Mixta;
      Tmp_StockPrecio_Mixto.asFloat         := fPrecio_Mixto;
      Tmp_StockMotivo_Inv.asString          := sMotivo_Inv;
      Tmp_StockClasif_Riesgo.asString       := sClasif_Riesgo;
      Tmp_Stock.FieldByName('Cupones_Cortados').asInteger   := iCupones_Cortados;

      Tmp_Stock.FieldByName('Valor_PAR_UM').asFloat      := fValor_PAR_UM;
      Tmp_Stock.FieldByName('Valor_PAR_MC').asFloat      := fValor_PAR_MC;
      Tmp_Stock.FieldByName('Saldo_Insoluto_UM').asFloat := fSaldo_Insoluto_UM;
      Tmp_Stock.FieldByName('Saldo_Insoluto_MC').asFloat := fSaldo_Insoluto_MC;
      Tmp_Stock.FieldByName('Valor_Pte_MC_TC_Cpa').asFloat := fValor_Pte_MC_TC_Cpa;

      Try
         Tmp_Stock.Post;
       except on E: EFDDBEngineException do
           begin
             ShowError(E);
             Resultado := False;
             Tmp_Stock.Cancel;
             Exit;
           end;
      end;
   end;
end;

procedure Registro_Caja(sEmpresa                   : String;
                        sCartera                   : String;
                        sTransaccion_tes           : String;
                        sfolio_interno_tes         : String;
                        sTransaccion               : String;
                        sFolio_Interno             : String;
                        fItem_Omd                  : Double;
                        dFecha_Mov                 : TDateTime;
                        dFecha_Pago                : TDateTime;
                        sTipo_Movimiento           : String;
                        sMoneda_Cartera            : String;
                        sNemotecnico               : String;
                        fIntereses_UM              : Double;
                        fAmortizacion_UM           : Double;
                        fSaldo_Insoluto            : Double;
                        fValor_Nominal             : Double;
                        fValor_Vencimiento_UM      : Double;
                        fValor_Vencimiento_MC      : Double;
                        fDiferencia_Vencimiento_UM : Double;
                        fDiferencia_Vencimiento_MC : Double;
                        iCuponVigente              : Integer;
                        sEmisor                    : String;
                        sInstrumento               : String;
                        sMoneda_pago               : String;
                        sContraparte               : String;
                        sCustodio                  : String;
                        var Modulo_Err             : String;
                        var String_Err             : String;
                        var Result                 : Boolean;
                        Reg_Parametros             : TParametros);
var sCodigo_Banco      : String;
    sCuenta_Banco      : String;
    sDescripcion       : String;
    sMotivo_OMD        : String;
    bResult            : Boolean;

    fValor_Vencimiento_UM_Corto : Double;
    fValor_Vencimiento_MC_Corto : Double;
    fValor_Vencimiento_UM_Largo : Double;
    fValor_Vencimiento_MC_Largo : Double;
    sMoneda_pos_corta           : String;
    sMoneda_pos_larga           : String;
    fTipo_Cambio_Corto          : Double;
    fTipo_Cambio_Largo          : Double;
    sTipo_Moneda                : String;
    sDescr_Moneda               : String;
    sUnidad_Conversion          : String;
    sMoneda_Compensacion        : String;
    fIntereses                  : Double;
    fAmortizacion               : Double;
begin

//   if (sFolio_Interno = '60116903')  then
//   begin
//       Application.MessageBox(PChar('Pasando por Folio 60116903 '), pchar('VALORIZACION STOCK'), MB_OK+MB_ICONEXCLAMATION+MB_APPLMODAL);
//   end;

   if NOT Reg_Parametros.bSolo_Stock then
   begin
      Result     := True;
      Modulo_Err := 'Registro Caja :';

      if bCuenta_Banco_por_defecto then
      begin
        Default_Cuenta_Banco( sEmpresa
                             ,sCartera
                             ,sTipo_Movimiento
                             ,sEmisor
                             ,sInstrumento
                             ,sMoneda_pago
                             ,sContraparte
                             ,sCustodio
                             ,dFecha_Mov
                             ,sCodigo_Banco
                             ,sCuenta_Banco
                             );
      end
      else
      begin
        sCodigo_Banco := '';
        sCuenta_Banco := '';
      end;

      //ggarcia 29-07-2021
      if BuscaStr(sImplicancia_Derivado,Trim(sTransaccion)) then
      begin
        sDescripcion       := '';
        sMotivo_OMD := Busca_Motivo_OMD_Mem(sEmpresa
                                           ,sTransaccion
                                           ,sFolio_Interno
                                           ,fItem_Omd
                                           ,dFecha_Mov);
        Busca_param_proceso('RESULT-FWD'
                           ,sMotivo_OMD
                           ,sDescripcion
                           ,bResult);
        if sDescripcion <> 'ENTFIS' then
        begin
          DMValorizacion.Tmp_Tes_Egring.EditKey;
          DMValorizacion.Tmp_Tes_Egring.FieldByName('Empresa').AsString           := sEmpresa;
          DMValorizacion.Tmp_Tes_Egring.FieldByName('Transaccion_omd').AsString   := sTransaccion;
          DMValorizacion.Tmp_Tes_Egring.FieldByName('Folio_Interno_omd').AsString := sFolio_Interno;
          DMValorizacion.Tmp_Tes_Egring.FieldByName('Fecha_Mov').AsDateTime       := dFecha_Mov;
          if DMValorizacion.Tmp_Tes_Egring.GotoKey then
          begin

            if DMValorizacion.Tmp_Tes_Egring.FieldByName('TIPO_MOVIMIENTO').asString = 'E' then
            begin
              fValor_Vencimiento_UM_Corto := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_UM_MOVIMIENTO').Asfloat;
              fValor_Vencimiento_MC_Corto := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_MC_MOVIMIENTO').Asfloat;
              fValor_Vencimiento_UM_Largo := fValor_Vencimiento_UM;
              fValor_Vencimiento_MC_Largo := fValor_Vencimiento_MC;
              sMoneda_pos_corta           := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONEDA_CARTERA').AsString;
              sMoneda_pos_larga           := sMoneda_Pago;
            end
            else
            begin
              fValor_Vencimiento_UM_Corto := fValor_Vencimiento_UM;
              fValor_Vencimiento_MC_Corto := fValor_Vencimiento_MC;
              fValor_Vencimiento_UM_Largo := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_UM_MOVIMIENTO').Asfloat;
              fValor_Vencimiento_MC_Largo := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_MC_MOVIMIENTO').Asfloat;
              sMoneda_pos_corta           := sMoneda_Pago;
              sMoneda_pos_larga           := DMValorizacion.Tmp_Tes_Egring.FieldByName('MONEDA_CARTERA').AsString;
            end;

            fValor_Vencimiento_MC := fValor_Vencimiento_MC_Largo - fValor_Vencimiento_MC_Corto;

            fIntereses            := Abs(fIntereses_um    - DMValorizacion.Tmp_Tes_Egring.FieldByName('INTERESES_UM').Asfloat);
            fAmortizacion         := Abs(fAmortizacion_um - DMValorizacion.Tmp_Tes_Egring.FieldByName('AMORTIZACION_UM').Asfloat);

            if fValor_Vencimiento_MC <> 0 then
            begin

              try
                 if fValor_Vencimiento_UM_Corto = 0 then    // se cae y no reconoce el except PAB 13/12/2023 La Popsitiva
                    fTipo_Cambio_Corto := 0
                 else
                    fTipo_Cambio_Corto := fValor_Vencimiento_MC_Corto/fValor_Vencimiento_UM_Corto;
              except
                 fTipo_Cambio_Corto := 0;
              end;

              try
                 if fValor_Vencimiento_UM_Largo = 0 then       // se cae y no reconoce el except PAB 13/12/2023 La Popsitiva
                    fTipo_Cambio_Largo := 0
                 else
                    fTipo_Cambio_Largo := fValor_Vencimiento_MC_Largo/fValor_Vencimiento_UM_Largo;
              except
                 fTipo_Cambio_Largo := 0;
              end;

              //ggarcia 18-08-2020
              Datos_Moneda_mem(sMoneda_pos_corta
                              ,sTipo_Moneda
                              ,sDescr_Moneda
                              ,sUnidad_Conversion);
              if (sTipo_Moneda = 'I') then
                 sMoneda_pos_corta := sUnidad_Conversion;

              Datos_Moneda_mem(sMoneda_pos_larga
                              ,sTipo_Moneda
                              ,sDescr_Moneda
                              ,sUnidad_Conversion);
              if (sTipo_Moneda = 'I') then
                 sMoneda_pos_larga := sUnidad_Conversion;

              with DMValorizacion.qry_aux do
              begin
                 SQL.clear;
                 SQL.Add('SELECT MONEDA_COMPENSACION '
                        +'  FROM QS_TRA_OMD_SWAP_DATADI '
                        +' WHERE FOLIO_INTERNO = :Folio_interno '
                        +'   AND TRANSACCION   = :Transaccion '
                        +'   AND EMPRESA       = :Empresa ');
                 ParamByName('Folio_interno').AsString := sFolio_Interno;
                 ParamByName('Transaccion').AsString   := sTransaccion;
                 ParamByName('Empresa').AsString       := sEmpresa;
                 Open;
                 sMoneda_Compensacion := FieldByName('MONEDA_COMPENSACION').AsString;
                 Close;
              end;

              if sMoneda_Compensacion <> sMoneda_Cartera then
              begin
                 //ggarcia 06-02-2025 if sMoneda_Cartera = sMoneda_pos_corta then
                 if sMoneda_Compensacion = sMoneda_pos_corta then
                 begin
                    fValor_Vencimiento_UM := fValor_Vencimiento_MC / fTipo_Cambio_Corto;
                    fIntereses            := fIntereses            / fTipo_Cambio_Corto;
                    fAmortizacion         := fAmortizacion         / fTipo_Cambio_Corto;
                 end
                 else
                 begin
                    fValor_Vencimiento_UM := fValor_Vencimiento_MC / fTipo_Cambio_Largo;
                    fIntereses            := fIntereses            / fTipo_Cambio_Largo;
                    fAmortizacion         := fAmortizacion         / fTipo_Cambio_Largo;
                 end;
              end
              else
                fValor_Vencimiento_UM := fValor_Vencimiento_MC;

              if fValor_Vencimiento_UM < 0 then
              begin
                 fValor_Vencimiento_UM := fValor_Vencimiento_UM *-1;
                 sTipo_Movimiento      := 'E';
              end
              else
                 sTipo_Movimiento      := 'I';

              fValor_Vencimiento_UM := Redondeo_Moneda_Mem(sMoneda_Compensacion,
                                                           dFecha_Mov,
                                                           fValor_Vencimiento_UM);
              fIntereses            := Redondeo_Moneda_Mem(sMoneda_Compensacion,
                                                           dFecha_Mov,
                                                           fIntereses);
              fAmortizacion         := Redondeo_Moneda_Mem(sMoneda_Compensacion,
                                                           dFecha_Mov,
                                                           fAmortizacion);
              DMValorizacion.Tmp_Tes_Egring.Edit;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('MONEDA_CARTERA').AsString     := sMoneda_Compensacion;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('TIPO_MOVIMIENTO').AsString    := sTipo_Movimiento;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('NEMOTECNICO').AsString        := '';
              DMValorizacion.Tmp_Tes_Egring.FieldByName('ITEM_OMD').Asfloat            := 1; //ggarcia 11-10-2023  0;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('INTERESES_UM').Asfloat        := fIntereses;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('AMORTIZACION_UM').Asfloat     := fAmortizacion;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('SALDO_INSOLUTO').Asfloat      := 0;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('VALOR_NOMINAL').Asfloat       := 0;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('DIF_VENCIMIENTO_UM').Asfloat  := fValor_Vencimiento_UM;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('DIF_VENCIMIENTO_MC').Asfloat  := fValor_Vencimiento_UM;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_UM_MOVIMIENTO').Asfloat := fValor_Vencimiento_UM;
              DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_MC_MOVIMIENTO').Asfloat := fValor_Vencimiento_UM;
              if (not transaccion_implica_mem(sEmpresa,'MOVTO_CAJA')) and
                 (not transaccion_implica_mem(sEmpresa,'NOPAGOAUTO')) then
              begin
                DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_UM_PAGADO').asFloat   := fValor_Vencimiento_UM;
                DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_MC_PAGADO').asFloat   := fValor_Vencimiento_UM;
              end
              else
              begin
                DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_UM_PAGADO').asFloat   := 0;
                DMValorizacion.Tmp_Tes_Egring.FieldByName('MONTO_MC_PAGADO').asFloat   := 0;
              end;
              DMValorizacion.Tmp_Tes_Egring.Post;
            end
            else
            begin
              DMValorizacion.Tmp_Tes_Egring.Delete;
            end;
            Exit;
          end
          else
          begin
            // si no estan las dos patas en el select principal (por uso de filtros) no puede generar registro en tesoreria
            if not Seleccion_Derivado(sEmpresa
                                     ,sTransaccion
                                     ,sFolio_Interno) then
            begin
              String_Err := 'No se puede generar registro en tesoreria ya que no se seleccionaron los dos activos del Swap por compensacion';
              Result     := False;
              Exit;
            end
            else
            begin
              with DMValorizacion.Qry_aux do
              begin
                SQL.Clear;
                Sql.Clear;
                Sql.Add('DELETE FROM QS_TES_EGRING' );
                Sql.Add(' WHERE Transaccion       = ''VCTO''' );
                Sql.Add('   AND Fecha_Mov         = :Fecha_Mov' );
                Sql.Add('   AND Folio_Interno_omd = :Folio_Interno' );
                Sql.Add('   AND Transaccion_omd   = :Transaccion' );
                Sql.Add('   AND Empresa           = :Empresa' );
                Parambyname('Fecha_Mov').asDate       := dFecha_Mov;
                Parambyname('Folio_Interno').AsString := sFolio_Interno;
                Parambyname('Transaccion').AsString   := sTransaccion;
                Parambyname('Empresa').AsString       := sEmpresa;
                try
                  ExecSQL;
                except on E: EFDDBEngineException do
                  begin
                    ShowError(E);
                    String_Err := 'ERROR AL EIMINAR FOLIO :' +sFolio_Interno+' MOVIMIENTO :'+sTipo_Movimiento
                                 +' DE TABLA QS_TES_EGRING( Mov.Caja )';
                    Result := False;
                    Exit;
                  end;
                end;
              end;
            end;
          end;
        end;
      end;

      with DMValorizacion do
      begin
         Tmp_Tes_Egring.Insert;
         Tmp_Tes_Egring.FieldByName('EMPRESA').asString              := sEmpresa;
         Tmp_Tes_Egring.FieldByName('TRANSACCION').asString          := sTransaccion_Tes; //'VCTO';
         Tmp_Tes_Egring.FieldByName('FOLIO_INTERNO').asString        := sFolio_interno_tes;
         Tmp_Tes_Egring.FieldByName('TIPO_MOVIMIENTO').asString      := sTipo_Movimiento;
         Tmp_Tes_Egring.FieldByName('CARTERA').asString              := sCartera;
         if BuscaStr(sImplicancia_Derivado,Trim(sTransaccion)) then
            Tmp_Tes_Egring.FieldByName('MONEDA_CARTERA').asString       := sMoneda_Pago //sMoneda_Cartera; GG & ES 30-07-2025
         else
            Tmp_Tes_Egring.FieldByName('MONEDA_CARTERA').asString       := sMoneda_Cartera;
         Tmp_Tes_Egring.FieldByName('FECHA_MOV').AsDateTime          := dFecha_Mov;
         Tmp_Tes_Egring.FieldByName('SALDO_INSOLUTO').asFloat        := fSaldo_Insoluto;
         Tmp_Tes_Egring.FieldByName('VALOR_NOMINAL').asFloat         := fValor_Nominal;
         Tmp_Tes_Egring.FieldByName('INTERESES_UM').asFloat          := fIntereses_UM;
         Tmp_Tes_Egring.FieldByName('AMORTIZACION_UM').asFloat       := fAmortizacion_UM;
         Tmp_Tes_Egring.FieldByName('MONTO_UM_MOVIMIENTO').asFloat   := fValor_Vencimiento_UM;
         Tmp_Tes_Egring.FieldByName('DIF_VENCIMIENTO_UM').asFloat    := fDiferencia_Vencimiento_UM;
         Tmp_Tes_Egring.FieldByName('MONTO_MC_MOVIMIENTO').asFloat   := fValor_Vencimiento_MC;
         Tmp_Tes_Egring.FieldByName('DIF_VENCIMIENTO_MC').asFloat    := fDiferencia_Vencimiento_MC;
         Tmp_Tes_Egring.FieldByName('NEMOTECNICO').asString          := sNemotecnico;
         if (not transaccion_implica_mem(sEmpresa,'MOVTO_CAJA')) and
            (not transaccion_implica_mem(sEmpresa,'NOPAGOAUTO')) then
         begin
            Tmp_Tes_Egring.FieldByName('FECHA_PAGO').AsDateTime      := dFecha_Pago;
            Tmp_Tes_Egring.FieldByName('MONTO_UM_PAGADO').asFloat    := fValor_Vencimiento_UM;
            Tmp_Tes_Egring.FieldByName('MONTO_MC_PAGADO').asFloat    := fValor_Vencimiento_MC;
         end
         else
         begin
//          Se omite para que la fecha quede en nulo 12-09-2024 P.M. G.G. E.S. F.I.
            Tmp_Tes_Egring.FieldByName('FECHA_PAGO').clear;
            Tmp_Tes_Egring.FieldByName('MONTO_UM_PAGADO').asFloat    := 0;
            Tmp_Tes_Egring.FieldByName('MONTO_MC_PAGADO').asFloat    := 0;
         end;
         Tmp_Tes_Egring.FieldByName('FECHA_EMISION_PAGO').AsDateTime := dFecha_Mov;
         Tmp_Tes_Egring.FieldByName('TRANSACCION_OMD').asString      := sTransaccion;
         Tmp_Tes_Egring.FieldByName('FOLIO_INTERNO_OMD').asString    := sFolio_Interno;
         Tmp_Tes_Egring.FieldByName('ITEM_OMD').asFloat              := fItem_Omd;
         Tmp_Tes_Egring.FieldByName('NRO_CUPON').asFloat             := iCuponVigente;
         Tmp_Tes_Egring.FieldByName('CODIGO_BANCO').AsString         := sCodigo_Banco;
         Tmp_Tes_Egring.FieldByName('CUENTA_BANCO').AsString         := sCuenta_Banco;
         try
            Tmp_Tes_Egring.Post;
         except on E: EFDDBEngineException do
             begin
               ShowError(E);
               Tmp_Tes_Egring.Cancel;
               String_Err := 'ERROR AL INSERTAR FOLIO :' +sFolio_Interno_Tes+' MOVIMIENTO :'+sTipo_Movimiento
                        +' TABLA QS_TES_EGRING( Mov.Caja )';
               Result := False;
               Exit;
             end;
         end;
      end;
   end;{solo stock}
end;

