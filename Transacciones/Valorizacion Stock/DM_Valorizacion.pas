function Existe_definicion_cuenta_banco_por_defecto(sString_Empresas : String) : Boolean;
var
    num_regs : Double;
begin
  Result   := False;
  WITH DMValorizacion.Qry_Aux do
  begin
     SQL.Clear;
     SQL.Add('SELECT COUNT(*) AS Numero_Registros FROM QS_SYS_CUENTA_DEFAULT ');
     SQL.Add('WHERE empresa IN '+sString_Empresas);
     try
        Open
     except
        exit
     end;
     num_regs := FieldByName('Numero_Registros').AsFloat;
     Close;
     Result := (num_regs > 0);
  end;
end;

function Folio_en_Pacto(sEmpresa, sTransaccion, sFolio_Interno : String; fItem_Omd : Double; dFecha_Vcto : TDateTime) : Boolean;
begin
  Result := False;
  WITH DMValorizacion.Qry_Aux do
  begin
     SQL.Clear;
     SQL.Add('SELECT a.Folio_Interno ');
     SQL.Add('  FROM QS_TRA_OMD_DET_RF a ');
     SQL.Add('      ,QS_TRA_OMD b ');
     SQL.Add(' WHERE a.Folio_Interno_Rel = :Folio_Interno ');
     SQL.Add('   AND a.Item_Omd_Rel      = :Item_Omd ');
     SQL.Add('   AND a.Transaccion_Rel   = :Transaccion ');
     SQL.Add('   AND a.Empresa_Rel       = :Empresa ');
     SQL.Add('   AND a.transaccion       IN '+sImplicancia_Pacto);
     SQL.Add('   AND a.Folio_interno not in (SELECT e.folio');
                                    SQL.Add('  FROM qs_ctr_anulacion e');
                                    SQL.Add(' WHERE e.folio   = a.folio_interno');
                                    SQL.Add('   AND e.transaccion = a.transaccion');
                                    SQL.Add('   AND e.empresa = a.empresa)');
     SQL.Add('   AND b.Folio_Interno = a.Folio_Interno ');
     SQL.Add('   AND b.Transaccion   = a.Transaccion ');
     SQL.Add('   AND b.Empresa       = a.Empresa ');
     SQL.Add('   AND b.fecha_operacion  <=:Fecha_Vcto ');  // <=
     SQL.Add('   AND b.Fecha_Vcto_Pacto > :Fecha_Vcto ');  // <=

     ParamByName('Empresa').AsString       := sEmpresa;
     ParamByName('Transaccion').AsString   := sTransaccion;
     ParamByName('Folio_Interno').AsString := sFolio_Interno;
     ParamByName('Item_Omd').AsFloat       := fItem_Omd;
     ParamByName('Fecha_Vcto').asDate      := dFecha_Vcto;
     Open;
     if Not Eof then
        Result := True;
     Close;
  end;

end;

procedure Default_Cuenta_Banco( sEmpresa          : String;
                                sCartera          : String;
                                sTipo_Movimiento  : String;
                                sEmisor           : String;
                                sInstrumento      : String;
                                sMoneda_pago      : String;
                                sContraparte      : String;
                                sCustodio         : String;
                                dFecha_Mov        : TDateTime;
                                var sCodigo_Banco : String;
                                var sCuenta_Banco : String
                                );
var
   bEncontro : Boolean;
   iPaso     : Integer;
begin
  bEncontro := False;
  iPaso     := 1;
  WITH DMValorizacion.Qry_Aux do
  begin
     SQL.Clear;
     SQL.Add('SELECT Codigo_banco   ');
     SQL.Add('      ,Cuenta_Banco   ');
     SQL.Add('  FROM QS_SYS_CUENTA_DEFAULT  ');
     SQL.Add(' WHERE EMPRESA          = :EMPRESA           ');
     SQL.Add('   AND CARTERA          = :CARTERA           ');
     SQL.Add('   AND TIPO_MOVIMIENTO  = :TIPO_MOVIMIENTO   ');
     SQL.Add('   AND EMISOR           = :EMISOR            ');
     SQL.Add('   AND INSTRUMENTO      = :INSTRUMENTO       ');
     SQL.Add('   AND MONEDA_PAGO      = :MONEDA_PAGO       ');
     SQL.Add('   AND CONTRAPARTE      = :CONTRAPARTE       ');
     SQL.Add('   AND CUSTODIO         = :CUSTODIO          ');
     SQL.Add('   AND FECHA_DESDE      <= :FECHA_DESDE       ');
     SQL.Add('   AND (FECHA_HASTA     >= :FECHA_HASTA OR FECHA_HASTA IS NULL) ');

     ParamByName('EMPRESA'        ).AsString   := sEmpresa         ;
     ParamByName('CARTERA'        ).AsString   := sCartera         ;
     ParamByName('TIPO_MOVIMIENTO').AsString   := sTipo_Movimiento ;
     ParamByName('EMISOR'         ).AsString   := sEmisor          ;
     ParamByName('INSTRUMENTO'    ).AsString   := sInstrumento     ;
     ParamByName('MONEDA_PAGO'    ).AsString   := sMoneda_pago     ;
     ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
     ParamByName('CUSTODIO'       ).AsString   := sCustodio        ;
     ParamByName('FECHA_DESDE'    ).asDate := dFecha_Mov       ;
     ParamByName('FECHA_HASTA'    ).asDate := dFecha_Mov       ;

     WHILE (NOT bEncontro) AND (iPaso <= 24) do
     begin
        Open;
        if (NOT FieldByName('Codigo_banco').IsNull)        AND
           (    FieldByName('Codigo_banco').AsString <> '') THEN
        begin
          bEncontro := True;
          sCodigo_Banco := FieldByName('Codigo_banco').AsString;
          sCuenta_Banco := FieldByName('Cuenta_Banco').AsString;
          Close;
          Continue;
        end;
        Close;
        iPaso := iPaso + 1;
        Case iPaso of
          2: ParamByName('CUSTODIO'   ).AsString := '';
          3: ParamByName('CONTRAPARTE').AsString := '';
          4: ParamByName('INSTRUMENTO').AsString := '';
          5: ParamByName('EMISOR'     ).AsString := '';

          6: ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
          7: begin
             ParamByName('CONTRAPARTE').AsString := '';
             ParamByName('CUSTODIO'       ).AsString   := sCustodio        ;
             end;

          8: ParamByName('TIPO_MOVIMIENTO').AsString := '';
          9: ParamByName('CARTERA'    ).AsString := '';

          10: begin  // Todo de nuevo sin cartera
               ParamByName('EMPRESA'        ).AsString   := sEmpresa         ;
               ParamByName('TIPO_MOVIMIENTO').AsString   := sTipo_Movimiento ;
               ParamByName('EMISOR'         ).AsString   := sEmisor          ;
               ParamByName('INSTRUMENTO'    ).AsString   := sInstrumento     ;
               ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
               ParamByName('CUSTODIO'       ).AsString   := sCustodio        ;
              end;

          11: ParamByName('CUSTODIO'   ).AsString := '';
          12: ParamByName('CONTRAPARTE').AsString := '';
          13: ParamByName('INSTRUMENTO').AsString := '';
          14: ParamByName('EMISOR'     ).AsString := '';
          15: ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
          16: begin
              ParamByName('CONTRAPARTE').AsString := '';
              ParamByName('CUSTODIO'       ).AsString   := sCustodio        ;
              end;
          17: ParamByName('TIPO_MOVIMIENTO'     ).AsString := '';

          18: begin  // Todo de nuevo sin cartera y sin tipo de movimiento
               ParamByName('EMPRESA'        ).AsString   := sEmpresa         ;
               ParamByName('TIPO_MOVIMIENTO').AsString   := sTipo_Movimiento ;
               ParamByName('EMISOR'         ).AsString   := sEmisor          ;
               ParamByName('INSTRUMENTO'    ).AsString   := sInstrumento     ;
               ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
               ParamByName('CUSTODIO'       ).AsString   := sCustodio        ;
             end;

          19: ParamByName('CUSTODIO'   ).AsString := '';
          20: ParamByName('CONTRAPARTE').AsString := '';
          21: ParamByName('INSTRUMENTO').AsString := '';
          22: ParamByName('EMISOR'     ).AsString := '';
          23: ParamByName('CONTRAPARTE'    ).AsString   := sContraparte     ;
          24: begin
              ParamByName('CONTRAPARTE').AsString := '';
              ParamByName('CUSTODIO'   ).AsString   := sCustodio        ;
              end;
        end;
     end;
  end;
end;

procedure Lee_Curva_Forward(sCodigo_Curva        : String;
                        var sTIPO                : String;
                        var sCODIGO              : String;
                        var sPARIDAD             : String;
                        var sTIPO_VALUACION      : String;
                        var sORIGEN_PRECIO       : String;
                        var sCODIGO_CALCULO      : String;
                        var fBASE_PRECIO         : Double;
                        var sMON_IND_PRECIO      : String;
                        var fPORC_PARTICIPACION  : Double;
                        var sOPERACION           : String;
                        var fVALOR               : Double;
                        var sMONEDA_RESULTADO    : String;
                        var sUNIDAD_MON          : String;
                        var sEMISOR              : String;
                        var sINSTRUMENTO         : String;
                        var sSERIE               : String;
                        var dFECHA_EMISION_CURVA : TDateTime;
                        var dFECHA_VCTO_CURVA    : TDateTime;
                        var sEMISION_IMPLICITA   : String);
begin
   with DMValorizacion.QRY_Aux do
   begin
      SQL.Clear;
      SQL.Add('select a.*, c.UNIDAD_MON, b.Codigo_Identidad, b.Codigo_Instrumento, b.Serie, b.Fecha_emision, b.Fecha_vencimiento,b.Emision_Implicita '
             +'  from QS_FIN_CURVA_FORWARD a '
             +'      ,QS_FIN_NEM_RFIJA     b '
             +'      ,QS_FIN_DESCRIPTOR    c '
             +' WHERE a.Codigo_Curva       = :Codigo_Curva '
             +'   AND a.Tipo               = ''NEMOTECNIC'' '
             +'   AND b.Codigo_Nemotecnico = a.Codigo '
             +'   AND c.CODIGO_EMISOR      = b.Codigo_Identidad '
             +'   AND c.Codigo_Instrumento = b.Codigo_Instrumento '
             +'   AND c.Serie              = b.Serie '
             +'union '
             +'select a.*, b.MONEDA_INSTRUM, b.emisor, b.Instrumento, b.Serie, b.Fecha_emision, b.Fecha_vencimiento, ''N'' '
             +'  from QS_FIN_CURVA_FORWARD a '
             +'      ,QS_TRA_OMD_DET_RF    b '
             +' WHERE a.Codigo_Curva       = :Codigo_Curva '
             +'   AND a.Tipo               = ''NEMOTECNIC'' '
             +'   AND B.NEMOTECNICO  = A.CODIGO '
             +'   AND b.Tipo_Instrum <> ''S'' '
             +'   AND b.Tipo_Instrum <> ''R''  '
             +'   AND NOT EXISTS (SELECT x.Codigo_Nemotecnico  '
             +'                      FROM QS_FIN_NEM_RVARI x '
             +'                     WHERE x.Codigo_Nemotecnico = b.NEMOTECNICO) '
             +'   AND NOT EXISTS (SELECT x.Codigo_Nemotecnico  '
             +'                      FROM QS_FIN_NEM_RFIJA x '
             +'                     WHERE x.Codigo_Nemotecnico = b.NEMOTECNICO) '
             +'union '
             +'select a.*, '''' UNIDAD_MON,'''' as Codigo_Identidad, '''' as Codigo_Instrumento, '''' as Serie, null as Fecha_emision, null as Fecha_vencimiento, '''' as Emision_Implicita '
             +'  from QS_FIN_CURVA_FORWARD a '
             +' WHERE a.Codigo_Curva       = :Codigo_Curva '
             +'   AND a.Tipo               = ''MONEDA'' '
             );
      ParamByName('Codigo_Curva').AsString := sCodigo_Curva;
      Open;
      if not FieldByName('TIPO').IsNull then
      begin
         sTIPO                := FieldByName('TIPO').asString;
         sCODIGO              := FieldByName('CODIGO').asString;
         sPARIDAD             := FieldByName('PARIDAD').asString;
         sTIPO_VALUACION      := FieldByName('TIPO_VALUACION').asString;
         sORIGEN_PRECIO       := FieldByName('ORIGEN').asString;
         sCODIGO_CALCULO      := FieldByName('CODIGO_CALCULO').asString;
         fBASE_PRECIO         := FieldByName('BASE_PRECIO').asFloat;
         sMON_IND_PRECIO      := FieldByName('MON_IND_PRECIO').asString;
         fPORC_PARTICIPACION  := FieldByName('PORC_PARTICIPACION').asFloat;
         sOPERACION           := FieldByName('OPERACION').asString;
         fVALOR               := FieldByName('VALOR').asFloat;
         sMONEDA_RESULTADO    := FieldByName('MONEDA_RESULTADO').asString;
         sUNIDAD_MON          := FieldByName('UNIDAD_MON').asString;
         sEMISOR              := FieldByName('Codigo_Identidad').asString;
         sINSTRUMENTO         := FieldByName('Codigo_Instrumento').asString;
         sSERIE               := FieldByName('Serie').asString;
         dFECHA_EMISION_CURVA := FieldByName('Fecha_Emision').AsDateTime;
         dFECHA_VCTO_CURVA    := FieldByName('Fecha_Vencimiento').AsDateTime;
         sEMISION_IMPLICITA   := FieldByName('Emision_Implicita').asString;
      end;
      Close;
      UnPrepare;
   end;
end;

/////////////////////////////////////////////////////////////////////////////////
