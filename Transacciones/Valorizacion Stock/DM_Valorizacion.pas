         SQL.Add('   WHERE a.Pid               = :Pid  '  );
         SQL.Add('     AND a.Fecha_Creacion    = :Fecha_Creacion  '  );
         SQL.Add('     AND a.Emision_Implicita = ''S'' '  );
         ParamByName('Pid').AsString              := IntToStr(Application.Handle);
         ParamByName('Fecha_Creacion').asDate := dFecha_Hora;
         Open;
         Mostrar_Mensaje( 'Seleccionando Registros OMD''s ...(30)', bAbortar);
         Application.ProcessMessages;

         While Not eof do
         begin
            sNemotecnico := FieldByName('Nemotecnico').asString;
//            Reg_Val_In.Emision_Implicita := 'S';

            Carga_RegDes(FieldByName('Tipo_Instrum').asString
                        ,FieldByName('Nemotecnico').asString
                        ,FieldByName('Emisor').asString
                        ,FieldByName('Instrumento').asString
                        ,FieldByName('Serie').asString
                        ,FieldByName('Moneda_Instrum').asString
                        ,FieldByName('Tasa_Emision').asFloat
                        ,RegDes
                        ,sModulo_Error
                        ,sString_Error
                        ,Result
                        );
            Reg_Fechas.Fecha_Compra   := FieldByName('Fecha_Operacion').AsDateTime;
            Reg_Fechas.Fecha_Emision  := FieldByName('Fecha_Emision').AsDateTime;
            Reg_Fechas.Fecha_Calculo  := dFecha_Inicial;

            Emision_Implicita( FieldByName('Nemotecnico').asString,
                               FieldByName('Emisor').asString,
                               FieldByName('Instrumento').asString,
                               FieldByName('Serie').asString,
                               Reg_Fechas,
                               'SI',       //sDescriptor_Cargado: String;
                               dFecha_Emision,
                               dFecha_Vencimiento,
                               RegDes,
                               sModulo_Error,
                               sString_Error,
                               Result
                              );

            Reg_Fechas.Fecha_Emision  := dFecha_Emision;

            carga_parametros_formulas_mem(RegDes.Cod_Calc_PAR_D
                                         ,RegDes.Cod_Calc_TIR_D
                                         ,Reg_Formula_PAR
                                         ,Reg_Formula_TIR
                                         ,sModulo_Error
                                         ,sString_Error
                                         ,Result
                                         );
            sMetodo_Sin_Tasa_Referencia := Metodo_Sin_Tasa_Referencia_Mem(Reg_Formula_PAR.Codigo_Formula
                                                                         ,Reg_Fechas.Fecha_Calculo);

            carga_Mem_Desarr(Array_Mem_Desarr
                            ,FieldByName('Nemotecnico').asString
                            ,RegDes
                            ,Reg_Fechas
                            ,sMetodo_Sin_Tasa_Referencia
                            ,True // bconcupon
                            ,True
                            ,sModulo_Error
                            ,sString_Error
                            ,Result);
            Cambia_Nemotecnico(Array_Mem_Desarr
                              ,Reg_Fechas.Fecha_Calculo
                              ,Reg_Fechas.Fecha_Emision
                              ,True // bconcupon
                              ,RegDes
                              ,sNemotecnico
                              ,sModulo_Error
                              ,sString_Error
                              ,Result);

            if FieldByName('Nemotecnico').asString <> sNemotecnico then
            begin
               with Qry_General2 do
               begin
                  SQL.clear;
                  SQL.Add('UPDATE QS_FIN_VALORIZACION_RES2  ');
                  SQL.Add('   SET Nemotecnico       = :Nemotecnico ');
                  SQL.Add('      ,Fecha_Emision     = :Fecha_Emision ');
                  SQL.Add('      ,Fecha_Vencimiento = :Fecha_Vencimiento ');
                  SQL.Add('      ,Emision_Implicita = ''N'' ');
                  SQL.Add('  WHERE Pid            = :Pid    ');
                  SQL.Add('    AND Fecha_Creacion = :Fecha_Creacion ');
                  SQL.Add('    AND Folio_interno  = :Folio_interno ');
                  SQL.Add('    AND Item_OMD       = :Item_OMD ');
                  SQL.Add('    AND Transaccion    = :Transaccion ');
                  SQL.Add('    AND Empresa        = :Empresa ');
                  ParamByName('Pid').AsString                 := IntToStr(Application.Handle);
                  ParamByName('Fecha_Creacion').asDate    := dFecha_Hora;
                  ParamByName('Folio_interno').AsString       := Qry_General.FieldByName('Folio_interno').asString;
                  ParamByName('Item_OMD').AsFloat             := Qry_General.FieldByName('Item_OMD').AsFloat;
                  ParamByName('Transaccion').AsString         := Qry_General.FieldByName('Transaccion').asString;
                  ParamByName('Empresa').AsString             := Qry_General.FieldByName('Empresa').asString;
                  ParamByName('Nemotecnico').AsString         := sNemotecnico;
                  ParamByName('Fecha_Emision').asDate     := dFecha_Emision;
                  ParamByName('Fecha_Vencimiento').asDate := dFecha_Vencimiento;
                  ExecSql;
               end;
            end;
            Next;
         end;


         //ggarcia 25-05-2016  elimina los registros de cobertura de los swaps
         SQL.Clear;
         SQL.Add(' DELETE FROM QS_FIN_VALORIZACION_RES2 ');
         SQL.Add('  WHERE Pid            = :Pid  '  );
         SQL.Add('    AND Fecha_Creacion = :Fecha_Creacion  '  );
         SQL.Add('    AND Transaccion in '+sImplicancia_Derivado );
         SQL.Add('    AND Item_OMD > 2' );
         ParamByName('Pid').AsString              := IntToStr(Application.Handle);
         ParamByName('Fecha_Creacion').asDate := dFecha_Hora;
         ExecSql;


         SQL.Clear;
         SQL.Add('  INSERT INTO QS_FIN_VALORIZ_NEMOS '  );
         SQL.Add('  SELECT DISTINCT a.NEMOTECNICO        '  );
         SQL.Add('       ,:Pid                           '  );
         SQL.Add('       ,:Fecha_Creacion                '  );
         SQL.Add('   FROM QS_FIN_VALORIZACION_RES2 a     '  );
         SQL.Add('  WHERE Pid            = :Pid  '  );
         SQL.Add('    AND Fecha_Creacion = :Fecha_Creacion  '  );
         ParamByName('Pid').AsString              := IntToStr(Application.Handle);
         ParamByName('Fecha_Creacion').asDate := dFecha_Hora;
         ExecSql;

         // 19-02-2014 F.I.   No se estaban cargando los valores para la proyeccion de tasas de nemos que siendo
         // * , ya no lo son a la fecha de valorizacion   (Caso Cardif)
         // Lo que esta mas arriba esta solo para los que tienen "Emision_Implicita = 'S' Lo que no se da en los "*"
         SQL.Clear;
         SQL.Add('  INSERT INTO QS_FIN_VALORIZ_NEMOS                                ');
         SQL.Add('  SELECT DISTINCT B.CODIGO_NEMOTECNICO,:Pid,:Fecha_Creacion      ');
         SQL.Add('  FROM QS_FIN_VALORIZ_NEMOS A                                     ');
         SQL.Add('      ,QS_FIN_NEM_RFIJA B                                         ');
         SQL.Add('  WHERE A.Pid            = :Pid                                   ');
         SQL.Add('    AND A.Fecha_Creacion = :Fecha_Creacion                        ');
         SQL.Add('    AND (A.NEMOTECNICO LIKE ''%*%'' OR A.NEMOTECNICO LIKE ''%&%'')');

         if (sDriver = 'ORACLE') then
            SQL.Add('    AND SUBSTRB(B.CODIGO_NEMOTECNICO ,1,5) = SUBSTRB(A.NEMOTECNICO ,1,5)        ')
         else
            SQL.Add('    AND SUBSTRING(B.CODIGO_NEMOTECNICO ,1,5) = SUBSTRING(A.NEMOTECNICO ,1,5)  ');

         SQL.Add('    AND b.FECHA_VENCIMIENTO > :Fecha_Creacion                                       ');
         SQL.Add('    AND NOT (B.CODIGO_NEMOTECNICO LIKE ''%*%'' OR B.CODIGO_NEMOTECNICO LIKE ''%&%'') ');
         SQL.Add('    AND B.CODIGO_NEMOTECNICO NOT IN (SELECT C.NEMOTECNICO                        ');
         SQL.Add('          				 FROM QS_FIN_VALORIZ_NEMOS C               ');
         SQL.Add('    					WHERE C.NEMOTECNICO = B.CODIGO_NEMOTECNICO ');
         SQL.Add('                                        AND C.Pid         = :Pid                 '); //ggarcia 29-10-2014 no se cargaba si existia con otro pid
         SQL.Add('      	  			)                                          ');
         SQL.Add('    ORDER BY B.CODIGO_NEMOTECNICO                                                ');
         ParamByName('Pid').AsString              := IntToStr(Application.Handle);
         ParamByName('Fecha_Creacion').asDate := dFecha_Hora;
         ExecSql;

     if (sDriver = 'ORACLE') and
        (dmBaseDatos.Conexion_BaseDatos.InTransaction) then
         dmBaseDatos.Conexion_BaseDatos.Commit;

      if (sDriver = 'ORACLE') and
         (NOT dmBaseDatos.Conexion_BaseDatos.InTransaction) then
         dmBaseDatos.Conexion_BaseDatos.StartTransaction;


     end;

end;

