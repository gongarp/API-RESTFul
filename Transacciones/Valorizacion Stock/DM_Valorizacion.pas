Procedure Genera_Operacion_Compra_RV(sEmpresa              : String;
                                     sCartera              : String;
                                     sTransaccion          : String;
                                     sFolio_Interno        : String;
                                     fItem_Omd             : Double;
                                     sTransaccion_Rel      : String;
                                     dFecha_Mov            : TDateTime;
                                     dFecha_Pago           : TDateTime;
                                     sMoneda_Cartera       : String;
                                     fValor_Nominal        : Double;
                                     fValor_Vencimiento_UM : Double;
                                     fValor_Vencimiento_MC : Double;
                                     sMoneda_pago          : String;
                                     RegDes                : TReg_Descriptor;
                                     var Modulo_Err        : String;
                                     var String_Err        : String;
                                     var Result            : Boolean);
var Flag_Instruccion      :Boolean;
    Flag_Instruccion_Ctas :Boolean;
    aux_pchar             :Array[0..250] of Char;
    sRelacion             :String;
    sSistema              :String;
    sDescripcion          :String;
    bResult               :Boolean;
    sNulo                 :String;
    FechaNula             :TDatetime;
    sTransaccion_Compra   :String;
    sFolio_Compra         :String;
    sNemotecnico          :String;
    sEmisor               :String;
    sInstrumento          :String;
    sSerie                :String;
    sMoneda_instrum       :String;
    fFolio                :Double;
    sCodigo_Bolsa         :String;
    sOperador             :String;
    sMotivo_Inv           :String;
    sForma_Pago           :String;
    sTipo_Documento       :String;
    sTipo_de_Pago         :String;
    sMotivo_omd           :String;
    sTipo_Instruccion     :String;
    sDescrpcion_Clasificacion : String;
    sMoneda_NAcional      :String;
    sMoneda_Caja          :String;
    fValor_Invertido      :Double;
    sParametro            :String;
    sContraparte          :String;
    sCustodia_Destino     :String;
    sCta_Custodia_Destino :String;
    sBanco_Destino        :String;
    sCta_Banco_Destino    :String;
    sTipo_Codigo_Transferencia :String;
    sCodigo_Transferencia      :String;
    sReferencia                :String;
    sId_Cuenta_Rel             :String;
    sNro_Cta_Rel               :String;
begin
    Result := true;

    if sTransaccion_Rel = 'DIV' then
       Modulo_Err := 'Calculo de Dividendos'
    else
       Modulo_Err := 'Valorizador Renta Fija';

    // Si existe una transaccion relacionada al folio de la OMD, no hace nada.
    with DMValorizacion.QRY_Cash do
    begin
       SQL.Clear;
       SQL.Add('SELECT a.* '
              +'  FROM QS_TRA_OMD_DET_RF a '
              +'      ,QS_TRA_OMD        b '
              +' WHERE a.Folio_Interno_Rel = :Folio_Interno_Rel '
              +'   AND a.Item_OMD_Rel      = :Item_OMD_Rel '
              +'   AND a.Transaccion_Rel   = :Transaccion_Rel '
              +'   AND b.Fecha_Operacion   = :Fecha_Operacion '
              +'   AND a.Empresa_Rel       = :Empresa_Rel '
              +'   AND b.Folio_Interno     = a.Folio_Interno '
              +'   AND b.Transaccion       = a.Transaccion '
              +'   AND b.Empresa           = a.Empresa '
              );
       ParamByName('Folio_Interno_Rel').AsString := Copy(sFolio_Interno,1,15);
       ParamByName('Item_OMD_Rel').AsFloat       := fItem_OMD;
       ParamByName('Transaccion_Rel').AsString   := sTransaccion_Rel; //'VCTO';
       ParamByName('Fecha_Operacion').asDate     := dFecha_Mov;
       ParamByName('Empresa_Rel').AsString       := sEmpresa;
       Open;
       if not eof then
       begin
          if sTransaccion_Rel = 'DIV' then
             String_Err := 'Ya existe Transaccion con Folio '+sFolio_Interno
          else
             String_Err := aux_pchar;
          Close;
          Exit;
       end;
       Close;
    end;

    FechaNula := encodedate(1899,12,30);

    with DMValorizacion.QRY_Cash do
    begin
       SQL.Clear;
       SQL.Add('SELECT Tipo_Instruccion From QS_TRA_OMD WHERE Empresa = ''''');
       Flag_Instruccion := True;
       Try
          Open;
       Except
          Flag_Instruccion  := False;
       end;
       Close;
       SQL.Clear;
       SQL.Add('SELECT CTA_Custodia_Origen From QS_TRA_OMD WHERE Empresa = ''''');
       Flag_Instruccion_Ctas := True;
       Try
          Open;
       Except
          Flag_Instruccion_Ctas          := False;
       end;
    end;

    // Transaccion
    sTransaccion_Compra := 'CRV';
    if not Datos_Transaccion(sTransaccion_Compra
                            ,sRelacion
                            ,sSistema
                            ,sDescripcion
                            ,Modulo_Err
                            ,String_Err) then
    begin
       Result := False;
       exit;
    end;

    // Folio Interno
    fFolio := 0;
    // Busco Folio por Cartera
    Leer_Grabar_Folio(sEmpresa_Usuario,
                      sCartera,  // Entidad es Código de Cartera
                      'CARTERA', // sRelacion,
                      'I',
                      solo_fecha(fecha_hora_Servidor),
                      fFolio,
                      bResult);
    if Not bResult then
    begin
       // Busco folio por Transacción
       Leer_Grabar_Folio(sEmpresa_Usuario,
                         ' ',                  // Entidad va en blanco para folio unico empresa
                         sTransaccion_Compra,  // sRelacion,
                         'I',
                         solo_fecha(fecha_hora_Servidor),
                         fFolio,
                         bResult);
       if NOT bResult then
       begin
         Leer_Grabar_Folio(sEmpresa_Usuario,
                           ' ',           // Entidad va en blanco para folio unico empresa
                           sRelacion,
                           'I',
                           solo_fecha(fecha_hora_Servidor),
                           fFolio,
                           bResult);
         if NOT bResult then
         begin
            strpcopy(aux_pchar
                    ,'No se encontró definición vigente para folio'#10
                    +'Para: '
                    +sEmpresa_Usuario
                    +' - '
                    +sTransaccion_Compra
                    +' - '
                    +sRelacion
                    +''#10
                    +'Folio Actual es NULO'#10
                    +'Avise al administrador del sistema'
                    );
           String_Err := aux_pchar;
           Result := False;
           exit;
         end;
       end;
    end;
    sFolio_Compra := trim(floattostr(fFolio));

    // Codigo Bolsa
    sCodigo_Bolsa := '';

//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'CODBOLSA'
//                       ,sCodigo_Bolsa
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'CODBOLSA'
                       ,sCodigo_Bolsa
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''CODBOLSA''';
       Result := False;
       exit;
    end;

    // Operador
    sOperador := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'OPERADOR'
//                       ,sOperador
//                       ,bResult);

//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'OPERADOR'
                       ,sOperador
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''OPERADOR''';
       Result := False;
       exit;
    end;

    // Motivo Inversion
    sMotivo_Inv := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'MOTIVOINV'
//                       ,sMotivo_Inv
//                       ,bResult);

//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'MOTIVOINV'
                       ,sMotivo_Inv
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''MOTIVOINV''';
       Result := False;
       exit;
    end;

    // Forma Pago
    sForma_Pago := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'FORMAPAGO'
//                       ,sForma_Pago
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'FORMAPAGO'
                       ,sForma_Pago
                       ,bResult);

    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''FORMAPAGO''';
       Result := False;
       exit;
    end;

    // Tipo Documento
    sTipo_Documento := '';

//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'TIPODOCUM'
//                       ,sTipo_Documento
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'TIPODOCUM'
                       ,sTipo_Documento
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''TIPODOCUM''';
       Result := False;
       exit;
    end;

    // Tipo de Pago
    sTipo_de_Pago := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'TIPOPAGO'
//                       ,sTipo_de_Pago
//                       ,bResult);

    //   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'TIPOPAGO'
                       ,sTipo_de_Pago
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''TIPOPAGO''';
       Result := False;
       exit;
    end;

    // Motivo omd
    sMotivo_omd := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'MOTIVOOMD'
//                       ,sMotivo_omd
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'MOTIVOOMD'
                       ,sMotivo_omd
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''MOTIVOOMD''';
       Result := False;
       exit;
    end;

    // Tipo Instruccion
    sTipo_Instruccion := '';
//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'TIPOINSTRU'
//                       ,sTipo_Instruccion
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'TIPOINSTRU'
                       ,sTipo_Instruccion
                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''TIPOINSTRU''';
       Result := False;
       exit;
    end;

    // Nemotecnico
    sNemotecnico := '';
    sParametro := 'NEMO_'+trim(RegDes.Unidad_Mon);

//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,sParametro
//                       ,sNemotecnico
//                       ,bResult);
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,sParametro
                       ,sNemotecnico
                       ,bResult);
    if not bResult then
    begin
      sNemotecnico := '';
      sParametro := trim(RegDes.Unidad_Mon);
//      Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                         ,sParametro
//                         ,sNemotecnico
//                         ,bResult);
//   F.I. 01-09-2020
      Busca_param_proceso('MOV_CPA_RV'
                         ,sParametro
                         ,sNemotecnico
                         ,bResult);
      if not bResult then
      begin
        sParametro := 'NEMO_'+trim(RegDes.Unidad_Mon);
//        Modulo_Err := 'Valorizador Renta Fija';
        String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - '''+sParametro+'''';
        Result := False;
        exit;
      end;
    end;
    Datos_Nemotecnico(sNemotecnico
                     ,dFecha_Mov
                     ,sEmisor
                     ,sInstrumento
                     ,sSerie
                     ,sNulo
                     ,sNulo
                     ,sNulo
                     ,sMoneda_instrum
                     ,bResult);
    if Not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No se pueden obtener datos del nemotecnico '+sNemotecnico;
       Result := false;
       Exit;
    end;

    // Moneda Caja - Valor Invertido
    sMoneda_Nacional := Moneda_Nacional;
    if RegDes.Unidad_Mon = sMoneda_Nacional then
    begin
       sMoneda_Caja     := RegDes.Unidad_Mon;
       fValor_Invertido := fValor_Vencimiento_UM;
    end
    else
    begin
       Clasificaciones_Mem('NEMOTECNIC'
                          ,sNemotecnico
                          ,'PAGOCUPON'
                          ,sDescrpcion_Clasificacion
                          ,bResult);
       if (bResult) and (sDescrpcion_Clasificacion = sMoneda_Nacional) then
       begin
          sMoneda_Caja := sMoneda_Nacional;
          conversion_unidad_mon(RegDes.Unidad_Mon
                               ,sMoneda_Nacional
                               ,'BC'
                               ,dFecha_Mov
                               ,fValor_Vencimiento_UM
                               ,fValor_Invertido
                               ,Modulo_Err
                               ,String_Err
                               ,bResult);
          if NOT bResult then
          begin
             Result := false;
             Exit;
          end;
       end
       else
       begin
          sMoneda_Caja     := RegDes.Unidad_Mon;
          fValor_Invertido := fValor_Vencimiento_UM;
       end;
    end;

    // Contraparte
    sContraparte := '';
//   F.I. 01-09-2020
    Busca_param_proceso('MOV_CPA_RV'
                       ,'CONTRA_'+trim(sMoneda_Caja)
                       ,sContraparte
                       ,bResult);

//    Busca_Param_Proceso_Mem('MOV_CPA_RV'
//                       ,'CONTRA_'+trim(sMoneda_Caja)
//                       ,sContraparte
//                       ,bResult);
    if not bResult then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No existe parametro de proceso ''MOV_CPA_RV'' - ''CONTRA_'+trim(sMoneda_Caja)+'''';
       Result := False;
       exit;
    end;

    //Custodia_Destino
    sCustodia_Destino := Default_Custodio(sContraparte
                                         ,sMoneda_Caja
                                         ,dFecha_Mov);

    //Cta_Custodia_Destino
    sCta_Custodia_Destino := Obtiene_Nro_Cuenta(Trim(sEmpresa) //sContraparte
                                               ,'CUSTODIA'
                                               ,''  // debe ir vacio, edosan 02-01-2020
                                               ,sCustodia_Destino
                                               ,sMoneda_Caja
                                               ,dFecha_Mov);

    //Banco_Destino
    Datos_Cuenta(Trim(sEmpresa) //sContraparte
                ,'CUSTODIA'
                ,sCustodia_Destino
                ,sCta_Custodia_Destino
                ,dFecha_Mov
                ,sMoneda_Caja
                ,sTipo_Codigo_Transferencia
                ,sCodigo_Transferencia
                ,sReferencia
                ,sId_Cuenta_Rel
                ,sNro_Cta_Rel);
    sBanco_Destino := sId_Cuenta_Rel; //'';

    //Cta_Banco_Destino
    sCta_Banco_Destino := sNro_Cta_Rel; //'';

    if (sBanco_Destino = '') or (sCta_Banco_Destino = '') then
    begin
//       Modulo_Err := 'Valorizador Renta Fija';
       String_Err := 'No se pudo obtener Banco y Cuenta para liquidacion en Tesoreria.';
       Result := False;
       exit;
    end;

    // Inserta Registros
    with DMValorizacion.QRY_Cash do
    begin
      SQL.Clear;
      SQL.Add('INSERT INTO QS_TRA_OMD'
             +'('
             +'Empresa,'
             +'Transaccion,'
             +'Folio_interno,'
             +'Entidad,'
             +'Login_Usuario,'
             +'Operador,'
             +'Contraparte,'
