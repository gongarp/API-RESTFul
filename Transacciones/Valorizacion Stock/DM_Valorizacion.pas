Procedure Carga_Tasa_Deuda_Garantia(dFecha_Proceso : TDateTime;
                                    sProceso       : String);
var i : Integer;
begin
    with DMValorizacion.Qry_Aux do
    begin
        sql.Clear;
        sql.add('SELECT count(*) as Nro_Reg ');
        sql.add('  FROM QS_SUP_MATRIZ_DEUDA_GARANT_DET ');
        sql.add(' WHERE fecha   = (SELECT max(fecha) ');
        sql.add('                    FROM QS_SUP_MATRIZ_DEUDA_GARANT_DET ');
        sql.add('                   WHERE fecha   <= :fecha_proceso ');
        sql.add('                     AND Proceso =  :Proceso) ');
        sql.add('   AND Proceso = :Proceso ');
        ParamByname('fecha_proceso').asDate := dFecha_Proceso;
        ParamByname('Proceso'      ).AsString   := sProceso;
        Open;
        i := 0;
        if not eof then i := Fieldbyname('Nro_Reg').asInteger;
        Close;
        Reg_TasaDeudaGarantia.Instrumento := VarArrayCreate([0, i], varOleStr);
        Reg_TasaDeudaGarantia.Fecha       := VarArrayCreate([0, i], varDate);
        Reg_TasaDeudaGarantia.Dias_Desde  := VarArrayCreate([0, i], varDouble);
        Reg_TasaDeudaGarantia.Dias_Hasta  := VarArrayCreate([0, i], varDouble);
        Reg_TasaDeudaGarantia.Valor_Desde := VarArrayCreate([0, i], varDouble);
        Reg_TasaDeudaGarantia.Valor_Hasta := VarArrayCreate([0, i], varDouble);
        Reg_TasaDeudaGarantia.Tasa        := VarArrayCreate([0, i], varDouble);

        sql.Clear;
        sql.add('SELECT * ');
        sql.add('  FROM QS_SUP_MATRIZ_DEUDA_GARANT_DET ');
        sql.add(' WHERE fecha   = (SELECT max(fecha) ');
        sql.add('                    FROM QS_SUP_MATRIZ_DEUDA_GARANT_DET ');
        sql.add('                   WHERE fecha   <= :fecha_proceso ');
        sql.add('                     AND Proceso =  :Proceso) ');
        sql.add('   AND Proceso = :Proceso                                   ');
        ParamByname('fecha_proceso').asDate := dFecha_Proceso;
        ParamByname('Proceso'      ).AsString   := sProceso;
        open;
        For i := 0 to VarArrayHighBound( Reg_TasaDeudaGarantia.Instrumento, 1 ) do
        begin
          if Fieldbyname('Tasa').asFloat <> 0 Then
          begin
             Reg_TasaDeudaGarantia.Instrumento[i] := Fieldbyname('Instrumento').AsString;
             Reg_TasaDeudaGarantia.Fecha[i]       := Fieldbyname('Fecha').AsDateTime;
             Reg_TasaDeudaGarantia.Dias_Desde[i]  := Fieldbyname('Dias_Desde').asFloat;
             Reg_TasaDeudaGarantia.Dias_Hasta[i]  := Fieldbyname('Dias_Hasta').asFloat;
             Reg_TasaDeudaGarantia.Valor_Desde[i] := Fieldbyname('Valor_Desde').asFloat;
             Reg_TasaDeudaGarantia.Valor_Hasta[i] := Fieldbyname('Valor_Hasta').asFloat;
             Reg_TasaDeudaGarantia.Tasa[i]        := Fieldbyname('Tasa').asFloat;
          end;
          Next;
        end;
        Close;
    end;
end;

Procedure Busca_Tasa_Deuda_Garantia(dFecha_Proceso      : TDateTime;
                                    sInstrumento        : String;
                                    fDias_Morosidad     : Double;
                                    fSaldoInsoluto      : Double;
                                    Var Dias_Desde      : Double;
                                    Var Dias_Hasta      : Double;
                                    Var Valor_Desde     : Double;
                                    Var Valor_Hasta     : Double;
                                    Var Tasa            : Double;
                                    Var Result          : Boolean );
var i : Integer;
begin
    Result := False;

    if NOT VarIsArray(Reg_TasaDeudaGarantia.Instrumento) then
       Carga_Tasa_Deuda_Garantia(dFecha_Proceso
                                ,'SUPER'); //sProceso);

    Tasa   := 0;
    For i := 0 to VarArrayHighBound( Reg_TasaDeudaGarantia.Instrumento, 1 ) do
    begin
       //ggarcia 03-11-2016
       fSaldoInsoluto := redondeo(fSaldoInsoluto,8);
       if (sInstrumento   = Reg_TasaDeudaGarantia.Instrumento[i]) Then
          if ( fDias_Morosidad >= Reg_TasaDeudaGarantia.Dias_Desde[i])    and
             ( (fDias_Morosidad <= Reg_TasaDeudaGarantia.Dias_Hasta[i]) or
               (Reg_TasaDeudaGarantia.Dias_Hasta[i] = 0)                  ) Then
               if ( fSaldoInsoluto >= Reg_TasaDeudaGarantia.Valor_Desde[i])    and
                  ( (fSaldoInsoluto <= Reg_TasaDeudaGarantia.Valor_Hasta[i]) or
                  (Reg_TasaDeudaGarantia.Valor_Hasta[i] = 0)                  ) Then
                begin
                   Dias_Desde  := Reg_TasaDeudaGarantia.Dias_Desde[i];
                   Dias_Hasta  := Reg_TasaDeudaGarantia.Dias_Hasta[i];
                   Valor_Desde := Reg_TasaDeudaGarantia.Valor_Desde[i];
                   Valor_Hasta := Reg_TasaDeudaGarantia.Valor_Hasta[i];
                   Tasa        := Reg_TasaDeudaGarantia.Tasa[i];
                   Result      := True;
                   break;
                end;
    end;
end;

procedure recursivo_ventas(sFolio_interno :string;
                           fitem_omd       :Double;
                           stransaccion    :string;
                           sempresa        :string;
                           dFecha          :TDateTime;
                       var fItem_recursivo :Double);
begin
   fItem_recursivo := fitem_omd;
   with DMValorizacion.Qry_Aux do
   begin
      SQL.Clear;
      SQL.Add('select A.EMPRESA '
             +'      ,A.TRANSACCION_OMD '
             +'      ,A.FOLIO_INTERNO_OMD '
	 		       +'	     ,max(a.item_omd) as Item_recursivo'
             +'	from qs_tra_omd_traza a  '
             +' where a.Folio_interno_omd = :Folio_interno '
             +'   and a.item_movimiento   = :item_omd '
             +'   and a.transaccion_omd   = :transaccion '
             +'   and a.empresa           = :empresa '
             +'	  and a.item_omd         <> a.item_movimiento '
             +'	  and a.FECHA_MOVIMIENTO  > :Fecha '
             +' group by A.EMPRESA  '
             +'	        ,A.TRANSACCION_OMD '
             +'	        ,A.FOLIO_INTERNO_OMD '
	 			     +'	  	    ,a.item_movimiento ');
      ParamByName('empresa').AsString       := sempresa;
      ParamByName('TRANSACCION').AsString   := stransaccion;
      ParamByName('Folio_interno').AsString := sFolio_interno;
      ParamByName('ITEM_OMD').AsFloat       := fitem_omd;
      ParamByName('Fecha').AsDateTime       := dFecha;
      Open;
      if not eof then
      begin
         fItem_recursivo := FieldByName('Item_recursivo').Asfloat;
         recursivo_ventas(FieldByName('Folio_interno_omd').AsString
                         ,FieldByName('Item_recursivo').Asfloat
                         ,FieldByName('transaccion_omd').AsString
                         ,FieldByName('empresa').AsString
                         ,dFecha
                         ,fItem_recursivo);
      end;
   end;
end;

function leer_estado_nemotecnico(sNemotecnico: String; dFecha: TDateTime) :String;
begin
   with DMValorizacion.Qry_Aux do
   begin
      sql.Clear;
      sql.add('SELECT codigo_estado ');
      sql.add('  FROM QS_FIN_NEM_RFIJA_EST ');
      sql.add(' WHERE Codigo_Nemotecnico = :Nemotecnico ');
      sql.add('   AND FECHA_DESDE       <= :Fecha ');
      sql.add('   AND (FECHA_HASTA      >= :Fecha or FECHA_HASTA is null) ');
      ParamByname('Nemotecnico').AsString := sNemotecnico;
      ParamByname('Fecha').AsDateTime     := dFecha;
      Open;
      if not eof then
         Result := FieldByname('codigo_estado').AsString
      else
         Result := default_codgen_Mem('ESTNEMRFIJ','FI',''); //'1';
      Close;
   end;
end;

function Seleccion_Derivado(sEmpresa       :String;
                            sTransaccion   :String;
                            sFolio_Interno :String) :Boolean;
begin
   Result := False;
   with DMValorizacion.Qry_aux do
   begin
      SQL.Clear;
      Sql.Add('SELECT count(*) as Reg '
             +'  FROM QS_FIN_VALORIZACION_RES2 a'
             +' WHERE Pid           = :Pid'
             +'   AND Folio_Interno = :Folio_Interno'
             +'   AND Transaccion   = :Transaccion'
             +'   AND Empresa       = :Empresa'
             );
      Parambyname('Pid').AsString           := IntToStr(Application.Handle);
      Parambyname('Folio_Interno').AsString := sFolio_Interno;
      Parambyname('Transaccion').AsString   := sTransaccion;
      Parambyname('Empresa').AsString       := sEmpresa;
      Open;
      if Fieldbyname('Reg').AsFloat > 1 then
         Result := True;
   end;
end;

procedure Calculo_Deteriorio_Modelo_V1(sNemotecnico       : String;
                                       dFecha             : TDateTime;
                                       sFolio_Interno     : string;
                                       sTransaccion       : string;
                                       sEmpresa           : string;
                                       sCartera           : string;
                                       sInstrumento       : string;
                                       sCustodia_Dest     : String;
                                       sInstrumento_Equiv : string;
                                       sProceso           : string;
                                       sClasif_Riesgo     : String;
                                       fSaldo_insoluto_UM : Double;
                                       fValor_Pte_UM_Cpa  : Double;
                                       fPlazo_al_Vcto     : Double;
                                   var fRecupero          : Double;
                                   var fCapital_Residual  : Double;
                                   var fPD                : Double;
                                   var fProbabilidad_Deterioro   : Double;
                                   var fValor_Unitario_Deterioro : Double;
                                   var fPrecio_Deterioro         : Double;
                                   var bResult_Excl              : Boolean);
var Result        : Boolean;
    sEstado       : string;
    sMensaje      : string;
    fPD2          : Double;
begin

 // Rutinas calculo Modeo BICEVIDA

   Valida_Param_Proceso_Mem('DETERIORO', 'EXC-OPE' ,sTransaccion, bResult_Excl);
   if Not bResult_Excl then
     Valida_Param_Proceso_Mem('DETERIORO', 'EXC-CARTER' ,sCartera, bResult_Excl);
     if Not bResult_Excl then
        Valida_Param_Proceso_Mem('DETERIORO', 'EXC-INS' ,sInstrumento_Equiv, bResult_Excl);

   if Not bResult_Excl then  // Busqueda de Carteras, Instrumentos y Transaccion
   begin
      fCapital_Residual := fSaldo_insoluto_UM;
      Busca_Prob_Deterioro_Nemo_Mem(dFecha
                                   ,sNemotecnico
                                   ,fPD
                                   ,Result);
      if not Result then
      begin
         Busca_Prob_Deterioro_Clasif_Riesgo_Mem(dFecha
                                               ,sCustodia_Dest
                                               ,sClasif_Riesgo
                                               ,fPD
                                               ,Result);
      end;
      if (bRecupero) then
         Busca_Prob_Recupero_Nemo_Mem(dFecha
                                     ,sNemotecnico
                                     ,fRecupero
                                     ,bResult_Rec);
      if Result or bResult_Rec then
      begin
         if Not bResult_Rec then
            Busca_Recupero_Inst_Mem(dFecha
                                   ,sInstrumento
                                   ,fRecupero
                                   ,Result);
         if Result or bResult_Rec then
         begin
            sEstado := leer_estado_nemotecnico(sNemotecnico,dFecha);
            if (sEstado = '') or (sEstado = ' ') then
            begin
               Insertar_Registro_Errores_Mesa(sEmpresa,
                                              sProceso,
                                              dFecha,
                                              sLogin_Sistema,
                                              sMensaje,
                                              'Valorizador Renta Fija',
                                              'Advertencia: No se encontro estado para calculo de deterioro, Nemotecnico: '+sNemotecnico,
                                              '');
            end
            else
            begin
               case sEstado[1] of
                  '1': fProbabilidad_Deterioro    := fValor_Pte_UM_Cpa * (fPD/100) * (1 - (fRecupero/100));
                  '2': begin
                          fPD2                    := 1-(power(1-(fPD/100),fPlazo_al_Vcto));
                          fProbabilidad_Deterioro := fValor_Pte_UM_Cpa * fPD2 * (1 - (fRecupero/100));
                       end;
                  '3': fProbabilidad_Deterioro    := fValor_Pte_UM_Cpa;
               end;
               if fCapital_Residual > 0 then
                  fValor_Unitario_Deterioro       := fProbabilidad_Deterioro / fCapital_Residual;
               try
                  fPrecio_Deterioro                  := 100-((fProbabilidad_Deterioro * 100) / fValor_Pte_UM_Cpa);
               except
                 begin
                  fPrecio_Deterioro                  := 0;
                  Insertar_Registro_Errores_Mesa(sEmpresa,
                                                sProceso,
                                                dFecha,
                                                sLogin_Sistema,
                                                sMensaje,
                                                'Valorizador Renta Fija',
                                                'No pudo calcular deterioro para Folio: '+trim(sFolio_Interno)+' '+
                                                ' ,Nemotecnico: '+sNemotecnico,
                                                '');
                 end;

               end;
            end;
         end
         else
         begin
            Insertar_Registro_Errores_Mesa(sEmpresa,
                                           sProceso,
                                           dFecha,
                                           sLogin_Sistema,
                                           sMensaje,
                                           'Valorizador Renta Fija',
                                           'Advertencia: No se pudo determinar Recupero, Instrumento:'+sInstrumento,
                                           '');
         end;
      end
      else
      begin
         Result := True;
         Insertar_Registro_Errores_Mesa(sEmpresa,
                                        sProceso,
                                        dFecha,
                                        sLogin_Sistema,
                                        sMensaje,
                                        'Valorizador Renta Fija',
                                        'Advertencia: No se pudo determinar Probabilidad de Deterioro, nemotécnico:'+sNemotecnico+', Clasif.Riesgo: '+sClasif_Riesgo,
                                        '');
      end;
   end;
end;

procedure Calculo_Deteriorio_Modelo_V2(sNemotecnico       : String;
                                       dFecha             : TDateTime;
                                       sFolio_Interno     : string;
                                       fItem_Omd          : Double;
                                       sTransaccion       : string;
                                       sEmpresa           : string;
                                       sCartera           : string;
                                       sInstrumento       : string;
                                       sCustodia_Dest     : String;
                                       sTipo_Instrumento  : string;
                                       sMoneda_Instrum    : string;
                                       sMoneda_Conversion : string;
                                       sClasif_Riesgo     : String;
                                       sInstrumento_Equiv : string;
                                       sProceso           : string;
                                       fSaldo_insoluto_UM : Double;
                                       fValor_Pte_UM_Cpa  : Double;
                                       fValor_Pte_MC_Cpa  : Double;
                                       fPlazo_al_Vcto     : Double;
                                       fTasa_Mercado      : Double;
                                       fTasa_Compra       : Double;
                                       fTasa_Emision      : Double;
                                   var fRecupero          : Double;
                                   var fCapital_Residual  : Double;
                                   var fPD                : Double;
                                   var fProbabilidad_Deterioro   : Double;
                                   var fValor_Unitario_Deterioro : Double;
                                   var fPrecio_Deterioro         : Double;
                                   var fStage                    : Double;
                                   var bResult_Excl              : Boolean);
var bResult         : Boolean;
    fEad            : Double;
    fSaldo_insoluto : Double;
    fSpread         : Double;
    fFD             : Double;
//    dFecha_Final,
//    dFecha_Inicial  : TDateTime;
    fValor_Paridad  : Double;
    fTasa_Interpolacion : Double;
    sModulo_Err,
    sString_Err     : string;
    sBase           : string;
    fPorcentaje     : Double;
    fDeterioroAdic  : Double;
    fLGD            : Double;
    fNodo           : Double;
//    aa,
//    mm,
//    dd : word;
    fProbabilidad_Deterioro_UM : Double;
begin
 // Rutinas calculo Modeo OHIO


    fRecupero                 := 0;
    fCapital_Residual         := 0;
    fPD                       := 0;
    fProbabilidad_Deterioro   := 0;
    fValor_Unitario_Deterioro := 0;
    fPrecio_Deterioro         := 0;
    fStage                    := 0;

    Valida_Param_Proceso_Mem('DETERIORO', 'EXC-OPE' ,sTransaccion, bResult_Excl);
    if Not bResult_Excl then
       Valida_Param_Proceso_Mem('DETERIORO', 'EXC-CARTER' ,sCartera, bResult_Excl);
       if Not bResult_Excl then
          Valida_Param_Proceso_Mem('DETERIORO', 'EXC-INS' ,sInstrumento_Equiv, bResult_Excl);

    if bResult_Excl then
       Exit;


    leer_valor_cambio2(sMoneda_Instrum
                      ,sMoneda_Conversion
                      ,'BC'
                      ,dFecha
                      ,fValor_Paridad
                      ,bResult
                      );

// Calculo Ead (1)
    if sTipo_Instrumento = 'S' then
    begin
       fSaldo_insoluto := fSaldo_insoluto_UM;        // Regla general SII
//       fEad := (fSaldo_insoluto/fValor_Paridad) * (1 + (fTasa_Emision/100));
       fEad := fSaldo_insoluto * (1 + (fTasa_Emision/100));
    end
    else
    begin
       fSaldo_insoluto := fValor_Pte_UM_Cpa;   // Excepción	Valor Presente a tir de compra para Unicos (Depósitos, AFR, NE, BR)
//       fEad := (fSaldo_insoluto/fValor_Paridad) * (1 + (fTasa_Compra/100));
       fEad := fSaldo_insoluto * (1 + (fTasa_Emision/100));
     end;


    with DMValorizacion.Qry_General2 do
    begin
      sql.Clear;
      sql.add('SELECT COD_MONEDA_TASA_REF ');
      sql.add('  FROM QS_SYS_MONEDAS_TASA_REF ');
      sql.add(' WHERE COD_MONEDA = :COD_MONEDA ');
      ParamByname('COD_MONEDA').AsString := sMoneda_Instrum;
      Open;
      if NOT eof then
      begin
        if Not Busca_valor_cambio_tramo_interpola_Mem(FieldByName('COD_MONEDA_TASA_REF').asString
                                                     ,fPlazo_al_Vcto
                                                     ,dFecha
                                                     ,fTasa_Interpolacion) then
              sString_Err := 'No se pudo interpolar tasa : '
                             +FieldByName('COD_MONEDA_TASA_REF').asString+#10
                             +'Con Fecha '
                             +DateToStr(dFecha)
                             +' para '
                             +FloatToStr(fPlazo_al_Vcto)
                             +' días';
      end;
    end;



    fSpread := (fTasa_Mercado - fTasa_Interpolacion)*100;

// Calculo fPD (2)

    if fSpread <= 0 then
       fPrecio_Deterioro := 0
    else
       if fPlazo_al_Vcto <= 1 then
          fPrecio_Deterioro := 1 - Exp((fSpread *-1) / 10000)
       else
          fPrecio_Deterioro := (1 - Exp((fSpread *-1) / 10000)) / fPlazo_al_Vcto;
    fProbabilidad_Deterioro := fPrecio_Deterioro * 100; // para dejarlo como porcentaje


// Calculo LGD (3)

    fLGD  := 0;
    fNodo := 0;
    Determina_Nodo_Clasificacion( 'NEMOTECNIC'
                                 ,sNemotecnico
                                 ,'CERO-ECL'
                                 ,fNodo);

    if fNodo = 0 then
       Determina_Nodo_Clasificacion( 'INSTRUM'
                                    ,sInstrumento
                                    ,'CERO-ECL'
                                    ,fNodo);

    bResult := False;
    if fNodo <> 0 then
       Busca_Loss_Given_Default(dFecha     // esto hará que los Bonos Garantizados queden en cero
                               ,'CERO-ECL'
                               ,fNodo
                               ,fLGD
                               ,bResult);

    if Not bResult then
       Busca_Prob_Deterioro_Clasif_Riesgo_Mem(dFecha
                                             ,sCustodia_Dest
                                             ,sClasif_Riesgo
                                             ,fLGD   // (Equivalente a Columna LGD)
                                             ,bResult);

// Calculo FD Factor de Descuento (4)
//    dFecha_Inicial := dFecha; // EncodeDate(2020,12,31);
//    DecodeDate(dFecha_Inicial,aa,mm,dd);
//    dFecha_Final := EncodeDate(aa+1,mm,dd);
//    fFD := Power((1/(1+(fTasa_Compra/100))), (((dFecha_Inicial - dFecha_Final)/365)));    // Factor de Descuento
    fFD := (1/(1+(fTasa_Compra/100)));  // Factor de Descuento
    fStage := fFD;

    fDeterioroAdic := 0;
    Buscar_Deterioro_Adicional_Mem(dFecha
                                  ,sNemotecnico
                                  ,sBase
                                  ,fPorcentaje
                                  ,bResult);

    if bResult then
    begin
       if sBase = 'VALOR_PTE' then
          fDeterioroAdic := ((fValor_Pte_UM_Cpa*fPorcentaje)/100) * fValor_Paridad;
    end;

    fPD := fProbabilidad_Deterioro;
    fProbabilidad_Deterioro   := (fEad * (fPD/100) * (fLGD/100) * fFD) * fValor_Paridad;
    fProbabilidad_Deterioro   := fProbabilidad_Deterioro + fDeterioroAdic;

    fRecupero                 := fLGD;
    fPrecio_Deterioro         := fSpread;
    fValor_Unitario_Deterioro := fEad;

// convierto el valor para guardrlo en la moneda del instrumento
    conversion_unidad_mon(sMoneda_Conversion
                         ,sMoneda_Instrum
                         ,'BC'
                         ,dFecha
                         ,fProbabilidad_Deterioro
                         ,fProbabilidad_Deterioro_UM
                         ,sModulo_Err
                         ,sString_Err
                         ,bResult);
    fProbabilidad_Deterioro := fProbabilidad_Deterioro_UM;

end;

procedure Calculo_Deteriorio_Modelo_V3(sEmpresa                  : String;
                                       sCartera                  : string;
                                       dFecha                    : TDateTime;
                                       sTransaccion              : string;
                                       sEmisor                   : string;
                                       sInstrumento_Equiv        : string;
                                       sSerie                    : string;
                                       sNemotecnico              : String;
                                       sClasificadora            : string;
                                       fSaldo_insoluto_UM        : Double;
                                       fValor_Pte_UM_Cpa         : Double;
                                       sProceso                  : string;
                                       sMensaje                  : string;
                                   var fRecupero                 : Double;
                                   var fPD                       : Double;
                                   var fProbabilidad_Deterioro   : Double;
                                   var fValor_Unitario_Deterioro : Double;
                                   var fPrecio_Deterioro         : Double;
                                   var fStage                    : Double;
                                   var sRating_Deterioro         : string;
                                   var sTipo_Rating              : string;
                                   var bResult_Excl              : Boolean);
var sTipo_Clasif    :String;
    sClasif_Riesgo  :String;
    fFactor_Riesgo  :Double;
    sEmisor_Pagador :String;
    fStage_1_PD     :Double;
    fStage_2_PD     :Double;
    fLong_Term_PD   :Double;
    sEstado         :String;
//    iEstado         :Integer;
    bResult         :Boolean;
begin

    fRecupero                 := 0;
    fPD                       := 0;
    fProbabilidad_Deterioro   := 0;
    fValor_Unitario_Deterioro := 0;
    fPrecio_Deterioro         := 0;
    fStage                    := 0;

    Valida_Param_Proceso_Mem('DETERIORO', 'EXC-OPE' ,sTransaccion, bResult_Excl);
    if Not bResult_Excl then
       Valida_Param_Proceso_Mem('DETERIORO', 'EXC-CARTER' ,sCartera, bResult_Excl);
       if Not bResult_Excl then
          Valida_Param_Proceso_Mem('DETERIORO', 'EXC-INS' ,sInstrumento_Equiv, bResult_Excl);
    if bResult_Excl then
       Exit;

    if (sClasificadora = '') or (sClasificadora = ' ') then
    begin
       Insertar_Registro_Errores_Mesa(sEmpresa,
                                      sProceso,
                                      dFecha,
                                      sLogin_Sistema,
                                      sMensaje,
                                      'Valorizador Renta Fija',
                                      'Advertencia: No se encontro parametro de proceso para Clasificadora de Riesgo Deterioro',
                                      '');
       Exit;
    end;

   Busca_Clasif_Riesgo_Origen_Tipo_Mem(sEmisor,
                                       sInstrumento_Equiv,
                                       sSerie,
                                       sNemotecnico,
                                       dFecha,
                                       sClasificadora,
                                       sTipo_Clasif,
                                       False,
                                       sClasif_Riesgo,
                                       fFactor_Riesgo,
                                       sEmisor_Pagador);
    if (sClasif_Riesgo = '') or (sClasif_Riesgo = ' ') then
    begin
       Insertar_Registro_Errores_Mesa(sEmpresa,
                                      sProceso,
                                      dFecha,
                                      sLogin_Sistema,
                                      sMensaje,
                                      'Valorizador Renta Fija',
                                      'Advertencia: No se encontro rating para calculo de deterioro, Nemotecnico: '+sNemotecnico+', Clasificadora: '+sClasificadora,
                                      '');
    end;
    sRating_Deterioro := sClasif_Riesgo;
    sTipo_Rating      := sTipo_Clasif;


    Busca_Prob_Deterioro_Nemo_Mem(dFecha
                                 ,sNemotecnico
                                 ,fPD
                                 ,bResult);
    if not bResult then
    begin
      Busca_Deterioro_Cl_Riesgo(dFecha
                               ,sClasif_Riesgo
                               ,fStage_1_PD
                               ,fStage_2_PD
                               ,fLong_Term_PD
                               ,bResult);
      if not bResult then
      begin
         Insertar_Registro_Errores_Mesa(sEmpresa,
                                        sProceso,
                                        dFecha,
                                        sLogin_Sistema,
                                        sMensaje,
                                        'Valorizador Renta Fija',
                                        'Advertencia: No se pudo determinar Probabilidad de Deterioro, nemotécnico:'+sNemotecnico+', Clasif.Riesgo: '+sClasif_Riesgo+', Clasificadora: '+sClasificadora,
                                        '');
      end;
    end
    else
    begin
       fStage_1_PD := fPD;
       fStage_2_PD := fPD;
    end;


    Busca_Prob_Recupero_Nemo_Mem(dFecha
                                ,sNemotecnico
                                ,fRecupero
                                ,bResult);
    if not bresult then
    begin
       Busca_Recupero_Inst_Mem(dFecha
                              ,sInstrumento_Equiv
                              ,fRecupero
                              ,bResult);
       if not bResult then
       begin
          Insertar_Registro_Errores_Mesa(sEmpresa,
                                         sProceso,
                                         dFecha,
                                         sLogin_Sistema,
                                         sMensaje,
                                         'Valorizador Renta Fija',
                                         'Advertencia: No se pudo determinar Recupero para calculo de deterioro, intrumento: '+sInstrumento+' - nemotecnico: '+sNemotecnico,
                                         '');
       end;
    end;


    sEstado := leer_estado_nemotecnico(sNemotecnico,dFecha);

    case sEstado[1] of
       '1': begin
              fProbabilidad_Deterioro := fValor_Pte_UM_Cpa * (fStage_1_PD/100) * (1 - (fRecupero/100));
              fPD                     := fStage_1_PD;
              fStage                  := StrToInt(sEstado);
            end;
       '2': begin
              fProbabilidad_Deterioro := fValor_Pte_UM_Cpa * (fStage_2_PD/100) * (1 - (fRecupero/100));
              fPD                     := fStage_2_PD;
              fStage                  := StrToInt(sEstado);
            end;
       '3': begin
              fProbabilidad_Deterioro := fValor_Pte_UM_Cpa * (1 - (fRecupero/100));
              fPD                     := 1;
              fStage                  := StrToInt(sEstado);
            end;
    else
       Insertar_Registro_Errores_Mesa(sEmpresa,
                                      sProceso,
                                      dFecha,
                                      sLogin_Sistema,
                                      sMensaje,
                                      'Valorizador Renta Fija',
                                      'Advertencia: No se encontro estado o es incorrecto para calculo de deterioro, Nemotecnico: '+sNemotecnico,
                                      '');
    end;

    if fSaldo_insoluto_UM > 0 then
       fValor_Unitario_Deterioro := fProbabilidad_Deterioro / fSaldo_insoluto_UM;

    try
       fPrecio_Deterioro := 100-((fProbabilidad_Deterioro * 100) / fValor_Pte_UM_Cpa);
    except
      begin
        fPrecio_Deterioro  := 0;
        Insertar_Registro_Errores_Mesa(sEmpresa,
                                       sProceso,
                                       dFecha,
                                       sLogin_Sistema,
                                       sMensaje,
                                       'Valorizador Renta Fija',
                                       'No se pudo calcular deterioro para Nemotecnico: '+sNemotecnico,
                                       '');
      end;
    end;

end;

procedure Actualiza_BR_Por_Inflacion(fValor_Nominal           : Double;
                                     dFecha_Emision           : TDateTime;
                                     dFecha_Calculo           : TDateTime;
                                     sProceso                 : String;
                                     sMoneda                  : String;
                                     sMoneda_Conversion       : String;
                                     var fValor_Convertido_UM : Double;
                                     var fValor_Convertido_MC : Double;
                                     var bResult              : Boolean);
var
 aa,mm,dd       : Word;
 fValor_IPC_Act,
 fValor_IPC_Emi : Double;
 bResult_IPC    : Boolean;
 dFecha_Aux     : TDateTime;
 sModulo_Error,
 sString_Error  : String;
begin
 bResult := False;

 DecodeDate( dFecha_Calculo, aa, mm,dd );
 mm := mm - 1;
 if mm = 0 then
 begin
  mm := 1;
 end;

 dd := ultimo_dia_mes( mm, aa );
 dFecha_Aux := encodedate(aa,mm,dd );

 Busca_Ipc_Mem(dFecha_Aux, fValor_IPC_Act, bResult_IPC);

 if Not bResult_IPC then
 begin
  Insertar_Registro_Errores_Mesa(sEmpresa,
                                 sProceso,
                                 dFecha_Calculo,
                                 sLogin_Sistema,
                                 'Valorización de Saldo Insoluto para BR',
                                 'Valorizador Renta Fija',
                                 'No se encontró IPC con fecha: '+DateToStr(dFecha_Aux),
                                 '');
 end;

 DecodeDate( dFecha_Emision, aa, mm,dd );
 //mm := mm + 1;
 //if mm = 13 then
 //begin
 // mm := 1;
 // aa := aa + 1;
 //end;

 dd := ultimo_dia_mes( mm, aa );
 dFecha_Aux := encodedate(aa,mm,dd );
 Busca_Ipc_Mem(dFecha_Aux, fValor_IPC_Emi, bResult_IPC);

 if Not bResult_IPC then
 begin
  Insertar_Registro_Errores_Mesa(sEmpresa,
                                 sProceso,
                                 dFecha_Calculo,
                                 sLogin_Sistema,
                                 'Valorización de Saldo Insoluto para BR',
                                 'Valorizador Renta Fija',
                                 'No se encontró IPC con fecha: '+DateToStr(dFecha_Aux),
                                 '');
 end;

 if (fValor_IPC_Act > 0) and
    (fValor_IPC_Emi > 0) then
 begin
  fValor_Convertido_UM := fValor_Nominal * (fValor_IPC_Act / fValor_IPC_Emi);
  conversion_unidad_mon(sMoneda
                       ,sMoneda_Conversion
                       ,'BC'
                       ,dFecha_Calculo
                       ,fValor_Convertido_UM
                       ,fValor_Convertido_MC
                       ,sModulo_Error
                       ,sString_Error
                       ,bResult);

  if Not bResult_IPC then
  begin
   Insertar_Registro_Errores_Mesa(sEmpresa,
                                  sProceso,
                                  dFecha_Calculo,
                                  sLogin_Sistema,
                                  sModulo_Error,
                                  'Valorizador Renta Fija',
                                  sString_Error,
                                  '');
  end;
  bResult := True;

  fValor_Convertido_UM := Redondeo_Moneda_Mem(sMoneda_Conversion
                                             ,dFecha_Calculo
                                             ,fValor_Convertido_UM);

  fValor_Convertido_MC := Redondeo_Moneda_Mem(sMoneda_Conversion
                                             ,dFecha_Calculo
                                             ,fValor_Convertido_MC);
 end
 else
 begin
  bResult := False;
 end;
end;

end.

